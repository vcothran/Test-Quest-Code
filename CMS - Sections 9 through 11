CMSApp.prototype.normalizePassageConsistency = function(questions) {
  console.log('📖 Normalizing passage consistency to fix truncation bug...');
  
  // Group questions by test type
  const readingQuestions = questions.filter(q => q.testType === 'Reading');
  
  if (readingQuestions.length === 0) {
    console.log('   No Reading questions found');
    return questions;
  }
  
  // Find the longest passage (most complete)
  let longestPassage = null;
  let longestLength = 0;
  
  readingQuestions.forEach(q => {
    if (q.passageContext && q.passageContext.length > longestLength) {
      longestPassage = q.passageContext;
      longestLength = q.passageContext.length;
    }
  });
  
  console.log(`📖 Longest passage found: ${longestLength} chars`);
  console.log(`📖 Passage lengths before normalization:`, 
    readingQuestions.map(q => `Q${q.questionNumber}=${q.passageContext?.length || 0}`).join(', ')
  );
  
  // Apply longest passage to ALL reading questions
  const normalized = questions.map(q => {
    if (q.testType === 'Reading' && longestPassage) {
      return { ...q, passageContext: longestPassage };
    }
    return q;
  });
  
  console.log(`✅ All Reading questions now have ${longestLength} char passage`);
  
  return normalized;
};

// ===========================================
// NEW v7: VERIFY ANSWER KEY APPLICATION
// ===========================================
CMSApp.prototype.verifyAnswerKeyApplication = function(questions, answerKey) {
  console.log('🔍 Verifying answer key application...');
  
  const mismatches = [];
  
  questions.forEach(q => {
    if (answerKey[q.questionNumber]) {
      const expectedLetter = answerKey[q.questionNumber].toUpperCase();
      const expectedIndex = this.letterToIndex(expectedLetter);
      
      if (q.correct !== expectedIndex) {
        mismatches.push({
          question: q.questionNumber,
          expected: expectedLetter,
          expectedIndex: expectedIndex,
          actual: this.indexToLetter(q.correct, q.testType),
          actualIndex: q.correct
        });
      }
    }
  });
  
  if (mismatches.length > 0) {
    console.error('❌ ANSWER KEY VERIFICATION FAILED:', mismatches);
    this.showAlert(
      '⚠️ Answer Key Mismatch Detected!\n\n' + 
      mismatches.map(m => 
        `Q${m.question}: Expected ${m.expected} (index ${m.expectedIndex}), got ${m.actual || 'undefined'} (index ${m.actualIndex})`
      ).join('\n') +
      '\n\nPlease review before saving.',
      'warning'
    );
  } else {
    console.log('✅ Answer key verification passed - all answers match');
  }
};

CMSApp.prototype.letterToIndex = function(letter) {
  // Handle both A-E (Math/Science) and F-J (Reading) formats
  if (['F', 'G', 'H', 'J'].includes(letter)) {
    return ['F', 'G', 'H', 'J'].indexOf(letter);
  }
  return letter.charCodeAt(0) - 65; // A=0, B=1, etc.
};

CMSApp.prototype.indexToLetter = function(index, testType) {
  if (testType === 'Reading') {
    return ['F', 'G', 'H', 'J'][index] || `Index${index}`;
  }
  return String.fromCharCode(65 + index); // 0=A, 1=B, etc.
};

