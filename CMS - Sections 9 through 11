CMSApp.prototype.deleteQuestion = function(bankId, questionIndex) {
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  if (!bank) { this.showAlert('Question bank not found.', 'error'); return; }
  const questions = bank.questions || [];
  const question = questions[questionIndex];
  if (!question) { this.showAlert('Question not found.', 'error'); return; }
  const preview = (question.text || question.question || 'Question ' + (questionIndex+1)).substring(0,60) + '…';
  if (!confirm(`Delete this question?\n\n"${preview}"\n\nThis cannot be undone.`)) return;

  this.showProcessing('Deleting question...');
  const updated = questions.filter((_, i) => i !== questionIndex);
  this.updateDoc(this.doc(this.db, 'questionBanks', bankId), {
    questions: updated,
    updatedAt: this.serverTimestamp()
  }).then(() => {
    bank.questions = updated;
    if (updated.length === 0) {
