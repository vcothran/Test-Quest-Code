  select.innerHTML = '<option value="">Select a question bank...</option>';
  const createNewOption = document.createElement('option');
  createNewOption.value = 'CREATE_NEW';
  createNewOption.textContent = '--- Create New Question Bank ---';
  select.appendChild(createNewOption);
  this.state.questionBanks.forEach(bank => {
    const option = document.createElement('option');
    option.value = bank.id;
    const questionCount = (bank.questions || []).length;
    const lastExtraction = bank.lastExtraction;
    option.textContent = `${bank.name || 'Untitled Bank'} (${bank.approach || 'General'}) - ${questionCount} questions${lastExtraction ? ` - Last: ${lastExtraction.testType}` : ''}`;
