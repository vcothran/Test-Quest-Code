};

// ─────────────────────────────────────────────────────────────
// OVERRIDE: editQuestion defined here LAST so it always wins
// over any older version defined in other sections.
// Handles both parser format (array) and manual format (object)
// ─────────────────────────────────────────────────────────────
CMSApp.prototype.editQuestion = function(bankId, questionIndex) {
  console.log('✏️ editQuestion v3 - bankId:', bankId, 'index:', questionIndex);
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  if (!bank) { this.showAlert('Question bank not found.', 'error'); return; }
  const questions = bank.questions || [];
  const question = questions[questionIndex];
  if (!question) { this.showAlert('Question not found.', 'error'); return; }

  const isObjectOptions = question.options && !Array.isArray(question.options);
  const questionText = (question.text || question.question || '').replace(/</g,'&lt;');

  // Normalize to [{letter, text}] regardless of storage format
  let optionPairs = [];
  if (isObjectOptions) {
    optionPairs = Object.entries(question.options).map(([letter, text]) => ({ letter, text }));
  } else if (Array.isArray(question.options)) {
    optionPairs = question.options.map((text, i) => ({ letter: String.fromCharCode(65 + i), text }));
  }

  // Current correct letter
  let currentCorrectLetter = '';
  if (isObjectOptions) {
    currentCorrectLetter = question.correct || (optionPairs[0] && optionPairs[0].letter) || 'A';
  } else {
    const idx = typeof question.correct === 'number' ? question.correct
              : typeof question.correctAnswer === 'number' ? question.correctAnswer : 0;
    currentCorrectLetter = optionPairs[idx] ? optionPairs[idx].letter : 'A';
  }

  const passageVal = (question.passageContext || question.passage || '').replace(/</g,'&lt;');

  const existing = document.getElementById('edit-question-modal');
  if (existing) existing.remove();

  // Build toolbar helper inline
  const tb = (id) => {
    const b = (label, title, action) =>
      `<button type="button" title="${title}" onclick="${action}"
        style="padding:3px 7px;border:1px solid #ced4da;border-radius:4px;background:#fff;
               cursor:pointer;font-size:12px;margin:1px;"
        onmouseover="this.style.background='#e9ecef'"
        onmouseout="this.style.background='#fff'">${label}</button>`;
    return `<div style="background:#f8f9fa;border:1px solid #ced4da;border-bottom:none;
                        border-radius:6px 6px 0 0;padding:5px 7px;display:flex;flex-wrap:wrap;gap:1px;">
      ${b('<b>B</b>','Bold',`window.cmsApp.wrapSelection('${id}','**','**')`)}
      ${b('<i>I</i>','Italic',`window.cmsApp.wrapSelection('${id}','_','_')`)}
      ${b('<u>U</u>','Underline',`window.cmsApp.wrapSelection('${id}','[u]','[/u]')`)}
      <span style="border-left:1px solid #ced4da;margin:1px 3px;"></span>
      ${b('√','Square root',`window.cmsApp.insertAtCursor('${id}','√')`)}
      ${b('x²','Superscript 2',`window.cmsApp.wrapSelection('${id}','','\u00B2')`)}
      ${b('x³','Superscript 3',`window.cmsApp.wrapSelection('${id}','','\u00B3')`)}
      ${b('xⁿ','Superscript',`window.cmsApp.wrapSelection('${id}','^{','}')`)}
      ${b('x₁','Subscript',`window.cmsApp.wrapSelection('${id}','_{','}')`)}
      <span style="border-left:1px solid #ced4da;margin:1px 3px;"></span>
      ${b('π','Pi',`window.cmsApp.insertAtCursor('${id}','π')`)}
      ${b('°','Degree',`window.cmsApp.insertAtCursor('${id}','°')`)}
      ${b('≠','Not equal',`window.cmsApp.insertAtCursor('${id}','≠')`)}
      ${b('≤','Less/equal',`window.cmsApp.insertAtCursor('${id}','≤')`)}
      ${b('≥','Greater/equal',`window.cmsApp.insertAtCursor('${id}','≥')`)}
      ${b('×','Multiply',`window.cmsApp.insertAtCursor('${id}','×')`)}
      ${b('÷','Divide',`window.cmsApp.insertAtCursor('${id}','÷')`)}
      ${b('±','Plus/minus',`window.cmsApp.insertAtCursor('${id}','±')`)}
    </div>`;
  };

  const ta = (id, rows, val) =>
