
      // Add compact toolbar for passage annotation
      const addPassageToolbar = () => {
        document.getElementById('passage-toolbar')?.remove();
        
        const toolbar = document.createElement('div');
        toolbar.id = 'passage-toolbar';
        toolbar.style.cssText = `
          position: fixed;
          top: 80px;
