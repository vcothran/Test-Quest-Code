          ">
            <span style="color: white; font-weight: bold; font-size: 14px;">📐 Scratch Pad</span>
            <button id="close-scratch" style="background: #e74c3c; border: none; color: white; width: 24px; height: 24px; border-radius: 50%; cursor: pointer;">×</button>
          </div>
          
          <div style="background: #2c3e50; padding: 8px; display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
            <button class="scratch-tool" data-tool="pen" style="background: #3498db; border: 2px solid #2980b9; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;">✏️</button>
            <button class="scratch-tool" data-tool="highlighter" style="background: #f39c12; border: 2px solid #e67e22; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;">🖍️</button>
            <button class="scratch-tool" data-tool="line" style="background: #16a085; border: 2px solid #138d75; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;">📏</button>
            <button class="scratch-tool" data-tool="circle" style="background: #8e44ad; border: 2px solid #7d3c98; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;">⭕</button>
            <button class="scratch-tool" data-tool="rectangle" style="background: #c0392b; border: 2px solid #a93226; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;">▢</button>
            <button class="scratch-tool" data-tool="triangle" style="background: #27ae60; border: 2px solid #229954; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;">△</button>
            <button class="scratch-tool" data-tool="polygon" style="background: #d35400; border: 2px solid #ba4a00; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;" title="Freeform Polygon">⬡</button>
            <button class="scratch-tool" data-tool="eraser" style="background: #95a5a6; border: 2px solid #7f8c8d; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 12px;">🧹</button>
            
            <div style="width: 1px; height: 24px; background: #34495e; margin: 0 5px;"></div>
            
            <button class="scratch-color" data-color="#ffeb3b" style="background: #ffeb3b; width: 20px; height: 20px; border: 2px solid #34495e; border-radius: 50%; cursor: pointer;"></button>
            <button class="scratch-color" data-color="#ff5722" style="background: #ff5722; width: 20px; height: 20px; border: 2px solid #34495e; border-radius: 50%; cursor: pointer;"></button>
            <button class="scratch-color" data-color="#4caf50" style="background: #4caf50; width: 20px; height: 20px; border: 2px solid #34495e; border-radius: 50%; cursor: pointer;"></button>
            <button class="scratch-color" data-color="#2196f3" style="background: #2196f3; width: 20px; height: 20px; border: 2px solid #34495e; border-radius: 50%; cursor: pointer;"></button>
            <button class="scratch-color" data-color="#9c27b0" style="background: #9c27b0; width: 20px; height: 20px; border: 2px solid #34495e; border-radius: 50%; cursor: pointer;"></button>
            <button class="scratch-color" data-color="#000000" style="background: #000000; width: 20px; height: 20px; border: 2px solid #ecf0f1; border-radius: 50%; cursor: pointer;"></button>
            
            <div style="width: 1px; height: 24px; background: #34495e; margin: 0 5px;"></div>
            
            <button id="clear-scratch" style="background: #e74c3c; border: none; color: white; padding: 6px 10px; border-radius: 5px; cursor: pointer; font-size: 11px;">Clear</button>
          </div>
          
          <div style="flex: 1; position: relative; background: white;">
            <canvas id="scratch-canvas" style="position: absolute; width: 100%; height: 100%; cursor: crosshair;"></canvas>
          </div>
        `;
        
        document.body.appendChild(overlay);
        
        const canvas = document.getElementById('scratch-canvas');
        const container = canvas.parentElement;
        canvas.width = container.clientWidth;
        canvas.height = container.clientHeight;
        
        annotationState.scratchCanvas = canvas;
        annotationState.scratchCtx = canvas.getContext('2d');
        annotationState.scratchTool = 'pen';
        annotationState.scratchColor = '#000000';
        
        // Draw grid
        drawScratchGrid();
        
        // Add ResizeObserver to handle scratch pad resizing
        const resizeObserver = new ResizeObserver(entries => {
          for (let entry of entries) {
            const newWidth = Math.max(entry.contentRect.width, canvas.width);
            const newHeight = Math.max(entry.contentRect.height, canvas.height);
            
            // Only resize if we're GROWING (prevent content loss when shrinking)
            if (newWidth <= canvas.width && newHeight <= canvas.height) {
              // Shrinking - don't resize canvas, just let CSS handle display
              return;
            }
            
            // Growing - need to expand canvas
            if (Math.abs(canvas.width - newWidth) < 2 && Math.abs(canvas.height - newHeight) < 2) {
              return;
            }
            
            // Save current drawing at FULL resolution
            const tempCanvas = document.createElement('canvas');
            tempCanvas.width = canvas.width;
            tempCanvas.height = canvas.height;
            const tempCtx = tempCanvas.getContext('2d');
            tempCtx.drawImage(canvas, 0, 0);
            
            // Expand canvas to new size
            canvas.width = newWidth;
            canvas.height = newHeight;
            
            // Redraw grid
            drawScratchGrid();
            
            // Restore drawing at original position (top-left, no scaling)
            annotationState.scratchCtx.drawImage(tempCanvas, 0, 0);
            
            // Reset polygon points on significant resize
            annotationState.polygonPoints = [];
          }
        });
        
        resizeObserver.observe(container);
        
        // Setup drawing
        setupScratchDrawing();
        
        // Close button
        document.getElementById('close-scratch').onclick = toggleScratchPad;
        
        // Tool buttons
        document.querySelectorAll('.scratch-tool').forEach(btn => {
          btn.onclick = () => {
            const previousTool = annotationState.scratchTool;
            const newTool = btn.dataset.tool;
            
            // If switching TO polygon tool from another tool, start fresh
            if (newTool === 'polygon' && previousTool !== 'polygon') {
              annotationState.polygonPoints = [];
            }
            
            annotationState.scratchTool = newTool;
            document.querySelectorAll('.scratch-tool').forEach(b => b.style.transform = 'none');
            btn.style.transform = 'scale(1.1)';
          };
        });
        
        // Color buttons
        document.querySelectorAll('.scratch-color').forEach(btn => {
          btn.onclick = () => {
            annotationState.scratchColor = btn.dataset.color;
            document.querySelectorAll('.scratch-color').forEach(b => b.style.transform = 'none');
            btn.style.transform = 'scale(1.2)';
          };
        });
        
        // Clear button
        document.getElementById('clear-scratch').onclick = () => {
          if (confirm('Clear scratch pad?')) {
            // Reset polygon state
            annotationState.polygonPoints = [];
            
            // Redraw grid
            drawScratchGrid();
          }
        };
        
        // Select pen by default
        document.querySelector('[data-tool="pen"]').style.transform = 'scale(1.1)';
        document.querySelector('[data-color="#000000"]').style.transform = 'scale(1.2)';
        
        // Dragging
        makeDraggable(overlay, document.getElementById('scratch-handle'));
      };

      // Draw grid on scratch pad
      const drawScratchGrid = () => {
        const canvas = annotationState.scratchCanvas;
        const ctx = annotationState.scratchCtx;
        
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        ctx.strokeStyle = '#e0e0e0';
        ctx.lineWidth = 0.5;
        
        for (let x = 0; x <= canvas.width; x += 20) {
          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, canvas.height);
          ctx.stroke();
        }
        
        for (let y = 0; y <= canvas.height; y += 20) {
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(canvas.width, y);
          ctx.stroke();
        }
      };

      // Setup scratch pad drawing
      const setupScratchDrawing = () => {
        const canvas = annotationState.scratchCanvas;
        const ctx = annotationState.scratchCtx;
        
        let drawing = false;
        let startX, startY;
        let lastImageData = null;
        
        canvas.onmousedown = (e) => {
          const rect = canvas.getBoundingClientRect();
          
          // Calculate scale factor between canvas actual size and display size
          const scaleX = canvas.width / rect.width;
          const scaleY = canvas.height / rect.height;
          
          // Get mouse position relative to canvas display, then scale to canvas coordinates
          const x = (e.clientX - rect.left) * scaleX;
          const y = (e.clientY - rect.top) * scaleY;
          
          const tool = annotationState.scratchTool;
          
          // Polygon tool uses clicks, not drag
          if (tool === 'polygon') {
            if (annotationState.polygonPoints.length === 0) {
              lastImageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            }
            
            annotationState.polygonPoints.push({x, y});
            
            // Draw preview
            ctx.putImageData(lastImageData, 0, 0);
            ctx.globalCompositeOperation = 'source-over';
            ctx.strokeStyle = annotationState.scratchColor;
            ctx.lineWidth = 2;
            ctx.globalAlpha = 1.0;
            
            if (annotationState.polygonPoints.length > 1) {
              ctx.beginPath();
              ctx.moveTo(annotationState.polygonPoints[0].x, annotationState.polygonPoints[0].y);
              for (let i = 1; i < annotationState.polygonPoints.length; i++) {
                ctx.lineTo(annotationState.polygonPoints[i].x, annotationState.polygonPoints[i].y);
              }
              ctx.stroke();
              
              // Draw dots at points
              annotationState.polygonPoints.forEach(pt => {
                ctx.fillStyle = annotationState.scratchColor;
                ctx.beginPath();
                ctx.arc(pt.x, pt.y, 3, 0, 2 * Math.PI);
                ctx.fill();
              });
            }
            return;
          }
          
          drawing = true;
          startX = x;
          startY = y;
          
          // Save state for shapes
          lastImageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
          
          if (tool === 'pen' || tool === 'highlighter' || tool === 'eraser') {
            ctx.beginPath();
            ctx.moveTo(startX, startY);
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            if (tool === 'eraser') {
              ctx.lineWidth = 20;
              ctx.globalCompositeOperation = 'destination-out';
              ctx.globalAlpha = 1.0;
            } else {
              ctx.lineWidth = tool === 'highlighter' ? 12 : 2;
              ctx.globalCompositeOperation = 'source-over';
              ctx.strokeStyle = annotationState.scratchColor;
              ctx.globalAlpha = tool === 'highlighter' ? 0.3 : 1.0;
            }
          }
        };
        
        canvas.onmousemove = (e) => {
          if (!drawing) return;
          const rect = canvas.getBoundingClientRect();
          
          // Calculate scale factor
          const scaleX = canvas.width / rect.width;
          const scaleY = canvas.height / rect.height;
          
          const x = (e.clientX - rect.left) * scaleX;
          const y = (e.clientY - rect.top) * scaleY;
          
          const tool = annotationState.scratchTool;
          
          if (tool === 'pen' || tool === 'highlighter' || tool === 'eraser') {
            ctx.lineTo(x, y);
            ctx.stroke();
          } else {
            // Shapes - preview
            ctx.putImageData(lastImageData, 0, 0);
            ctx.globalCompositeOperation = 'source-over';
            ctx.strokeStyle = annotationState.scratchColor;
            ctx.lineWidth = 2;
            ctx.globalAlpha = 1.0;
            
            const width = x - startX;
            const height = y - startY;
            
            if (tool === 'line') {
              ctx.beginPath();
              ctx.moveTo(startX, startY);
              ctx.lineTo(x, y);
              ctx.stroke();
            } else if (tool === 'circle') {
              const radius = Math.sqrt(width * width + height * height);
              ctx.beginPath();
              ctx.arc(startX, startY, radius, 0, 2 * Math.PI);
              ctx.stroke();
            } else if (tool === 'rectangle') {
              ctx.strokeRect(startX, startY, width, height);
            } else if (tool === 'triangle') {
              ctx.beginPath();
              ctx.moveTo(startX, startY);
              ctx.lineTo(x, y);
              ctx.lineTo(startX - width, y);
              ctx.closePath();
              ctx.stroke();
            }
          }
        };
        
        canvas.onmouseup = () => {
          drawing = false;
          ctx.closePath();
          ctx.globalAlpha = 1.0;
          ctx.globalCompositeOperation = 'source-over';
          lastImageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        };
        
        canvas.onmouseleave = () => {
          drawing = false;
        };
        
        // Double-click to finish polygon
        canvas.ondblclick = () => {
          if (annotationState.scratchTool === 'polygon' && annotationState.polygonPoints.length > 2) {
            ctx.putImageData(lastImageData, 0, 0);
            ctx.globalCompositeOperation = 'source-over';
            ctx.strokeStyle = annotationState.scratchColor;
            ctx.lineWidth = 2;
            ctx.globalAlpha = 1.0;
            
            // Draw final polygon
            ctx.beginPath();
            ctx.moveTo(annotationState.polygonPoints[0].x, annotationState.polygonPoints[0].y);
            for (let i = 1; i < annotationState.polygonPoints.length; i++) {
              ctx.lineTo(annotationState.polygonPoints[i].x, annotationState.polygonPoints[i].y);
            }
            ctx.closePath();
            ctx.stroke();
            
            // Reset
            annotationState.polygonPoints = [];
            lastImageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
          }
        };
        
        // Touch support
        canvas.addEventListener('touchstart', (e) => {
          e.preventDefault();
          const touch = e.touches[0];
          const mouseEvent = new MouseEvent('mousedown', {
            clientX: touch.clientX,
            clientY: touch.clientY
          });
          canvas.dispatchEvent(mouseEvent);
        }, { passive: false });
        
        canvas.addEventListener('touchmove', (e) => {
          e.preventDefault();
          const touch = e.touches[0];
          const mouseEvent = new MouseEvent('mousemove', {
            clientX: touch.clientX,
            clientY: touch.clientY
          });
          canvas.dispatchEvent(mouseEvent);
        }, { passive: false });
        
        canvas.addEventListener('touchend', (e) => {
          e.preventDefault();
          canvas.dispatchEvent(new MouseEvent('mouseup'));
        }, { passive: false });
      };

      // Make element draggable
      const makeDraggable = (element, handle) => {
        let isDragging = false;
        let startX, startY;
        
        handle.onmousedown = (e) => {
          if (e.target.id === 'close-scratch') return;
          isDragging = true;
          startX = e.clientX - element.offsetLeft;
          startY = e.clientY - element.offsetTop;
        };
        
        document.onmousemove = (e) => {
          if (!isDragging) return;
          element.style.left = (e.clientX - startX) + 'px';
          element.style.top = (e.clientY - startY) + 'px';
          element.style.right = 'auto';
          element.style.bottom = 'auto';
        };
        
        document.onmouseup = () => {
          isDragging = false;
        };
      };

      console.log('✅ Section 13: Direct Passage Annotation + Scratch Pad loaded');

/* === SECTION 14: ADAPTIVE DIFFICULTY SYSTEM (MINIMAL) === */

      // Adaptive difficulty system
      const adaptiveDifficulty = {
        currentLevel: 5,        // Scale 1-10 (5 = baseline ACT difficulty)
        history: [],            // Last 3 episode difficulties
        performanceHistory: [], // Last 3 episode scores
        
        // Calculate next difficulty based on performance
        adjustDifficulty: function(performance) {
          let adjustment = 0;
          
          if (performance >= 90) {
            adjustment = 1;  // Mastery: level up!
          } else if (performance >= 75) {
            adjustment = 0;  // Proficient: maintain
          } else if (performance >= 60) {
            adjustment = -1; // Developing: easier
          } else {
            adjustment = -2; // Struggling: much easier
          }
          
          this.currentLevel = Math.max(1, Math.min(10, this.currentLevel + adjustment));
          this.history.push(this.currentLevel);
          
          // Keep only last 3
          if (this.history.length > 3) {
            this.history.shift();
          }
          
          return this.currentLevel;
        },
        
        // Get difficulty trend
        getTrend: function() {
          if (this.history.length < 2) return 'stable';
          
          const recent = this.history.slice(-2);
          if (recent[1] > recent[0]) return 'rising';
          if (recent[1] < recent[0]) return 'declining';
          return 'stable';
        },
        
        // Get difficulty descriptor for display
        getDifficultyDescriptor: function() {
          const descriptors = {
            1: 'Basic fundamentals, Grade 8-9, ACT 16-19',
            2: 'Foundational, Grade 9-10, ACT 20-23',
            3: 'Intermediate, Grade 10, ACT 24-26',
            4: 'Solid, Grade 10-11, ACT 27-29',
            5: 'Standard ACT, Grade 11, ACT 28-30',
            6: 'Challenging, Grade 11-12, ACT 31-33',
            7: 'Advanced, Grade 12, ACT 34-35',
            8: 'Highly Advanced, College-level, ACT 35-36',
            9: 'Expert, Advanced College, Perfect Score',
            10: 'Master, Graduate-level reasoning'
          };
          return descriptors[this.currentLevel] || descriptors[5];
        }
