          };
        });
        
        // Clear button
        document.getElementById('clear-passage').onclick = () => {
          if (confirm('Clear all annotations?')) {
            annotationState.passageCtx.clearRect(
              0, 0,
              annotationState.passageCanvas.width,
              annotationState.passageCanvas.height
            );
          }
        };
        
        // Auto-select highlighter
        selectPassageTool('highlighter');
        toolbar.querySelector('[data-tool="highlighter"]').style.transform = 'scale(1.15)';
      };

      // Select passage annotation tool
      const selectPassageTool = (tool) => {
        annotationState.currentTool = tool;
        
        if (tool === 'highlighter') {
          annotationState.lineWidth = 12;
          annotationState.currentColor = '#ffeb3b';
        } else if (tool === 'pen') {
          annotationState.lineWidth = 2;
          annotationState.currentColor = '#e74c3c';
        } else if (tool === 'eraser') {
          annotationState.lineWidth = 20;
        }
      };

      // Setup passage drawing
      const setupPassageDrawing = () => {
        const canvas = annotationState.passageCanvas;
        const ctx = annotationState.passageCtx;
        let path = [];
        
        canvas.onmousedown = (e) => {
          annotationState.isDrawing = true;
          const rect = canvas.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          path = [{x, y}];
          
          if (annotationState.currentTool === 'eraser') {
            ctx.globalCompositeOperation = 'destination-out';
            ctx.globalAlpha = 1.0;
            ctx.lineWidth = annotationState.lineWidth;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.beginPath();
            ctx.moveTo(x, y);
          }
        };
        
        canvas.onmousemove = (e) => {
          if (!annotationState.isDrawing) return;
          const rect = canvas.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          path.push({x, y});
          
          if (annotationState.currentTool === 'eraser') {
            // Eraser works immediately
            ctx.lineTo(x, y);
            ctx.stroke();
          }
        };
        
        canvas.onmouseup = () => {
          if (!annotationState.isDrawing) return;
          annotationState.isDrawing = false;
          
          if (annotationState.currentTool !== 'eraser' && path.length > 1) {
            // Draw the complete path as a single stroke (prevents spray effect!)
            ctx.globalCompositeOperation = 'source-over';
            ctx.strokeStyle = annotationState.currentColor;
            ctx.globalAlpha = annotationState.currentTool === 'highlighter' ? 0.20 : 1.0;
            ctx.lineWidth = annotationState.lineWidth;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            ctx.beginPath();
            ctx.moveTo(path[0].x, path[0].y);
            for (let i = 1; i < path.length; i++) {
              ctx.lineTo(path[i].x, path[i].y);
            }
            ctx.stroke();
          }
          
          ctx.closePath();
          ctx.globalAlpha = 1.0;
          ctx.globalCompositeOperation = 'source-over';
          path = [];
        };
        
        canvas.onmouseleave = () => {
          annotationState.isDrawing = false;
        };
        
        // Touch support
        canvas.addEventListener('touchstart', (e) => {
          e.preventDefault();
          const touch = e.touches[0];
          const mouseEvent = new MouseEvent('mousedown', {
            clientX: touch.clientX,
            clientY: touch.clientY
          });
          canvas.dispatchEvent(mouseEvent);
        }, { passive: false });
        
        canvas.addEventListener('touchmove', (e) => {
          e.preventDefault();
          const touch = e.touches[0];
          const mouseEvent = new MouseEvent('mousemove', {
            clientX: touch.clientX,
            clientY: touch.clientY
          });
          canvas.dispatchEvent(mouseEvent);
        }, { passive: false });
        
        canvas.addEventListener('touchend', (e) => {
          e.preventDefault();
          canvas.dispatchEvent(new MouseEvent('mouseup'));
        }, { passive: false });
      };

      // Toggle scratch pad
      const toggleScratchPad = () => {
        const existing = document.getElementById('scratch-overlay');
        
        if (existing) {
          existing.remove();
          document.getElementById('scratch-pad-btn').innerHTML = '📐 Scratch Pad';
          
          // Show passage toolbar if it was hidden
          const passageToolbar = document.getElementById('passage-toolbar');
          if (passageToolbar) {
            passageToolbar.style.display = 'flex';
          }
        } else {
          createScratchPad();
          document.getElementById('scratch-pad-btn').innerHTML = '✅ Close Scratch Pad';
          
          // Hide passage toolbar while scratch pad is open (z-index conflict)
          const passageToolbar = document.getElementById('passage-toolbar');
          if (passageToolbar) {
            passageToolbar.style.display = 'none';
          }
        }
      };

      // Create scratch pad overlay
      const createScratchPad = () => {
        const overlay = document.createElement('div');
        overlay.id = 'scratch-overlay';
        overlay.style.cssText = `
          position: fixed;
          bottom: 20px;
          right: 20px;
          width: 450px;
          height: 350px;
          background: rgba(30, 42, 56, 0.98);
          border: 3px solid #9b59b6;
          border-radius: 15px;
          box-shadow: 0 10px 40px rgba(0,0,0,0.6);
          z-index: 9999;
          display: flex;
          flex-direction: column;
          resize: both;
          overflow: hidden;
          min-width: 300px;
          min-height: 250px;
        `;
        
        overlay.innerHTML = `
          <div id="scratch-handle" style="
            background: linear-gradient(145deg, #9b59b6, #8e44ad);
            padding: 8px;
            cursor: move;
            display: flex;
            justify-content: space-between;
            align-items: center;
