        toolbar.innerHTML = `
          <button data-tool="highlighter" style="background: #f39c12; padding: 8px 12px; border: none; border-radius: 5px; cursor: pointer; font-size: 14px;" title="Highlighter">🖍️</button>
          <button data-tool="pen" style="background: #3498db; padding: 8px 12px; border: none; border-radius: 5px; cursor: pointer; font-size: 14px;" title="Pen">✏️</button>
          <button data-tool="eraser" style="background: #95a5a6; padding: 8px 12px; border: none; border-radius: 5px; cursor: pointer; font-size: 14px;" title="Eraser">🧹</button>
