CMSApp.prototype.handleSaveApiKey = function() {
  const apiKeyInput = document.getElementById('gemini-api-key');
  const apiKey = apiKeyInput ? apiKeyInput.value.trim() : '';
  if (!apiKey) { this.showAlert('Please enter an API key.', 'error'); return; }
  if (!apiKey.startsWith('AIza')) {
    this.showAlert('Invalid API key format. Gemini API keys start with "AIza".', 'error');
    return;
  }
  if (this.saveApiKey(apiKey)) {
    this.showAlert('API key saved successfully! Reinitializing parser...', 'success');
    this.initializeUltimateParser();
    this.updateApiKeyStatus();
  } else {
    this.showAlert('Failed to save API key.', 'error');
  }
};

CMSApp.prototype.handleTestApiKey = function() {
  const apiKey = this.getStoredApiKey();
  if (!apiKey) { this.showAlert('Please save an API key first.', 'warning'); return; }
  this.showProcessing('Testing API connection...');
  if (this.geminiModel) {
    this.geminiModel.generateContent('Respond with exactly: {"status": "connected"}').then(result => {
      this.hideProcessing();
      this.showAlert('✅ API key is working correctly!', 'success');
      this.updateApiKeyStatus(true);
    }).catch(error => {
      this.hideProcessing();
      let msg = '❌ API key test failed. ';
      if (error.message.includes('API_KEY_INVALID')) msg += 'The API key is invalid.';
      else if (error.message.includes('quota') || error.message.includes('429')) msg += 'API quota exceeded.';
      else msg += 'Please check your key and billing settings.';
      this.showAlert(msg, 'error');
      this.updateApiKeyStatus(false);
    });
  } else {
    this.hideProcessing();
    this.showAlert('Parser not initialized. Please save API key first.', 'warning');
  }
};

CMSApp.prototype.updateApiKeyStatus = function(testResult = null) {
  const statusDiv = document.getElementById('api-key-status');
  const statusText = document.getElementById('api-key-status-text');
  if (!statusDiv || !statusText) return;
  const hasKey = !!this.getStoredApiKey();
  if (testResult === true) {
    statusDiv.style.display = 'block';
    statusDiv.style.background = 'rgba(40,167,69,0.1)';
    statusDiv.style.border = '1px solid var(--success-color)';
    statusText.style.color = 'var(--success-color)';
    statusText.textContent = '✅ API key is working correctly';
  } else if (testResult === false) {
    statusDiv.style.display = 'block';
    statusDiv.style.background = 'rgba(220,53,69,0.1)';
    statusDiv.style.border = '1px solid var(--danger-color)';
    statusText.style.color = 'var(--danger-color)';
    statusText.textContent = '❌ API key test failed';
  } else if (hasKey) {
    statusDiv.style.display = 'block';
    statusDiv.style.background = 'rgba(255,193,7,0.1)';
    statusDiv.style.border = '1px solid var(--warning-color)';
    statusText.style.color = 'var(--warning-color)';
    statusText.textContent = '🔑 API key saved (not tested)';
  } else {
    statusDiv.style.display = 'none';
  }
};

