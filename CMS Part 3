      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('≥')" title="Greater/equal">≥</button>
      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('×')" title="Multiply">×</button>
      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('÷')" title="Divide">÷</button>
