CMSApp.prototype.loadQuestionBanksForEpisode = function() {
  console.log('🔄 Loading question banks for episode sliders...');
  const togglesContainer = document.getElementById('question-banks-toggles');
  if (!togglesContainer) { console.error('Question banks toggles container not found'); return Promise.resolve(); }
  return new Promise((resolve) => {
    this.getDocs(this.collection(this.db, 'questionBanks')).then(qBanksSnapshot => {
      togglesContainer.innerHTML = '';
      if (qBanksSnapshot.empty) {
        togglesContainer.innerHTML = '<div style="text-align:center;color:#6c757d;padding:20px;">No question banks found. Create question banks first.</div>';
        resolve();
        return;
      }
      this.setupToggleAllButton();
      qBanksSnapshot.forEach(doc => {
        const bank = { id: doc.id, ...doc.data() };
        this.renderQuestionBankToggle(bank, togglesContainer);
      });
      console.log('✅ Question banks loaded for episode toggles');
      resolve();
    }).catch(error => {
      console.error('Error loading question banks for episode:', error);
      togglesContainer.innerHTML = '<div style="text-align:center;color:#dc3545;padding:20px;">Error loading question banks</div>';
      resolve();
    });
  });
};

CMSApp.prototype.renderQuestionBankToggle = function(bank, container) {
  const questions = Array.isArray(bank.questions) ? bank.questions : [];
  const bankItem = document.createElement('div');
  bankItem.className = 'bank-toggle-item';
  bankItem.dataset.bankId = bank.id;
  bankItem.innerHTML = `
    <div class="bank-info">
      <div class="bank-name">${bank.name || 'Untitled Bank'}</div>
      <div class="bank-details">${bank.approach || 'General'} • ${questions.length} questions</div>
    </div>
    <label class="toggle-switch">
      <input type="checkbox" class="bank-toggle" data-bank-id="${bank.id}">
      <span class="toggle-slider"></span>
    </label>
  `;
  container.appendChild(bankItem);
  const toggle = bankItem.querySelector('.bank-toggle');
  toggle.addEventListener('change', (e) => {
    bankItem.classList.toggle('enabled', e.target.checked);
  });
};

CMSApp.prototype.setupToggleAllButton = function() {
  const toggleAllBtn = document.getElementById('toggle-all-banks-btn');
  if (!toggleAllBtn) return;
  const newButton = toggleAllBtn.cloneNode(true);
  toggleAllBtn.parentNode.replaceChild(newButton, toggleAllBtn);
  newButton.addEventListener('click', () => this.toggleAllQuestionBanks());
};

CMSApp.prototype.toggleAllQuestionBanks = function() {
  const toggles = document.querySelectorAll('.bank-toggle');
  if (toggles.length === 0) return;
  const allChecked = Array.from(toggles).every(t => t.checked);
  toggles.forEach(toggle => {
    toggle.checked = !allChecked;
    toggle.closest('.bank-toggle-item').classList.toggle('enabled', !allChecked);
  });
};

CMSApp.prototype.setSelectedQuestionBanks = function(selectedBankIds) {
  document.querySelectorAll('.bank-toggle').forEach(toggle => {
    const isSelected = selectedBankIds.includes(toggle.dataset.bankId);
    toggle.checked = isSelected;
    toggle.closest('.bank-toggle-item').classList.toggle('enabled', isSelected);
  });
};

CMSApp.prototype.getSelectedQuestionBanks = function() {
  const selectedBanks = [];
  document.querySelectorAll('.bank-toggle:checked').forEach(toggle => {
    selectedBanks.push(toggle.dataset.bankId);
  });
  console.log('📚 Getting selected banks:', selectedBanks);
  return selectedBanks;
};

