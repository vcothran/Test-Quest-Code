CMSApp.prototype.initEncounterEditor = function(encounters) {
  const list = document.getElementById('encounters-list');
  if (!list) return;
  list.innerHTML = '';
  this._encounterCount = 0;
  if (encounters && encounters.length > 0) {
    encounters.forEach(enc => this.addEncounterRow(enc));
  } else {
    this.addEncounterRow();
  }
};

CMSApp.prototype.addEncounterRow = function(data) {
  const list = document.getElementById('encounters-list');
  if (!list) return;
  const idx = this._encounterCount || 0;
  this._encounterCount = idx + 1;
  const row = document.createElement('div');
  row.className = 'encounter-row';
  row.dataset.encounterIdx = idx;
  const title       = (data && data.title)    || '';
  const narrative   = (data && data.narrative) || '';
  const qCount      = (data && (data.questionsPerApproach || data.qCount)) || 5;
  const minCorrect  = (data && data.successThreshold && data.successThreshold.minCorrect  != null)
                      ? data.successThreshold.minCorrect : '';
  const minAccuracy = (data && data.successThreshold && data.successThreshold.minAccuracy != null)
                      ? data.successThreshold.minAccuracy : 60;
  row.innerHTML = `
    <div class="encounter-row-header">
      <span class="encounter-row-title">⚔️ Encounter ${idx + 1}</span>
      <button type="button" class="encounter-remove-btn"
              onclick="window.cmsApp.removeEncounterRow(${idx})">Remove</button>
    </div>
    <div class="encounter-field" style="margin-bottom:12px;">
      <label>Encounter Title</label>
      <input type="text" class="enc-title" placeholder="e.g. Signal Detection" value="${title}">
    </div>
    <div class="encounter-field" style="margin-bottom:12px;">
      <label>Narrative / Story Description</label>
      <textarea class="enc-narrative"
                placeholder="Describe what happens in this encounter...">${narrative}</textarea>
    </div>
    <div class="encounter-grid">
      <div class="encounter-field">
        <label>Questions Per Encounter</label>
        <input type="number" class="enc-qcount" min="1" max="100" value="${qCount}" placeholder="5">
      </div>
      <div class="encounter-field">
        <label>Min Accuracy to Pass (%)</label>
        <input type="number" class="enc-accuracy" min="0" max="100" value="${minAccuracy}" placeholder="60">
      </div>
    </div>
    <div class="encounter-field" style="margin-top:4px;">
      <label>Min Correct Answers to Pass (optional)</label>
      <input type="number" class="enc-mincorrect" min="0" value="${minCorrect}"
             placeholder="e.g. 3 (leave blank for accuracy only)">
    </div>
  `;
  list.appendChild(row);
  this._updateEncounterNumbers();
};

CMSApp.prototype.removeEncounterRow = function(idx) {
  const list = document.getElementById('encounters-list');
  if (!list) return;
  const row = list.querySelector(`[data-encounter-idx="${idx}"]`);
  if (row) row.remove();
  this._updateEncounterNumbers();
};

CMSApp.prototype._updateEncounterNumbers = function() {
  document.querySelectorAll('.encounter-row').forEach((row, i) => {
    const titleEl = row.querySelector('.encounter-row-title');
    if (titleEl) titleEl.textContent = `⚔️ Encounter ${i + 1}`;
  });
};

CMSApp.prototype.getEncountersFromEditor = function() {
  const encounters = [];
  document.querySelectorAll('.encounter-row').forEach(row => {
    const title      = row.querySelector('.enc-title').value.trim();
    const narrative  = row.querySelector('.enc-narrative').value.trim();
    const qCount     = parseInt(row.querySelector('.enc-qcount').value) || 5;
    const accuracy   = parseInt(row.querySelector('.enc-accuracy').value) || 60;
    const minCorrect = row.querySelector('.enc-mincorrect').value.trim();
    const enc = {
      title, narrative,
      questionsPerApproach: qCount,
      qCount,
      successThreshold: { minAccuracy: accuracy }
    };
    if (minCorrect !== '') enc.successThreshold.minCorrect = parseInt(minCorrect);
    encounters.push(enc);
  });
  return encounters;
};

CMSApp.prototype.handleEpisodeSubmit = function() {
  const title       = document.getElementById('episode-title').value.trim();
  const genre       = document.getElementById('episode-genre').value;
  const description = document.getElementById('episode-description').value.trim();
  const active      = document.getElementById('episode-active').checked;
  const selectedApproaches = [];
  document.querySelectorAll('.approach-checkbox:checked').forEach(cb => selectedApproaches.push(cb.value));
  const selectedQuestionBanks = this.getSelectedQuestionBanks();
  if (!title || !genre) { this.showAlert('Please fill in all required fields.', 'error'); return; }
  if (selectedApproaches.length === 0) { this.showAlert('Please select at least one available approach.', 'error'); return; }
  const encounters = this.getEncountersFromEditor();
  if (encounters.length === 0) { this.showAlert('Please add at least one encounter.', 'error'); return; }

  // ── Read cutscene settings ────────────────────────────────────
  const cutsceneEncountersEnabled = document.getElementById('cutscene-encounters-enabled')
    ? document.getElementById('cutscene-encounters-enabled').checked
    : true;
  const cutsceneCompletionEnabled = document.getElementById('cutscene-completion-enabled')
    ? document.getElementById('cutscene-completion-enabled').checked
    : true;
  const encounterCutsceneStyle = (document.getElementById('enc-style-novel') && document.getElementById('enc-style-novel').checked)
    ? 'graphic_novel'
    : 'cinematic';
  const completionCutsceneStyle = (document.getElementById('comp-style-cinematic') && document.getElementById('comp-style-cinematic').checked)
    ? 'cinematic'
    : 'graphic_novel';

  this.showProcessing(this.state.editingEpisodeId ? 'Updating episode...' : 'Creating episode...');
  const episodeData = {
    title, genre, description, active,
    availableApproaches:    selectedApproaches,
    selectedQuestionBanks:  selectedQuestionBanks,
    encounters:             encounters,
    cutsceneEncountersEnabled,
    cutsceneCompletionEnabled,
    encounterCutsceneStyle,
    completionCutsceneStyle,
    updatedAt:              this.serverTimestamp()
  };
  const promise = this.state.editingEpisodeId
    ? this.updateDoc(this.doc(this.db, 'episodes', this.state.editingEpisodeId), episodeData)
    : this.addDoc(this.collection(this.db, 'episodes'), {
        ...episodeData, createdAt: this.serverTimestamp(), createdWith: 'Ultimate Parser CMS v2.3'
      });
  promise.then(() => {
    this.showAlert(
      `Episode ${this.state.editingEpisodeId ? 'updated' : 'created'} with ${encounters.length} encounter${encounters.length !== 1 ? 's' : ''} and ${selectedQuestionBanks.length} question bank${selectedQuestionBanks.length !== 1 ? 's' : ''}!`,
      'success'
    );
    this.closeModal('episode-modal');
    this.loadEpisodes();
    this.state.editingEpisodeId = null;
  }).catch(error => {
    console.error('Error saving episode:', error);
    this.showAlert('Error saving episode.', 'error');
  }).finally(() => { this.hideProcessing(); });
};

CMSApp.prototype.handleGenreSubmit = function() {
  const name = document.getElementById('genre-name').value.trim();
  const descField = document.getElementById('genre-description');
  const subjectField = document.getElementById('genre-subject');
  const description = descField ? descField.value.trim() : '';
  const primarySubject = subjectField ? subjectField.value : '';
  if (!name) { this.showAlert('Please enter a genre name.', 'error'); return; }
  this.showProcessing(this.state.editingGenreId ? 'Updating genre...' : 'Creating genre...');
  const genreData = { name, description, primarySubject, updatedAt: this.serverTimestamp() };
  const promise = this.state.editingGenreId
    ? this.updateDoc(this.doc(this.db, 'genres', this.state.editingGenreId), genreData)
    : this.addDoc(this.collection(this.db, 'genres'), { ...genreData, createdAt: this.serverTimestamp() });
  promise.then(() => {
    this.showAlert(this.state.editingGenreId ? 'Genre updated!' : 'Genre created!', 'success');
    this.closeModal('genre-modal');
    this.loadGenres();
    this.state.editingGenreId = null;
  }).catch(error => {
    console.error('Error saving genre:', error);
    this.showAlert('Error saving genre.', 'error');
  }).finally(() => { this.hideProcessing(); });
};

