      <button class="edit-image" onclick="event.stopPropagation();window.cmsApp.editImage('${context}',${index})" title="Edit">✏️</button>
      <button class="remove-image" onclick="event.stopPropagation();window.cmsApp.removeImage('${context}',${index})" title="Remove">×</button>
      <div class="image-label">Image ${index+1}</div>
    </div>
  `).join('');
};

// ─────────────────────────────────────────────
// IMAGE UPLOAD HANDLERS
// ─────────────────────────────────────────────
CMSApp.prototype.setupImageUploadHandlers = function(optionLetters) {
  this.setupImageHandler('passage');
  this.setupImageHandler('question');
  if (optionLetters) {
    optionLetters.forEach(letter => this.setupImageHandler(`option-${letter}`));
  }
};

CMSApp.prototype.setupImageHandler = function(context) {
  const zone = document.getElementById(`${context}-image-zone`);
  const input = document.getElementById(`${context}-image-input`);
  if (!zone || !input) return;

  input.addEventListener('change', (e) => this.handleImageFiles(e.target.files, context));

  ['dragenter','dragover','dragleave','drop'].forEach(ev => {
    zone.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); });
  });
  zone.addEventListener('dragover', () => zone.classList.add('dragover'));
  zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
  zone.addEventListener('drop', (e) => {
    zone.classList.remove('dragover');
    const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
    if (files.length > 0) this.handleImageFiles(files, context);
  });
  zone.addEventListener('mouseenter', () => { this.imageManager.currentContext = context; });
};

CMSApp.prototype.setupGlobalPasteListener = function() {
  document.addEventListener('paste', (e) => {
    if (!document.getElementById('edit-question-modal') || !this.imageManager || !this.imageManager.currentContext) return;
    const items = e.clipboardData?.items;
    if (!items) return;
    for (let i = 0; i < items.length; i++) {
      if (items[i].type.indexOf('image') !== -1) {
        e.preventDefault();
        this.handleImageFiles([items[i].getAsFile()], this.imageManager.currentContext);
        break;
      }
    }
  });
};

CMSApp.prototype.handleImageFiles = function(files, context) {
  Array.from(files).forEach(file => {
    if (!file || !file.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      if (this.imageManager.compressionEnabled) {
        this.compressImage(e.target.result, (compressed) => this.addImageToGallery(compressed, context));
      } else {
        this.addImageToGallery(e.target.result, context);
      }
    };
    reader.readAsDataURL(file);
  });
};

CMSApp.prototype.compressImage = function(imageData, callback) {
  const img = new Image();
  img.onload = () => {
    const canvas = document.createElement('canvas');
    let w = img.width, h = img.height;
    const max = 1200;
    if (w > max || h > max) {
      if (w > h) { h = (h/w)*max; w = max; } else { w = (w/h)*max; h = max; }
    }
    canvas.width = w; canvas.height = h;
    canvas.getContext('2d').drawImage(img, 0, 0, w, h);
    callback(canvas.toDataURL('image/jpeg', this.imageManager.compressionQuality));
  };
  img.src = imageData;
};

CMSApp.prototype.toggleCompression = function(enabled) {
  this.imageManager.compressionEnabled = enabled;
};

CMSApp.prototype.addImageToGallery = function(imageData, context) {
  if (context === 'passage') {
    this.imageManager.images.passage.push(imageData);
  } else if (context === 'question') {
    this.imageManager.images.question.push(imageData);
  } else if (context.startsWith('option-')) {
    const key = context.replace('option-', '');
    if (!this.imageManager.images.options[key]) this.imageManager.images.options[key] = [];
    this.imageManager.images.options[key].push(imageData);
  }
  this.updateImageGallery(context);
};

CMSApp.prototype.updateImageGallery = function(context) {
  const gallery = document.getElementById(`${context}-images-gallery`);
  if (!gallery) return;
  let images;
  if (context === 'passage') images = this.imageManager.images.passage;
  else if (context === 'question') images = this.imageManager.images.question;
  else if (context.startsWith('option-')) {
    const key = context.replace('option-', '');
    images = this.imageManager.images.options[key] || [];
  }
  gallery.innerHTML = this.renderImageGallery(images, context);
};

CMSApp.prototype.removeImage = function(context, index) {
  if (context === 'passage') {
    this.imageManager.images.passage.splice(index, 1);
  } else if (context === 'question') {
    this.imageManager.images.question.splice(index, 1);
  } else if (context.startsWith('option-')) {
    const key = context.replace('option-', '');
    if (this.imageManager.images.options[key]) this.imageManager.images.options[key].splice(index, 1);
  }
  this.updateImageGallery(context);
};

CMSApp.prototype.viewImage = function(imageData) {
  const viewer = document.createElement('div');
  viewer.className = 'image-viewer-modal active';
  viewer.innerHTML = `
    <div class="image-viewer-content">
      <button class="image-viewer-close" onclick="this.closest('.image-viewer-modal').remove()">×</button>
      <img src="${imageData}" alt="Full size image">
    </div>`;
  document.body.appendChild(viewer);
  viewer.addEventListener('click', e => { if (e.target === viewer) viewer.remove(); });
  document.addEventListener('keydown', function esc(e) {
    if (e.key === 'Escape') { viewer.remove(); document.removeEventListener('keydown', esc); }
  });
};

CMSApp.prototype.editImage = function(context, index) {
  let imageData;
  if (context === 'passage') imageData = this.imageManager.images.passage[index];
  else if (context === 'question') imageData = this.imageManager.images.question[index];
  else if (context.startsWith('option-')) {
    const key = context.replace('option-', '');
    imageData = this.imageManager.images.options[key]?.[index];
  }
  if (!imageData) return;

  const existing = document.getElementById('image-editor-modal');
  if (existing) existing.remove();

  const editorEl = document.createElement('div');
  editorEl.className = 'image-editor-modal active';
  editorEl.id = 'image-editor-modal';
  editorEl.innerHTML = `
    <div class="image-editor-container">
      <h3 style="margin:0 0 15px 0;">✏️ Edit Image</h3>
      <div class="image-editor-toolbar">
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.rotateImage(-90)">↶ Rotate Left</button>
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.rotateImage(90)">↷ Rotate Right</button>
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.adjustBrightness(10)">☀️ Brighter</button>
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.adjustBrightness(-10)">🌙 Darker</button>
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.adjustContrast(10)">◐ More Contrast</button>
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.adjustContrast(-10)">◑ Less Contrast</button>
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.resetImageEdits()">🔄 Reset</button>
      </div>
      <div class="image-editor-canvas-container">
        <canvas id="image-editor-canvas" class="image-editor-canvas"></canvas>
      </div>
      <div class="image-editor-actions">
        <button class="cms-btn cms-btn-secondary" onclick="window.cmsApp.closeImageEditor()">Cancel</button>
        <button class="cms-btn cms-btn-primary" onclick="window.cmsApp.saveEditedImage('${context}',${index})">💾 Save</button>
      </div>
    </div>`;
  document.body.appendChild(editorEl);

  this.currentEditingImage = { originalData: imageData, context, index, rotation: 0, brightness: 0, contrast: 0 };
  this.loadImageToCanvas(imageData);
};

CMSApp.prototype.loadImageToCanvas = function(imageData) {
  const canvas = document.getElementById('image-editor-canvas');
  const img = new Image();
  img.onload = () => {
    canvas.width = img.width; canvas.height = img.height;
    this.currentEditingImage.img = img;
    this.renderEditedImage();
  };
  img.src = imageData;
};

CMSApp.prototype.renderEditedImage = function() {
  const canvas = document.getElementById('image-editor-canvas');
  const ctx = canvas.getContext('2d');
  const { img, rotation, brightness, contrast } = this.currentEditingImage;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.save();
  ctx.translate(canvas.width/2, canvas.height/2);
  ctx.rotate(rotation * Math.PI / 180);
  ctx.translate(-canvas.width/2, -canvas.height/2);
  ctx.filter = `brightness(${100+brightness}%) contrast(${100+contrast}%)`;
  ctx.drawImage(img, 0, 0);
  ctx.restore();
};

CMSApp.prototype.rotateImage = function(deg) { this.currentEditingImage.rotation += deg; this.renderEditedImage(); };
CMSApp.prototype.adjustBrightness = function(v) { this.currentEditingImage.brightness += v; this.renderEditedImage(); };
CMSApp.prototype.adjustContrast = function(v) { this.currentEditingImage.contrast += v; this.renderEditedImage(); };
CMSApp.prototype.resetImageEdits = function() {
  this.currentEditingImage.rotation = 0;
  this.currentEditingImage.brightness = 0;
  this.currentEditingImage.contrast = 0;
  this.renderEditedImage();
};

CMSApp.prototype.saveEditedImage = function(context, index) {
  const canvas = document.getElementById('image-editor-canvas');
  const editedData = canvas.toDataURL('image/jpeg', 0.9);
  if (context === 'passage') this.imageManager.images.passage[index] = editedData;
  else if (context === 'question') this.imageManager.images.question[index] = editedData;
  else if (context.startsWith('option-')) {
    const key = context.replace('option-', '');
    this.imageManager.images.options[key][index] = editedData;
  }
  this.updateImageGallery(context);
  this.closeImageEditor();
  this.showAlert('Image saved!', 'success');
};

CMSApp.prototype.closeImageEditor = function() {
  const editor = document.getElementById('image-editor-modal');
  if (editor) editor.remove();
  this.currentEditingImage = null;
};

CMSApp.prototype.getCurrentEditingQuestion = function() {
  if (!this.imageManager || !this.imageManager.currentBankId) return null;
  const bank = this.state.questionBanks.find(b => b.id === this.imageManager.currentBankId);
  if (!bank) return null;
  return (bank.questions || [])[this.imageManager.currentQuestionIndex];
};

