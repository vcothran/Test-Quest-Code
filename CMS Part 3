<script>
console.log('📝 Loading Section 14.5: Manual Question Adding...');

CMSApp.prototype.showAddQuestionModal = function(bankId) {
  console.log('➕ Opening add question modal for bank:', bankId);
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  if (!bank) { this.showAlert('Question bank not found.', 'error'); return; }
  this.state.addingQuestionToBankId = bankId;

  // Remove any existing instance
  const existing = document.getElementById('add-question-modal');
  if (existing) existing.remove();

  // Build modal and append directly to body so it sits above everything
  const modalEl = document.createElement('div');
  modalEl.id = 'add-question-modal';
  modalEl.style.cssText = `
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.6);
    z-index: 99998;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-y: auto;
    padding: 20px;
  `;

  modalEl.innerHTML = `
    <div style="
      background: #ffffff;
      border-radius: 10px;
      padding: 30px;
      width: 100%;
      max-width: 640px;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
      box-shadow: 0 8px 40px rgba(0,0,0,0.35);
      z-index: 99999;
    ">
      <!-- Header -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;border-bottom:2px solid #e9ecef;padding-bottom:14px;">
        <h2 style="margin:0;font-size:20px;color:#212529;">➕ Add Question to: ${bank.name}</h2>
        <button onclick="window.cmsApp.closeAddQuestionModal()"
                style="background:none;border:none;font-size:24px;cursor:pointer;color:#6c757d;line-height:1;padding:0 4px;"
                title="Cancel">&times;</button>
      </div>

      <form id="add-question-form" onsubmit="event.preventDefault(); window.cmsApp.handleManualQuestionSubmit();">

        <!-- Format -->
        <div style="margin-bottom:16px;">
          <label style="display:block;font-weight:600;margin-bottom:6px;color:#495057;">Answer Format *</label>
          <select id="manual-q-format"
                  onchange="window.cmsApp.renderManualQuestionOptions(this.value)"
                  style="width:100%;padding:10px;border:1px solid #ced4da;border-radius:6px;font-size:14px;background:#fff;">
            <option value="abcd">A, B, C, D — Standard ACT (Math / Science / English)</option>
            <option value="fghj">F, G, H, J — ACT Reading</option>
            <option value="tf">True / False</option>
            <option value="custom">Custom (up to 5 options A–E)</option>
          </select>
        </div>

        <!-- Question Text -->
        <div style="margin-bottom:16px;">
          <label style="display:block;font-weight:600;margin-bottom:6px;color:#495057;">Question Text *</label>
          <textarea id="manual-q-text" rows="3" required
                    placeholder="Enter your question here..."
                    style="width:100%;padding:10px;border:1px solid #ced4da;border-radius:6px;font-size:14px;resize:vertical;box-sizing:border-box;"></textarea>
        </div>

        <!-- Passage -->
        <div style="margin-bottom:16px;">
          <label style="display:block;font-weight:600;margin-bottom:6px;color:#495057;">
            Passage / Context
            <span style="font-weight:400;color:#6c757d;">(Optional — for Reading questions)</span>
          </label>
          <textarea id="manual-q-passage" rows="4"
                    placeholder="Enter the reading passage or context if applicable..."
                    style="width:100%;padding:10px;border:1px solid #ced4da;border-radius:6px;font-size:14px;resize:vertical;box-sizing:border-box;"></textarea>
        </div>

        <!-- Dynamic options -->
        <div id="manual-options-container"></div>

        <!-- Explanation -->
        <div style="margin-bottom:20px;">
          <label style="display:block;font-weight:600;margin-bottom:6px;color:#495057;">
            Explanation
            <span style="font-weight:400;color:#6c757d;">(Optional)</span>
          </label>
          <textarea id="manual-q-explanation" rows="3"
                    placeholder="Explain why this answer is correct..."
                    style="width:100%;padding:10px;border:1px solid #ced4da;border-radius:6px;font-size:14px;resize:vertical;box-sizing:border-box;"></textarea>
        </div>

        <!-- Buttons -->
        <div style="display:flex;gap:12px;">
          <button type="submit"
                  style="flex:1;padding:12px;background:#28a745;color:white;border:none;border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;">
            ➕ Add Question
          </button>
          <button type="button"
                  onclick="window.cmsApp.closeAddQuestionModal()"
                  style="flex:1;padding:12px;background:#6c757d;color:white;border:none;border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;">
            Cancel
          </button>
        </div>

      </form>
    </div>
  `;

  document.body.appendChild(modalEl);

  // Close on backdrop click
  modalEl.addEventListener('click', (e) => {
    if (e.target === modalEl) window.cmsApp.closeAddQuestionModal();
  });

  // Render default options
  this.renderManualQuestionOptions('abcd');
};

CMSApp.prototype.closeAddQuestionModal = function() {
  const modal = document.getElementById('add-question-modal');
  if (modal) modal.remove();
  this.state.addingQuestionToBankId = null;
};

// Render options based on selected format
CMSApp.prototype.renderManualQuestionOptions = function(format) {
  const container = document.getElementById('manual-options-container');
  if (!container) return;

  const inputStyle = 'width:100%;padding:10px;border:1px solid #ced4da;border-radius:6px;font-size:14px;box-sizing:border-box;';
  const groupStyle = 'margin-bottom:12px;';
  const labelStyle = 'display:block;font-weight:500;margin-bottom:4px;color:#495057;';

  let letters = [];
  if (format === 'abcd') letters = ['A','B','C','D'];
  else if (format === 'fghj') letters = ['F','G','H','J'];
  else if (format === 'tf') letters = ['T','F2'];
  else if (format === 'custom') letters = ['A','B','C','D','E'];

  let optionsHTML = `<div style="margin-bottom:16px;">
    <div style="font-weight:600;color:#495057;margin-bottom:10px;font-size:15px;">Answer Options *</div>`;

  if (format === 'tf') {
    optionsHTML += `
      <div style="${groupStyle}">
        <label style="${labelStyle}">Option 1:</label>
        <input type="text" id="manual-option-T" value="True" readonly style="${inputStyle}background:#f8f9fa;">
      </div>
      <div style="${groupStyle}">
        <label style="${labelStyle}">Option 2:</label>
        <input type="text" id="manual-option-F2" value="False" readonly style="${inputStyle}background:#f8f9fa;">
      </div>
    `;
  } else {
    const placeholder = format === 'custom' ? ' (leave blank to omit)' : '';
    letters.forEach(l => {
      optionsHTML += `
        <div style="${groupStyle}">
          <label style="${labelStyle}">${l}:</label>
          <input type="text" id="manual-option-${l}" placeholder="Option ${l}${placeholder}" style="${inputStyle}">
        </div>
      `;
    });
  }

  // Correct answer dropdown
  let correctOptions = '';
  if (format === 'tf') {
    correctOptions = '<option value="T">True</option><option value="F2">False</option>';
  } else {
    letters.forEach(l => { correctOptions += `<option value="${l}">${l}</option>`; });
  }

  optionsHTML += `
    <div style="${groupStyle}">
      <label style="${labelStyle}">Correct Answer *</label>
      <select id="manual-correct-answer" required style="${inputStyle}background:#fff;">
        ${correctOptions}
      </select>
    </div>
  </div>`;

  container.innerHTML = optionsHTML;
};

CMSApp.prototype.handleManualQuestionSubmit = function() {
  const bankId = this.state.addingQuestionToBankId;
  if (!bankId) { this.showAlert('No bank selected.', 'error'); return; }

  const questionText = document.getElementById('manual-q-text').value.trim();
  const passage = document.getElementById('manual-q-passage').value.trim();
  const explanation = document.getElementById('manual-q-explanation').value.trim();
  const format = document.getElementById('manual-q-format').value;
  const correctAnswer = document.getElementById('manual-correct-answer').value;

  if (!questionText) { this.showAlert('Please enter a question.', 'error'); return; }

  // Collect options
  const options = {};
  let letters = [];
  if (format === 'abcd') letters = ['A','B','C','D'];
  else if (format === 'fghj') letters = ['F','G','H','J'];
  else if (format === 'tf') letters = ['T','F2'];
  else if (format === 'custom') letters = ['A','B','C','D','E'];

  let hasOptions = false;
  letters.forEach(letter => {
    const input = document.getElementById(`manual-option-${letter}`);
    if (input && input.value.trim()) { options[letter] = input.value.trim(); hasOptions = true; }
  });

  if (!hasOptions) { this.showAlert('Please enter at least one answer option.', 'error'); return; }
  if (!options[correctAnswer]) { this.showAlert('The correct answer option must have text entered.', 'error'); return; }

  const newQuestion = {
    question: questionText,
    text: questionText,
    options,
    correct: correctAnswer,
    format,
    passage: passage || '',
    explanation: explanation || '',
    addedManually: true,
    createdAt: new Date().toISOString()
  };

  this.showProcessing('Adding question...');
  const bankRef = this.doc(this.db, 'questionBanks', bankId);
  this.getDoc(bankRef).then(docSnap => {
    if (!docSnap.exists()) throw new Error('Question bank not found');
    const currentQuestions = docSnap.data().questions || [];
    currentQuestions.push(newQuestion);
    return this.updateDoc(bankRef, { questions: currentQuestions, updatedAt: this.serverTimestamp() });
  }).then(() => {
    this.showAlert('Question added successfully!', 'success');
    this.closeAddQuestionModal();
    // Reload bank then refresh questions view
    const { doc, getDoc } = window.firebaseV9;
    getDoc(doc(this.db, 'questionBanks', bankId)).then(snap => {
      if (snap.exists()) {
        const bank = this.state.questionBanks.find(b => b.id === bankId);
        if (bank) {
          bank.questions = snap.data().questions || [];
          this.showQuestionsViewModal(bank);
        }
      }
    });
    this.loadQuestionBanks();
  }).catch(error => {
    console.error('Error adding question:', error);
    this.showAlert('Error adding question: ' + error.message, 'error');
  }).finally(() => { this.hideProcessing(); });
};

console.log('✅ Section 14.5 loaded — modal appended to body, z-index 99999, cancel works');
</script>
