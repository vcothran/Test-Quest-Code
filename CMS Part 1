CMSApp.prototype.initializeGeminiModel = function(modelName = null) {
  const targetModel = modelName || window.GEMINI_MODEL;
  
  console.log('🤖 Initializing Gemini Model...');
  console.log('🎯 Attempting model:', targetModel);
  
  try {
    if (!window.GoogleGenerativeAI) {
      throw new Error('GoogleGenerativeAI not loaded. Check Section 1 imports.');
