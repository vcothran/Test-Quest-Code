// ===========================================
// ENHANCED RETRY WITH QUOTA DETECTION
// ===========================================
CMSApp.prototype.retryWithBackoff = async function(operation, maxRetries = 3) {
  let lastError = null;
  
  for (let attempt = 1; attempt <= maxRetries; attempt++) {
    try {
      console.log(`🔄 Attempt ${attempt}/${maxRetries}...`);
      return await operation();
    } catch (error) {
      lastError = error;
      console.warn(`❌ Attempt ${attempt} failed:`, error.message);
      
      // Check for quota/rate limit errors
      const isQuotaError = error.message.includes('quota') || 
                          error.message.includes('429') || 
                          error.message.includes('RESOURCE_EXHAUSTED') ||
                          error.message.includes('Too Many Requests');
      
      if (isQuotaError) {
        console.warn('⚠️ Quota/rate limit detected');
        
        // Try fallback model on first quota error
        if (attempt === 1 && this.currentModelName !== window.ULTIMATE_PARSER_CONFIG.MODELS.FALLBACK) {
          console.log('🔄 Switching to fallback model...');
          const fallbackSuccess = this.initializeGeminiModel(window.ULTIMATE_PARSER_CONFIG.MODELS.FALLBACK);
          
          if (fallbackSuccess) {
            this.showAlert('Switched to alternative model due to quota limits. Retrying...', 'info');
            continue; // Try again with fallback model
          }
        }
        
        if (attempt < maxRetries) {
          const delay = attempt * 3000; // 3s, 6s, 9s
          console.log(`⏳ Waiting ${delay/1000} seconds before retry...`);
          this.showAlert(`Rate limit hit. Waiting ${delay/1000} seconds...`, 'info');
          await new Promise(resolve => setTimeout(resolve, delay));
        } else {
          // Final attempt failed
          throw new Error(`API quota exceeded after ${maxRetries} attempts.\n\nYour account has $300 credit, but you've hit rate limits.\n\nSolutions:\n1. Wait 2-3 minutes between uploads\n2. Upload 1 page at a time (not 2-3)\n3. The free tier has strict rate limits even with credits\n4. Consider upgrading to paid tier for higher limits`);
        }
      } else {
        // Non-quota error, throw immediately
        throw error;
      }
    }
  }
  
  // If we get here, all retries failed
  throw lastError;
};

// ===========================================
// ENHANCED API CALL
// ===========================================
CMSApp.prototype.makeEnhancedAPICall = async function(prompt, operation = 'API Call', retryEnabled = true) {
  console.log(`📞 Making ${operation}...`);
  console.log(`🎯 Using model: ${this.currentModelName}`);
  
  if (!this.geminiModel) {
    throw new Error('Parser not initialized. Please add API key in Settings.');
  }
  
  const apiCall = async () => {
    try {
      const result = await this.geminiModel.generateContent(prompt);
      const response = await result.response;
      const text = response.text();
      
      console.log(`✅ ${operation} successful`);
      console.log('📝 Response length:', text.length);
      
      return text;
    } catch (error) {
      console.error(`❌ ${operation} failed:`, error);
      
      // Add more context to error message
      if (error.message.includes('429') || error.message.includes('quota')) {
        error.message = `Rate limit exceeded. ${error.message}`;
      }
      
      throw error;
    }
  };
  
  if (retryEnabled) {
    return await this.retryWithBackoff(apiCall);
  } else {
    return await apiCall();
  }
};

// ===========================================
// FILE TO BASE64 CONVERSION
// ===========================================
CMSApp.prototype.fileToBase64 = function(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    
    reader.onload = (e) => {
      const base64 = e.target.result.split(',')[1];
      resolve(base64);
    };
    
    reader.onerror = (e) => {
      reject(new Error('Failed to read file'));
    };
    
    reader.readAsDataURL(file);
  });
};

