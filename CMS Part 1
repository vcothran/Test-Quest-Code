    if (!window.GEMINI_API_KEY) {
      throw new Error('No API key found. Please add your API key in Settings.');
    }
    
    console.log('✅ GoogleGenerativeAI found');
    console.log('🔑 API Key present');
    
    const genAI = new window.GoogleGenerativeAI(window.GEMINI_API_KEY);
    this.geminiModel = genAI.getGenerativeModel({ model: targetModel });
    this.currentModelName = targetModel;
    
