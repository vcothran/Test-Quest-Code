CMSApp.prototype.setupApiKey = async function() {
  console.log('\u{1F511} Setting up API key...');

  if (window.ULTIMATE_PARSER_CONFIG && window.ULTIMATE_PARSER_CONFIG.GEMINI_API_KEY) {
    window.GEMINI_API_KEY = window.ULTIMATE_PARSER_CONFIG.GEMINI_API_KEY;
    console.log('\u2705 Gemini API key loaded from ULTIMATE_PARSER_CONFIG');
    return;
  }

  const storedKey = this.getStoredApiKey();
  if (storedKey) {
    window.GEMINI_API_KEY = storedKey;
    window._localStorageKey = storedKey;
    console.log('\u2705 Gemini API key loaded from localStorage (will upgrade via Cloud Function when auth ready)');
    return;
  }

  console.warn('\u26A0\uFE0F No Gemini API key found in localStorage. Parser will be limited until auth completes.');
};

CMSApp.prototype.fetchTeacherApiKey = async function(user) {
  try {
    const { httpsCallable, getFunctions } = window.firebaseV9;

    // FIX v4: user is passed directly from onAuthStateChanged callback
    // No getAuth() re-call — eliminates auth instance mismatch
    if (!user) {
      console.warn('CMS: Not authenticated, cannot fetch API key');
      return null;
    }

    console.log('CMS: Fetching API key for user:', user.uid);

    // Force token refresh to ensure the credential is fresh
    await user.getIdToken(true);

    const functions = getFunctions(this.firebaseApp);
    const getGeminiKey = httpsCallable(functions, 'getGeminiKey');
    const result = await getGeminiKey();

    if (result.data && result.data.key) {
      console.log('CMS: API key loaded (source: ' + result.data.source + ')');
      return result.data.key;
    }
    throw new Error('No key returned from function');

  } catch (error) {
    if (error.code === 'functions/permission-denied') {
      alert('Your API key access has been deactivated.\n\nPlease contact your administrator to restore access.');
      return null;
    }
    if (error.code === 'functions/unauthenticated') {
      console.warn('CMS: Not authenticated, cannot fetch API key');
      return null;
    }
    console.warn('CMS: Cloud Function unavailable:', error.message);
    return null;
  }
};

