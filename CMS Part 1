<script>
// Highlight active radio card borders
(function() {
  function updateRadioCards(name) {
    document.querySelectorAll(`input[name="${name}"]`).forEach(radio => {
      const label = radio.closest('label');
      if (!label) return;
      if (radio.checked) {
        label.style.borderColor = '#667eea';
        label.style.background  = 'rgba(102,126,234,0.06)';
      } else {
        label.style.borderColor = '#dee2e6';
        label.style.background  = '#fff';
      }
    });
  }

  function initCutsceneUI() {
    // Radio card highlighting
    ['encounter-cutscene-style', 'completion-cutscene-style'].forEach(name => {
      document.querySelectorAll(`input[name="${name}"]`).forEach(radio => {
        radio.addEventListener('change', () => updateRadioCards(name));
      });
      updateRadioCards(name);
    });

    // Toggle encounter style row visibility
    const encToggle = document.getElementById('cutscene-encounters-enabled');
    const encStyleRow = document.getElementById('encounter-cutscene-style-row');
    if (encToggle && encStyleRow) {
      encToggle.addEventListener('change', function() {
        encStyleRow.style.opacity  = this.checked ? '1' : '0.4';
        encStyleRow.style.pointerEvents = this.checked ? 'auto' : 'none';
      });
    }

    // Toggle completion style row visibility
    const compToggle = document.getElementById('cutscene-completion-enabled');
    const compStyleRow = document.getElementById('completion-cutscene-style-row');
    if (compToggle && compStyleRow) {
      compToggle.addEventListener('change', function() {
        compStyleRow.style.opacity  = this.checked ? '1' : '0.4';
        compStyleRow.style.pointerEvents = this.checked ? 'auto' : 'none';
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCutsceneUI);
  } else {
    initCutsceneUI();
  }
})();
</script>
	
