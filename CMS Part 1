CMSApp.prototype.switchPage = function(pageId) {
  console.log('\u{1F4C4} Switched to page:', pageId);
  document.querySelectorAll('.cms-nav-tab').forEach(tab => {
    tab.classList.remove('active');
    if (tab.getAttribute('data-page') === pageId) tab.classList.add('active');
  });
  document.querySelectorAll('.cms-page').forEach(page => {
    page.style.display = 'none';
    page.classList.remove('active');
  });
  const targetPage = document.getElementById('page-' + pageId);
  if (targetPage) { targetPage.style.display = 'block'; targetPage.classList.add('active'); }
};

