            8: 'Highly Advanced, College-level, ACT 35-36',
            9: 'Expert, Advanced College, Perfect Score',
            10: 'Master, Graduate-level reasoning'
          };
          return descriptors[this.currentLevel] || descriptors[5];
        }
      };

      // Reputation system
      const reputationSystem = {
        score: 0,               // -100 to +100
        title: 'Apprentice',
        relationshipScores: {},
        
        // Update reputation based on performance tier
        updateReputation: function(tier) {
          const changes = {
            mastery: 15,
            proficient: 5,
            developing: 0,
            struggling: -5
          };
          
          this.score += changes[tier];
          this.score = Math.max(-100, Math.min(100, this.score));
          this.updateTitle();
          
          return this.score;
        },
        
        // Update title based on score
        updateTitle: function() {
          if (this.score >= 80) {
            this.title = 'Master Scholar';
          } else if (this.score >= 60) {
            this.title = 'Renowned Expert';
          } else if (this.score >= 40) {
            this.title = 'Skilled Practitioner';
          } else if (this.score >= 20) {
            this.title = 'Rising Scholar';
          } else if (this.score >= 0) {
            this.title = 'Dedicated Student';
          } else if (this.score >= -20) {
            this.title = 'Struggling Apprentice';
          } else {
            this.title = 'Novice Learner';
          }
        },
        
        // Update relationship with NPC
        updateRelationship: function(npcId, change) {
          if (!this.relationshipScores[npcId]) {
            this.relationshipScores[npcId] = 50;
          }
          this.relationshipScores[npcId] += change;
          this.relationshipScores[npcId] = Math.max(0, Math.min(100, this.relationshipScores[npcId]));
        }
      };

      // Calculate performance tier (used by Character Stats panel)
      const calculatePerformanceTier = (percentage) => {
        if (percentage >= 90) return 'mastery';
        if (percentage >= 75) return 'proficient';
        if (percentage >= 60) return 'developing';
        return 'struggling';
      };

      console.log('✅ Section 14: Adaptive Difficulty System (Minimal) loaded');

/* === SECTION 15: ENDING SYSTEM (STREAMLINED) === */

      // Display episode ending and apply consequences
      const completeEpisode = async () => {
