        // Save progress (use the global function from Section 9)
        if (typeof savePlayerProgress === 'function') {
          await savePlayerProgress();
        }
      };

      // Apply ending consequences (XP, gold, reputation, difficulty)
      const applyEndingConsequences = (tier, percentage) => {
        const consequences = {
          mastery: {
            xpBonus: 150,
            gold: 100,
            reputationChange: 15,
            difficultyAdjustment: 1,
            message: '🌟 Exceptional Performance!'
          },
