            // If switching TO polygon tool from another tool, start fresh
            if (newTool === 'polygon' && previousTool !== 'polygon') {
              annotationState.polygonPoints = [];
            }
            
            annotationState.scratchTool = newTool;
            document.querySelectorAll('.scratch-tool').forEach(b => b.style.transform = 'none');
            btn.style.transform = 'scale(1.1)';
          };
        });
        
        // Color buttons
        document.querySelectorAll('.scratch-color').forEach(btn => {
          btn.onclick = () => {
