// over any older version defined in other sections.
// Handles both parser format (array) and manual format (object)
// ─────────────────────────────────────────────────────────────
CMSApp.prototype.editQuestion = function(bankId, questionIndex) {
  console.log('✏️ editQuestion v3 - bankId:', bankId, 'index:', questionIndex);
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  if (!bank) { this.showAlert('Question bank not found.', 'error'); return; }
  const questions = bank.questions || [];
  const question = questions[questionIndex];
  if (!question) { this.showAlert('Question not found.', 'error'); return; }

  const isObjectOptions = question.options && !Array.isArray(question.options);
  const questionText = (question.text || question.question || '').replace(/</g,'&lt;');

  // Normalize to [{letter, text}] regardless of storage format
  let optionPairs = [];
  if (isObjectOptions) {
    optionPairs = Object.entries(question.options).map(([letter, text]) => ({ letter, text }));
  } else if (Array.isArray(question.options)) {
    optionPairs = question.options.map((text, i) => ({ letter: String.fromCharCode(65 + i), text }));
  }

  // Current correct letter
  let currentCorrectLetter = '';
  if (isObjectOptions) {
    currentCorrectLetter = question.correct || (optionPairs[0] && optionPairs[0].letter) || 'A';
  } else {
    const idx = typeof question.correct === 'number' ? question.correct
              : typeof question.correctAnswer === 'number' ? question.correctAnswer : 0;
    currentCorrectLetter = optionPairs[idx] ? optionPairs[idx].letter : 'A';
  }

  const passageVal = (question.passageContext || question.passage || '').replace(/</g,'&lt;');

  const existing = document.getElementById('edit-question-modal');
  if (existing) existing.remove();

  // Build toolbar helper inline
  const tb = (id) => {
    const b = (label, title, action) =>
      `<button type="button" title="${title}" onclick="${action}"
        style="padding:3px 7px;border:1px solid #ced4da;border-radius:4px;background:#fff;
               cursor:pointer;font-size:12px;margin:1px;"
        onmouseover="this.style.background='#e9ecef'"
        onmouseout="this.style.background='#fff'">${label}</button>`;
    return `<div style="background:#f8f9fa;border:1px solid #ced4da;border-bottom:none;
                        border-radius:6px 6px 0 0;padding:5px 7px;display:flex;flex-wrap:wrap;gap:1px;">
      ${b('<b>B</b>','Bold',`window.cmsApp.wrapSelection('${id}','**','**')`)}
      ${b('<i>I</i>','Italic',`window.cmsApp.wrapSelection('${id}','_','_')`)}
      ${b('<u>U</u>','Underline',`window.cmsApp.wrapSelection('${id}','[u]','[/u]')`)}
      <span style="border-left:1px solid #ced4da;margin:1px 3px;"></span>
      ${b('√','Square root',`window.cmsApp.insertAtCursor('${id}','√')`)}
      ${b('x²','Superscript 2',`window.cmsApp.wrapSelection('${id}','','\u00B2')`)}
      ${b('x³','Superscript 3',`window.cmsApp.wrapSelection('${id}','','\u00B3')`)}
      ${b('xⁿ','Superscript',`window.cmsApp.wrapSelection('${id}','^{','}')`)}
      ${b('x₁','Subscript',`window.cmsApp.wrapSelection('${id}','_{','}')`)}
      <span style="border-left:1px solid #ced4da;margin:1px 3px;"></span>
      ${b('π','Pi',`window.cmsApp.insertAtCursor('${id}','π')`)}
      ${b('°','Degree',`window.cmsApp.insertAtCursor('${id}','°')`)}
      ${b('≠','Not equal',`window.cmsApp.insertAtCursor('${id}','≠')`)}
      ${b('≤','Less/equal',`window.cmsApp.insertAtCursor('${id}','≤')`)}
      ${b('≥','Greater/equal',`window.cmsApp.insertAtCursor('${id}','≥')`)}
      ${b('×','Multiply',`window.cmsApp.insertAtCursor('${id}','×')`)}
      ${b('÷','Divide',`window.cmsApp.insertAtCursor('${id}','÷')`)}
      ${b('±','Plus/minus',`window.cmsApp.insertAtCursor('${id}','±')`)}
    </div>`;
  };

  const ta = (id, rows, val) =>
    `<textarea id="${id}" rows="${rows}"
       style="width:100%;padding:10px;border:1px solid #ced4da;border-radius:0 0 6px 6px;
              font-size:14px;box-sizing:border-box;resize:vertical;font-family:inherit;"
     >${val}</textarea>`;

  const optionFields = optionPairs.map(({letter, text}) => `
    <div style="margin-bottom:12px;">
      <label style="display:block;font-weight:600;margin-bottom:3px;color:#495057;">${letter}:</label>
      ${tb(`eq-option-${letter}`)}
      ${ta(`eq-option-${letter}`, 2, text.replace(/</g,'&lt;'))}
    </div>
  `).join('');

  const correctOptions = optionPairs.map(({letter}) =>
    `<option value="${letter}" ${letter === currentCorrectLetter ? 'selected' : ''}>${letter}</option>`
  ).join('');

  const modalEl = document.createElement('div');
  modalEl.id = 'edit-question-modal';
  modalEl.style.cssText = `position:fixed;top:0;left:0;right:0;bottom:0;
    background:rgba(0,0,0,0.6);z-index:99995;display:flex;
    align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto;`;

  modalEl.innerHTML = `
    <div style="background:#ffffff;border-radius:10px;padding:28px;width:100%;max-width:680px;
                position:relative;box-shadow:0 8px 40px rgba(0,0,0,0.35);margin:auto;">
      <div style="display:flex;justify-content:space-between;align-items:center;
                  margin-bottom:18px;border-bottom:2px solid #e9ecef;padding-bottom:12px;">
        <h2 style="margin:0;font-size:20px;color:#212529;">
          ✏️ Edit Question ${question.questionNumber || (questionIndex+1)}
          ${question.addedManually ? '<span style="font-size:11px;background:#fff3cd;color:#856404;padding:2px 7px;border-radius:10px;margin-left:8px;">MANUAL</span>' : ''}
        </h2>
        <button onclick="window.cmsApp.closeEditQuestionModal()"
                style="background:none;border:none;font-size:26px;cursor:pointer;color:#6c757d;padding:0 4px;">&times;</button>
      </div>
      <form onsubmit="window.cmsApp.saveEditedQuestion(event,'${bankId}',${questionIndex})">
        ${passageVal ? `<div style="margin-bottom:14px;">
          <label style="display:block;font-weight:600;margin-bottom:3px;color:#495057;">📖 Passage:</label>
          ${tb('eq-passage')}${ta('eq-passage', 4, passageVal)}
        </div>` : ''}
        <div style="margin-bottom:14px;">
          <label style="display:block;font-weight:600;margin-bottom:3px;color:#495057;">Question Text *</label>
          ${tb('eq-text')}${ta('eq-text', 4, questionText)}
        </div>
        <div style="margin-bottom:14px;">
          <div style="font-weight:600;color:#495057;margin-bottom:8px;">Answer Options:</div>
          ${optionFields}
        </div>
        <div style="margin-bottom:14px;">
          <label style="display:block;font-weight:600;margin-bottom:6px;color:#495057;">Correct Answer *</label>
          <select id="eq-correct" required
                  style="width:100%;padding:10px;border:1px solid #ced4da;border-radius:6px;font-size:14px;background:#fff;">
            ${correctOptions}
          </select>
        </div>
        <div style="margin-bottom:18px;">
          <label style="display:block;font-weight:600;margin-bottom:3px;color:#495057;">
            Explanation <span style="font-weight:400;color:#6c757d;">(Optional)</span>
          </label>
          ${tb('eq-explanation')}${ta('eq-explanation', 3, (question.explanation||'').replace(/</g,'&lt;'))}
        </div>
        <div style="display:flex;gap:12px;">
          <button type="submit"
                  style="flex:1;padding:12px;background:#007bff;color:white;border:none;
                         border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;">
            💾 Save Changes
          </button>
          <button type="button" onclick="window.cmsApp.closeEditQuestionModal()"
                  style="flex:1;padding:12px;background:#6c757d;color:white;border:none;
                         border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;">
            Cancel
          </button>
        </div>
      </form>
    </div>
  `;

  document.body.appendChild(modalEl);
  modalEl.addEventListener('click', e => { if (e.target === modalEl) window.cmsApp.closeEditQuestionModal(); });
  modalEl.dataset.isObjectOptions = isObjectOptions ? '1' : '0';
  modalEl.dataset.optionLetters = optionPairs.map(p => p.letter).join(',');
};

