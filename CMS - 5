CMSApp.prototype.renderQuestions = function(questions, bankId) {
  return questions.map((q, index) => {
    const qNum = q.questionNumber || (index + 1);
    const questionText = q.text || q.question || 'No question text';
    const hasPassage = q.passageContext || q.passage;

    // Support both option formats
    let optionsHTML = '<p style="color:#6c757d;font-style:italic;">No options</p>';
    let correctDisplay = '?';

    if (Array.isArray(q.options) && q.options.length > 0) {
      const correctIdx = typeof q.correct === 'number' ? q.correct
                       : typeof q.correctAnswer === 'number' ? q.correctAnswer : 0;
      correctDisplay = String.fromCharCode(65 + correctIdx);
      optionsHTML = q.options.map((opt, i) => {
        const isCorrect = i === correctIdx;
        return `<div style="padding:8px 12px;margin:4px 0;border-radius:5px;font-size:13px;
                            background:${isCorrect ? '#d4edda' : '#f8f9fa'};
                            border-left:4px solid ${isCorrect ? '#28a745' : '#dee2e6'};">
                  ${opt}${isCorrect ? ' <strong style="color:#28a745;">✓</strong>' : ''}
                </div>`;
      }).join('');
    } else if (q.options && typeof q.options === 'object') {
      correctDisplay = q.correct || '?';
      optionsHTML = Object.entries(q.options).map(([letter, text]) => {
        const isCorrect = letter === q.correct;
        return `<div style="padding:8px 12px;margin:4px 0;border-radius:5px;font-size:13px;
                            background:${isCorrect ? '#d4edda' : '#f8f9fa'};
                            border-left:4px solid ${isCorrect ? '#28a745' : '#dee2e6'};">
                  <strong>${letter}:</strong> ${text}
                  ${isCorrect ? ' <strong style="color:#28a745;">✓</strong>' : ''}
                </div>`;
      }).join('');
    }

    return `
      <div style="border:1px solid #dee2e6;border-radius:8px;padding:16px;
                  margin-bottom:16px;background:#fff;">
        <div style="display:flex;justify-content:space-between;align-items:center;
                    margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid #e9ecef;">
          <div style="display:flex;align-items:center;gap:8px;">
            <strong style="color:#495057;">Q${qNum}</strong>
            <span style="background:#28a745;color:white;padding:2px 10px;
                         border-radius:10px;font-size:12px;font-weight:600;">
              Answer: ${correctDisplay}
            </span>
            ${q.testType ? `<span style="background:#6c757d;color:white;padding:2px 8px;border-radius:10px;font-size:11px;">${q.testType}</span>` : ''}
            ${q.addedManually ? `<span style="background:#fff3cd;color:#856404;padding:2px 8px;border-radius:10px;font-size:11px;">✏️ Manual</span>` : ''}
            ${hasPassage ? `<span style="background:#17a2b8;color:white;padding:2px 8px;border-radius:10px;font-size:11px;">📖 Passage</span>` : ''}
          </div>
          <div style="display:flex;gap:8px;">
            <button onclick="window.cmsApp.editQuestion('${bankId}',${index})"
                    style="padding:5px 12px;background:#007bff;color:white;border:none;
                           border-radius:5px;font-size:12px;cursor:pointer;">✏️ Edit</button>
            <button onclick="window.cmsApp.deleteQuestion('${bankId}',${index})"
                    style="padding:5px 12px;background:#dc3545;color:white;border:none;
                           border-radius:5px;font-size:12px;cursor:pointer;">🗑️ Delete</button>
          </div>
        </div>

        ${hasPassage ? `
          <details style="margin-bottom:10px;">
            <summary style="cursor:pointer;color:#007bff;font-size:12px;
                            padding:4px 8px;background:#e7f3ff;border-radius:4px;">
              📖 Passage (${(q.passageContext || q.passage).length} chars)
            </summary>
            <div style="margin-top:6px;padding:10px;background:#f8f9fa;
                        border-left:3px solid #007bff;border-radius:4px;
                        max-height:180px;overflow-y:auto;font-size:13px;
                        line-height:1.6;white-space:pre-wrap;">${q.passageContext || q.passage}</div>
          </details>
        ` : ''}

        <p style="margin:8px 0;font-size:15px;line-height:1.5;"><strong>${questionText}</strong></p>
        ${optionsHTML}

        ${q.explanation ? `
          <div style="margin-top:10px;padding:10px 14px;background:#e7f3ff;
                      border-left:4px solid #007bff;border-radius:4px;font-size:13px;">
            <strong style="color:#004085;">💡 Explanation:</strong>
            <span style="color:#004085;"> ${q.explanation}</span>
          </div>
        ` : ''}
      </div>
    `;
  }).join('');
};

CMSApp.prototype.closeQuestionsViewModal = function() {
  const modal = document.getElementById('questions-view-modal');
  if (modal) modal.remove();
  this.state.currentViewingBankId = null;
  this.loadQuestionBanks();
};

// ─────────────────────────────────────────────
// EDIT QUESTION — handles both option formats
// ─────────────────────────────────────────────
CMSApp.prototype.editQuestion = function(bankId, questionIndex) {
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  if (!bank) { this.showAlert('Question bank not found.', 'error'); return; }
  const questions = bank.questions || [];
  const question = questions[questionIndex];
  if (!question) { this.showAlert('Question not found.', 'error'); return; }

  const isObjectOptions = question.options && !Array.isArray(question.options);
  const questionText = (question.text || question.question || '').replace(/</g,'&lt;');

  // Normalize to [{letter, text}] pairs
  let optionPairs = [];
  if (isObjectOptions) {
    optionPairs = Object.entries(question.options).map(([letter, text]) => ({ letter, text }));
  } else if (Array.isArray(question.options)) {
    optionPairs = question.options.map((text, i) => ({ letter: String.fromCharCode(65 + i), text }));
  }

  // Current correct letter
  let currentCorrectLetter = '';
  if (isObjectOptions) {
    currentCorrectLetter = question.correct || (optionPairs[0] && optionPairs[0].letter) || 'A';
  } else {
    const idx = typeof question.correct === 'number' ? question.correct
              : typeof question.correctAnswer === 'number' ? question.correctAnswer : 0;
    currentCorrectLetter = optionPairs[idx] ? optionPairs[idx].letter : 'A';
  }

  const passageVal = (question.passageContext || question.passage || '').replace(/</g,'&lt;');

  const existing = document.getElementById('edit-question-modal');
  if (existing) existing.remove();

  const modalEl = document.createElement('div');
  modalEl.id = 'edit-question-modal';
  modalEl.style.cssText = `position:fixed;top:0;left:0;right:0;bottom:0;
    background:rgba(0,0,0,0.6);z-index:99995;display:flex;
    align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto;`;

  // Build option fields with toolbars
  const optionFields = optionPairs.map(({letter, text}) => {
    const id = `eq-option-${letter}`;
    return `<div style="margin-bottom:14px;">
      <label style="display:block;font-weight:600;margin-bottom:4px;color:#495057;">${letter}:</label>
      ${this.buildToolbar(id)}
      <textarea id="${id}" rows="2"
                style="width:100%;padding:10px;border:1px solid #ced4da;
                       border-radius:0 0 6px 6px;font-size:14px;
                       box-sizing:border-box;resize:vertical;font-family:inherit;"
      >${text.replace(/</g,'&lt;')}</textarea>
    </div>`;
  }).join('');

  const correctOptions = optionPairs.map(({letter}) =>
    `<option value="${letter}" ${letter === currentCorrectLetter ? 'selected' : ''}>${letter}</option>`
  ).join('');

  modalEl.innerHTML = `
    <div style="background:#ffffff;border-radius:10px;padding:30px;width:100%;max-width:680px;
                position:relative;box-shadow:0 8px 40px rgba(0,0,0,0.35);margin:auto;">

      <div style="display:flex;justify-content:space-between;align-items:center;
                  margin-bottom:20px;border-bottom:2px solid #e9ecef;padding-bottom:14px;">
        <h2 style="margin:0;font-size:20px;color:#212529;">
          ✏️ Edit Question ${question.questionNumber || (questionIndex + 1)}
          ${question.addedManually ? '<span style="font-size:12px;background:#fff3cd;color:#856404;padding:2px 8px;border-radius:10px;margin-left:8px;">MANUAL</span>' : ''}
        </h2>
        <button onclick="window.cmsApp.closeEditQuestionModal()"
                style="background:none;border:none;font-size:26px;cursor:pointer;color:#6c757d;padding:0 4px;">&times;</button>
      </div>

      <form onsubmit="window.cmsApp.saveEditedQuestion(event,'${bankId}',${questionIndex})">

        ${passageVal ? `
        <div style="margin-bottom:16px;">
          <label style="display:block;font-weight:600;margin-bottom:4px;color:#495057;">📖 Passage / Context:</label>
          ${this.buildToolbar('eq-passage')}
          <textarea id="eq-passage" rows="4"
                    style="width:100%;padding:10px;border:1px solid #ced4da;
                           border-radius:0 0 6px 6px;font-size:14px;
                           box-sizing:border-box;resize:vertical;font-family:inherit;"
          >${passageVal}</textarea>
        </div>
        ` : ''}

        <div style="margin-bottom:16px;">
          <label style="display:block;font-weight:600;margin-bottom:4px;color:#495057;">Question Text: *</label>
          ${this.buildToolbar('eq-text')}
          <textarea id="eq-text" rows="4" required
                    style="width:100%;padding:10px;border:1px solid #ced4da;
                           border-radius:0 0 6px 6px;font-size:14px;
                           box-sizing:border-box;resize:vertical;font-family:inherit;"
          >${questionText}</textarea>
        </div>

        <div style="margin-bottom:16px;">
          <div style="font-weight:600;color:#495057;margin-bottom:10px;">Answer Options:</div>
          ${optionFields}
        </div>

        <div style="margin-bottom:16px;">
          <label style="display:block;font-weight:600;margin-bottom:6px;color:#495057;">Correct Answer: *</label>
          <select id="eq-correct" required
                  style="width:100%;padding:10px;border:1px solid #ced4da;
                         border-radius:6px;font-size:14px;background:#fff;">
            ${correctOptions}
          </select>
        </div>

        <div style="margin-bottom:20px;">
          <label style="display:block;font-weight:600;margin-bottom:4px;color:#495057;">
            Explanation <span style="font-weight:400;color:#6c757d;">(Optional)</span>
          </label>
          ${this.buildToolbar('eq-explanation')}
          <textarea id="eq-explanation" rows="3"
                    style="width:100%;padding:10px;border:1px solid #ced4da;
                           border-radius:0 0 6px 6px;font-size:14px;
                           box-sizing:border-box;resize:vertical;font-family:inherit;"
          >${(question.explanation||'').replace(/</g,'&lt;')}</textarea>
        </div>

        <div style="display:flex;gap:12px;">
          <button type="submit"
                  style="flex:1;padding:12px;background:#007bff;color:white;border:none;
                         border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;">
            💾 Save Changes
          </button>
          <button type="button" onclick="window.cmsApp.closeEditQuestionModal()"
                  style="flex:1;padding:12px;background:#6c757d;color:white;border:none;
                         border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;">
            Cancel
          </button>
        </div>

      </form>
    </div>
  `;

  document.body.appendChild(modalEl);
  modalEl.addEventListener('click', e => { if (e.target === modalEl) window.cmsApp.closeEditQuestionModal(); });

  // Store metadata for save
  modalEl.dataset.isObjectOptions = isObjectOptions ? '1' : '0';
  modalEl.dataset.optionLetters = optionPairs.map(p => p.letter).join(',');
};

CMSApp.prototype.closeEditQuestionModal = function() {
  const modal = document.getElementById('edit-question-modal');
  if (modal) modal.remove();
};

CMSApp.prototype.saveEditedQuestion = function(event, bankId, questionIndex) {
  event.preventDefault();
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  if (!bank) { this.showAlert('Question bank not found.', 'error'); return; }
  const questions = bank.questions || [];
  const question = questions[questionIndex];

  const modal = document.getElementById('edit-question-modal');
  const isObjectOptions = modal && modal.dataset.isObjectOptions === '1';
  const optionLetters = modal ? modal.dataset.optionLetters.split(',') : [];

  const editedText      = document.getElementById('eq-text').value;
  const editedCorrect   = document.getElementById('eq-correct').value;
  const editedExplain   = document.getElementById('eq-explanation').value;
  const passageField    = document.getElementById('eq-passage');
  const editedPassage   = passageField ? passageField.value : (question.passageContext || question.passage || '');

  let editedOptions;
  if (isObjectOptions) {
    editedOptions = {};
    optionLetters.forEach(letter => {
      const input = document.getElementById(`eq-option-${letter}`);
      if (input) editedOptions[letter] = input.value;
    });
  } else {
    editedOptions = optionLetters.map(letter => {
      const input = document.getElementById(`eq-option-${letter}`);
      return input ? input.value : '';
    });
  }

  // Correct value: letter for object, index for array
  let correctValue;
  if (isObjectOptions) {
    correctValue = editedCorrect;
  } else {
    correctValue = optionLetters.indexOf(editedCorrect);
    if (correctValue === -1) correctValue = 0;
  }

  questions[questionIndex] = {
    ...question,
    text: editedText,
    question: editedText,
    options: editedOptions,
    correct: correctValue,
    correctAnswer: correctValue,
    explanation: editedExplain,
    passageContext: editedPassage,
    passage: editedPassage
  };

  this.showProcessing('Saving changes...');
  this.updateDoc(this.doc(this.db, 'questionBanks', bankId), {
    questions,
    updatedAt: this.serverTimestamp()
  }).then(() => {
    bank.questions = questions;
    this.closeEditQuestionModal();
    this.showQuestionsViewModal(bank);
    this.showAlert('Question updated successfully!', 'success');
  }).catch(error => {
    console.error('❌ Error updating question:', error);
    this.showAlert('Error updating question. Please try again.', 'error');
  }).finally(() => { this.hideProcessing(); });
};

// ─────────────────────────────────────────────
// DELETE QUESTION
// ─────────────────────────────────────────────
CMSApp.prototype.deleteQuestion = function(bankId, questionIndex) {
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  if (!bank) { this.showAlert('Question bank not found.', 'error'); return; }
  const questions = bank.questions || [];
  const question = questions[questionIndex];
  if (!question) { this.showAlert('Question not found.', 'error'); return; }
  const preview = (question.text || question.question || 'Question ' + (questionIndex+1)).substring(0,60) + '…';
  if (!confirm(`Delete this question?\n\n"${preview}"\n\nThis cannot be undone.`)) return;

  this.showProcessing('Deleting question...');
  const updated = questions.filter((_, i) => i !== questionIndex);
  this.updateDoc(this.doc(this.db, 'questionBanks', bankId), {
    questions: updated,
    updatedAt: this.serverTimestamp()
  }).then(() => {
    bank.questions = updated;
    if (updated.length === 0) {
      this.closeQuestionsViewModal();
      this.showAlert('All questions deleted. Question bank is now empty.', 'info');
    } else {
      this.showQuestionsViewModal(bank);
      this.showAlert('Question deleted.', 'success');
    }
  }).catch(error => {
    console.error('❌ Error deleting question:', error);
    this.showAlert('Error deleting question. Please try again.', 'error');
  }).finally(() => { this.hideProcessing(); });
};
