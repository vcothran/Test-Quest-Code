    </div>`;

  const optionFields = optionPairs.map(({letter, text}, i) => `
    <div style="margin-bottom:20px;padding:15px;background:#f8f9fa;border-radius:8px;">
      <label style="font-size:14px;font-weight:600;color:#495057;margin-bottom:8px;display:block;">
        Option ${letter}:
      </label>
      ${richToolbar(`edit-option-${letter}`)}
      <div id="edit-option-${letter}" class="rich-text-editor" contenteditable="true"
           style="margin-top:0;">${text}</div>
      <div style="margin-top:10px;">
        <label style="font-size:12px;color:#6c757d;">🖼️ Option ${letter} Images (optional):</label>
