      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('²')" title="Squared">x²</button>
      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('³')" title="Cubed">x³</button>
      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('π')" title="Pi">π</button>
      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('°')" title="Degree">°</button>
      <button type="button" class="rich-text-button" onclick="window.cmsApp.insertIntoFocused('≠')" title="Not equal">≠</button>
