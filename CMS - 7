// Track whether the episode modal has unsaved changes
CMSApp.prototype._episodeModalDirty = false;

CMSApp.prototype._markEpisodeModalDirty = function() {
  this._episodeModalDirty = true;
};

CMSApp.prototype._resetEpisodeModalDirty = function() {
  this._episodeModalDirty = false;
};

// Call this instead of closeModal('episode-modal') from X button / backdrop
CMSApp.prototype.requestCloseEpisodeModal = function() {
  if (this._confirmingEpisodeClose) return;
  if (this._episodeModalDirty) {
    this._confirmingEpisodeClose = true;
    const confirmed = confirm('You have unsaved changes. Close anyway and lose your work?');
    this._confirmingEpisodeClose = false;
    if (!confirmed) return;
  }
  this._resetEpisodeModalDirty();
  this.closeModal('episode-modal');
};

// Attach dirty listeners once the episode modal is shown
CMSApp.prototype._attachEpisodeDirtyListeners = function() {
  this._resetEpisodeModalDirty();
  const modal = document.getElementById('episode-modal');
  if (!modal) return;

  // Watch all inputs/textareas/selects/checkboxes inside the modal
  const handler = () => this._markEpisodeModalDirty();
  modal.querySelectorAll('input, textarea, select').forEach(el => {
    el.removeEventListener('change', handler);
    el.addEventListener('change', handler);
    el.removeEventListener('input', handler);
    el.addEventListener('input', handler);
  });

  // Block backdrop click from silently closing
  modal.onclick = (e) => {
    if (e.target === modal) this.requestCloseEpisodeModal();
  };
};
