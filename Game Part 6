        const cinema  = document.getElementById('cutscene-cinematic');
        const loading = document.getElementById('cutscene-loading');
        const gnTitle = document.getElementById('gn-title');
        const titleEl = document.getElementById('gn-title-text');
        const grid    = document.getElementById('gn-panels');
        const contBtn = document.getElementById('gn-continue-btn');
        if (!screen || !novel) { if (typeof onComplete === 'function') onComplete(); return; }

        screen.style.display  = 'flex';
        novel.style.display   = 'block';
        cinema.style.display  = 'none';
        loading.style.display = 'none';
        grid.innerHTML        = '';
        contBtn.style.display = 'none';
        gnTitle.style.opacity = '0';

        if (title) { titleEl.textContent = title; setTimeout(() => { gnTitle.style.opacity = '1'; }, 200); }

        const finish = () => {
          screen.style.display = 'none';
          novel.style.display  = 'none';
          if (typeof onComplete === 'function') onComplete();
        };
        contBtn.onclick = finish;

        let loadedCount = 0;
        const checkAllLoaded = () => {
          loadedCount++;
          if (loadedCount === panels.length) {
            setTimeout(() => { contBtn.style.display = 'inline-block'; }, 400);
          }
        };

        panels.forEach((panel, i) => {
          const panelEl = document.createElement('div');
          panelEl.className = 'gn-panel';

          const img = document.createElement('img');
          img.alt = `Panel ${i + 1}`;

          const caption = document.createElement('div');
          caption.className = 'gn-panel-caption';
          caption.textContent = panel.caption || '';

          panelEl.appendChild(img);
          panelEl.appendChild(caption);
          grid.appendChild(panelEl);

          const reveal = () => setTimeout(() => { panelEl.classList.add('revealed'); checkAllLoaded(); }, i * 350);

          img.onload  = reveal;
          img.onerror = () => {
            img.style.display = 'none';
            panelEl.style.minHeight = '140px';
            panelEl.style.display = 'flex';
            panelEl.style.alignItems = 'center';
            panelEl.style.justifyContent = 'center';
            reveal();
          };
          img.src = panel.imageSrc;
        });
      };

      // ── ORCHESTRATOR: cinematic (generates image then shows) ──────
      const playCinematicCutscene = async (transitionContext, narrative, onComplete) => {
        const screen  = document.getElementById('cutscene-screen');
        const loading = document.getElementById('cutscene-loading');
        const loadTxt = document.getElementById('cutscene-loading-text');
        if (!screen) { if (typeof onComplete === 'function') onComplete(); return; }

        screen.style.display = 'flex';
        loading.style.display = 'flex';
        document.getElementById('cutscene-cinematic').style.display    = 'none';
        document.getElementById('cutscene-graphic-novel').style.display = 'none';
        if (loadTxt) loadTxt.textContent = '♦ Painting your world… ♦';

        try {
          const imagePrompt = buildCutsceneImagePrompt({
            genre:             episodeNarrative.genre,
            episodeTitle:      episodeNarrative.episodeTitle,
            encounterTitle:    transitionContext.encounterTitle || '',
            passed:            transitionContext.passed,
            isCompletion:      transitionContext.isCompletion || false,
            performanceLabel:  transitionContext.performanceLabel || 'solid'
          });
          const imageSrc = await generateCutsceneImage(imagePrompt, '16:9');
          showCinematicCutscene(narrative, imageSrc, onComplete);
        } catch (err) {
          console.error('Cinematic cutscene image failed:', err);
          showCinematicCutscene(narrative, '', onComplete);
        }
      };

      // ── ORCHESTRATOR: graphic novel (3 parallel images) ──────────
      const playGraphicNovelCutscene = async (episode, endingContext, narrative, onComplete) => {
        const screen  = document.getElementById('cutscene-screen');
        const loading = document.getElementById('cutscene-loading');
        const loadTxt = document.getElementById('cutscene-loading-text');
        if (!screen) { if (typeof onComplete === 'function') onComplete(); return; }

        screen.style.display = 'flex';
        loading.style.display = 'flex';
        document.getElementById('cutscene-cinematic').style.display    = 'none';
        document.getElementById('cutscene-graphic-novel').style.display = 'none';
        if (loadTxt) loadTxt.textContent = '♦ Illustrating your legend… ♦';

        const { percentage } = endingContext;
        const performanceLabel = percentage >= 80 ? 'exceptional' :
                                 percentage >= 60 ? 'solid'       :
                                 percentage >= 40 ? 'struggling'  : 'difficult';
        const desc  = episodeNarrative.episodeDescription || episodeNarrative.episodeTitle || episode.title || 'epic quest';
        const genre = episodeNarrative.genre || 'fantasy';

        // Split narrative into 3 captions
        const sentences = narrative ? narrative.split(/(?<=[.!?])\s+/).filter(s => s.trim()) : [];
        const third = Math.ceil(sentences.length / 3);
        const caps = [
          sentences.slice(0, third).join(' ') || `${player.name} sets forth.`,
          sentences.slice(third, third * 2).join(' ') || 'The greatest trial is met.',
          sentences.slice(third * 2).join(' ') || `${player.name}'s legend grows.`
        ];

        const panelPrompts = [
          { prompt: `${genre} adventure opening scene. ${desc}. ${player.name} the hero arrives, establishing shot, dramatic sky.`, caption: caps[0] },
          { prompt: `${genre} adventure climax. ${player.name} the ${player.className} faces the ultimate challenge. Intense action, dramatic lighting.`, caption: caps[1] },
          { prompt: `${genre} adventure resolution. ${player.name} ${performanceLabel === 'exceptional' || performanceLabel === 'solid' ? 'triumphant, victorious, golden light' : 'determined, hard-won wisdom, sunset'}. Epic final scene.`, caption: caps[2] }
        ];

        const gnTitle = `${episode.title || episodeNarrative.episodeTitle} — ${
          performanceLabel === 'exceptional' ? 'A Legend is Born'        :
          performanceLabel === 'solid'       ? 'Victory Earned'          :
          performanceLabel === 'struggling'  ? 'Lessons of the Trial'    : 'The Journey Continues'
        }`;

        try {
          // Stagger panel requests and retry once on 429
          const panelResults = [];
          for (let pi = 0; pi < panelPrompts.length; pi++) {
            if (pi > 0) await new Promise(r => setTimeout(r, 1000));
            let attempt = 0;
            let success = false;
            while (attempt < 2 && !success) {
              try {
                if (attempt > 0) await new Promise(r => setTimeout(r, 2500));
                const img = await generateCutsceneImage(panelPrompts[pi].prompt, '4:3');
                panelResults.push({ status: 'fulfilled', value: img });
                success = true;
              } catch (e) {
                attempt++;
                if (attempt >= 2) {
                  console.warn(`Panel ${pi + 1} image failed after retry:`, e.message);
                  panelResults.push({ status: 'rejected', reason: e });
                } else {
                  console.warn(`Panel ${pi + 1} attempt ${attempt} failed, retrying...`, e.message);
                }
              }
            }
          }
          const panels = panelPrompts.map((p, i) => ({
            imageSrc: panelResults[i].status === 'fulfilled' ? panelResults[i].value : '',
            caption:  p.caption
          }));
          showGraphicNovelCutscene(panels, gnTitle, onComplete);
        } catch (err) {
          console.error('Graphic novel cutscene failed:', err);
          // Fallback to cinematic
          await playCinematicCutscene(
            { passed: true, isCompletion: true, performanceLabel },
            narrative,
            onComplete
          );
        }
      };

      console.log('🎬 Cutscene system loaded — cinematic + graphic novel modes ready');

      console.log('✅ Section 17 v5: AI Narrative Generation + Cutscene System loaded');
      console.log('♦ Diamond loader: ENABLED (uses #narrative-loader — narrative-text untouched)');
      console.log('✦ Teaching moments: persistent until clicked');
      console.log('🔥 Streak milestone: clickable close + 12s auto-dismiss');
      console.log('⚔️ Encounter transition: generateEncounterTransition ENABLED');
	
  </script>
	
