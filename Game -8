// ─────────────────────────────────────────────────────────────────────────
// COMPRESS IMAGE — reduces base64 size to fit Firestore 1MB field limit
// Target: ~600px wide, 0.7 quality JPEG — well under 800KB
// ─────────────────────────────────────────────────────────────────────────
window.compressPortraitImage = (base64Data) => {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      // Target max 600px wide — portrait ratio 3:4
      const maxWidth = 600;
      const scale = Math.min(1, maxWidth / img.width);
      canvas.width  = Math.round(img.width  * scale);
      canvas.height = Math.round(img.height * scale);
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
      // Convert to compressed JPEG — 0.72 quality keeps it under 700KB
      const compressed = canvas.toDataURL('image/jpeg', 0.72);
      const base64Only = compressed.split(',')[1];
      console.log('🎨 Portrait compressed:', Math.round(base64Only.length / 1024) + 'KB');
      resolve(compressed); // resolve with full data: URL, not raw base64
    };
    img.onerror = reject;
    // Handle both raw base64 and full dataUrl inputs
    img.src = base64Data.startsWith('data:') ? base64Data : `data:image/jpeg;base64,${base64Data}`;
  });
};

