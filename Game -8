window.updateHUDPortrait = () => {
  if (!player) return;
  const avatarEl = document.getElementById('player-avatar');
  if (!avatarEl) return;

  // Sanitize — ensure data: prefix is present; raw base64 causes 414 URL errors
  let portraitUrl = player.currentPortraitUrl || null;
  if (portraitUrl && !portraitUrl.startsWith('data:') && !portraitUrl.startsWith('http')) {
    portraitUrl = `data:image/jpeg;base64,${portraitUrl}`;
    player.currentPortraitUrl = portraitUrl; // fix in memory so it doesn't repeat
  }

  if (portraitUrl) {
    // Replace emoji with circular portrait thumbnail
    // Check for existing portrait img specifically — ignore WordPress emoji imgs (s.w.org)
    const existingPortrait = Array.from(avatarEl.querySelectorAll('img'))
      .find(img => !img.src.includes('s.w.org') && !img.classList.contains('emoji'));
    if (!existingPortrait) {
      avatarEl.innerHTML = '';
      avatarEl.style.cssText = `
        width:46px;height:46px;border-radius:50%;overflow:hidden;
        border:2px solid #e67e22;flex-shrink:0;cursor:pointer;
        box-shadow:0 2px 8px rgba(0,0,0,0.4);display:inline-block;`;
      const img = document.createElement('img');
