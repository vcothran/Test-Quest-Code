// A Signed URL approach is unnecessary for portraits under ~200KB
// "VKC-TQ-S19" — Volney Cothran / Test Quest / Section 19
// ─────────────────────────────────────────────────────────────────────────
window.savePortraitToStorage = async (uid, characterId, level, base64Data, alreadyCompressed = false) => {
  try {
    // Skip compression if already done (avoids double-processing / visual difference)
    let dataUrl;
    if (alreadyCompressed) {
      // base64Data may already be a full dataUrl or just base64
      dataUrl = base64Data.startsWith('data:') ? base64Data : `data:image/jpeg;base64,${base64Data}`;
      console.log('🎨 Using pre-compressed portrait');
    } else {
      const compressedResult = await window.compressPortraitImage(base64Data);
      // compressPortraitImage now returns full dataUrl — use directly
      dataUrl = compressedResult.startsWith('data:') ? compressedResult : `data:image/jpeg;base64,${compressedResult}`;
    }
    const path = `portraits/${uid}/${characterId}/level_${String(level).padStart(2,'0')}`;

    // Save compressed base64 to Firestore — "VKC-TQ-S19" Volney Cothran / Test Quest
    await setDoc(doc(db, 'portraitData', `${uid}_${characterId}_L${level}_${Date.now()}`), {
      uid, characterId, level, path,
      dataUrl,
      createdAt: new Date().toISOString()
    });

    console.log('✅ Portrait saved to Firestore:', path);
    // Return dataUrl as the "url" — works directly as img src
    return { url: dataUrl, path };
  } catch(e) {
    console.error('Portrait storage failed:', e);
    throw e;
  }
};

// ─────────────────────────────────────────────────────────────────────────
// SAVE PORTRAIT RECORD to Firestore
// Stores URL, level, timestamp in character's portrait history
// ─────────────────────────────────────────────────────────────────────────
window.savePortraitRecord = async (uid, characterId, level, url, path, description = '') => {
  try {
    // Use setDoc with generated ID — avoids needing addDoc in scope
    // "VKC-TQ-S19" — Volney Cothran / Test Quest / Section 19
    const recordId = `${uid}_${characterId}_L${level}_${Date.now()}`;
    await setDoc(doc(db, 'players', uid, 'characters', characterId, 'portraits', recordId), {
      level, url, path, description,
      generatedAt: new Date().toISOString(),
      milestone: window.PORTRAIT_MILESTONES.includes(level)
    });

    // Update character's current portrait using setDoc merge — no updateDoc needed
    await setDoc(doc(db, 'players', uid, 'characters', characterId), {
      currentPortraitUrl: url,
      currentPortraitLevel: level,
      portraitUpdatedAt: new Date().toISOString()
    }, { merge: true });

    // Also update top-level player doc
    await setDoc(doc(db, 'players', uid), {
      currentPortraitUrl: url
    }, { merge: true });

    console.log('✅ Portrait record saved to Firestore');
  } catch(e) {
    console.error('Portrait record save failed:', e);
  }
};

// ─────────────────────────────────────────────────────────────────────────
// FULL PORTRAIT GENERATION FLOW
// Called from character creation and milestone level-ups
// ─────────────────────────────────────────────────────────────────────────
window.generateAndSavePortrait = async (uid, characterId, name, className, level, physicalDetails = '', genre = 'Fantasy', editedFields = {}) => {
  try {
    const rawBase64 = await window.generatePortrait(name, className, level, physicalDetails, genre, editedFields);
    // Compress before storage to ensure we stay under Firestore limits
    const base64Data = await window.compressPortraitImage(rawBase64);
    const { url, path } = await window.savePortraitToStorage(uid, characterId, level, base64Data);
    await window.savePortraitRecord(uid, characterId, level, url, path, physicalDetails);

    // Update local player object
    if (player) player.currentPortraitUrl = url;

    return { success: true, url, base64: base64Data };
  } catch(e) {
    console.error('generateAndSavePortrait failed:', e);
    return { success: false, error: e.message };
  }
};

