// Takes player name, class, level, and optional student description
// Returns a rich visual prompt for Imagen
// ─────────────────────────────────────────────────────────────────────────
window.buildPortraitPrompt = (name, className, level, studentDescription = '', genre = 'Fantasy', editedFields = {}) => {
  const cv  = window.CLASS_VISUALS[className] || window.CLASS_VISUALS.Strategist;
  const evo = window.MILESTONE_EVOLUTION[level] || window.MILESTONE_EVOLUTION[1];
  const gc  = (window.GENRE_CONTEXTS || {})[genre] || {
    setting: `a ${genre} setting with authentic period details and dramatic lighting`,
    prefix: `${genre} themed digital painting,`
  };

  // Student edits take full priority over class defaults
  const style  = (editedFields.style  || cv.style  || '').trim();
  const gear   = (editedFields.gear   || cv.gear   || '').trim();
  const weapon = (editedFields.weapon || cv.weapon || '').trim();
  const aura   = (editedFields.aura   || cv.aura   || '').trim();

  const noWeapon = !weapon || weapon.toLowerCase().includes('none') || weapon.toLowerCase().includes('no weapon') || weapon.toLowerCase().includes('spell') || weapon.toLowerCase().includes('magic');
  const noGear   = !gear   || gear.toLowerCase().includes('none')   || gear.toLowerCase().includes('no armor');

  // Build unified character descriptor — same approach as cutscene prompt
  // Combining everything into one rich anchor string gives Imagen the best result
  const physParts = studentDescription && studentDescription.trim().length > 5
    ? studentDescription.trim().split(',').map(s => s.trim()).filter(Boolean)
    : [];
  const gearPart   = !noGear   ? gear   : 'casual clothing';
  const weaponPart = !noWeapon ? `holding ${weapon}` : 'hands open or gesturing with magical energy';
  const charDesc = [
    style,
    physParts.join(', '),
    `wearing ${gearPart}`,
    weaponPart,
    `${aura} expression`
  ].filter(Boolean).join(', ');

  // Lead with character descriptor — Imagen anchors identity from what it reads first
  let prompt = `${gc.prefix} upper body character portrait, dramatic cinematic lighting, painterly digital art. `;
  prompt += `${evo.prefix} ${charDesc}, named ${name}. `;
  prompt += `${evo.suffix}. `;
  prompt += `Setting: ${gc.setting}. `;
  prompt += `School appropriate, no gore.`;

  // Bump limit to 500 chars for richer prompts
  if (prompt.length > 500) prompt = prompt.substring(0, 497) + '...';
  console.log('🎨 Portrait prompt (' + prompt.length + ' chars):', prompt);
  return prompt;
};

