window.handlePortraitGenerate = async (characterId, name, className) => {
  const descInput   = document.getElementById('portrait-description-input');
  const genreSelect = document.getElementById('portrait-genre-select');
  const statusEl    = document.getElementById('portrait-status');
  const generateBtn = document.getElementById('portrait-generate-btn');
  const previewArea = document.getElementById('portrait-preview-area');
  const previewImg  = document.getElementById('portrait-preview-img');
  const saveBtnArea = document.getElementById('portrait-save-btn-area');

  const description = descInput ? descInput.value.trim() : '';
  const hairField = document.getElementById('portrait-field-hair');
  const eyesField = document.getElementById('portrait-field-eyes');
  const skinField = document.getElementById('portrait-field-skin');
  const hairDesc  = hairField && hairField.value.trim() ? hairField.value.trim() : '';
  const eyesDesc  = eyesField && eyesField.value.trim() ? eyesField.value.trim() : '';
  const skinDesc  = skinField && skinField.value.trim() ? skinField.value.trim() + ' skin' : '';
  // Combine physical details — these get explicit placement in the prompt
  const physicalDetails = [hairDesc, eyesDesc, skinDesc, description].filter(Boolean).join(', ');
  const genreCustom = document.getElementById('portrait-genre-custom');
  const genre = (genreSelect && genreSelect.value === 'Custom' && genreCustom && genreCustom.value.trim())
    ? genreCustom.value.trim()
    : (genreSelect ? genreSelect.value : 'Fantasy');

  // Collect edited fields
  const editedFields = {
    style:  (document.getElementById('portrait-field-style')  || {}).value  || '',
    gear:   (document.getElementById('portrait-field-gear')   || {}).value  || '',
    weapon: (document.getElementById('portrait-field-weapon') || {}).value  || '',
    aura:   (document.getElementById('portrait-field-aura')   || {}).value  || '',
  };

  // Content safety check — catch inappropriate inputs before sending to Imagen
  const unsafeTerms = ['nude', 'naked', 'topless', 'explicit', 'sexy', 'nsfw', 'underwear', 'lingerie'];
  // Note: skin COLOR descriptions are always allowed — only nudity terms are blocked
  const allInputs = Object.values(editedFields).join(' ').toLowerCase() + ' ' + physicalDetails.toLowerCase();
  const foundTerm = unsafeTerms.find(t => allInputs.includes(t));
  if (foundTerm) {
    statusEl.textContent = '⚠️ That description contains a term not allowed in portraits. Please revise and try again.';
    statusEl.style.color = '#e74c3c';
    // Reset the gear field to default if that's where the issue is
    const gearField = document.getElementById('portrait-field-gear');
    const cv = window.CLASS_VISUALS[className] || window.CLASS_VISUALS.Strategist;
    if (gearField && gearField.value.toLowerCase().includes(foundTerm)) {
      gearField.value = cv.gear;
      gearField.style.borderColor = '#e74c3c';
      setTimeout(() => { gearField.style.borderColor = ''; }, 3000);
    }
    return;
  }

  generateBtn.disabled = true;
  generateBtn.textContent = '⏳ Painting your legend...';
  statusEl.textContent = 'The AI is crafting your portrait — this takes about 15 seconds...';
  statusEl.style.color = '#c9a84c';

  try {
    const level = window.getPlayerLevel ? window.getPlayerLevel() : 1;
    const rawBase64 = await window.generatePortrait(name, className, level, physicalDetails, genre, editedFields);

    // Compress before preview so what you see is exactly what gets saved
    statusEl.textContent = 'Finalizing your portrait...';
    const compressedDataUrl = await window.compressPortraitImage(rawBase64);
    const base64Data = compressedDataUrl.split(',')[1]; // Strip data: prefix

    previewImg.src = compressedDataUrl; // Show the compressed version
    previewArea.style.display = 'block';
    statusEl.textContent = 'Your portrait is ready! Regenerate to try again, or save and begin your adventure.';
    statusEl.style.color = '#27ae60';
    generateBtn.textContent = '🔄 Regenerate';
    generateBtn.disabled = false;
    saveBtnArea.style.display = 'block';

    // Store compressedDataUrl as base64Data so save uses identical data to preview
    window._pendingPortrait = { characterId, name, className, level, base64Data: compressedDataUrl, physicalDetails, description, genre, editedFields };

  } catch(e) {
    statusEl.textContent = 'Portrait generation failed — you can try again or skip for now.';
    statusEl.style.color = '#e74c3c';
    generateBtn.textContent = '🎨 Try Again';
    generateBtn.disabled = false;
  }
};

window.confirmPortraitAndContinue = async () => {
  const statusEl = document.getElementById('portrait-status');
  const saveBtn  = document.querySelector('#portrait-save-btn-area button');
  if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = '💾 Saving...'; }
  statusEl.textContent = 'Saving your portrait to your character...';

  // Handle regen XP cost and cooldown inline — avoids double-wrapping
  const isRegen = window._regenMode;
  if (isRegen) {
    window._regenMode = false;
    player.xp = Math.max(0, (player.xp || 0) - window.PORTRAIT_REGEN_COST);
    window._safeNotify = window._safeNotify || ((msg,type) => { if(typeof showNotification==='function') showNotification(msg,type); else console.log(msg); });
    window._safeNotify(`-${window.PORTRAIT_REGEN_COST} XP — New portrait incoming...`, 'focus-loss');
    if (window._safeUpdateStats) window._safeUpdateStats();
  }

  if (window._pendingPortrait && player && player.uid) {
    const { characterId, name, className, level, base64Data, physicalDetails, description, genre, editedFields } = window._pendingPortrait;
    // Save the portrait that was already generated — do NOT call generatePortrait again
    // This ensures what you see in the preview is exactly what gets saved
    // base64Data was already compressed during preview generation — skip second compression
    const { url, path } = await window.savePortraitToStorage(player.uid, characterId, level, base64Data, true);
    await window.savePortraitRecord(player.uid, characterId, level, url, path, physicalDetails || description || '');
    if (player) player.currentPortraitUrl = url;

    // Save portrait descriptors to player object for cutscene use
    if (editedFields) {
      player.portraitEditedFields  = editedFields;
    }
    // Extract hair/eyes/skin from physicalDetails for cutscene prompts
    if (physicalDetails) {
      const parts = physicalDetails.split(',').map(s => s.trim()).filter(Boolean);
      player.portraitDescription = physicalDetails;
      // Try to find hair/eyes/skin individually
      const hairPart = parts.find(p => p.toLowerCase().includes('hair'));
      const eyesPart = parts.find(p => p.toLowerCase().includes('eye'));
      const skinPart = parts.find(p => p.toLowerCase().includes('skin'));
      if (hairPart) player.portraitHair = hairPart;
      if (eyesPart) player.portraitEyes = eyesPart;
      if (skinPart) player.portraitSkin = skinPart.replace(/ skin$/i, '');
    }

    // Persist to Firestore so it loads on re-select — include hair/eyes/skin for cutscene
    try {
      const portraitFirestoreData = {
        portraitEditedFields: editedFields || {},
        portraitDescription:  physicalDetails || '',
        portraitHair: player.portraitHair || '',
        portraitEyes: player.portraitEyes || '',
        portraitSkin: player.portraitSkin || '',
      };
      await setDoc(doc(db, 'players', player.uid, 'characters', characterId),
        portraitFirestoreData, { merge: true });
      await setDoc(doc(db, 'players', player.uid),
        portraitFirestoreData, { merge: true });
    } catch(e) { console.warn('Could not save portrait descriptors:', e); }

    window._pendingPortrait = null;

    // Save regen cooldown if this was a regen request
    if (isRegen) {
      try {
        await setDoc(doc(db, 'players', player.uid, 'characters', player.activeCharacterId), {
          lastPortraitRegen: new Date().toISOString()
        }, { merge: true });
      } catch(e) { console.warn('Could not save regen cooldown:', e); }
    }
  }

  const overlay = document.getElementById('portrait-creation-overlay');
  if (overlay) overlay.remove();
};

window.skipPortraitCreation = () => {
  window._pendingPortrait = null;
  const overlay = document.getElementById('portrait-creation-overlay');
  if (overlay) overlay.remove();
};

// ─────────────────────────────────────────────────────────────────────────
// MILESTONE PORTRAIT EVOLUTION
// Called from checkForLevelUp when hitting a milestone
// ─────────────────────────────────────────────────────────────────────────
window.triggerMilestonePortrait = async (level) => {
  if (!window.PORTRAIT_MILESTONES.includes(level) || level === 1) return;
  if (!player || !player.uid || !player.activeCharacterId) return;

  // Show a brief notification
  const notif = document.createElement('div');
  notif.style.cssText = `
    position:fixed;bottom:100px;right:20px;
    background:linear-gradient(135deg,#1a2035,#0d1117);
    border:2px solid #c9a84c;border-radius:12px;
    padding:14px 20px;z-index:99980;
    font-family:'Cinzel',serif;font-size:13px;color:#c9a84c;
    box-shadow:0 8px 32px rgba(0,0,0,0.5);max-width:260px;
    animation:levelupFadeIn 0.3s ease-out;`;
  notif.innerHTML = `🎨 <strong>Portrait Evolving...</strong><br><span style="font-size:11px;color:#8892a4;font-family:'Segoe UI',sans-serif;">Your Level ${level} portrait is being painted</span>`;
  document.body.appendChild(notif);
  setTimeout(() => { if (notif.parentNode) notif.remove(); }, 5000);

  try {
    const description = player.portraitDescription || '';
    await window.generateAndSavePortrait(
      player.uid, player.activeCharacterId,
      player.name, player.className, level, description
    );
    notif.innerHTML = `🎨 <strong>Portrait Updated!</strong><br><span style="font-size:11px;color:#27ae60;font-family:'Segoe UI',sans-serif;">Your Level ${level} portrait has been saved</span>`;
    notif.style.borderColor = '#27ae60';
  } catch(e) {
    console.warn('Milestone portrait failed silently:', e);
    if (notif.parentNode) notif.remove();
  }
};
