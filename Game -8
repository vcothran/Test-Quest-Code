      img.onclick = () => window.showPortraitGallery && window.showPortraitGallery();
      img.title = 'View Portrait Hall';
      avatarEl.appendChild(img);
    } else {
      // Update src if portrait changed — replace img entirely to avoid cached bad src
      const oldImg = avatarEl.querySelector('img');
      if (oldImg && oldImg.getAttribute('src') !== portraitUrl) {
        avatarEl.removeChild(oldImg);
        const img = document.createElement('img');
        img.src = portraitUrl;
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;border-radius:50%;';
        img.onclick = () => window.showPortraitGallery && window.showPortraitGallery();
