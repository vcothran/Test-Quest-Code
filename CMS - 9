window.openAssignEpisodesModal = async function(classId) {
  const cls = teacherClasses.find(c => c.id === classId);
  if (!cls) return;
  const db  = getDB();
  const app = window.cmsApp;
  const { collection, getDocs } = window.firebaseV9;
  let allEpisodes = (app && app.state && app.state.episodes) ? app.state.episodes : [];
  if (allEpisodes.length === 0 && db) {
    try {
      const snap = await getDocs(collection(db, 'episodes'));
      allEpisodes = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    } catch(e) { console.warn('Could not load episodes:', e); }
  }
  if (allEpisodes.length === 0) {
    if (app) app.showAlert('No episodes found. Create episodes first.', 'error');
    return;
  }
  const currentAssigned = cls.assignedEpisodes || [];
  const episodeCheckboxes = allEpisodes.map(ep =>
    '<label style="display:flex;align-items:center;gap:12px;padding:14px;border:1px solid #e0e0e0;border-radius:8px;cursor:pointer;margin-bottom:10px;background:white;" onmouseover="this.style.background=\'#f8f9ff\'" onmouseout="this.style.background=\'white\'">' +
    '<input type="checkbox" value="' + ep.id + '" ' + (currentAssigned.includes(ep.id)?'checked':'') + ' style="width:18px;height:18px;cursor:pointer;accent-color:#667eea;">' +
    '<div><div style="font-weight:600;color:#333;">' + (ep.title||'Untitled Episode') + '</div>' +
    '<div style="font-size:12px;color:#999;margin-top:2px;">' + (ep.genre||'General') + '</div></div></label>'
  ).join('');

  const existingModal = document.getElementById('assign-episodes-modal');
  if (existingModal) existingModal.remove();

  const modal = document.createElement('div');
  modal.id = 'assign-episodes-modal';
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);z-index:2000;display:flex;align-items:center;justify-content:center;padding:20px;';
  modal.innerHTML =
    '<div style="background:white;border-radius:16px;max-width:600px;width:100%;max-height:85vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.3);">' +
      '<div style="padding:24px 28px;border-bottom:1px solid #e0e0e0;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:white;z-index:1;">' +
        '<div><h2 style="color:#333;font-size:22px;margin-bottom:4px;">📚 Assign Episodes</h2>' +
        '<div style="font-size:13px;color:#999;">Class: <strong style="color:#667eea;">' + cls.name + '</strong></div></div>' +
        '<button onclick="closeAssignModal()" style="background:none;border:none;font-size:28px;color:#999;cursor:pointer;">×</button>' +
      '</div>' +
      '<div style="padding:24px 28px;">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">' +
          '<span style="font-size:14px;color:#666;">' + allEpisodes.length + ' episodes available</span>' +
          '<div style="display:flex;gap:8px;">' +
            '<button onclick="toggleAllEpisodes(true)" style="background:none;border:1px solid #667eea;color:#667eea;border-radius:6px;padding:5px 12px;cursor:pointer;font-size:12px;">Select All</button>' +
            '<button onclick="toggleAllEpisodes(false)" style="background:none;border:1px solid #e0e0e0;color:#666;border-radius:6px;padding:5px 12px;cursor:pointer;font-size:12px;">Clear All</button>' +
          '</div>' +
        '</div>' +
        '<div id="episode-checklist">' + episodeCheckboxes + '</div>' +
      '</div>' +
      '<div style="padding:16px 28px;border-top:1px solid #e0e0e0;display:flex;gap:10px;justify-content:flex-end;position:sticky;bottom:0;background:white;">' +
        '<button onclick="closeAssignModal()" class="cms-btn cms-btn-secondary">Cancel</button>' +
        '<button onclick="saveEpisodeAssignments(\'' + classId + '\')" class="cms-btn cms-btn-primary">✅ Save Assignments</button>' +
      '</div>' +
    '</div>';
  document.body.appendChild(modal);
};

window.closeAssignModal    = function() { const m=document.getElementById('assign-episodes-modal'); if(m) m.remove(); };
window.toggleAllEpisodes   = function(checked) { document.querySelectorAll('#episode-checklist input[type=checkbox]').forEach(cb => cb.checked=checked); };

window.saveEpisodeAssignments = async function(classId) {
  const db  = getDB();
  const app = window.cmsApp;
  if (!db) return;
  const { doc, updateDoc, arrayUnion, arrayRemove, serverTimestamp } = window.firebaseV9;
  const checked   = [...document.querySelectorAll('#episode-checklist input[type=checkbox]:checked')].map(cb=>cb.value);
  const unchecked = [...document.querySelectorAll('#episode-checklist input[type=checkbox]:not(:checked)')].map(cb=>cb.value);
  try {
    for (const epId of checked)   await updateDoc(doc(db,'episodes',epId), { assignedClasses: arrayUnion(classId) });
    for (const epId of unchecked) await updateDoc(doc(db,'episodes',epId), { assignedClasses: arrayRemove(classId) });
    await updateDoc(doc(db,'classes',classId), { assignedEpisodes: checked, updatedAt: serverTimestamp() });
    const cls = teacherClasses.find(c=>c.id===classId);
    if (cls) cls.assignedEpisodes = checked;
    closeAssignModal();
    renderClassesList();
    if (app) app.showAlert('Episodes assigned to class!', 'success');
  } catch(e) {
    console.error('Save assignments failed:', e);
    if (app) app.showAlert('Error saving assignments: ' + e.message, 'error');
  }
};

