  // Deduplicate by email (true account identifier)
  if (reportsAllStudents.length > 0) {
    const byUid = {};
    reportsAllStudents.forEach(student => {
      const key = student.email || student.uid || student.id;
      if (!byUid[key] || student.progressData.length > byUid[key].progressData.length) {
        byUid[key] = student;
      }
    });
    reportsAllStudents = Object.values(byUid);
    console.log('✅ After dedup:', reportsAllStudents.length, 'unique students');
  }

  if (!loadedFromFirebase || reportsAllStudents.length === 0) {
    console.log('📊 Using test data fallback for reports');
    reportsAllStudents = [
      { id:'student1', name:'Alice Johnson', email:'alice@test.com', xp:2450,
        progressData:[
          {episodeId:'ep1',episodeName:'Algebra Basics',completed:true,accuracy:0.92,questionsAnswered:25,correctAnswers:23,timestamp:'2025-01-15'},
          {episodeId:'ep2',episodeName:'Geometry Intro',completed:true,accuracy:0.88,questionsAnswered:20,correctAnswers:18,timestamp:'2025-01-20'}
        ]},
      { id:'student2', name:'Bob Smith', email:'bob@test.com', xp:1800,
        progressData:[
          {episodeId:'ep1',episodeName:'Algebra Basics',completed:true,accuracy:0.80,questionsAnswered:25,correctAnswers:20,timestamp:'2025-01-16'}
        ]},
      { id:'student3', name:'Carol Davis', email:'carol@test.com', xp:3200,
        progressData:[
          {episodeId:'ep1',episodeName:'Algebra Basics',completed:true,accuracy:0.96,questionsAnswered:25,correctAnswers:24,timestamp:'2025-01-14'},
          {episodeId:'ep2',episodeName:'Geometry Intro',completed:true,accuracy:0.94,questionsAnswered:20,correctAnswers:19,timestamp:'2025-01-19'}
