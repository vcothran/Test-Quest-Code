
CMSApp.prototype.handleManualQuestionSubmit = function() {
  const bankId = this.state.addingQuestionToBankId;
  if (!bankId) { this.showAlert('No bank selected.', 'error'); return; }

  const questionText = document.getElementById('manual-q-text').value.trim();
  const passage = document.getElementById('manual-q-passage').value.trim();
  const explanation = document.getElementById('manual-q-explanation').value.trim();
  const format = document.getElementById('manual-q-format').value;
  const correctAnswer = document.getElementById('manual-correct-answer').value;

  if (!questionText) { this.showAlert('Please enter a question.', 'error'); return; }

  // Collect options
  const options = {};
  let letters = [];
  if (format === 'abcd') letters = ['A','B','C','D'];
  else if (format === 'fghj') letters = ['F','G','H','J'];
  else if (format === 'tf') letters = ['T','F2'];
  else if (format === 'custom') letters = ['A','B','C','D','E'];

  let hasOptions = false;
  letters.forEach(letter => {
    const input = document.getElementById(`manual-option-${letter}`);
    if (input && input.value.trim()) { options[letter] = input.value.trim(); hasOptions = true; }
  });

  if (!hasOptions) { this.showAlert('Please enter at least one answer option.', 'error'); return; }
  if (!options[correctAnswer]) { this.showAlert('The correct answer option must have text entered.', 'error'); return; }

  const newQuestion = {
    question: questionText,
    text: questionText,
    options,
    correct: correctAnswer,
    format,
    passage: passage || '',
    explanation: explanation || '',
    addedManually: true,
    createdAt: new Date().toISOString()
  };

  this.showProcessing('Adding question...');
  const bankRef = this.doc(this.db, 'questionBanks', bankId);
  this.getDoc(bankRef).then(docSnap => {
    if (!docSnap.exists()) throw new Error('Question bank not found');
    const currentQuestions = docSnap.data().questions || [];
    currentQuestions.push(newQuestion);
    return this.updateDoc(bankRef, { questions: currentQuestions, updatedAt: this.serverTimestamp() });
  }).then(() => {
    this.showAlert('Question added successfully!', 'success');
    this.closeAddQuestionModal();
    // Reload bank then refresh questions view
    const { doc, getDoc } = window.firebaseV9;
    getDoc(doc(this.db, 'questionBanks', bankId)).then(snap => {
      if (snap.exists()) {
        const bank = this.state.questionBanks.find(b => b.id === bankId);
        if (bank) {
          bank.questions = snap.data().questions || [];
          this.showQuestionsViewModal(bank);
        }
      }
    });
    this.loadQuestionBanks();
  }).catch(error => {
    console.error('Error adding question:', error);
    this.showAlert('Error adding question: ' + error.message, 'error');
  }).finally(() => { this.hideProcessing(); });
};

