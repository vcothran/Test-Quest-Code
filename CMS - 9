window.saveNewClass = async function() {
  const app  = window.cmsApp;
  const name = document.getElementById('new-class-name').value.trim();
  if (!name) { if (app) app.showAlert('Please enter a class name.', 'error'); return; }

  const style = getCurrentCodeStyle();
  let joinCode;
  if (style === 'custom') {
    joinCode = document.getElementById('new-class-custom-code').value.trim().toUpperCase();
    if (!joinCode) { if (app) app.showAlert('Please enter a custom code.', 'error'); return; }
  } else {
    joinCode = document.getElementById('code-preview').textContent;
  }

  const currentUser = app ? app.state.currentUser : null;
  const teacherId   = currentUser ? (currentUser.uid || 'test-teacher') : 'test-teacher';
  const db          = typeof getDB === 'function' ? getDB() : (app ? app.db : null);

  const newClass = { name, joinCode, teacherId, studentCount: 0, assignedEpisodes: [], createdAt: new Date().toISOString() };

  if (db && window.firebaseV9) {
    const { collection, addDoc, serverTimestamp } = window.firebaseV9;
