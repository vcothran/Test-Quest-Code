// STUDENT DETAIL MODAL
// ================================================

window.openStudentModal = function(student) {
  if (!student) return;
  document.getElementById('student-modal-name').textContent     = student.name;
  document.getElementById('student-modal-xp').textContent       = student.xp || 0;
  document.getElementById('student-modal-level').textContent    = xpToLevel(student.xp || 0);
  document.getElementById('student-modal-episodes').textContent = student.progressData.filter(p=>p.completed).length;
  const avgAcc = student.progressData.reduce((s,p) => s+(p.accuracy||0), 0) / (student.progressData.length||1);
  document.getElementById('student-modal-accuracy').textContent = Math.round(avgAcc * 100) + '%';

  const chart = document.getElementById('student-modal-chart');
  chart.innerHTML = '';
  [...student.progressData].sort((a,b) => new Date(a.timestamp)-new Date(b.timestamp)).forEach(data => {
    const bar = document.createElement('div');
    bar.style.cssText = 'flex:1;background:linear-gradient(180deg,#667eea,#764ba2);height:' + (data.accuracy*200) + 'px;border-radius:4px 4px 0 0;position:relative;min-width:40px;';
    const label = document.createElement('div');
    label.style.cssText = 'position:absolute;bottom:-25px;left:50%;transform:translateX(-50%);font-size:11px;color:#666;white-space:nowrap;';
    label.textContent = Math.round(data.accuracy*100) + '%';
    bar.appendChild(label);
    chart.appendChild(bar);
  });

  const struggling = student.progressData.filter(p => p.accuracy < 0.75);
  document.getElementById('student-modal-struggling').innerHTML =
    '<h3 style="margin-bottom:15px;">Topics Needing Attention</h3>' +
    (struggling.length === 0
      ? '<p style="color:#28a745;">No struggling topics — great work!</p>'
      : struggling.map(d =>
          '<div style="background:#fff3cd;padding:15px;border-radius:8px;margin-bottom:10px;display:flex;justify-content:space-between;">' +
          '<span style="font-weight:600;color:#856404;">' + d.episodeName + '</span>' +
          '<span style="color:#856404;font-weight:600;">' + Math.round(d.accuracy*100) + '% accuracy</span></div>'
        ).join(''));

  const sorted = [...student.progressData].sort((a,b) => new Date(b.timestamp)-new Date(a.timestamp));
  document.getElementById('student-modal-history').innerHTML = sorted.length === 0
    ? '<p style="color:#999;text-align:center;">No episode history yet</p>'
    : sorted.map(ep =>
        '<div style="background:#f8f9fa;padding:20px;border-radius:10px;margin-bottom:15px;">' +
          '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">' +
            '<div style="font-weight:600;">' + ep.episodeName + '</div>' +
            '<span style="padding:4px 12px;border-radius:12px;font-size:12px;font-weight:600;background:' +
              (ep.completed?'#d4edda':'#fff3cd') + ';color:' + (ep.completed?'#155724':'#856404') + ';">' +
              (ep.completed?'Completed':'In Progress') + '</span>' +
          '</div>' +
          '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:15px;">' +
            '<div><div style="font-size:12px;color:#666;">Accuracy</div><div style="font-size:18px;font-weight:600;">' + Math.round(ep.accuracy*100) + '%</div></div>' +
            '<div><div style="font-size:12px;color:#666;">Questions</div><div style="font-size:18px;font-weight:600;">' + (ep.questionsAnswered||0) + '</div></div>' +
            '<div><div style="font-size:12px;color:#666;">Correct</div><div style="font-size:18px;font-weight:600;">' + (ep.correctAnswers||0) + '</div></div>' +
            '<div><div style="font-size:12px;color:#666;">Date</div><div style="font-size:14px;font-weight:600;">' + new Date(ep.timestamp).toLocaleDateString() + '</div></div>' +
          '</div>' +
        '</div>'
      ).join('');

  document.getElementById('student-detail-modal').style.display = 'flex';
};

window.closeStudentModal = function() {
  document.getElementById('student-detail-modal').style.display = 'none';
};

