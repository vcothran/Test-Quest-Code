  const cls      = teacherClasses.find(c => c.id === currentReportsClassId);
  const joinCode = cls ? cls.joinCode : null;
  const db       = getDB();
  let loadedFromFirebase = false;

  if (db && joinCode && window.firebaseV9) {
    const { collection, query, where, getDocs } = window.firebaseV9;
    try {
      const studentsSnapshot = await getDocs(
        query(collection(db, 'players'), where('enrolledCodes', 'array-contains', joinCode))
      );
      reportsAllStudents = [];
      for (const studentDoc of studentsSnapshot.docs) {
        const studentData = { id: studentDoc.id, ...studentDoc.data() };
        const progressSnapshot = await getDocs(
          query(collection(db, 'studentProgress'), where('studentId', '==', studentDoc.id))
        );
        studentData.progressData = progressSnapshot.docs.map(d => ({ id: d.id, ...d.data() }));
        reportsAllStudents.push(studentData);
      }
      loadedFromFirebase = true;
      console.log('✅ Loaded', reportsAllStudents.length, 'students for class:', joinCode);
