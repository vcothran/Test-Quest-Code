      // Setup passage drawing
      const setupPassageDrawing = () => {
        const canvas = annotationState.passageCanvas;
        const ctx = annotationState.passageCtx;
        let path = [];
        
        canvas.onmousedown = (e) => {
          annotationState.isDrawing = true;
          const rect = canvas.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          path = [{x, y}];
          
          if (annotationState.currentTool === 'eraser') {
            ctx.globalCompositeOperation = 'destination-out';
            ctx.globalAlpha = 1.0;
            ctx.lineWidth = annotationState.lineWidth;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.beginPath();
            ctx.moveTo(x, y);
          }
        };
        
        canvas.onmousemove = (e) => {
          if (!annotationState.isDrawing) return;
          const rect = canvas.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          path.push({x, y});
          
          if (annotationState.currentTool === 'eraser') {
            // Eraser works immediately
            ctx.lineTo(x, y);
            ctx.stroke();
          }
        };
        
        canvas.onmouseup = () => {
          if (!annotationState.isDrawing) return;
          annotationState.isDrawing = false;
          
          if (annotationState.currentTool !== 'eraser' && path.length > 1) {
            // Draw the complete path as a single stroke (prevents spray effect!)
            ctx.globalCompositeOperation = 'source-over';
            ctx.strokeStyle = annotationState.currentColor;
            ctx.globalAlpha = annotationState.currentTool === 'highlighter' ? 0.20 : 1.0;
            ctx.lineWidth = annotationState.lineWidth;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            ctx.beginPath();
            ctx.moveTo(path[0].x, path[0].y);
            for (let i = 1; i < path.length; i++) {
              ctx.lineTo(path[i].x, path[i].y);
            }
            ctx.stroke();
          }
          
          ctx.closePath();
          ctx.globalAlpha = 1.0;
