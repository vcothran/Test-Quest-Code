            eliminate: { uses: 3, maxUses: 3 },
            shadowStep: { uses: 1, maxUses: 1 },
            secondLook: { uses: 2, maxUses: 2 },
            emotionalInsight: { uses: 2, maxUses: 2 },
            keenEye: { uses: -1, maxUses: -1 },
            trailBlazer: { uses: 2, maxUses: 2 }
          };
        }
        
        if (!player.activeEffects) {
          player.activeEffects = {
            powerStrikeActive: false,
            eliminatedAnswers: [],
            secondLookUsed: false,
            secondLookWasted: false,
            lastAnswerCorrect: true
          };
        }
        
        if (!player.inventory) {
          player.inventory = {
            lastStandTrophy: null,
            consumables: []
          };
        }
      };

      const resetEpisodeAbilities = () => {
        if (!player || !player.abilities) return;
        
        Object.keys(player.abilities).forEach(ability => {
          player.abilities[ability].uses = player.abilities[ability].maxUses;
        });
        
        player.activeEffects = {
          powerStrikeActive: false,
          eliminatedAnswers: [],
          secondLookUsed: false,
          secondLookWasted: false,
          lastAnswerCorrect: true
        };
      };

      const screens = {
        login: document.getElementById('login-screen'),
        characterCreation: document.getElementById('character-creation-screen'),
        characterSelect: document.getElementById('character-select-screen'),
        episodeSelection: document.getElementById('episode-selection-screen'),
        gamePlay: document.getElementById('game-play-screen'),
        completion: document.getElementById('completion-screen')
      };

      const googleLoginBtn = document.getElementById('google-login-btn');
      const bypassLoginBtn = document.getElementById('bypass-login-btn');
      const startGameBtn = document.getElementById('start-game-btn');
      const episodeListDiv = document.getElementById('episode-list');
      const approachSelectionBox = document.getElementById('approach-selection-box');
      const classCards = document.querySelectorAll('.class-card');
      const submitAnswerBtn = document.getElementById('submit-answer-btn');
      const feedbackBox = document.getElementById('feedback-box');
      const nextEncounterBtn = document.getElementById('next-encounter-btn');
      const chooseAnotherAdventureBtn = document.getElementById('choose-another-adventure-btn');
      const exitToMenuBtn = document.getElementById('exit-to-menu-btn');

      const XP_PER_CORRECT = 10;
      const FOCUS_LOSS_PER_INCORRECT = 15;

      console.log('✅ Section 8: Firebase Initialization & Player Data loaded');
		
/* === SECTION 9: Game Mechanics & Class Abilities === */
      const showScreen = (screenName) => {
        Object.values(screens).forEach(screen => screen.classList.remove('active'));
        if(screens[screenName]) screens[screenName].classList.add('active');
      };

      // Notification system for XP/Focus changes
      const showNotification = (message, type) => {
        const notification = document.createElement('div');
        notification.className = `notification ${type}`;
        notification.textContent = message;
        document.body.appendChild(notification);
        
        setTimeout(() => notification.classList.add('show'), 100);
        setTimeout(() => {
          notification.classList.remove('show');
          setTimeout(() => document.body.removeChild(notification), 300);
        }, 2500);
      };

      // ENHANCED: Focus system with clamping, color coding, and overcharge
      const updatePlayerStats = () => {
        const xpElement = document.getElementById('hud-xp');
        const focusElement = document.getElementById('hud-focus');
        
        // CRITICAL FIX: Initialize focus if undefined, but DON'T reset 0 to 100
        if (player.focus === undefined || player.focus === null) {
          player.focus = 100;
        }
        
        // Clamp focus at 0 (never negative)
        player.focus = Math.max(0, player.focus);
        
        xpElement.textContent = player.xp || 0;
        focusElement.textContent = player.focus;
        
        // Focus color coding
        if (player.focus === 0) {
          focusElement.style.color = '#e74c3c'; // Red at 0
        } else if (player.focus < 30) {
          focusElement.style.color = '#e67e22'; // Orange below 30
        } else if (player.focus > 100) {
          focusElement.style.color = '#f39c12'; // Gold above 100 (overcharged)
        } else {
          focusElement.style.color = '#2ecc71'; // Green normal
        }
        
        xpElement.classList.add('stat-change');
        focusElement.classList.add('stat-change');
        
        setTimeout(() => {
          xpElement.classList.remove('stat-change');
          focusElement.classList.remove('stat-change');
        }, 600);
        
        // AUTO-UPDATE: If Character Stats panel is open, refresh it
        const panel = document.getElementById('char-stats-panel');
        if (panel && panel.style.display !== 'none') {
          if (typeof updateCharacterStatsPanel === 'function') {
            updateCharacterStatsPanel();
          }
        }
      };

      // ENHANCED: Overcharge decay system
      const applyOverchargeDecay = () => {
        if (player.focus > 100) {
          player.focus = Math.max(100, player.focus - 5);
          showNotification('Overcharge fading... (-5 Focus)', 'focus-loss');
        }
      };

      // ENHANCED: Small focus restoration on correct answers
      const restoreFocusOnCorrect = () => {
        if (player.focus < 100) {
          player.focus = Math.min(100, player.focus + 5);
          showNotification('+5 Focus Restored', 'xp-gain');
        }
      };

      // Save player progress with inventory
      const savePlayerProgress = async () => {
        if (!player || !player.uid) return;
        
        // Ensure inventory exists
        if (!player.inventory) {
          player.inventory = {
            lastStandTrophy: null,
            consumables: []
          };
        }
        
        if (isTestMode) {
          console.log('Test mode: Player stats saved to memory', player);
        } else {
          try {
            await setDoc(doc(db, "players", player.uid), {
              name: player.name,
              className: player.className,
              xp: player.xp,
              focus: player.focus,
              abilities: player.abilities,
              activeEffects: player.activeEffects,
              inventory: player.inventory
            });
          } catch (error) {
            console.error("Error saving player progress:", error);
          }
        }
      };

      // Get class avatar emoji
      const getClassAvatar = (className) => {
        const avatars = {
          'Strategist': '⚔️',
          'Arcanist': '🔮',
          'Infiltrator': '🗡️',
          'Empath': '❤️',
          'Pathfinder': '🧭'
        };
        return avatars[className] || '🗡️';
      };

      // Get class abilities list
      const getClassAbilities = (className) => {
        const abilities = {
          'Strategist': [
            { key: 'powerStrike', name: 'Power Strike', description: 'Double XP for next correct answer' },
            { key: 'tacticalAnalysis', name: 'Tactical Analysis', description: 'Eliminate two wrong answers' }
          ],
          'Arcanist': [
            { key: 'empoweredSpell', name: 'Empowered Spell', description: 'Double XP for next correct answer' },
            { key: 'arcaneKnowledge', name: 'Arcane Knowledge', description: 'Reveal the correct answer' }
          ],
          'Infiltrator': [
            { key: 'eliminate', name: 'Eliminate', description: 'Remove one wrong answer' },
            { key: 'shadowStep', name: 'Shadow Step', description: 'Skip this question without penalty' }
          ],
          'Empath': [
            { key: 'secondLook', name: 'Second Look', description: 'Get another chance if you answer incorrectly' },
            { key: 'emotionalInsight', name: 'Emotional Insight', description: 'Eliminate one wrong answer' }
          ],
          'Pathfinder': [
            { key: 'keenEye', name: 'Keen Eye', description: 'Highlight key passage words (unlimited)' },
            { key: 'trailBlazer', name: 'Trail Blazer', description: 'Eliminate two wrong answers' }
          ]
        };
        return abilities[className] || [];
      };

      // Render class abilities UI
      const renderClassAbilities = () => {
        const buttonContainer = document.getElementById('class-abilities-container');
        if (!buttonContainer) {
          console.log('Abilities container not found');
          return;
        }
        
        buttonContainer.innerHTML = '';
        
        const classAbilities = getClassAbilities(player.className);
        
        classAbilities.forEach(ability => {
          const usesRemaining = player.abilities[ability.key].uses;
          const isUnlimited = usesRemaining === -1;
          const isUsable = isUnlimited || usesRemaining > 0;
          
          const button = document.createElement('button');
          button.className = `game-btn ability-btn ${isUsable ? '' : 'disabled'}`;
          button.style.cssText = `
            padding: 8px 12px; 
            font-size: 12px; 
            margin: 0 5px 5px 0;
            ${!isUsable ? 'opacity: 0.5; cursor: not-allowed;' : ''}
          `;
          
          const usesText = isUnlimited ? '' : ` (${usesRemaining})`;
          button.textContent = ability.name + usesText;
          button.disabled = !isUsable;
          button.title = ability.description;
          
          if (isUsable) {
            button.onclick = () => useAbility(ability.key);
          }
          
          buttonContainer.appendChild(button);
        });
      };

      // XP award system (uses XP_PER_CORRECT from Section 8)
      const awardXP = async (amount) => {
        player.xp = (player.xp || 0) + amount;
        await savePlayerProgress();
        updatePlayerStats();
      };

      // SMART FOCUS COST: Halves cost when at 30 or below
      const deductFocusCost = (baseCost) => {
        let actualCost = baseCost;
        
        // Half cost when focus is 30 or below
        if (player.focus <= 30) {
          actualCost = Math.ceil(baseCost / 2);
          showNotification(`Low Focus: Ability cost reduced to ${actualCost}!`, 'ability-used');
        }
        
        player.focus -= actualCost;
        
        // CRITICAL: Check for exhaustion after deducting
        if (player.focus <= 0) {
          player.focus = 0;
          updatePlayerStats();
          
          // Trigger exhaustion handling
          handleFocusExhaustion();
        } else {
          updatePlayerStats();
        }
      };

      // NEW: Focus Exhaustion System (5 Options)
      const handleFocusExhaustion = async () => {
        console.log('💥 EXHAUSTION DIALOG OPENED');
        
        // ======= GENERATE AI EXHAUSTION NARRATIVE =======
        let exhaustionNarrative = '';
        if (typeof generateFocusExhaustionMoment === 'function') {
          try {
            const context = {
              questionsCompleted: sessionStats.totalQuestions,
              questionsRemaining: currentQuestionSet ? (currentQuestionSet.length - currentQuestionIndex) : 0,
              recentFailures: sessionStats.totalQuestions - sessionStats.correctAnswers,
              currentStreak: sessionStats.currentStreak
            };
            
            exhaustionNarrative = await generateFocusExhaustionMoment(context);
          } catch (error) {
            console.error('Exhaustion narrative generation failed:', error);
          }
        }
        // ===============================================
        
        return new Promise((resolve) => {
          const exhaustionDialog = document.createElement('div');
          exhaustionDialog.style.cssText = `
            position: fixed;
            top: 50%;
