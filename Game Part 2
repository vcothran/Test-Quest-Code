/* === SECTION 10: Ability Implementation & Game Flow === */
      const useAbility = async (abilityKey) => {
        // Track this ability use for AI narration
        if (typeof lastAbilityUsed !== 'undefined') {
          lastAbilityUsed = abilityKey;
        }
        
        // Check if answer already submitted (CRITICAL BUG FIX)
        if (submitAnswerBtn.disabled && submitAnswerBtn.style.display === 'none') {
          showNotification('Cannot use abilities after submitting answer', 'focus-loss');
          return;
        }
        
        if (!player.abilities[abilityKey] || player.abilities[abilityKey].uses === 0) return;
        
        const q = currentQuestionSet[currentQuestionIndex];
        if (!q) return;
        
        let feedbackMessage = '';
        
        switch (abilityKey) {
          case 'powerStrike':
            // Deduct use
            if (player.abilities[abilityKey].uses > 0) {
              player.abilities[abilityKey].uses--;
            }
            player.activeEffects.powerStrikeActive = true;
            feedbackMessage = 'Power Strike activated! Your next correct answer will grant double XP!';
            break;
            
          case 'tacticalAnalysis':
            // ENHANCED: Smart detection of remaining wrong answers
            const wrongAnswers = [];
            q.options.forEach((opt, index) => {
              if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                wrongAnswers.push(index);
              }
            });
            
            if (wrongAnswers.length < 2) {
              const confirmUse = confirm(`Only ${wrongAnswers.length} incorrect answer(s) remain. Use Tactical Analysis anyway?`);
              if (!confirmUse) {
                return; // Don't use the ability
              }
            }
            
            // Deduct use
            if (player.abilities[abilityKey].uses > 0) {
              player.abilities[abilityKey].uses--;
            }
            
            const toEliminate = wrongAnswers.slice(0, 2);
            toEliminate.forEach(index => {
              if (!player.activeEffects.eliminatedAnswers.includes(index)) {
                player.activeEffects.eliminatedAnswers.push(index);
              }
            });
            applyEliminatedAnswers();
            feedbackMessage = `Tactical Analysis eliminates ${toEliminate.length} wrong answer(s)!`;
            break;
            
          case 'empoweredSpell':
            // Deduct use
            if (player.abilities[abilityKey].uses > 0) {
              player.abilities[abilityKey].uses--;
            }
            
            // FIXED: Check for math keywords in question text
            const questionText = (q.text || '').toLowerCase();
            const hasMathKeywords = questionText.includes('calculate') || 
                                    questionText.includes('equation') || 
                                    questionText.includes('solve') ||
                                    questionText.includes('formula') ||
                                    questionText.includes('equals') ||
                                    /\d+[\+\-\*\/×÷]\d+/.test(questionText) ||
                                    questionText.includes('percent') ||
                                    questionText.includes('average');
            const isMath = selectedApproach === 'Calculation (Math)' || 
                           q.format === 'math' || 
                           hasMathKeywords;
            
            if (isMath) {
              // Math: 1 charge, auto-select correct
              selectedAnswerIndex = q.correct;
              highlightCorrectAnswer();
              feedbackMessage = 'Empowered Spell: Mathematical knowledge flows through you!';
            } else {
              // Non-math: Check if we have 2 charges
              if (player.abilities.empoweredSpell.uses >= 1) {
                // Deduct second charge
                player.abilities.empoweredSpell.uses--;
                selectedAnswerIndex = q.correct;
                highlightCorrectAnswer();
                feedbackMessage = 'Empowered Spell (2x charge): Arcane power reveals the answer!';
              } else {
                // Not enough charges, refund the one we took
                player.abilities.empoweredSpell.uses++;
                feedbackMessage = 'Empowered Spell needs 2 charges for non-math questions. (Only 1 charge for math)';
              }
            }
            break;
            
          case 'arcaneKnowledge':
            // Deduct use
            if (player.abilities[abilityKey].uses > 0) {
              player.abilities[abilityKey].uses--;
            }
            // FIXED: Detailed question-type-specific hints
            feedbackMessage = `Arcane Knowledge reveals: ${getDetailedQuestionHint(q)}`;
            break;
            
          case 'eliminate':
            // KEEP STACKING: User wants this as tactical choice
            const wrongAnswerOptions = [];
            q.options.forEach((opt, index) => {
              if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                wrongAnswerOptions.push(index);
              }
            });
            if (wrongAnswerOptions.length > 0) {
              // Deduct use
              if (player.abilities[abilityKey].uses > 0) {
                player.abilities[abilityKey].uses--;
              }
              const randomWrong = wrongAnswerOptions[Math.floor(Math.random() * wrongAnswerOptions.length)];
              player.activeEffects.eliminatedAnswers.push(randomWrong);
              applyEliminatedAnswers();
              feedbackMessage = 'Eliminate: One wrong answer has been removed from consideration.';
            } else {
              feedbackMessage = 'Eliminate: No more wrong answers to remove!';
            }
            break;
            
          case 'shadowStep':
            // Deduct use
            if (player.abilities[abilityKey].uses > 0) {
              player.abilities[abilityKey].uses--;
            }
            currentQuestionIndex++;
            loadQuestion();
            feedbackMessage = 'Shadow Step: You slip past this challenge undetected.';
            return; // Exit early since we're loading next question
            
          case 'secondLook':
            // Deduct use
            if (player.abilities[abilityKey].uses > 0) {
              player.abilities[abilityKey].uses--;
            }
            // FIXED: True retry system - marks for use BEFORE wrong answer
            player.activeEffects.secondLookUsed = true;
            feedbackMessage = 'Second Look prepared: Question will reset if you answer incorrectly!';
            break;
            
          case 'emotionalInsight':
            // ENHANCED: Show explanation text without revealing answer
            if (q.explanation) {
              // Deduct use
              if (player.abilities[abilityKey].uses > 0) {
                player.abilities[abilityKey].uses--;
              }
              feedbackMessage = `Emotional Insight reveals the key concept:\n\n"${q.explanation}"\n\nUse this knowledge to find the right answer!`;
            } else {
              // Fallback: Eliminate one wrong answer if no explanation exists
              const emotionalWrongAnswers = [];
              q.options.forEach((opt, index) => {
                if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                  emotionalWrongAnswers.push(index);
                }
              });
              if (emotionalWrongAnswers.length > 0) {
                // Deduct use
                if (player.abilities[abilityKey].uses > 0) {
                  player.abilities[abilityKey].uses--;
                }
                const randomWrong = emotionalWrongAnswers[Math.floor(Math.random() * emotionalWrongAnswers.length)];
                player.activeEffects.eliminatedAnswers.push(randomWrong);
                applyEliminatedAnswers();
                feedbackMessage = 'Emotional Insight: Understanding the characters reveals one wrong answer.';
              } else {
                feedbackMessage = 'Emotional Insight: No additional insights available for this question.';
              }
            }
            break;
            
          case 'keenEye':
            // Unlimited use - no deduction
            feedbackMessage = `Keen Eye reveals: ${getQuestionDifficulty(q)} difficulty, ${selectedApproach || 'General'} approach.`;
            break;
            
          case 'trailBlazer':
            const oldFocus = player.focus;
            player.focus = Math.min(150, (player.focus || 100) + 25);
            const actualGain = player.focus - oldFocus;
            
            if (player.focus === 150 && oldFocus === 150) {
              feedbackMessage = 'Trail Blazer: Already at maximum overcharge (150)!';
            } else {
              // Deduct use
              if (player.abilities[abilityKey].uses > 0) {
                player.abilities[abilityKey].uses--;
              }
              
              if (player.focus === 150) {
                feedbackMessage = `Trail Blazer: +${actualGain} Focus! ⚠️ Maximum overcharge reached (150)!`;
              } else if (player.focus > 100) {
                feedbackMessage = `Trail Blazer: +${actualGain} Focus! Overcharged status active!`;
              } else {
                feedbackMessage = `Trail Blazer: +${actualGain} Focus restored!`;
              }
            }
            
            updatePlayerStats();
            break;
        }
        
        // Show ability feedback
        const existingFeedback = document.querySelector('.ability-feedback');
        if (existingFeedback) existingFeedback.remove();
        
        const abilityFeedback = document.createElement('div');
        abilityFeedback.className = 'ability-feedback';
        abilityFeedback.style.whiteSpace = 'pre-line'; // Allow line breaks in feedback
        abilityFeedback.textContent = feedbackMessage;
        
        const abilityContainer = document.getElementById('ability-container');
        abilityContainer.appendChild(abilityFeedback);
        
        setTimeout(() => {
          if (abilityFeedback.parentNode) {
            abilityFeedback.parentNode.removeChild(abilityFeedback);
          }
        }, 5000); // Longer display for Emotional Insight
        
        renderClassAbilities();
        await savePlayerProgress();
        showNotification('Ability Used!', 'ability-used');
      };

