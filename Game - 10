// ─────────────────────────────────────────────────────────────────────────
// HOOK INTO EPISODE/ENCOUNTER LIFECYCLE
// ─────────────────────────────────────────────────────────────────────────
setTimeout(() => {
  // Expose current question getter for signature abilities that need it
  window._getCurrentQuestion = () => {
    if (typeof currentQuestionSet !== 'undefined' && typeof currentQuestionIndex !== 'undefined') {
      return currentQuestionSet[currentQuestionIndex] || null;
    }
    return null;
  };

  // Show signature button if player already has L15 upgrade
  if (player && player.abilityUpgrades && player.abilityUpgrades.tier3) {
    window.updateSignatureHUD();
  }

  // Hook level-up to show button when L15 is reached
  const origLevelUp = window.checkForLevelUp;
  if (origLevelUp && !window._s22LevelHooked) {
    window._s22LevelHooked = true;
    window.checkForLevelUp = () => {
      origLevelUp();
      if (player && player.abilityUpgrades && player.abilityUpgrades.tier3) {
        window.updateSignatureHUD();
      }
    };
  }

  // Reset signature use at episode start by patching csEnterGame
  // We do this via a MutationObserver on the episode screen becoming active
  const episodeScreen = document.getElementById('episodeSelection');
  if (episodeScreen) {
    new MutationObserver(() => {
      if (episodeScreen.classList.contains('active')) {
        // Player is back at episode select — next episode start will reset
        if (player && player.activeEffects) {
          player.activeEffects.signatureUsedThisEpisode = false;
          player.activeEffects.fortressStanceCount      = 0;
          player.activeEffects.timeStopCount            = 0;
          player.activeEffects.shadowCloakActive        = false;
          player.activeEffects.phantomStrikeActive      = false;
          player.activeEffects.deathMarkActive          = false;
          player.activeEffects.collectiveWillActive     = false;
          player.activeEffects.undyingActive            = false;
          player.activeEffects.resonanceActive          = false;
          player.activeEffects.enduranceActive          = false;
          player.activeEffects.skipAndKnowActive        = false;
          player.activeEffects.tacticalMasteryActive    = false;
        }
        window.updateSignatureHUD();
      }
    }).observe(episodeScreen, { attributes: true, attributeFilter: ['class'] });
  }

  console.log('✅ Signature ability hooks attached');
}, 3000);

