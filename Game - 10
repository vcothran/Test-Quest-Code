
// ─────────────────────────────────────────────────────────────────────────
// HOOK INTO EXISTING SYSTEMS via MutationObserver + event listeners
// ─────────────────────────────────────────────────────────────────────────
setTimeout(() => {
  // Hook feedback box for per-answer checks
  const feedbackBox = document.getElementById('feedback-box');
  if (feedbackBox) {
    const observer = new MutationObserver(() => {
      if (player && sessionStats) window.checkTitleTriggers();
    });
    observer.observe(feedbackBox, { childList: true, subtree: false });
    console.log('✅ Title/badge trigger observer attached');
  }

  // Hook return-to-episodes for episode completion checks
  const returnBtn = document.getElementById('return-to-episodes');
  if (returnBtn) {
    const origClick = returnBtn.onclick;
    returnBtn.onclick = (e) => {
      window.checkEpisodeTitleTriggers();
      if (origClick) origClick(e);
    };
  }

  // Init HUD title display
  window.updateHUDTitle();

  // Hook level-up check into Section 18's checkForLevelUp
  const origLevelUp = window.checkForLevelUp;
  if (origLevelUp && !window._s21LevelHooked) {
    window._s21LevelHooked = true;
    window.checkForLevelUp = () => {
      const levelBefore = window._lastKnownLevel || 1;
      origLevelUp();
      const levelAfter = window.getLevelData ? window.getLevelData(player.xp).level : 1;
      if (levelAfter > levelBefore) {
        window.checkLevelTitleTriggers(levelAfter);
        window.updateHUDTitle();
      }
    };
  }

  // Hook loot drop into Section 20
  const origShowLoot = window.showLootDropOverlay;
  if (origShowLoot && !window._s21LootHooked) {
    window._s21LootHooked = true;
    window.showLootDropOverlay = async (loot, streak) => {
      window.checkLootTitleTriggers(loot);
      await origShowLoot(loot, streak);
    };
  }

  // Hook portrait confirm into Section 19
  const origConfirm = window.confirmPortraitAndContinue;
  if (origConfirm && !window._s21PortraitHooked) {
    window._s21PortraitHooked = true;
    window.confirmPortraitAndContinue = async () => {
      await origConfirm();
      window.checkPortraitTitleTriggers();
    };
  }

  // Load existing titles/badges from player
  if (player) {
    if (!player.titles) player.titles = [];
    if (!player.badges) player.badges = [];
    window.updateHUDTitle();
  }

  console.log('✅ Title/badge hooks attached');
}, 2500);

