  maxDayBonus:  7,    // Caps at day 7 (25 + 6×10 = 85 XP)
  streakReset:  2,    // Days of absence before streak resets
};

// Bonus XP by day (1-7, then repeats at max)
window.getLoginBonusXP = (streak) => {
  const day = Math.min(streak, window.LOGIN_BONUS_CONFIG.maxDayBonus);
  return window.LOGIN_BONUS_CONFIG.baseXP + (day - 1) * window.LOGIN_BONUS_CONFIG.incrementXP;
};

// ─────────────────────────────────────────────────────────────────────────
// CHECK AND AWARD LOGIN BONUS
// Called once on game load after player data is available
// ─────────────────────────────────────────────────────────────────────────
window.checkDailyLoginBonus = async () => {
  if (!player || !player.uid) return;

  const now      = new Date();
  const todayStr = now.toISOString().split('T')[0]; // YYYY-MM-DD

  const lastLogin  = player.lastLoginDate  || null;
  const streak     = player.loginStreak    || 0;
  const longestStr = player.longestStreak  || 0;

  // Already claimed today
  if (lastLogin === todayStr) return;

  // Calculate new streak
  let newStreak = 1;
  if (lastLogin) {
    const last     = new Date(lastLogin);
    const diffDays = Math.floor((now - last) / (1000 * 60 * 60 * 24));
    if (diffDays === 1) {
      newStreak = streak + 1; // consecutive day
    } else if (diffDays < window.LOGIN_BONUS_CONFIG.streakReset) {
      newStreak = streak;     // missed one day — hold streak
    } else {
      newStreak = 1;          // streak broken
    }
  }

  const bonusXP       = window.getLoginBonusXP(newStreak);
  const newLongest    = Math.max(longestStr, newStreak);
  const streakBroken  = lastLogin && newStreak === 1 && streak > 1;

  // Award XP
  player.xp           = (player.xp || 0) + bonusXP;
  player.lastLoginDate = todayStr;
  player.loginStreak   = newStreak;
  player.longestStreak = newLongest;

  // Save to Firestore
  try {
    await setDoc(doc(db, 'players', player.uid), {
      xp:            player.xp,
      lastLoginDate: todayStr,
      loginStreak:   newStreak,
      longestStreak: newLongest,
    }, { merge: true });
    if (player.activeCharacterId) {
      await setDoc(doc(db, 'players', player.uid, 'characters', player.activeCharacterId), {
        xp: player.xp,
      }, { merge: true });
    }
  } catch(e) { console.warn('Could not save login bonus:', e); }

  if (window._safeUpdateStats) window._safeUpdateStats();
  if (window.checkForLevelUp)  window.checkForLevelUp();

  // Show overlay
  window.showLoginBonusOverlay(newStreak, bonusXP, streakBroken);
};

