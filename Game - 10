window.getPlayerSignature = () => {
  if (!player || !player.abilityUpgrades) return null;
  const sigId = player.abilityUpgrades.tier3;
  if (!sigId) return null;
  return window.SIGNATURE_DEFINITIONS[sigId] || null;
};

// ─────────────────────────────────────────────────────────────────────────
// SHOW SIGNATURE BUTTON IN HUD
// Called after level 15 upgrade is chosen and on each episode start
// ─────────────────────────────────────────────────────────────────────────
window.updateSignatureHUD = () => {
  const existing = document.getElementById('hud-signature-btn');
  if (existing) existing.remove();

  const sig = window.getPlayerSignature();
  if (!sig) return;

  const statsEl = document.getElementById('player-stats');
  if (!statsEl) return;

  const used = player.activeEffects && player.activeEffects.signatureUsedThisEpisode;

  const btn = document.createElement('button');
  btn.id = 'hud-signature-btn';
  btn.style.cssText = `
    cursor:${used ? 'not-allowed' : 'pointer'};
    background:${used ? 'rgba(255,255,255,0.04)' : 'linear-gradient(135deg,rgba(201,168,76,0.2),rgba(160,112,48,0.3))'};
    border:1px solid ${used ? 'rgba(255,255,255,0.1)' : 'rgba(201,168,76,0.5)'};
    color:${used ? '#3a4456' : '#c9a84c'};
    font-size:11px;padding:6px 10px;border-radius:6px;
    font-family:'Cinzel',serif;
    opacity:${used ? '0.5' : '1'};
    transition:all 0.2s;
    margin-left:6px;`;
  btn.innerHTML = `${sig.icon} ${sig.name}`;
  btn.title = used ? 'Already used this episode' : sig.desc;
  btn.disabled = used;

  if (!used) {
    btn.onclick = () => window.activateSignature();
    btn.onmouseenter = () => { if (!used) btn.style.background = 'linear-gradient(135deg,rgba(201,168,76,0.35),rgba(160,112,48,0.45))'; };
    btn.onmouseleave = () => { if (!used) btn.style.background = 'linear-gradient(135deg,rgba(201,168,76,0.2),rgba(160,112,48,0.3))'; };
  }

  statsEl.appendChild(btn);
};

// ─────────────────────────────────────────────────────────────────────────
// ACTIVATE SIGNATURE ABILITY
// ─────────────────────────────────────────────────────────────────────────
window.activateSignature = () => {
  const sig = window.getPlayerSignature();
  if (!sig) return;
  if (player.activeEffects && player.activeEffects.signatureUsedThisEpisode) {
    if (window._safeNotify) window._safeNotify('Signature already used this episode!', 'focus-loss');
    return;
  }

  const result = sig.activate();
  if (result === false) {
    if (window._safeNotify) window._safeNotify('Cannot use that right now.', 'focus-loss');
    return;
  }

  // Mark as used
  if (!player.activeEffects) player.activeEffects = {};
  player.activeEffects.signatureUsedThisEpisode = true;

  // Show dramatic overlay
  window.showSignatureActivationOverlay(sig, result);

  // Update HUD button to greyed out
  window.updateSignatureHUD();

  if (typeof savePlayerProgress === 'function') savePlayerProgress();
};

