CMSApp.prototype.editEpisode = function(episodeId) {
  const episode = this.state.episodes.find(e => e.id === episodeId);
  if (!episode) { this.showAlert('Episode not found.', 'error'); return; }

  document.getElementById('episode-title').value = episode.title || '';
  document.getElementById('episode-description').value = episode.description || '';
  document.getElementById('episode-active').checked = episode.active || false;

  const genreSelect = document.getElementById('episode-genre');
  if (genreSelect) {
    genreSelect.innerHTML = '<option value="">Select genre...</option>';
    if (this.state.genres && this.state.genres.length > 0) {
      this.state.genres.forEach(genre => {
        const option = document.createElement('option');
        option.value = genre.name;
        option.textContent = genre.name;
        genreSelect.appendChild(option);
      });
    } else {
      ['Mystery','Adventure','Science Fiction','Fantasy','Educational'].forEach(genreName => {
        const option = document.createElement('option');
        option.value = genreName;
        option.textContent = genreName;
        genreSelect.appendChild(option);
      });
    }
    genreSelect.value = episode.genre || '';
  }

  document.querySelectorAll('.approach-checkbox').forEach(checkbox => {
    checkbox.checked = (episode.availableApproaches || []).includes(checkbox.value);
  });

  // FIX #4: Load ALL question banks — no subject filtering that blocks banks
  const togglesContainer = document.getElementById('question-banks-toggles');
  if (togglesContainer && this.db) {
    togglesContainer.innerHTML = '<div class="loading-state" style="text-align:center;color:#6c757d;padding:20px;">Loading question banks...</div>';
    const { collection, getDocs } = window.firebaseV9;
    getDocs(collection(this.db, 'questionBanks')).then(snapshot => {
      if (snapshot.empty) {
        togglesContainer.innerHTML = '<div style="text-align:center;color:#6c757d;padding:20px;">No question banks found.</div>';
      } else {
        togglesContainer.innerHTML = '';
        snapshot.forEach(doc => {
          const bank = { id: doc.id, ...doc.data() };
          const questions = Array.isArray(bank.questions) ? bank.questions : [];
          const isSelected = (episode.selectedQuestionBanks || []).includes(bank.id);

          const bankItem = document.createElement('div');
          bankItem.className = 'bank-toggle-item' + (isSelected ? ' enabled' : '');
          bankItem.dataset.bankId = bank.id;
          bankItem.innerHTML = `
            <div class="bank-info">
              <div class="bank-name">${bank.name || 'Untitled Bank'}</div>
              <div class="bank-details">${bank.approach || 'General'} \u2022 ${questions.length} questions</div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" class="bank-toggle" data-bank-id="${bank.id}" ${isSelected ? 'checked' : ''}>
              <span class="toggle-slider"></span>
            </label>
          `;
          const toggle = bankItem.querySelector('.bank-toggle');
          toggle.addEventListener('change', (e) => {
            bankItem.classList.toggle('enabled', e.target.checked);
          });
          togglesContainer.appendChild(bankItem);
        });
      }
    }).catch(error => {
      console.error('Error loading question banks:', error);
      togglesContainer.innerHTML = '<div style="text-align:center;color:#dc3545;padding:20px;">Error loading question banks</div>';
    });
  }

  document.getElementById('episode-modal-title').textContent = 'Edit Episode';
  this.state.editingEpisodeId = episodeId;
  this.openModal('episode-modal');
  console.log('\u270F\uFE0F Episode edit modal opened for:', episodeId);
};

CMSApp.prototype.deleteEpisode = function(episodeId) {
  const episode = this.state.episodes.find(e => e.id === episodeId);
  const episodeName = episode ? episode.title : 'this episode';
  if (!confirm(`Are you sure you want to delete "${episodeName}"?\n\nThis action cannot be undone.`)) return;
  console.log('\u{1F5D1}\uFE0F Deleting episode:', episodeId);
  this.showProcessing('Deleting episode...');
  this.deleteDoc(this.doc(this.db, 'episodes', episodeId))
    .then(() => {
      console.log('\u2705 Episode deleted');
      this.showAlert('Episode deleted successfully!', 'success');
      this.loadEpisodes();
    })
    .catch(error => {
      console.error('\u274C Error deleting episode:', error);
      this.showAlert('Error deleting episode. Please try again.', 'error');
    })
    .finally(() => { this.hideProcessing(); });
};

