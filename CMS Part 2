                '<div style="text-align:center;"><span style="font-size:16px;font-weight:700;color:#667eea;display:block;">'+(char.xp||0)+'</span><span style="font-size:9px;color:#4a5568;text-transform:uppercase;">XP</span></div>' +
              '</div>' +
              '<div style="font-size:10px;color:#3a4456;">'+ago+'</div>' +
              '<button style="position:absolute;bottom:12px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#667eea,#764ba2);color:white;border:none;border-radius:14px;padding:5px 16px;font-size:12px;font-weight:700;cursor:pointer;opacity:'+(isSel?'1':'0')+';transition:opacity 0.2s;white-space:nowrap;" class="cs-play-btn">Play</button>';
            slot.onmouseenter = (function(el, idx) { return () => {
              if (csSelectedIndex !== idx) { el.style.transform = 'translateY(-6px)'; el.style.boxShadow = '0 16px 35px rgba(0,0,0,0.5)'; }
              const db = el.querySelector('.cs-del-btn'), pb = el.querySelector('.cs-play-btn');
              if (db) db.style.opacity = '1'; if (pb) pb.style.opacity = '1';
            }; })(slot, i);
            slot.onmouseleave = (function(el, idx) { return () => {
              if (csSelectedIndex !== idx) { el.style.transform = 'translateY(0)'; el.style.boxShadow = 'none'; }
              const db = el.querySelector('.cs-del-btn'), pb = el.querySelector('.cs-play-btn');
              if (db) db.style.opacity = '0'; if (pb) pb.style.opacity = (csSelectedIndex===idx)?'1':'0';
            }; })(slot, i);
            slot.onclick = (function(idx) { return () => csSelectSlot(idx); })(i);
          } else {
            slot.style.background = 'rgba(255,255,255,0.015)';
            slot.style.border     = '2px dashed rgba(255,255,255,0.09)';
            slot.innerHTML =
              '<span style="position:absolute;top:9px;left:12px;font-size:10px;font-weight:700;color:#3a4456;text-transform:uppercase;letter-spacing:1px;">#'+(i+1)+'</span>' +
              '<span style="font-size:32px;opacity:0.18;margin-bottom:10px;display:block;">+</span>' +
              '<div style="font-size:12px;color:#3a4456;">New Hero</div>';
            slot.onmouseenter = (function(el) { return () => { el.style.background='rgba(255,255,255,0.03)'; el.style.borderColor='rgba(255,255,255,0.18)'; }; })(slot);
            slot.onmouseleave = (function(el) { return () => { el.style.background='rgba(255,255,255,0.015)'; el.style.borderColor='rgba(255,255,255,0.09)'; }; })(slot);
            slot.onclick = (function(idx) { return () => csOpenCreate(idx); })(i);
          }
          grid.appendChild(slot);
        }
      };

      const csSelectSlot = (index) => {
        csSelectedIndex = index;
        csRenderGrid();
        const char = csCharacters.find(c => c.slotIndex === index);
        const btn  = document.getElementById('cs-enter-btn');
        if (!btn) return;
        btn.style.opacity = '1'; btn.style.pointerEvents = 'auto';
        btn.style.boxShadow = '0 14px 40px rgba(102,126,234,0.6)';
        btn.textContent = char ? 'Play as ' + char.name : 'Begin Adventure';
      };

      window.csEnterGame = async () => {
        const char = csCharacters.find(c => c.slotIndex === csSelectedIndex);
        if (!char) return;
        try {
          await setDoc(doc(db, 'players', player.uid), {
            name: char.name, className: char.className,
            xp: char.xp || 0, focus: char.focus || 100,
            abilities: char.abilities || null, activeEffects: char.activeEffects || null,
            inventory: char.inventory || null, enrolledCodes: char.enrolledCodes || [],
            activeCharacterId: char.id
          });
          await setDoc(doc(db, 'players', player.uid, 'characters', char.id), { lastPlayed: new Date().toISOString() }, { merge: true });
          player.name          = char.name;
          player.className     = char.className;
          player.xp            = char.xp            || 0;
          player.focus         = char.focus          || 100;
          player.abilities     = char.abilities      || null;
          player.activeEffects = char.activeEffects  || null;
          player.inventory     = char.inventory      || null;
          player.enrolledCodes = char.enrolledCodes  || [];
          player.activeCharacterId = char.id;
          if (player.xp    == null) player.xp    = 0;
          if (player.focus == null) player.focus  = 100;
          initializePlayerAbilities();
          await loadGameContent();
          showScreen('episodeSelection');
        } catch (e) { console.error('csEnterGame error:', e); alert('Error loading hero. Please try again.'); }
      };

      // -------------------------------------------------------
      // CREATE HERO MODAL
      // -------------------------------------------------------
      const csOpenCreate = (slotIndex) => {
        csCreatingSlot = slotIndex; csSelectedClass = null;
        const grid = document.getElementById('cs-class-grid');
        if (!grid) return;
        grid.innerHTML = '';
        CS_ORDER.forEach(cls => {
          const def  = CS_CLASSES[cls];
          const card = document.createElement('div');
          card.id    = 'cscard-' + cls;
          card.style.cssText = 'background:rgba(255,255,255,0.04);border:2px solid rgba(255,255,255,0.08);border-radius:11px;padding:13px 10px;text-align:center;cursor:pointer;transition:all 0.2s;';
          card.innerHTML = '<span style="font-size:26px;display:block;margin-bottom:5px;">'+def.icon+'</span><div style="font-size:13px;font-weight:700;color:white;margin-bottom:2px;">'+cls+'</div><div style="font-size:10px;color:#4a5568;line-height:1.4;">'+def.tagline+'</div>';
          card.onclick = (function(c, d, el) { return () => {
            csSelectedClass = c;
            document.querySelectorAll('[id^=cscard-]').forEach(x => { x.style.background='rgba(255,255,255,0.04)'; x.style.borderColor='rgba(255,255,255,0.08)'; });
            el.style.background = 'rgba(102,126,234,0.15)'; el.style.borderColor = d.color;
          }; })(cls, def, card);
          grid.appendChild(card);
        });
        const heroNameEl = document.getElementById('cs-hero-name');
        if (heroNameEl) heroNameEl.value = '';
        const modal = document.getElementById('cs-create-modal');
        if (modal) { modal.style.display = 'flex'; setTimeout(() => heroNameEl && heroNameEl.focus(), 100); }
      };

      window.csCloseCreate = () => {
        const modal = document.getElementById('cs-create-modal');
        if (modal) modal.style.display = 'none';
        csCreatingSlot = null; csSelectedClass = null;
      };

      window.csDoCreate = async () => {
        const heroNameEl = document.getElementById('cs-hero-name');
        const name = heroNameEl ? heroNameEl.value.trim() : '';
        if (!csSelectedClass) { alert('Please choose a class.'); return; }
        if (!name)            { alert('Please enter a hero name.'); return; }
        const btn = document.getElementById('cs-create-btn');
        if (btn) { btn.disabled = true; btn.textContent = 'Creating...'; }
        try {
          const newChar = { name, className: csSelectedClass, xp: 0, focus: 100, abilities: null, activeEffects: null, inventory: null, enrolledCodes: [], slotIndex: csCreatingSlot, createdAt: new Date().toISOString(), lastPlayed: null };
          const ref = doc(collection(db, 'players', player.uid, 'characters'));
          await setDoc(ref, Object.assign({}, newChar, { id: ref.id }));
          newChar.id = ref.id;
          csCharacters = csCharacters.filter(c => c.slotIndex !== csCreatingSlot);
          csCharacters.push(newChar);
          window.csCloseCreate();
          csRenderGrid();
        } catch (e) { console.error('csDoCreate error:', e); alert('Error creating hero. Please try again.'); }
        finally { if (btn) { btn.disabled = false; btn.textContent = 'Create Hero'; } }
      };

      window.csConfirmDelete = (slotIndex) => {
        const char = csCharacters.find(c => c.slotIndex === slotIndex);
        if (!char || !confirm('Delete ' + char.name + '? This cannot be undone.')) return;
        deleteDoc(doc(db, 'players', player.uid, 'characters', char.id))
          .then(() => {
            csCharacters = csCharacters.filter(c => c.slotIndex !== slotIndex);
            if (csSelectedIndex === slotIndex) {
              csSelectedIndex = null;
              const btn = document.getElementById('cs-enter-btn');
              if (btn) { btn.style.opacity = '0.35'; btn.style.pointerEvents = 'none'; btn.textContent = 'Begin Adventure'; }
            }
            csRenderGrid();
          })
          .catch(() => alert('Error deleting hero.'));
      };

      // -------------------------------------------------------
      // CLASS CODE MODAL
      // -------------------------------------------------------
      const csShowCodeModal = () => new Promise((resolve) => {
        if (player.role === 'teacher') { resolve(null); return; }

        csCodeResolve = resolve;
        const lastCode = (Array.isArray(player.enrolledCodes) && player.enrolledCodes[0]) || '';
        const input    = document.getElementById('cs-code-input');
        const badge    = document.getElementById('cs-prefill-badge');
        const prefill  = document.getElementById('cs-prefill-text');
        const error    = document.getElementById('cs-code-error');
        const checking = document.getElementById('cs-code-checking');
        const submit   = document.getElementById('cs-code-submit');
        if (!input || !submit) { resolve(null); return; }
        input.value = lastCode;
        if (error)    error.style.display    = 'none';
        if (checking) checking.style.display = 'none';
        submit.disabled = false; submit.style.opacity = '1';
        if (lastCode && prefill && badge) { prefill.textContent = lastCode; badge.style.display = 'flex'; }
        else if (badge) { badge.style.display = 'none'; }
        const modal = document.getElementById('cs-code-modal');
        if (modal) { modal.style.display = 'flex'; setTimeout(() => input.focus(), 100); }
      });

      window.csUsePrefill = () => {
        const input   = document.getElementById('cs-code-input');
        const prefill = document.getElementById('cs-prefill-text');
        if (input && prefill) input.value = prefill.textContent;
        window.csSubmitCode();
      };

      window.csSubmitCode = async () => {
        const input    = document.getElementById('cs-code-input');
        const error    = document.getElementById('cs-code-error');
        const checking = document.getElementById('cs-code-checking');
        const submit   = document.getElementById('cs-code-submit');
        const code     = input ? input.value.trim().toUpperCase() : '';
        if (!code) { if (error) { error.textContent = 'Please enter a code.'; error.style.display = 'block'; } return; }
        if (submit)   { submit.disabled = true; submit.style.opacity = '0.6'; }
        if (error)    error.style.display    = 'none';
        if (checking) checking.style.display = 'block';
        try {
          const q    = query(collection(db, 'classes'), where('joinCode', '==', code));
          const snap = await getDocs(q);
          if (checking) checking.style.display = 'none';
          if (!snap.empty) {
            const classData = Object.assign({ id: snap.docs[0].id }, snap.docs[0].data());
            await csAddCode(code);
            const modal = document.getElementById('cs-code-modal');
            if (modal) modal.style.display = 'none';
            if (csCodeResolve) { csCodeResolve({ code, classData }); csCodeResolve = null; }
          } else {
            if (error)  { error.textContent = 'Code not found — check with your teacher and try again.'; error.style.display = 'block'; }
            if (submit) { submit.disabled = false; submit.style.opacity = '1'; }
          }
        } catch (e) {
          if (checking) checking.style.display = 'none';
          if (error)    { error.textContent = 'Error checking code. Please try again.'; error.style.display = 'block'; }
          if (submit)   { submit.disabled = false; submit.style.opacity = '1'; }
        }
      };

      window.csSkipCode = () => {
        const modal = document.getElementById('cs-code-modal');
        if (modal) modal.style.display = 'none';
        if (csCodeResolve) { csCodeResolve(null); csCodeResolve = null; }
      };

      const csAddCode = async (code) => {
        const existing = Array.isArray(player.enrolledCodes) ? player.enrolledCodes : [];
        if (existing.includes(code)) return;
        const updated = [...existing, code];
        player.enrolledCodes = updated;
        try {
          if (player.activeCharacterId) await setDoc(doc(db, 'players', player.uid, 'characters', player.activeCharacterId), { enrolledCodes: updated }, { merge: true });
          await setDoc(doc(db, 'players', player.uid), { enrolledCodes: updated }, { merge: true });
        } catch (e) { console.warn('csAddCode error:', e); }
      };

      // -------------------------------------------------------
      // LEGAL MODAL
      // -------------------------------------------------------
      window.csOpenLegal = (tab) => {
        const modal = document.getElementById('cs-legal-modal');
        if (modal) modal.style.display = 'flex';
        window.csLegalTab(tab || 'terms');
      };

      window.csLegalTab = (tab) => {
        ['terms','privacy','contact'].forEach(t => {
          const panel = document.getElementById('lpanel-' + t);
          const btn   = document.getElementById('ltab-' + t);
          if (panel) panel.style.display = (t === tab) ? 'block' : 'none';
          if (btn) { btn.style.color = (t === tab) ? '#667eea' : '#4a5568'; btn.style.borderBottom = (t === tab) ? '3px solid #667eea' : '3px solid transparent'; }
        });
      };

      // -------------------------------------------------------
      // LOAD GAME CONTENT
      // -------------------------------------------------------
      const loadGameContent = async () => {
        episodeListDiv.innerHTML = 'Loading Adventures...';
        let activeClassId = null;

        if (!isTestMode) {
          const result = await csShowCodeModal();
          if (result && result.classData) activeClassId = result.classData.id;
        }

        try {
          const episodesSnapshot = await getDocs(collection(db, "episodes"));
          const allEpisodes      = episodesSnapshot.docs.map(d => ({ id: d.id, ...d.data() }));

          const qBanksSnapshot = await getDocs(collection(db, "questionBanks"));
          qBanksSnapshot.forEach(d => { questionBanks[d.id] = d.data(); });

          let filteredEpisodes;
          if (isTestMode || player.role === 'teacher' || !activeClassId) {
            filteredEpisodes = allEpisodes;
          } else {
            const codes    = Array.isArray(player.enrolledCodes) ? player.enrolledCodes : [];
            const classIds = await csGetClassIdsForCodes(codes);
            if (activeClassId && !classIds.includes(activeClassId)) classIds.push(activeClassId);
            filteredEpisodes = classIds.length === 0 ? [] : allEpisodes.filter(ep => {
              const assigned = Array.isArray(ep.assignedClasses) ? ep.assignedClasses : [];
              return assigned.some(cid => classIds.includes(cid));
            });
          }

          episodes = filteredEpisodes;
          episodeListDiv.innerHTML = '';

          if (episodes.length === 0) {
            episodeListDiv.innerHTML =
              '<div style="text-align:center;padding:40px;color:#95a5a6;">' +
                '<h3 style="color:#bdc3c7;">No Adventures Assigned Yet</h3>' +
                '<p>Your teacher has not assigned any episodes. Check back soon!</p>' +
                '<button onclick="document.getElementById(\'cs-code-modal\').style.display=\'flex\'" ' +
                  'style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;border:none;' +
                  'border-radius:10px;padding:12px 24px;font-size:14px;cursor:pointer;margin-top:10px;">' +
                  'Try a Different Code' +
                '</button>' +
              '</div>';
          } else {
            if (player.role !== 'teacher') {
              const bar = document.createElement('div');
              bar.style.cssText = 'display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding:11px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:10px;font-size:13px;color:#6c757d;';
              bar.innerHTML =
                '<span>Class code active · ' + episodes.length + ' adventure' + (episodes.length !== 1 ? 's' : '') + ' available</span>' +
                '<button onclick="document.getElementById(\'cs-code-modal\').style.display=\'flex\'" ' +
                  'style="background:none;border:1px solid rgba(102,126,234,0.35);color:#667eea;' +
                  'border-radius:8px;padding:5px 13px;font-size:12px;cursor:pointer;">Change Class</button>';
              episodeListDiv.appendChild(bar);
            }
            episodes.forEach(ep => {
              const epDiv = document.createElement('div');
              epDiv.className = 'episode-item';
              epDiv.innerHTML = `<h3>${ep.title}</h3><p>An epic quest awaits...</p>`;
              epDiv.onclick = () => startEpisode(ep.id);
              episodeListDiv.appendChild(epDiv);
            });
          }
        } catch (error) {
          console.error("Error loading content:", error);
          episodeListDiv.innerHTML = '<p>Could not load adventures. Please refresh and try again.</p>';
        }
      };

      const csGetClassIdsForCodes = async (codes) => {
        if (!codes || codes.length === 0) return [];
        try {
          const ids = [];
          for (let i = 0; i < codes.length; i += 10) {
            const batch = codes.slice(i, i + 10);
            const snap  = await getDocs(query(collection(db, 'classes'), where('joinCode', 'in', batch)));
            snap.docs.forEach(d => ids.push(d.id));
          }
          return ids;
        } catch (e) { console.warn('csGetClassIdsForCodes error:', e); return []; }
      };

      // -------------------------------------------------------
      // START EPISODE
      // -------------------------------------------------------
      const startEpisode = async (episodeId) => {
        if (!player || !player.name || !player.className) {
          console.error("Player data incomplete.");
          showScreen('characterSelect');
          return;
        }

        currentEpisode = episodes.find(ep => ep.id === episodeId);
        if (!currentEpisode) { console.error("Episode not found:", episodeId); return; }

        currentEncounterIndex       = 0;
        sessionStats.totalQuestions = 0;
        sessionStats.correctAnswers = 0;
        sessionStats.currentStreak  = 0;
        sessionStats.bestStreak     = 0;
        sessionStats.startXP        = player.xp || 0;

        resetEpisodeAbilities();
        if (typeof resetEpisodeNarrative === 'function') resetEpisodeNarrative(currentEpisode);

        document.getElementById('hud-player-name').textContent  = player.name;
        document.getElementById('hud-player-class').textContent = player.className;
        document.getElementById('player-avatar').textContent    = getClassAvatar(player.className);
        updatePlayerStats();

        showScreen('gamePlay');

        // Show diamond loader immediately
        if (typeof showNarrativeLoading === 'function') {
          showNarrativeLoading('Conjuring your story…');
        }

        // STEP 1: Generate AI narrative first — encounter loads after
        if (typeof generateEpisodeOpening === 'function') {
          try {
            await generateEpisodeOpening(currentEpisode);
          } catch (error) {
            console.error('Episode opening generation failed:', error);
          }
        }

        // STEP 2: Load encounter — questions appear after narrative is ready
        loadEncounter();
      };

      // -------------------------------------------------------
      // ENCOUNTER & APPROACH — v2: per-encounter question slicing
      //                             + pass/fail tracking
      // -------------------------------------------------------

      // Track per-encounter stats for pass/fail and AI narrative
      // (declared at module level in Section 12)

      const loadEncounter = async () => {
        feedbackBox.style.display = 'none';
        document.getElementById('next-encounter-box').style.display = 'none';
        document.getElementById('challenge-box').style.display      = 'none';
        approachSelectionBox.style.display = 'none';
        selectedApproach = null;
        player.activeEffects.eliminatedAnswers = [];
        player.activeEffects.secondLookUsed    = false;

        // Reset per-encounter stats
        encounterStats = { correct: 0, total: 0 };

        if (!currentEpisode || !currentEpisode.encounters ||
            currentEncounterIndex >= currentEpisode.encounters.length) {
          await completeEpisode();
          return;
        }

        const encounter = currentEpisode.encounters[currentEncounterIndex];

        // Only set narrative fallback if AI hasn't already populated it
        const narrativeEl = document.getElementById('narrative-text');
        if (!narrativeEl.textContent || narrativeEl.textContent.trim() === '') {
          narrativeEl.textContent = encounter.narrative || encounter.title || '';
        }

        const availableApproaches = currentEpisode.availableApproaches || ['General'];
        const selectedBankIds     = currentEpisode.selectedQuestionBanks || [];

        const matchingBanks = Object.entries(questionBanks).filter(([id, bank]) => {
          return selectedBankIds.includes(id) &&
            (availableApproaches.includes(bank.approach) || bank.approach === 'General');
        });

        if (matchingBanks.length === 0) {
          alert('Error: No question banks available for this encounter!');
          return;
        }

        if (availableApproaches.length === 1 ||
           (availableApproaches.length === 2 && availableApproaches.includes('General'))) {
          startChallengeWithApproach(encounter, availableApproaches.find(a => a !== 'General') || 'General');
        } else {
          displayApproachSelection(encounter, availableApproaches);
        }
      };

      const displayApproachSelection = (encounter, availableApproaches) => {
        approachSelectionBox.innerHTML = '<h3>Choose Your Approach:</h3>';
        approachSelectionBox.style.display = 'block';
        availableApproaches.filter(a => a !== 'General').forEach(approach => {
          const btn = document.createElement('button');
          btn.className = 'game-btn approach-btn';
          btn.textContent = approach;
          btn.onclick = () => startChallengeWithApproach(encounter, approach);
          approachSelectionBox.appendChild(btn);
        });
      };

      const startChallengeWithApproach = (encounter, approach) => {
        selectedApproach = approach;
        approachSelectionBox.style.display = 'none';

        const selectedBankIds = currentEpisode.selectedQuestionBanks || [];
        const matchingBanks   = Object.entries(questionBanks).filter(([id, bank]) => {
          return selectedBankIds.includes(id) &&
            (bank.approach === approach || bank.approach === 'General');
        });

        if (matchingBanks.length === 0) {
          alert(`Error: No question banks found for "${approach}".`);
          return setTimeout(() => loadEncounter(), 0);
        }

        let allQuestions = [];
        matchingBanks.forEach(([id, bank]) => {
          if (bank.questions && bank.questions.length > 0) {
            allQuestions = allQuestions.concat(bank.questions);
          }
        });

        if (allQuestions.length === 0) {
          alert(`Error: No questions in banks for "${approach}".`);
          return setTimeout(() => loadEncounter(), 0);
        }

        // Use per-encounter question count — questionsPerApproach takes priority over qCount
        const requestedCount = encounter.questionsPerApproach || encounter.qCount || 5;

        currentQuestionSet = [...allQuestions]
          .sort(() => 0.5 - Math.random())
          .slice(0, Math.min(requestedCount, allQuestions.length));

        currentQuestionIndex = 0;
        document.getElementById('challenge-box').style.display = 'flex';
        setTimeout(() => loadQuestion(), 0);
      };

      console.log('Section 11: Character Select, Teacher Routing & Episode Management loaded');
	</script>
	
