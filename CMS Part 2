// ── EPISODE MODAL ─────────────────────────────────

CMSApp.prototype.showEpisodeModal = function(episode) {
  // Reset all fields
  document.getElementById('episode-title').value = '';
  document.getElementById('episode-description').value = '';
  document.getElementById('episode-active').checked = true;
  document.querySelectorAll('.approach-checkbox').forEach(cb => cb.checked = false);
  this.populateGenreDropdown();
  this.state.editingEpisodeId = null;

  if (episode) {
    // ── EDIT mode: populate fields from existing episode ──
    document.getElementById('episode-modal-title').textContent = 'Edit Episode';
    this.state.editingEpisodeId = episode.id;

    if (episode.title)       document.getElementById('episode-title').value       = episode.title;
    if (episode.description) document.getElementById('episode-description').value = episode.description;
    if (typeof episode.active === 'boolean') {
      document.getElementById('episode-active').checked = episode.active;
    }
    if (episode.genre) {
      const genreSelect = document.getElementById('episode-genre');
      if (genreSelect) genreSelect.value = episode.genre;
    }
    if (Array.isArray(episode.approaches)) {
      document.querySelectorAll('.approach-checkbox').forEach(cb => {
        cb.checked = episode.approaches.includes(cb.value);
      });
    }

    // Load question banks, then pre-check the ones assigned to this episode
    this.loadQuestionBanksForEpisode(episode);

    // Initialize encounter editor with existing encounters
    const existingEncounters = (episode.encounters && episode.encounters.length > 0)
      ? episode.encounters
      : [];
    this.initEncounterEditor(existingEncounters);

    // ── Pre-populate cutscene settings ──────────────────────────
    const encEnabled  = document.getElementById('cutscene-encounters-enabled');
    const compEnabled = document.getElementById('cutscene-completion-enabled');
    const encCinema   = document.getElementById('enc-style-cinematic');
    const encNovel    = document.getElementById('enc-style-novel');
    const compCinema  = document.getElementById('comp-style-cinematic');
    const compNovel   = document.getElementById('comp-style-novel');

    if (encEnabled)  encEnabled.checked  = episode.cutsceneEncountersEnabled !== false;
    if (compEnabled) compEnabled.checked = episode.cutsceneCompletionEnabled !== false;

    const encStyle  = episode.encounterCutsceneStyle  || 'cinematic';
    const compStyle = episode.completionCutsceneStyle || 'graphic_novel';
    if (encCinema)  encCinema.checked  = encStyle  === 'cinematic';
    if (encNovel)   encNovel.checked   = encStyle  === 'graphic_novel';
    if (compCinema) compCinema.checked = compStyle === 'cinematic';
    if (compNovel)  compNovel.checked  = compStyle === 'graphic_novel';

  } else {
    // ── CREATE mode ──
    document.getElementById('episode-modal-title').textContent = 'Create Episode';
    this.loadQuestionBanksForEpisode();

    // Initialize encounter editor with one blank row
    this.initEncounterEditor([]);

    // Reset cutscene settings to defaults
    const encEnabled  = document.getElementById('cutscene-encounters-enabled');
    const compEnabled = document.getElementById('cutscene-completion-enabled');
    const encCinema   = document.getElementById('enc-style-cinematic');
    const compNovel   = document.getElementById('comp-style-novel');
    if (encEnabled)  encEnabled.checked  = true;
    if (compEnabled) compEnabled.checked = true;
    if (encCinema)   encCinema.checked   = true;
    if (compNovel)   compNovel.checked   = true;
  }

  this.openModal('episode-modal');
};

CMSApp.prototype.resetEpisodeModal = function() {
  document.getElementById('episode-title').value = '';
  document.getElementById('episode-description').value = '';
  document.getElementById('episode-active').checked = true;
  document.getElementById('episode-genre').value = '';
  document.querySelectorAll('.approach-checkbox').forEach(cb => cb.checked = false);
  const togglesContainer = document.getElementById('question-banks-toggles');
  if (togglesContainer) {
    togglesContainer.innerHTML = '<div class="loading-state" style="text-align:center;color:#6c757d;padding:20px;">Loading question banks...</div>';
  }
  // Reset encounter editor to one blank row
  this.initEncounterEditor([]);
  this.state.editingEpisodeId = null;
};

