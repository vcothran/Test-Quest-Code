  const descField = document.getElementById('q-bank-description');
  if (descField) descField.value = bank.description || '';
  document.getElementById('question-bank-modal-title').textContent = 'Edit Question Bank';
  this.state.editingBankId = bankId;
  this.openModal('question-bank-modal');
};

CMSApp.prototype.deleteQuestionBank = function(bankId) {
  const bank = this.state.questionBanks.find(b => b.id === bankId);
  const bankName = bank ? bank.name : 'this question bank';
  const qCount = bank && bank.questions ? bank.questions.length : 0;
  let msg = `Are you sure you want to delete "${bankName}"?`;
  if (qCount > 0) msg += `\n\nThis bank contains ${qCount} question${qCount !== 1 ? 's' : ''}.`;
  msg += '\n\nThis action cannot be undone.';
  if (!confirm(msg)) return;

  this.showProcessing('Deleting question bank...');
  this.deleteDoc(this.doc(this.db, 'questionBanks', bankId))
    .then(() => {
      this.showAlert('Question bank deleted.', 'success');
      this.loadQuestionBanks();
    })
    .catch(error => {
      console.error('❌ Error deleting bank:', error);
      this.showAlert('Error deleting question bank.', 'error');
    })
    .finally(() => { this.hideProcessing(); });
};

