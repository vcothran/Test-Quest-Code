<script>
CMSApp.prototype.loadAllData = function() {
  console.log('\u{1F504} Loading all data for Ultimate Parser CMS (Pure Firebase v9)...');
  return Promise.all([
    this.loadQuestionBanks(),
    this.loadEpisodes(),
    this.loadGenres()
  ]).then(() => {
    this.updateNavigationCounts();
    this.loadDashboardData();
    console.log('\u2705 All data loaded successfully (Pure Firebase v9)');
  }).catch(error => {
    console.error('\u274C Error loading data:', error);
    this.handleError(error, 'data loading');
  });
};

CMSApp.prototype.loadQuestionBanks = function() {
  return new Promise((resolve, reject) => {
    if (!this.elements.qBankList) { resolve(); return; }
    console.log('\u{1F504} Loading question banks (Pure Firebase v9)...');
    this.elements.qBankList.innerHTML = '<li class="loading-state">Loading question banks...</li>';
    const { collection, getDocs } = window.firebaseV9;
    try {
      getDocs(collection(this.db, 'questionBanks')).then(querySnapshot => {
        this.state.questionBanks = [];
        querySnapshot.forEach((doc) => {
          const data = doc.data();
          console.log('\u{1F4DA} Found question bank:', doc.id, data);
          this.state.questionBanks.push({ id: doc.id, ...data });
        });
        console.log('\u{1F4DA} Total question banks loaded:', this.state.questionBanks.length);
        this.displayQuestionBanks();
        this.populateAIImportBankSelect();
        resolve();
      }).catch(error => {
        console.error('\u274C Error loading question banks:', error);
        if (this.elements.qBankList) {
          this.elements.qBankList.innerHTML = '<li class="error-state">Error loading banks. Please refresh.</li>';
        }
        reject(error);
      });
    } catch (error) {
      console.error('\u274C Error creating collection reference:', error);
      reject(error);
    }
  });
};

CMSApp.prototype.displayQuestionBanks = function() {
  if (!this.elements.qBankList) return;
  if (this.state.questionBanks.length === 0) {
    this.elements.qBankList.innerHTML = '<li class="empty-state">No question banks found. Create one with Ultimate Parser!</li>';
    return;
  }
  this.elements.qBankList.innerHTML = this.state.questionBanks.map(bank => {
    const name = bank.name || 'Untitled Bank';
    const approach = bank.approach || 'General';
    const questions = Array.isArray(bank.questions) ? bank.questions : [];
    const questionCount = questions.length;
    const lastExtraction = bank.lastExtraction;
    return `
      <li class="cms-item">
        <div class="cms-item-content">
          <div class="cms-item-title">${name}</div>
          <div class="cms-item-meta">
            <span>\u{1F3AF} ${approach}</span>
            <span>\u{1F4CA} ${questionCount} questions</span>
            ${lastExtraction ? `<span>\u26A1 ${lastExtraction.testType || 'General'}</span>` : ''}
            ${questionCount > 0 ? '<span class="parser-badge" style="font-size:10px;padding:2px 6px;">\u26A1 ULTIMATE</span>' : ''}
          </div>
        </div>
        <div class="cms-item-actions">
          <button class="view-questions-btn cms-btn cms-btn-primary" data-id="${bank.id}" title="View/Edit Questions">\u{1F4DD} Questions (${questionCount})</button>
          <button class="edit-q-bank-btn" data-id="${bank.id}" title="Edit Bank">\u270F\uFE0F</button>
          <button class="delete-q-bank-btn" data-id="${bank.id}" title="Delete">\u{1F5D1}\uFE0F</button>
        </div>
      </li>
    `;
  }).join('');
  this.attachQuestionBankEventListeners();
  console.log('\u2705 Question banks displayed with correct counts');
};

CMSApp.prototype.attachQuestionBankEventListeners = function() {
  this.elements.qBankList.querySelectorAll('.view-questions-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const bankId = e.target.getAttribute('data-id') || e.target.closest('button').getAttribute('data-id');
      if (bankId) this.viewBankQuestions(bankId);
    });
  });
  this.elements.qBankList.querySelectorAll('.edit-q-bank-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const bankId = e.target.getAttribute('data-id') || e.target.closest('button').getAttribute('data-id');
      if (bankId) this.editQuestionBank(bankId);
    });
  });
