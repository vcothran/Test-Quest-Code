      const selectedBanks = episode.selectedQuestionBanks || [];
      const bankCount = selectedBanks.length;

      // FIX #3: Build tooltip with actual bank names
      const bankNames = selectedBanks.map(bankId => {
        const bank = this.state.questionBanks.find(b => b.id === bankId);
        return bank ? bank.name : bankId;
      });
      const tooltipText = bankNames.length > 0 ? bankNames.join('\n') : 'No banks assigned';

