CMSApp.prototype.openModal = function(modalId) {
  const modal = document.getElementById(modalId);
  if (modal) {
    modal.style.display = 'block';
    modal.classList.add('animate-fade-in');
    if (modalId === 'ai-import-modal') {
      this.prepareAIImportModal();
    }
    console.log(`📝 Modal opened: ${modalId}`);
  }
};

CMSApp.prototype.closeModal = function(modalId) {
  const modal = document.getElementById(modalId);
  if (modal) {
    modal.style.display = 'none';
    modal.classList.remove('animate-fade-in');
    this.resetModalContent(modalId);
    console.log(`❌ Modal closed: ${modalId}`);
  }
};

CMSApp.prototype.resetModalContent = function(modalId) {
  switch (modalId) {
    case 'ai-import-modal':     this.resetAIImportModal();     break;
    case 'question-bank-modal': this.resetQuestionBankModal(); break;
    case 'episode-modal':       this.resetEpisodeModal();       break;
    case 'genre-modal':         this.resetGenreModal();         break;
  }
};

CMSApp.prototype.resetAIImportModal = function() {
  if (this.elements.contentFileInput) this.elements.contentFileInput.value = '';
  if (this.elements.answerFileInput)  this.elements.answerFileInput.value = '';
  if (this.elements.contentPasteArea) this.elements.contentPasteArea.textContent = '';

  const contentPreview = document.getElementById('content-preview');
  const answerPreview  = document.getElementById('answer-preview');
  if (contentPreview) contentPreview.style.display = 'none';
  if (answerPreview)  answerPreview.style.display = 'none';

  if (this.elements.contentUploadArea) this.elements.contentUploadArea.classList.remove('has-content');
  if (this.elements.answerUploadArea)  this.elements.answerUploadArea.classList.remove('has-content');

  const frameworkCheckbox = document.getElementById('framework-mode-enable');
  if (frameworkCheckbox) frameworkCheckbox.checked = false;

  const advancedToggle   = document.getElementById('advanced-settings-toggle');
  const advancedSettings = document.getElementById('advanced-settings');
  if (advancedToggle)   advancedToggle.checked = false;
  if (advancedSettings) advancedSettings.style.display = 'none';

  this.state.contentFile = null;
  this.state.answerFile  = null;
  this.state.currentImportedDocument = null;

  this.hideProgress();
  console.log('🧹 AI Import modal reset');
};

CMSApp.prototype.prepareAIImportModal = function() {
  this.populateAIImportBankSelect();
  this.hideProgress();
  if (!this.parserReady) {
    this.showAlert('Ultimate Parser is not available. Please check Settings and add your API key.', 'warning');
  }
};

// ── QUESTION BANK MODAL ───────────────────────────

CMSApp.prototype.showQuestionBankModal = function() {
  document.getElementById('q-bank-name').value = '';
  document.getElementById('q-bank-approach').value = '';
  const descField = document.getElementById('q-bank-description');
  if (descField) descField.value = '';
