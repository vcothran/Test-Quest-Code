CMSApp.prototype.parseExtractedQuestionsV7 = function(extractedData, frameworkMode, answerKey) {
  console.log('🔍 Parsing questions V7...');
  
  try {
    const cleaned = this.cleanJSONResponse(extractedData);
    const parsed = JSON.parse(cleaned);
    
    let questions = frameworkMode 
      ? (parsed.originalQuestions || parsed.questions || [])
      : (parsed.extractedQuestions || parsed.questions || []);
    
    if (!Array.isArray(questions)) {
      throw new Error('Invalid format - questions is not an array');
    }
    
    console.log(`✅ Found ${questions.length} questions`);
    
    let mappedQuestions = questions.map((q, i) => {
      let correctAnswer = q.correctAnswer !== undefined ? q.correctAnswer : (q.correct !== undefined ? q.correct : 0);
      
      // Extract correct answer from explanation if framework mode
      if (frameworkMode && q.explanation) {
        const explainedAnswer = this.extractCorrectAnswerFromExplanation(q.explanation, q.options);
        if (explainedAnswer !== -1) {
          console.log(`🔍 Framework Q${i+1}: Explanation indicates ${explainedAnswer}, was ${correctAnswer}`);
          correctAnswer = explainedAnswer;
        }
      }
      
      return {
        text: q.text || q.question || '',
        options: q.options || [],
        correct: correctAnswer,
        explanation: q.explanation || '',
        testType: q.testType || parsed.testType || 'General',
        format: 'text',
        partialCredit: [],
        questionNumber: q.questionNumber || (i + 1),
        passageContext: q.passageContext || parsed.originalPassage || '',
        passageImages: [],
        questionImages: [],
        optionImages: {},
        frameworkGenerated: frameworkMode,
        confidence: q.confidence || 1.0
      };
    });
    
    console.log('📋 BEFORE answer key:', mappedQuestions.map(q => `Q${q.questionNumber}:${q.correct}`).join(', '));
    
    // Apply answer key override with ABSOLUTE PRIORITY
    if (answerKey && Object.keys(answerKey).length > 0) {
      console.log('🔑 ⚠️ APPLYING ANSWER KEY OVERRIDES');
      
      mappedQuestions = mappedQuestions.map(q => {
        const qNum = q.questionNumber;
        if (answerKey[qNum]) {
          const answerLetter = answerKey[qNum].toUpperCase();
          
          let answerIndex;
          if (['F', 'G', 'H', 'J'].includes(answerLetter)) {
            answerIndex = ['F', 'G', 'H', 'J'].indexOf(answerLetter);
          } else {
            answerIndex = answerLetter.charCodeAt(0) - 65;
          }
          
          console.log(`🔑 Q${qNum}: ${q.correct} → ${answerIndex} (${answerLetter})`);
          
          // FORCE override
          return { 
            ...q, 
            correct: answerIndex,
            answerKeyApplied: true
          };
        }
        return q;
      });
    }
    
    console.log('📋 AFTER answer key:', mappedQuestions.map(q => `Q${q.questionNumber}:${q.correct}`).join(', '));
    
    return mappedQuestions;
    
  } catch (error) {
    console.error('❌ Parse error:', error);
    throw new Error(`Failed to parse: ${error.message}`);
  }
};

// ===========================================
// EXTRACT CORRECT ANSWER FROM EXPLANATION
// ===========================================
CMSApp.prototype.extractCorrectAnswerFromExplanation = function(explanation, options) {
  if (!explanation || !options || options.length === 0) return -1;
  
  const patterns = [
    /([A-J])\s+is\s+(the\s+)?(correct|right)/i,
    /answer\s+is\s+([A-J])/i,
    /([A-J])\)\s+is\s+(correct|right)/i,
    /([A-J])\s+because/i
  ];
  
  for (const pattern of patterns) {
    const match = explanation.match(pattern);
    if (match) {
      const letter = match[1].toUpperCase();
      
      for (let i = 0; i < options.length; i++) {
        const optionText = options[i].trim();
        if (optionText.startsWith(letter + ')') || 
            optionText.startsWith(letter + '.') ||
            optionText.startsWith(letter + ' ')) {
          console.log(`✅ Extracted ${letter} (index ${i}) from explanation`);
          return i;
        }
      }
    }
  }
  
  return -1;
};

