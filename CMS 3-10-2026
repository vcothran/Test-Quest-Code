    </div>`;
  }).join('');

  const correctOptions = optionPairs.map(({letter}) =>
    `<option value="${letter}" ${letter === currentCorrectLetter ? 'selected' : ''}>${letter}</option>`
  ).join('');

  modalEl.innerHTML = `
    <div style="background:#ffffff;border-radius:10px;padding:30px;width:100%;max-width:680px;
                position:relative;box-shadow:0 8px 40px rgba(0,0,0,0.35);margin:auto;">

