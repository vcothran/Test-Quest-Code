                    title="${tooltipText}"
                    style="cursor:help; border-bottom: 1px dotted #666; position:relative;"
                    onmouseenter="window.cmsApp.showBankTooltip(this, '${episode.id}')"
                    onmouseleave="window.cmsApp.hideBankTooltip()">
                \u{1F4DA} ${bankCount} banks
              </span>
            </div>
          </div>
          <div class="cms-item-actions">
            <button class="edit-episode-btn" data-id="${episode.id}" title="Edit">\u270F\uFE0F</button>
            <button class="delete-episode-btn" data-id="${episode.id}" title="Delete">\u{1F5D1}\uFE0F</button>
