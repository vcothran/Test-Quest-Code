CMSApp.prototype.preserveMathNotationV7 = function(questions) {
  return questions.map(q => {
    if (q.testType !== 'Math' && q.testType !== 'Science') return q;
    
    return {
      ...q,
      text: this.convertMathNotationV7(q.text),
      options: (q.options || []).map(opt => this.convertMathNotationV7(opt)),
      passageContext: q.passageContext ? this.convertMathNotationV7(q.passageContext) : q.passageContext
    };
  });
};

CMSApp.prototype.convertMathNotationV7 = function(text) {
  if (!text) return text;
  
  let converted = text;
  
  const subscriptMap = {'0':'₀','1':'₁','2':'₂','3':'₃','4':'₄','5':'₅','6':'₆','7':'₇','8':'₈','9':'₉'};
  const superscriptMap = {'0':'⁰','1':'¹','2':'²','3':'³','4':'⁴','5':'⁵','6':'⁶','7':'⁷','8':'⁸','9':'⁹'};
  
  // Trig functions: cos2x → cos²x
  converted = converted.replace(/(sin|cos|tan)(\d)x/gi, (m, func, num) => 
    `${func}${superscriptMap[num] || `^${num}`}x`
  );
  
  // Variables: a1 → a₁
  converted = converted.replace(/\b([a-z])(\d)\b/gi, (m, letter, num) =>
    `${letter}${subscriptMap[num] || num}`
  );
  
  // Square root: ✓ → √
  converted = converted.replace(/✓/g, '√');
  converted = converted.replace(/sqrt\s*\(/gi, '√(');
  
  // Chemical: CO2 → CO₂
  converted = converted.replace(/CO2\b/g, 'CO₂');
  converted = converted.replace(/H2O\b/g, 'H₂O');
  
  // Log: log24 → log₂4
  converted = converted.replace(/log(\d)(\d)/g, (m, base, num) =>
    `log${subscriptMap[base]}${num}`
  );
  
  return converted;
};

// ===========================================
// FORMAT ENGLISH UNDERLINES
// ===========================================
CMSApp.prototype.formatEnglishUnderlines = function(questions) {
  return questions.map(q => {
    if (q.testType !== 'English' || !q.passageContext) return q;
    
    let formatted = q.passageContext;
    
    // Convert [Q61] → <u>word</u>₍₆₁₎
    formatted = formatted.replace(/(\w+)\[Q?(\d+)\]/g, '<u>$1</u><sub>[$2]</sub>');
    
    return { ...q, passageContext: formatted };
  });
};

