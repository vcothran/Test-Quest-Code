  if (style === 'custom') {
    customInput.style.display = 'block';
    preview.textContent = document.getElementById('new-class-custom-code').value || 'YOURCODE';
  } else {
    customInput.style.display = 'none';
    preview.textContent = style === 'lastname' ? generateLastNameCode() : generateRandomCode();
  }
};

window.refreshCodePreview = function() {
  const style = getCurrentCodeStyle();
  const preview = document.getElementById('code-preview');
  if (style === 'lastname') preview.textContent = generateLastNameCode();
