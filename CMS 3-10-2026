CMSApp.prototype.makeGeminiVisionCall = async function(textPrompt, contentData) {
  if (!this.geminiModel) throw new Error('Gemini model not initialized');
  
  let parts = [{ text: textPrompt }];
  
  if (contentData.contentType === 'image') {
    const imageDataArray = contentData.sourceImages || 
                          JSON.parse(contentData.mainContent.replace('[PDF_IMAGES:', '').replace(']', ''));
    
    for (const imageDataUrl of imageDataArray) {
      const base64Match = imageDataUrl.match(/data:([^;]+);base64,(.+)/);
      if (base64Match) {
        parts.push({ inlineData: { mimeType: base64Match[1], data: base64Match[2] }});
      }
    }
  }
  
  const result = await this.geminiModel.generateContent(parts);
  const response = await result.response;
  return response.text();
};

CMSApp.prototype.convertPDFToImages = function(pdfFile, testType) {
  const self = this;
  return new Promise((resolve, reject) => {
    if (typeof pdfjsLib === 'undefined') {
      reject(new Error('PDF.js not loaded'));
      return;
    }
    
    const reader = new FileReader();
    reader.onload = (e) => {
      const typedArray = new Uint8Array(e.target.result);
      
      pdfjsLib.getDocument(typedArray).promise.then(pdf => {
        let maxPages = testType === 'English' ? Math.min(pdf.numPages, 3) : Math.min(pdf.numPages, 2);
        
        console.log(`📄 Processing ${maxPages}/${pdf.numPages} pages (${testType})`);
        
        if (pdf.numPages > maxPages) {
          self.showAlert(`PDF has ${pdf.numPages} pages. Processing first ${maxPages} for ${testType}.`, 'info');
        }
        
        const imagePromises = [];
        
        for (let pageNum = 1; pageNum <= maxPages; pageNum++) {
          const pagePromise = pdf.getPage(pageNum).then(page => {
            const scale = 1.5;
            const viewport = page.getViewport({ scale });
            
            const canvas = document.createElement('canvas');
            const context = canvas.getContext('2d');
            canvas.height = viewport.height;
            canvas.width = viewport.width;
            
            return page.render({ canvasContext: context, viewport }).promise.then(() => {
              return canvas.toDataURL('image/jpeg', 0.85);
            });
          });
          
          imagePromises.push(pagePromise);
        }
        
        Promise.all(imagePromises).then(resolve).catch(reject);
      }).catch(reject);
    };
    
    reader.onerror = () => reject(new Error('Failed to read PDF'));
    reader.readAsArrayBuffer(pdfFile);
  });
};

CMSApp.prototype.getTextFromFile = function(fileObj, testType) {
  return new Promise((resolve, reject) => {
    const fileType = fileObj.type;
    const fileName = fileObj.name.toLowerCase();
    
    if (fileType === 'text/plain' || fileName.endsWith('.txt')) {
      const reader = new FileReader();
      reader.onload = (e) => resolve({ content: e.target.result, type: 'text' });
      reader.onerror = () => reject(new Error('Text read error'));
      reader.readAsText(fileObj);
      return;
    }
    
    if (fileType.startsWith('image/')) {
      const reader = new FileReader();
      reader.onload = (e) => {
        resolve({ content: '[PDF_IMAGES:' + JSON.stringify([e.target.result]) + ']', type: 'image' });
      };
      reader.onerror = () => reject(new Error('Image read error'));
      reader.readAsDataURL(fileObj);
      return;
    }
    
    if (fileType === 'application/pdf' || fileName.endsWith('.pdf')) {
      this.convertPDFToImages(fileObj, testType).then(imageDataArray => {
        resolve({ content: '[PDF_IMAGES:' + JSON.stringify(imageDataArray) + ']', type: 'image' });
      }).catch(reject);
      return;
    }
    
    reject(new Error(`Unsupported file type: ${fileType}`));
  });
};

CMSApp.prototype.cleanJSONResponse = function(text) {
  let cleaned = text.replace(/```json\s*/g, '').replace(/```\s*/g, '').trim();
  const jsonStart = cleaned.indexOf('{');
  const jsonEnd = cleaned.lastIndexOf('}');
  if (jsonStart !== -1 && jsonEnd !== -1) {
    cleaned = cleaned.substring(jsonStart, jsonEnd + 1);
  }
  return cleaned;
};

CMSApp.prototype.handleImportError = function(error) {
  let userMessage = 'Import failed: ';
  
  if (error.message.includes('quota') || error.message.includes('429')) {
    userMessage = '⚠️ API Quota/Rate Limit:\n\nWait 2-3 minutes\nUpload 1-3 pages only';
  } else if (error.message.includes('token count exceeds')) {
    userMessage = '⚠️ Content Too Large:\n\nUpload fewer pages';
  } else {
    userMessage = `❌ ${error.message}`;
  }
  
  this.showAlert(userMessage, 'error');
};

