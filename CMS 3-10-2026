  const uploadAreas = [
    { area: this.elements.contentUploadArea, input: this.elements.contentFileInput, type: 'content' },
    { area: this.elements.answerUploadArea,  input: this.elements.answerFileInput,  type: 'answer' }
  ];
  uploadAreas.forEach(({ area, input, type }) => {
    if (area && input) {
      ['dragenter','dragover','dragleave','drop'].forEach(ev => {
        area.addEventListener(ev, (e) => { e.preventDefault(); e.stopPropagation(); });
      });
      area.addEventListener('dragover',  () => area.classList.add('dragover'));
      area.addEventListener('dragleave', () => area.classList.remove('dragover'));
      area.addEventListener('drop', (e) => {
        area.classList.remove('dragover');
        if (e.dataTransfer.files.length > 0) this.handleFileSelection(e.dataTransfer.files[0], type);
      });
    }
  });
