CMSApp.prototype.validateQuestionSequence = function(questions) {
  const issues = [];
  const questionNumbers = questions.map(q => q.questionNumber).filter(n => n);
  
  if (questionNumbers.length === 0) return { valid: true, issues: [] };
  
  const duplicates = questionNumbers.filter((n, i) => questionNumbers.indexOf(n) !== i);
  if (duplicates.length > 0) {
    issues.push(`❌ Duplicate: ${[...new Set(duplicates)].join(', ')}`);
  }
  
  const sorted = [...questionNumbers].sort((a, b) => a - b);
  for (let i = 1; i < sorted.length; i++) {
    if (sorted[i] - sorted[i-1] > 1) {
      issues.push(`⚠️ Gap: ${sorted[i-1]} → ${sorted[i]}`);
    }
  }
  
  return { valid: issues.length === 0, issues };
};

CMSApp.prototype.detectMissingAnswers = function(questions) {
  return questions
    .filter(q => q.options && q.options.length > 0 && (q.correct === undefined || q.correct === null || q.correct < 0))
    .map(q => q.questionNumber || 'Unknown');
};

CMSApp.prototype.fixHyphenationImproved = function(questions) {
  return questions.map(q => ({
    ...q,
    text: this.cleanHyphenationImproved(q.text),
    options: (q.options || []).map(opt => this.cleanHyphenationImproved(opt)),
    passageContext: q.passageContext ? this.cleanHyphenationImproved(q.passageContext) : q.passageContext
  }));
};

CMSApp.prototype.cleanHyphenationImproved = function(text) {
  if (!text) return text;
  let cleaned = text.replace(/(\w+)-\s+([a-z])/g, '$1$2');
  cleaned = cleaned.replace(/(\w+)-\n([a-z])/g, '$1$2');
  cleaned = cleaned.replace(/(\w+)-\s{2,}([a-z])/g, '$1$2');
  return cleaned;
};

CMSApp.prototype.formatPassageLineNumbersImproved = function(questions) {
  return questions.map(q => {
    if (!q.passageContext) return q;
    
    let formatted = q.passageContext;
    formatted = formatted.replace(/(\n|^)\s*(\d{1,3})\s+([a-zA-Z])/g, (match, lineStart, num, nextChar) => {
      const number = parseInt(num);
      if (number % 5 === 0 && number >= 5 && number <= 100) {
        return `${lineStart}${num} ${nextChar}`;
      }
      return match;
    });
    
    return { ...q, passageContext: formatted };
  });
};

