  console.log('✅ Comparison view displayed');
};

// ===========================================
// RENDER EXTRACTED QUESTIONS (COMPACT)
// ===========================================
CMSApp.prototype.renderExtractedQuestionsCompact = function(questions, content) {
  return questions.map((q, index) => {
    const qNum = q.questionNumber || (index + 1);
    const confidence = q.confidence || 0;
    const hasPassage = q.passageContext && q.passageContext.length > 50;
    const testType = q.testType || 'General';
    
    // Determine if answer is missing
    const hasMissingAnswer = (q.correct === undefined || q.correct === null || q.correct < 0);
    
    return `
      <div style="background: white; border: 1px solid #dee2e6; border-radius: 4px; padding: 10px; margin-bottom: 8px; font-size: 13px;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
          <strong style="color: #495057;">Q${qNum}</strong>
          <div style="display: flex; gap: 4px; font-size: 11px;">
            ${testType !== 'General' ? 
              `<span style="background: #6c757d; color: white; padding: 2px 6px; border-radius: 8px;">${testType}</span>` : ''
            }
            ${confidence >= 0.8 ? 
              `<span style="background: #28a745; color: white; padding: 2px 6px; border-radius: 8px;">${(confidence * 100).toFixed(0)}%</span>` :
              `<span style="background: #ffc107; color: #000; padding: 2px 6px; border-radius: 8px;">⚠️ ${(confidence * 100).toFixed(0)}%</span>`
            }
            ${hasPassage ? 
              `<span style="background: #17a2b8; color: white; padding: 2px 6px; border-radius: 8px;">📖</span>` : ''
            }
            ${hasMissingAnswer ? 
              `<span style="background: #dc3545; color: white; padding: 2px 6px; border-radius: 8px;">❌ No Answer</span>` : ''
            }
          </div>
        </div>
        
        ${hasPassage ? `
          <details style="margin-bottom: 6px;">
            <summary style="cursor: pointer; color: #007bff; font-size: 12px; padding: 4px; background: #e7f3ff; border-radius: 3px;">
              📖 ${testType === 'Reading' ? 'Passage' : 'Context'} (${q.passageContext.length} chars)
            </summary>
            <div style="margin-top: 6px; padding: 8px; background: #f8f9fa; border-left: 3px solid #007bff; max-height: 200px; overflow-y: auto;">
              <pre style="white-space: pre-wrap; font-family: ${testType === 'Reading' ? "'Georgia', serif" : 'monospace'}; font-size: 12px; line-height: 1.6; margin: 0;">${this.escapeHtml(q.passageContext)}</pre>
            </div>
          </details>
        ` : ''}
        
        <p style="margin: 6px 0; font-size: 13px; line-height: 1.5;"><strong>${this.escapeHtml(q.text)}</strong></p>
        
        ${q.options && q.options.length > 0 ? `
          <div style="margin: 6px 0;">
            ${q.options.map((opt, i) => {
              const isCorrect = i === (q.correct || q.correctAnswer || -1);
              return `
                <div style="padding: 4px 8px; margin: 3px 0; background: ${isCorrect ? '#d4edda' : '#f8f9fa'}; border-left: 3px solid ${isCorrect ? '#28a745' : '#dee2e6'}; border-radius: 3px; font-size: 12px; line-height: 1.4;">
                  ${this.escapeHtml(opt)} ${isCorrect ? '<strong style="color: #28a745;">✓</strong>' : ''}
                </div>
              `;
            }).join('')}
          </div>
        ` : ''}
        
        ${hasMissingAnswer ? `
          <div style="margin-top: 6px; padding: 6px; background: #f8d7da; border-left: 3px solid #dc3545; border-radius: 3px; font-size: 11px; color: #721c24;">
            ⚠️ <strong>Warning:</strong> This question does not have a correct answer marked. Please verify the answer key.
          </div>
        ` : ''}
        
      </div>
    `;
  }).join('');
};

// ===========================================
// ESCAPE HTML (PREVENT XSS)
// ===========================================
CMSApp.prototype.escapeHtml = function(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
};

// ===========================================
// RENDER SOURCE CONTENT (ZOOMABLE)
// ===========================================
CMSApp.prototype.renderSourceContentZoomable = function(content) {
  if (content.contentType === 'image' && content.sourceImages) {
    return content.sourceImages.map((img, index) => `
      <div style="margin-bottom: 15px;">
        <h4 style="color: #495057; margin: 0 0 8px 0; font-size: 14px;">Page ${index + 1}</h4>
        <img src="${img}" style="max-width: 100%; border: 2px solid #dee2e6; border-radius: 4px; display: block;" alt="Source page ${index + 1}" />
      </div>
    `).join('');
  } else if (content.contentType === 'text') {
    return `<pre style="white-space: pre-wrap; font-family: monospace; font-size: 13px; line-height: 1.5; margin: 0;">${this.escapeHtml(content.mainContent)}</pre>`;
  }
  
  return '<p style="color: #6c757d; font-size: 13px;">Source not available</p>';
};

// ===========================================
// ZOOM SOURCE CONTENT
// ===========================================
CMSApp.prototype.zoomSource = function(change) {
  const display = document.getElementById('source-content-display');
  if (!display) return;
  
  if (change === 'reset') {
    this.sourceZoomLevel = 1.0;
  } else {
    this.sourceZoomLevel = Math.max(0.5, Math.min(3.0, this.sourceZoomLevel + change));
  }
  
  display.style.transform = `scale(${this.sourceZoomLevel})`;
  
  console.log('🔍 Zoom level:', this.sourceZoomLevel);
};

// ===========================================
// CONFIRM CLOSE WITH PROTECTION
// ===========================================
CMSApp.prototype.confirmCloseComparison = function() {
  const confirmed = confirm(
    '⚠️ Cancel Import?\n\n' +
    'All extracted questions will be lost.\n\n' +
    'Are you sure?'
  );
  
  if (confirmed) {
    this.closeComparisonView(false);
  }
};

CMSApp.prototype.handleComparisonClose = function() {
  this.confirmCloseComparison();
};

// ===========================================
// CLOSE COMPARISON VIEW
// ===========================================
CMSApp.prototype.closeComparisonView = function(confirmed) {
  const modal = document.getElementById('comparison-view-modal');
  if (modal) {
    modal.remove();
  }
  
  if (!confirmed) {
    this.state.lastExtraction = null;
    this.hideProgress();
    this.showAlert('Import cancelled.', 'info');
  }
};

// ===========================================
// CONFIRM AND SAVE EXTRACTION
// ===========================================
CMSApp.prototype.confirmAndSaveExtraction = async function() {
  console.log('✅ User confirmed extraction, saving...');
  
  if (!this.state.lastExtraction) {
    this.showAlert('No extraction data found.', 'error');
    return;
  }
  
  const { questions, bankId, settings, frameworkMode } = this.state.lastExtraction;
  
  this.closeComparisonView(true);
  this.updateProgress(85, 'Saving confirmed questions...');
  
  try {
    await this.finalizeImport(bankId, questions, settings, frameworkMode);
  } catch (error) {
    console.error('❌ Error finalizing import:', error);
    this.showAlert('Error saving questions: ' + error.message, 'error');
  }
};

