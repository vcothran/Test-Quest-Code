  return result;
};

// ===========================================
// TEST TYPE DETECTION
// ===========================================
CMSApp.prototype.detectTestType = function(content) {
  const contentLower = content.toLowerCase();
  
  if (contentLower.includes('passage') || contentLower.includes('line') || contentLower.includes('author')) {
    return 'Reading';
  }
  if (contentLower.includes('equation') || contentLower.includes('calculate') || contentLower.includes('solve')) {
    return 'Math';
  }
  if (contentLower.includes('grammar') || contentLower.includes('underlined') || contentLower.includes('sentence')) {
    return 'English';
  }
  if (contentLower.includes('data') || contentLower.includes('experiment') || contentLower.includes('hypothesis')) {
    return 'Science';
  }
  
  return 'General';
};

// ===========================================
// BUILD EXTRACTION PROMPT
// ===========================================
CMSApp.prototype.buildExtractionPrompt = function(content, testType, settings) {
  const basePrompt = `
You are an expert ACT test question extractor. Extract all questions from the following ${testType} test content.

**CRITICAL INSTRUCTIONS:**
1. Extract EVERY question you find
2. Preserve exact question text
3. Keep all answer options exactly as written
4. Identify the correct answer (0=A, 1=B, 2=C, 3=D, 4=E)
5. Include explanations if present

**TEST TYPE:** ${testType}
**EXPECTED QUESTIONS:** ${settings.expectedQuestions || 'auto-detect'}

**CONTENT:**
${content}

**REQUIRED OUTPUT FORMAT - MUST BE VALID JSON:**
{
  "testType": "${testType}",
  "extractedQuestions": [
    {
      "questionNumber": 1,
      "text": "question text",
      "options": ["A) option 1", "B) option 2", "C) option 3", "D) option 4"],
      "correctAnswer": 0,
      "explanation": "explanation",
      "testType": "${testType}"
    }
  ]
}

Return ONLY valid JSON, no markdown, no extra text.`;

  return basePrompt;
};

// ===========================================
// CLEAN JSON RESPONSE
// ===========================================
CMSApp.prototype.cleanJSONResponse = function(text) {
  console.log('🧹 Cleaning JSON response...');
  
  let cleaned = text.replace(/```json\s*/g, '').replace(/```\s*/g, '');
  cleaned = cleaned.trim();
  
  const jsonStart = cleaned.indexOf('{');
  const jsonEnd = cleaned.lastIndexOf('}');
  
  if (jsonStart !== -1 && jsonEnd !== -1 && jsonEnd > jsonStart) {
    cleaned = cleaned.substring(jsonStart, jsonEnd + 1);
  }
  
  console.log('✅ JSON cleaned, length:', cleaned.length);
  return cleaned;
};

