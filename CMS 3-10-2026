window.openStudentModal = function(student) {
  if (!student) return;
  document.getElementById('student-modal-name').textContent     = student.name;
  document.getElementById('student-modal-xp').textContent       = student.xp || 0;
  document.getElementById('student-modal-level').textContent    = student.level || 1;
  document.getElementById('student-modal-episodes').textContent = student.progressData.filter(p => p.completed).length;
  const avgAcc = student.progressData.reduce((s, p) => s + (p.accuracy || 0), 0) / (student.progressData.length || 1);
  document.getElementById('student-modal-accuracy').textContent = Math.round(avgAcc * 100) + '%';

  const chart = document.getElementById('student-modal-chart');
  chart.innerHTML = '';
  [...student.progressData]
    .sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp))
    .forEach(data => {
      const bar = document.createElement('div');
      bar.style.cssText = 'flex:1; background:linear-gradient(180deg,#667eea,#764ba2); height:' + (data.accuracy * 200) + 'px; border-radius:4px 4px 0 0; position:relative; min-width:40px;';
      const label = document.createElement('div');
      label.style.cssText = 'position:absolute; bottom:-25px; left:50%; transform:translateX(-50%); font-size:11px; color:#666; white-space:nowrap;';
      label.textContent = Math.round(data.accuracy * 100) + '%';
      bar.appendChild(label);
      chart.appendChild(bar);
    });

  const struggling = student.progressData.filter(p => p.accuracy < 0.75);
  const sEl = document.getElementById('student-modal-struggling');
  sEl.innerHTML = '<h3 style="margin-bottom:15px;">Topics Needing Attention</h3>' +
    (struggling.length === 0
      ? '<p style="color:#28a745;">No struggling topics — great work!</p>'
      : struggling.map(d =>
          '<div style="background:#fff3cd; padding:15px; border-radius:8px; margin-bottom:10px; display:flex; justify-content:space-between;">' +
          '<span style="font-weight:600; color:#856404;">' + d.episodeName + '</span>' +
          '<span style="color:#856404; font-weight:600;">' + Math.round(d.accuracy * 100) + '% accuracy</span></div>'
        ).join(''));

  const history = document.getElementById('student-modal-history');
  const sorted  = [...student.progressData].sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
