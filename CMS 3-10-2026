};

CMSApp.prototype.initializeFirebaseV9 = function() {
  console.log('\u{1F525} Initializing Firebase v9 with modular SDK...');
  try {
    if (!window.firebaseV9) throw new Error('Firebase v9 SDK not loaded. Check your imports.');
    const { initializeApp, getFirestore, getStorage, getAuth, onAuthStateChanged } = window.firebaseV9;
    this.firebaseApp = initializeApp(FIREBASE_CONFIG);
    console.log('\u2705 Firebase v9 app initialized');
    this.db = getFirestore(this.firebaseApp);
    console.log('\u2705 Firestore v9 initialized');
    this.storage = getStorage(this.firebaseApp);
    console.log('\u2705 Storage v9 initialized');
    try {
      const auth = getAuth(this.firebaseApp);
      this.firebaseAuth = auth;
      onAuthStateChanged(auth, (user) => {
        if (user) {
          this.state.currentUser = {
            uid: user.uid,
            name: user.displayName || '',
            displayName: user.displayName || '',
            email: user.email || ''
          };
          console.log('\u2705 CMS teacher identified:', user.displayName || user.email);

          // User is confirmed signed in — safe to call Cloud Function now
          // Small delay to ensure Firebase Auth token is fully propagated
          setTimeout(() => {
            user.getIdToken(true).then(() => {
              return this.fetchTeacherApiKey();
            }).then(key => {
              if (key) {
                window.GEMINI_API_KEY = key;
                console.log('\u2705 Gemini API key upgraded from Cloud Function');
                if (this.ultimateParser) this.ultimateParser.apiKey = key;
                if (this.genAI) {
                  try {
                    const { GoogleGenerativeAI } = window;
                    if (GoogleGenerativeAI) this.genAI = new GoogleGenerativeAI(key);
                  } catch(e) {}
                }
              }
            }).catch(e => console.warn('Could not upgrade to Cloud Function key:', e));
          }, 2500);

        } else {
          this.state.currentUser = null;
          console.log('\u2139\uFE0F No auth user in CMS');
        }
      });
    } catch (authError) {
      console.warn('\u26A0\uFE0F Auth state listener failed (non-blocking):', authError);
    }
    this.setupFirebaseV9Utils();
    this.firebaseReady = true;
    console.log('\u2705 Firebase v9 initialization complete');
  } catch (error) {
    console.error('\u274C Firebase v9 initialization failed:', error);
    this.firebaseReady = false;
    throw new Error(`Firebase v9 initialization failed: ${error.message}`);
  }
};

CMSApp.prototype.setupFirebaseV9Utils = function() {
  console.log('\u{1F6E0}\uFE0F Setting up Firebase v9 utilities...');
  const {
    doc, getDoc, getDocs, addDoc, updateDoc, deleteDoc,
    serverTimestamp, collection, query, where, orderBy, limit,
    ref, uploadBytes, getDownloadURL
  } = window.firebaseV9;
  this._v9Functions = {
    doc, getDoc, getDocs, addDoc, updateDoc, deleteDoc,
    serverTimestamp, collection, query, where, orderBy, limit,
    ref, uploadBytes, getDownloadURL
  };
  this.setupUtilityWrappers();
  console.log('\u2705 Firebase v9 utilities configured');
};

CMSApp.prototype.setupUtilityWrappers = function() {
  console.log('\u{1F527} Setting up utility wrappers...');
  this.collection = (pathOrDb, collectionPath) => {
    if (typeof pathOrDb === 'string') return this._v9Functions.collection(this.db, pathOrDb);
    else if (collectionPath && typeof collectionPath === 'string') return this._v9Functions.collection(pathOrDb, collectionPath);
    else throw new Error('Collection requires a string path');
  };
  this.doc = (dbOrPath, pathOrId, docId) => {
    if (typeof dbOrPath === 'string' && pathOrId && typeof pathOrId === 'string') return this._v9Functions.doc(this.db, dbOrPath, pathOrId);
    else if (typeof dbOrPath === 'string' && !pathOrId) return this._v9Functions.doc(this.db, dbOrPath);
    else if (pathOrId && typeof pathOrId === 'string' && docId && typeof docId === 'string') return this._v9Functions.doc(dbOrPath, pathOrId, docId);
    else if (pathOrId && typeof pathOrId === 'string' && !docId) return this._v9Functions.doc(dbOrPath, pathOrId);
    else throw new Error('Document requires valid path parameters');
  };
  this.addDoc         = (ref, data)           => this._v9Functions.addDoc(ref, data);
  this.updateDoc      = (ref, data)           => this._v9Functions.updateDoc(ref, data);
  this.deleteDoc      = (ref)                 => this._v9Functions.deleteDoc(ref);
  this.getDocs        = (ref)                 => this._v9Functions.getDocs(ref);
  this.getDoc         = (ref)                 => this._v9Functions.getDoc(ref);
  this.query          = (ref, ...constraints) => this._v9Functions.query(ref, ...constraints);
  this.where          = (f, op, val)          => this._v9Functions.where(f, op, val);
  this.orderBy        = (f, dir)              => this._v9Functions.orderBy(f, dir);
  this.limit          = (n)                   => this._v9Functions.limit(n);
  this.serverTimestamp = ()                   => this._v9Functions.serverTimestamp();
  this.ref            = (path)                => this._v9Functions.ref(this.storage, path);
  this.uploadBytes    = (ref, bytes)          => this._v9Functions.uploadBytes(ref, bytes);
  this.getDownloadURL = (ref)                 => this._v9Functions.getDownloadURL(ref);
  console.log('\u2705 Utility wrappers configured');
};

