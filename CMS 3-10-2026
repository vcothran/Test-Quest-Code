async function ensureTeacherLicense() {
  const app = window.cmsApp;
  const currentUser = app ? app.state.currentUser : null;
  if (!currentUser || !currentUser.uid) return;
  const db = getDB();
  if (!db) return;

  const { doc, getDoc, setDoc } = window.firebaseV9;
  try {
    const userRef = doc(db, 'users', currentUser.uid);
    const snap = await getDoc(userRef);
    const data = snap.exists() ? snap.data() : {};
    if (!data.license) {
      // setDoc with merge:true creates the doc if missing, updates if exists
