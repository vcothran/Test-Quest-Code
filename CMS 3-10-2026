window.loadTeacherClasses = async function() {
  console.log('🏫 Loading teacher classes...');

  // Wait for firebaseV9 to be fully populated
  if (!window.firebaseV9 || !window.firebaseV9.collection) {
    console.warn('⚠️ firebaseV9 not ready, retrying in 500ms...');
    setTimeout(window.loadTeacherClasses, 500);
    return;
  }

  // Wait for auth user
  const currentUser = window.cmsApp ? window.cmsApp.state.currentUser : null;
  if (!currentUser) {
    console.warn('⚠️ No current user yet, retrying in 500ms...');
    setTimeout(window.loadTeacherClasses, 500);
    return;
  }

  document.getElementById('classes-loading').style.display = 'block';
  document.getElementById('classes-empty').style.display = 'none';
  document.getElementById('classes-list').innerHTML = '';

  const teacherId = currentUser.uid || currentUser.id || 'test-teacher';
  const db = window.cmsApp.db;

  const { collection, query, where, orderBy, getDocs } = window.firebaseV9;

  try {
    let snapshot;
    try {
      const q = query(
        collection(db, 'classes'),
        where('teacherId', '==', teacherId),
        orderBy('createdAt', 'desc')
      );
      snapshot = await getDocs(q);
    } catch (e) {
      console.warn('⚠️ orderBy failed (index missing?), trying without sort:', e);
      const q2 = query(
        collection(db, 'classes'),
        where('teacherId', '==', teacherId)
      );
      snapshot = await getDocs(q2);
    }
    teacherClasses = snapshot.docs.map(d => ({ id: d.id, ...d.data() }));
    console.log('✅ Loaded', teacherClasses.length, 'classes from Firebase');
  } catch (e) {
    console.warn('Could not load classes from Firebase:', e);
