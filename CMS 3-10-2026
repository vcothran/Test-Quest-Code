CMSApp.prototype.handleQuestionBankSubmit = function() {
  const name = document.getElementById('q-bank-name').value.trim();
  const approach = document.getElementById('q-bank-approach').value;
  const descField = document.getElementById('q-bank-description');
  const description = descField ? descField.value.trim() : '';
  if (!name || !approach) { this.showAlert('Please fill in all required fields.', 'error'); return; }
  this.showProcessing(this.state.editingBankId ? 'Updating question bank...' : 'Creating question bank...');
  const bankData = { name, approach, description, updatedAt: this.serverTimestamp() };
  const promise = this.state.editingBankId
    ? this.updateDoc(this.doc(this.db, 'questionBanks', this.state.editingBankId), bankData)
    : this.addDoc(this.collection(this.db, 'questionBanks'), {
        ...bankData, questions: [], createdAt: this.serverTimestamp(), createdWith: 'Ultimate Parser CMS v2.3'
      });
  promise.then(() => {
    this.showAlert(this.state.editingBankId ? 'Question bank updated!' : 'Question bank created!', 'success');
    this.closeModal('question-bank-modal');
    this.loadQuestionBanks();
    this.state.editingBankId = null;
    // Restore pending import if any
    if (this.state.pendingImport) {
      setTimeout(() => {
        this.showAlert('Question bank created! Reopening AI Import with your content...', 'success');
        setTimeout(() => {
          this.state.contentFile = this.state.pendingImport.contentFile;
          this.state.answerFile = this.state.pendingImport.answerFile;
          this.showQuickImport();
          setTimeout(() => {
            if (this.state.contentFile) {
              this.elements.contentUploadArea.classList.add('has-content');
              const contentPreview = document.getElementById('content-preview');
              const contentFileName = document.getElementById('content-file-name');
              if (contentPreview) contentPreview.style.display = 'block';
              if (contentFileName) contentFileName.textContent = this.state.contentFile.name;
            }
            if (this.state.pendingImport.contentText && this.elements.contentPasteArea) {
              this.elements.contentPasteArea.textContent = this.state.pendingImport.contentText;
            }
            const frameworkCheckbox = document.getElementById('framework-mode-enable');
            if (frameworkCheckbox && this.state.pendingImport.frameworkMode) frameworkCheckbox.checked = true;
            this.state.pendingImport = null;
            console.log('✅ Import state restored successfully');
          }, 500);
        }, 1000);
      }, 500);
    }
  }).catch(error => {
    console.error('Error saving question bank:', error);
    this.showAlert('Error saving question bank.', 'error');
  }).finally(() => { this.hideProcessing(); });
};

// ⭐ EPISODES WITH ENCOUNTERS ARRAY ⭐
CMSApp.prototype.handleEpisodeSubmit = function() {
  const title = document.getElementById('episode-title').value.trim();
  const genre = document.getElementById('episode-genre').value;
  const description = document.getElementById('episode-description').value.trim();
  const active = document.getElementById('episode-active').checked;
  const selectedApproaches = [];
  document.querySelectorAll('.approach-checkbox:checked').forEach(cb => selectedApproaches.push(cb.value));
  const selectedQuestionBanks = this.getSelectedQuestionBanks();
  if (!title || !genre) { this.showAlert('Please fill in all required fields.', 'error'); return; }
  if (selectedApproaches.length === 0) { this.showAlert('Please select at least one available approach.', 'error'); return; }
  this.showProcessing(this.state.editingEpisodeId ? 'Updating episode...' : 'Creating episode...');
  const episodeData = {
    title, genre, description, active,
    availableApproaches: selectedApproaches,
    selectedQuestionBanks: selectedQuestionBanks,
    encounters: [{
      narrative: description || `Welcome to ${title}! Prepare yourself for the challenges ahead.`,
      qCount: 75
    }],
    updatedAt: this.serverTimestamp()
  };
  const promise = this.state.editingEpisodeId
    ? this.updateDoc(this.doc(this.db, 'episodes', this.state.editingEpisodeId), episodeData)
    : this.addDoc(this.collection(this.db, 'episodes'), {
        ...episodeData, createdAt: this.serverTimestamp(), createdWith: 'Ultimate Parser CMS v2.3'
      });
  promise.then(() => {
    this.showAlert(`Episode ${this.state.editingEpisodeId ? 'updated' : 'created'} with ${selectedQuestionBanks.length} question banks!`, 'success');
    this.closeModal('episode-modal');
    this.loadEpisodes();
    this.state.editingEpisodeId = null;
  }).catch(error => {
    console.error('Error saving episode:', error);
    this.showAlert('Error saving episode.', 'error');
  }).finally(() => { this.hideProcessing(); });
};

