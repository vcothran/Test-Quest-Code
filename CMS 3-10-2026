          <h2 style="color:#333; font-size:22px; margin-bottom:4px;">📚 Assign Episodes</h2>
          <div style="font-size:13px; color:#999;">Class: <strong style="color:#667eea;">${cls.name}</strong> · Code: <strong style="font-family:monospace;">${cls.joinCode}</strong></div>
        </div>
        <button onclick="closeAssignModal()" style="background:none; border:none; font-size:28px; color:#999; cursor:pointer;">×</button>
      </div>
      <div style="padding:24px 28px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
          <span style="font-size:14px; color:#666;">${allEpisodes.length} episode${allEpisodes.length !== 1 ? 's' : ''} available</span>
          <div style="display:flex; gap:8px;">
            <button onclick="toggleAllEpisodes(true)" style="background:none; border:1px solid #667eea; color:#667eea; border-radius:6px; padding:5px 12px; cursor:pointer; font-size:12px;">Select All</button>
            <button onclick="toggleAllEpisodes(false)" style="background:none; border:1px solid #e0e0e0; color:#666; border-radius:6px; padding:5px 12px; cursor:pointer; font-size:12px;">Clear All</button>
