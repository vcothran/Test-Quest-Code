window.exportStudentReport = function() {
  if (reportsAllStudents.length === 0) {
    if (window.cmsApp) window.cmsApp.showAlert('No student data to export.', 'error');
    return;
  }
  const cls = teacherClasses.find(c => c.id === currentReportsClassId);
  let csv = 'Class,' + (cls ? cls.name : 'Unknown') + '\n';
  csv += 'Name,Email,Episodes Completed,Overall Accuracy,Status\n';
  reportsAllStudents.forEach(student => {
    const completed = student.progressData.filter(p => p.completed).length;
    const total     = student.progressData.length || 1;
    const accuracy  = Math.round(student.progressData.reduce((s, p) => s + (p.accuracy || 0), 0) / total * 100);
    const status    = accuracy >= 90 ? 'Excellent' : accuracy >= 75 ? 'Good' : accuracy >= 60 ? 'Fair' : 'Needs Help';
    csv += student.name + ',' + (student.email || '') + ',' + completed + '/' + total + ',' + accuracy + '%,' + status + '\n';
  });
  const blob = new Blob([csv], { type: 'text/csv' });
  const url  = window.URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = 'class-report-' + (cls ? cls.name.replace(/\s+/g, '-') : 'export') + '-' +
    new Date().toISOString().split('T')[0] + '.csv';
  a.click();
};

