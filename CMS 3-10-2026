CMSApp.prototype.handleFileSelection = function(file, type) {
  console.log(`\u{1F4E4} File selected (${type}):`, file.name, file.type, file.size);
  if (type === 'content') {
    this.state.contentFile = file;
    this.state.currentImportedDocument = file;
    if (this.elements.contentPasteArea) this.elements.contentPasteArea.textContent = '';
    const fileName = document.getElementById('content-file-name');
    const preview  = document.getElementById('content-preview');
    if (fileName) fileName.textContent = file.name;
    if (preview)  preview.style.display = 'block';
    this.elements.contentUploadArea.classList.add('has-content');
  } else if (type === 'answer') {
    this.state.answerFile = file;
    const fileName = document.getElementById('answer-file-name');
    const preview  = document.getElementById('answer-preview');
    if (fileName) fileName.textContent = file.name;
    if (preview)  preview.style.display = 'block';
    this.elements.answerUploadArea.classList.add('has-content');
  }
  this.showFileTypeMessage(file);
};

CMSApp.prototype.showFileTypeMessage = function(file) {
  const fileName = file.name.toLowerCase();
  let message = '';
  if (fileName.endsWith('.pdf')) message = '\u{1F4C4} PDF uploaded - Ultimate Parser will process first 3 pages automatically';
  else if (fileName.match(/\.(jpg|jpeg|png|gif|webp)$/)) message = '\u{1F5BC}\uFE0F Image uploaded - Ultimate Parser will extract questions using OCR';
  else if (fileName.endsWith('.txt')) message = '\u{1F4DD} Text file uploaded - Ultimate Parser will analyze content directly';
