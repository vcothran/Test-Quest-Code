CMSApp.prototype.makeEnhancedAPICall = async function(prompt, operation = 'API Call', retryEnabled = true) {
  console.log(`📞 Making ${operation}...`);
  console.log(`🎯 Using model: ${this.currentModelName}`);
  
  if (!this.geminiModel) {
