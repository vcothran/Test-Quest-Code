CMSApp.prototype.extractAnswerKeyFromText = function(text) {
  console.log('📋 Checking for answer key in text...');
  
  const patterns = [
    /(\d+)\.\s*([A-K])/gi,
    /(\d+)\)\s*([A-K])/gi,
    /(\d+):\s*([A-K])/gi,
    /Question\s+(\d+):\s*([A-K])/gi,
    /(\d+)\s*-\s*([A-K])/gi,
    /(\d+)\s+([A-K])\b/gi
  ];
  
  const answers = {};
  
  for (const pattern of patterns) {
    const matches = text.matchAll(pattern);
    for (const match of matches) {
      const questionNum = parseInt(match[1]);
      const answer = match[2].toUpperCase();
      answers[questionNum] = answer;
    }
  }
  
  if (Object.keys(answers).length > 0) {
    console.log(`✅ Found ${Object.keys(answers).length} answers:`, answers);
    return answers;
  }
  
  return null;
};

