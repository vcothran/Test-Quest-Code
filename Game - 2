            break;
            
          case 'tacticalAnalysis': {
            if (!q || !q.options) {
              showNotification('Tactical Analysis unavailable for this question type.', 'focus-loss');
              break;
            }
            const wrongAnswers = [];
            // Handle both array format and object format {A:..., B:..., C:..., D:...}
            if (Array.isArray(q.options)) {
              q.options.forEach((opt, index) => {
                if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                  wrongAnswers.push(index);
                }
              });
            } else {
              Object.keys(q.options).forEach((key, index) => {
                if (key !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                  wrongAnswers.push(index);
                }
              });
            }

            // warCouncil (Strategist L10) — eliminate 3 instead of 2
            const tacticalCount = upgrades.tier2 === 'warCouncil' ? 3 : 2;

            if (wrongAnswers.length < tacticalCount) {
              const confirmUse = confirm(`Only ${wrongAnswers.length} incorrect answer(s) remain. Use Tactical Analysis anyway?`);
              if (!confirmUse) return;
            }

            deductUse(abilityKey);
            // tacticalReload (Strategist L5) — restore +1 use per episode (tracked via flag)
            if (upgrades.tier1 === 'tacticalReload' && !player.activeEffects.tacticalReloadUsed) {
              player.activeEffects.tacticalReloadUsed = true;
              player.abilities.tacticalAnalysis.uses++;
              showNotification('Tactical Reload: +1 use restored!', 'ability-used');
            }

            const toEliminate = wrongAnswers.slice(0, tacticalCount);
            toEliminate.forEach(idx => {
              if (!player.activeEffects.eliminatedAnswers.includes(idx)) {
                player.activeEffects.eliminatedAnswers.push(idx);
              }
            });
            applyEliminatedAnswers();
            feedbackMessage = `Tactical Analysis eliminates ${toEliminate.length} wrong answer(s)!`;
            break;
          }
            
          case 'empoweredSpell':
            deductUse(abilityKey);
            
            const questionText = (q.text || '').toLowerCase();
            const hasMathKeywords = questionText.includes('calculate') || 
                                    questionText.includes('equation') || 
                                    questionText.includes('solve') ||
                                    questionText.includes('formula') ||
                                    questionText.includes('equals') ||
                                    /\d+[\+\-\*\/×÷]\d+/.test(questionText) ||
                                    questionText.includes('percent') ||
                                    questionText.includes('average');
            const isMath = selectedApproach === 'Calculation (Math)' || 
                           q.format === 'math' || 
                           hasMathKeywords;

            // arcaneBoost (Arcanist L5) — works on any question type with 1 charge
            const boostAnyType = upgrades.tier1 === 'arcaneBoost';
            
            if (isMath || boostAnyType) {
              selectedAnswerIndex = q.correct;
              highlightCorrectAnswer();
              // overcharge (Arcanist L10) — double XP persists for 2 questions
              if (upgrades.tier2 === 'overcharge') {
                player.activeEffects.doubleXPNext = true;
                player.activeEffects.doubleXPDuration = 2;
                player.activeEffects.bonusXP = 2;
                feedbackMessage = 'Empowered Spell + Overcharge: Answer revealed, double XP for next 2 questions!';
              } else {
                player.activeEffects.doubleXPNext = true;
                feedbackMessage = boostAnyType
                  ? 'Arcane Boost: Power flows through you!'
                  : 'Empowered Spell: Mathematical knowledge flows through you!';
              }
            } else {
              if (player.abilities.empoweredSpell.uses >= 1) {
                if (player.abilities.empoweredSpell.uses > 0) player.abilities.empoweredSpell.uses--;
                selectedAnswerIndex = q.correct;
                highlightCorrectAnswer();
                feedbackMessage = 'Empowered Spell (2x charge): Arcane power reveals the answer!';
              } else {
                player.abilities.empoweredSpell.uses++;
                feedbackMessage = 'Empowered Spell needs 2 charges for non-math questions. (Only 1 charge for math)';
              }
            }
            break;
            
          case 'arcaneKnowledge':
            deductUse(abilityKey);
            // omniscience (Arcanist L10) — reveals correct answer directly
            if (upgrades.tier2 === 'omniscience') {
              selectedAnswerIndex = q.correct;
              highlightCorrectAnswer();
              feedbackMessage = 'Omniscience: The correct answer is revealed!';
            } else {
              // knowledgeExpanded (Arcanist L5) — eliminates 2 wrong answers instead of hinting
              if (upgrades.tier1 === 'knowledgeExpanded') {
                const knowledgeWrong = [];
                q.options.forEach((opt, index) => {
                  if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                    knowledgeWrong.push(index);
                  }
                });
                const toRemove = knowledgeWrong.slice(0, 2);
                toRemove.forEach(index => player.activeEffects.eliminatedAnswers.push(index));
                applyEliminatedAnswers();
                feedbackMessage = 'Knowledge Expanded: 2 wrong answers eliminated!';
              } else {
                feedbackMessage = `Arcane Knowledge reveals: ${getDetailedQuestionHint(q)}`;
              }
            }
            break;
            
          case 'eliminate':
            const wrongAnswerOptions = [];
            q.options.forEach((opt, index) => {
              if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                wrongAnswerOptions.push(index);
              }
            });
            if (wrongAnswerOptions.length > 0) {
              deductUse(abilityKey);
              // shadowStrike (Infiltrator L5) — removes 2 wrong answers instead of 1
              const eliminateCount = upgrades.tier1 === 'shadowStrike' ? 2 : 1;
              const toRemove = wrongAnswerOptions.slice(0, eliminateCount);
              toRemove.forEach(index => player.activeEffects.eliminatedAnswers.push(index));
              applyEliminatedAnswers();
              feedbackMessage = eliminateCount > 1
                ? 'Shadow Strike: Two wrong answers eliminated!'
                : 'Eliminate: One wrong answer has been removed from consideration.';
              // assassinate (Infiltrator L10) — can target correct answer to reveal it
              if (upgrades.tier2 === 'assassinate' && wrongAnswerOptions.length === 1) {
                selectedAnswerIndex = q.correct;
                highlightCorrectAnswer();
                feedbackMessage = 'Assassinate: The correct answer is exposed!';
              }
            } else {
              feedbackMessage = 'Eliminate: No more wrong answers to remove!';
            }
            break;
            
          case 'shadowStep':
            deductUse(abilityKey);
            // ghostStep (Infiltrator L5) — grants +15 XP when used
            if (upgrades.tier1 === 'ghostStep') {
              player.xp = (player.xp || 0) + 15;
              if (window._safeUpdateStats) window._safeUpdateStats();
              showNotification('+15 XP — Ghost Step bonus!', 'xp-gain');
            }
            // phantomMove (Infiltrator L10) — skip 2 questions in a row
            if (upgrades.tier2 === 'phantomMove' && !player.activeEffects.phantomMoveActive) {
              player.activeEffects.phantomMoveActive = true; // next skip is also free
            }
            currentQuestionIndex++;
            loadQuestion();
            feedbackMessage = 'Shadow Step: You slip past this challenge undetected.';
            return;
            
          case 'secondLook':
            deductUse(abilityKey);
            player.activeEffects.secondLookUsed = true;
            // secondChance (Empath L5) — resets question twice instead of once
            if (upgrades.tier1 === 'secondChance') {
              player.activeEffects.secondLookCount = 2;
              feedbackMessage = 'Second Chance: Question will reset up to twice if you answer incorrectly!';
            } else {
              feedbackMessage = 'Second Look prepared: Question will reset if you answer incorrectly!';
            }
            // boundlessHeart (Empath L10) — works even after seeing result
            // (handled in Section 12 wrong-answer path — flag already set)
            break;
            
          case 'emotionalInsight':
            if (q.explanation) {
              deductUse(abilityKey);
              // trueSight (Empath L10) — reveals explanation AND removes a wrong answer
              if (upgrades.tier2 === 'trueSight') {
                const trueSightWrong = [];
                q.options.forEach((opt, index) => {
                  if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                    trueSightWrong.push(index);
                  }
                });
                if (trueSightWrong.length > 0) {
                  const toRemove = trueSightWrong[Math.floor(Math.random() * trueSightWrong.length)];
                  player.activeEffects.eliminatedAnswers.push(toRemove);
                  applyEliminatedAnswers();
                }
                feedbackMessage = `True Sight reveals:\n\n"${q.explanation}"\n\nPlus one wrong answer removed!`;
              } else {
                // empathyWave (Empath L5) — eliminates 2 wrong answers instead of showing hint
                if (upgrades.tier1 === 'empathyWave') {
                  const empathyWrong = [];
                  q.options.forEach((opt, index) => {
                    if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                      empathyWrong.push(index);
                    }
                  });
                  const toRemove = empathyWrong.slice(0, 2);
                  toRemove.forEach(index => player.activeEffects.eliminatedAnswers.push(index));
                  applyEliminatedAnswers();
                  feedbackMessage = `Empathy Wave eliminates 2 wrong answers!\n\n"${q.explanation}"`;
                } else {
                  feedbackMessage = `Emotional Insight reveals the key concept:\n\n"${q.explanation}"\n\nUse this knowledge to find the right answer!`;
                }
              }
            } else {
              // Fallback: eliminate one wrong answer
              const emotionalWrongAnswers = [];
              q.options.forEach((opt, index) => {
                if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                  emotionalWrongAnswers.push(index);
                }
              });
              if (emotionalWrongAnswers.length > 0) {
                deductUse(abilityKey);
                const count = upgrades.tier1 === 'empathyWave' ? 2 : 1;
                emotionalWrongAnswers.slice(0, count).forEach(index => {
                  player.activeEffects.eliminatedAnswers.push(index);
                });
                applyEliminatedAnswers();
                feedbackMessage = `Emotional Insight: Understanding the characters reveals ${count} wrong answer(s).`;
              } else {
                feedbackMessage = 'Emotional Insight: No additional insights available for this question.';
              }
            }
            break;
            
          case 'keenEye':
            // Unlimited use - no deduction
            // sharpEye (Pathfinder L5) — also highlights most important word in question
            if (upgrades.tier1 === 'sharpEye') {
              // Find longest meaningful word as a proxy for "most important"
              const words = (q.text || '').split(/\s+/).filter(w => w.length > 4);
              const keyWord = words.sort((a,b) => b.length - a.length)[0] || '';
              feedbackMessage = `Sharp Eye: ${getQuestionDifficulty(q)} difficulty, ${selectedApproach || 'General'} approach. Key term: "${keyWord.replace(/[^a-zA-Z]/g,'')}"`;
            } else if (upgrades.tier2 === 'eagleVision') {
              // eagleVision (Pathfinder L10) — reveals difficulty and approach type
              feedbackMessage = `Eagle Vision: ${getQuestionDifficulty(q)} difficulty — this question tests ${selectedApproach || 'General'} skills. Focus on: ${getDetailedQuestionHint(q)}`;
            } else {
              feedbackMessage = `Keen Eye reveals: ${getQuestionDifficulty(q)} difficulty, ${selectedApproach || 'General'} approach.`;
            }
            break;
            
          case 'trailBlazer':
            const oldFocus = player.focus;
            // trailblazerBoost (Pathfinder L5) — removes 3 wrong answers instead of 2
            // (trailBlazer in the original restores Focus — keeping that but also wiring the boost)
            const trailEliminateCount = upgrades.tier1 === 'trailblazerBoost' ? 3 : 2;
            
            // Eliminate wrong answers
            const trailWrong = [];
            q.options.forEach((opt, index) => {
              if (index !== q.correct && !player.activeEffects.eliminatedAnswers.includes(index)) {
                trailWrong.push(index);
              }
            });
            if (trailWrong.length > 0) {
              trailWrong.slice(0, trailEliminateCount).forEach(index => {
                player.activeEffects.eliminatedAnswers.push(index);
              });
              applyEliminatedAnswers();
            }

            // pathMastery (Pathfinder L10) — also restores 10 Focus when used
            if (upgrades.tier2 === 'pathMastery') {
              const maxFocus = window.getMaxFocus ? window.getMaxFocus(window.getPlayerLevel ? window.getPlayerLevel() : 1) : 100;
              player.focus = Math.min(maxFocus, (player.focus || 0) + 10);
              showNotification('+10 Focus — Path Mastery!', 'xp-gain');
            }

            deductUse(abilityKey);
            
            feedbackMessage = trailEliminateCount > 2
              ? `Trailblazer Boost: ${trailEliminateCount} wrong answers eliminated!`
              : `Trail Blazer: ${trailWrong.length > 0 ? trailEliminateCount + ' wrong answers eliminated!' : 'No wrong answers to eliminate!'}`;
            
            updatePlayerStats();
            break;
        }
        
        // Show ability feedback
        const existingFeedback = document.querySelector('.ability-feedback');
        if (existingFeedback) existingFeedback.remove();
        
        const abilityFeedback = document.createElement('div');
        abilityFeedback.className = 'ability-feedback';
        abilityFeedback.style.whiteSpace = 'pre-line';
        abilityFeedback.textContent = feedbackMessage;
        
        const abilityContainer = document.getElementById('ability-container');
        abilityContainer.appendChild(abilityFeedback);
        
        setTimeout(() => {
          if (abilityFeedback.parentNode) {
            abilityFeedback.parentNode.removeChild(abilityFeedback);
          }
        }, 5000);
        
        renderClassAbilities();
        await savePlayerProgress();
        showNotification('Ability Used!', 'ability-used');
      };

      const applyEliminatedAnswers = () => {
        const answerButtons = document.querySelectorAll('#answer-options .answer-option');
        answerButtons.forEach((btn, index) => {
          if (player.activeEffects.eliminatedAnswers.includes(index)) {
            btn.classList.add('eliminated');
            btn.disabled = true;
          }
        });
      };

      const highlightCorrectAnswer = () => {
        const answerButtons = document.querySelectorAll('#answer-options .answer-option');
        answerButtons.forEach(btn => btn.classList.remove('selected'));
        if (answerButtons[selectedAnswerIndex]) {
          answerButtons[selectedAnswerIndex].classList.add('selected');
          submitAnswerBtn.style.display = 'block';
        }
      };
