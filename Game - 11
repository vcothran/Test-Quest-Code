  document.body.appendChild(overlay);
  setTimeout(() => {
    overlay.style.transition = 'opacity 0.5s';
    overlay.style.opacity = '0';
    setTimeout(() => { if (overlay.parentNode) overlay.remove(); }, 500);
  }, 2000);
};

// ─────────────────────────────────────────────────────────────────────────
// CHAMPION'S CALL HUD BUTTON
// Shows for Legacy characters (any character on an account with a Level 20)
// ─────────────────────────────────────────────────────────────────────────
window.updateChampionsCallHUD = () => {
  const existing = document.getElementById('hud-champions-call-btn');
  if (existing) existing.remove();

  if (!window.hasLegacy()) return;

  const statsEl = document.getElementById('player-stats');
  if (!statsEl) return;

  const used = (player.activeEffects || {}).championsCallUsed;

  const btn = document.createElement('button');
  btn.id = 'hud-champions-call-btn';
  btn.style.cssText = `
    cursor:${used ? 'not-allowed' : 'pointer'};
    background:${used ? 'rgba(255,255,255,0.04)' : 'linear-gradient(135deg,rgba(201,168,76,0.15),rgba(160,112,48,0.25))'};
    border:1px solid ${used ? 'rgba(255,255,255,0.08)' : 'rgba(201,168,76,0.4)'};
    color:${used ? '#3a4456' : '#c9a84c'};
    font-size:11px;padding:6px 10px;border-radius:6px;
    font-family:'Cinzel',serif;
    opacity:${used ? '0.4' : '1'};
    margin-left:6px;`;
  btn.innerHTML = `👑 Champion's Call`;
  btn.title = used ? 'Already used this episode' : "Reveal the correct answer — once per episode";
  btn.disabled = used;
  if (!used) btn.onclick = () => window.activateChampionsCall();
  statsEl.appendChild(btn);
};

// ─────────────────────────────────────────────────────────────────────────
// PRESTIGE UNLOCK — called when player hits Level 20
// ─────────────────────────────────────────────────────────────────────────
window.unlockPrestige = async () => {
  if (!player || !player.uid) return;
  if (player.prestigeUnlocked) return; // already done

  player.prestigeUnlocked  = true;
  player.accountPrestige    = true; // account-level flag — persists to new characters
  player.undyingWillActive  = true;

  // Save account-level prestige flag
  try {
    await setDoc(doc(db, 'players', player.uid), {
      prestigeUnlocked: true,
      accountPrestige:  true,
      undyingWillActive: true,
    }, { merge: true });
    if (player.activeCharacterId) {
      await setDoc(doc(db, 'players', player.uid, 'characters', player.activeCharacterId), {
        prestigeUnlocked: true,
      }, { merge: true });
    }
  } catch(e) { console.warn('Could not save prestige:', e); }

  window.applyPrestigeVisuals();
  window.applyUndyingWill();
  window.showPrestigeUnlockOverlay();
};

