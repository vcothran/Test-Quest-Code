
// ─────────────────────────────────────────────────────────────────────────
// CHAMPION'S CALL — once-per-episode ability for Legacy characters
// Reveals the correct answer on one question
// ─────────────────────────────────────────────────────────────────────────
window.activateChampionsCall = () => {
  if (!player || !window.hasLegacy()) return;
  if ((player.activeEffects || {}).championsCallUsed) {
    if (window._safeNotify) window._safeNotify("Champion's Call already used this episode!", 'focus-loss');
    return;
  }

  const q = window._getCurrentQuestion ? window._getCurrentQuestion() : null;
  if (!q) {
    if (window._safeNotify) window._safeNotify("No active question.", 'focus-loss');
    return;
  }

  // Reveal correct answer
  if (typeof selectedAnswerIndex !== 'undefined') {
    window._setSelectedAnswer && window._setSelectedAnswer(q.correct);
  }
  const buttons = document.querySelectorAll('#answer-options .answer-option');
  if (buttons[q.correct]) {
    buttons[q.correct].style.boxShadow = '0 0 20px 6px rgba(201,168,76,0.9)';
    buttons[q.correct].style.border    = '3px solid #c9a84c';
    buttons[q.correct].click();
  }

  player.activeEffects.championsCallUsed = true;
  window.updateChampionsCallHUD();

  // Dramatic overlay
  window.showChampionsCallOverlay();

  if (typeof savePlayerProgress === 'function') savePlayerProgress();
};

window.showChampionsCallOverlay = () => {
  const overlay = document.createElement('div');
  overlay.style.cssText = `
    position:fixed;inset:0;background:rgba(0,0,0,0.6);
    display:flex;align-items:center;justify-content:center;
    z-index:99989;pointer-events:none;
    animation:loginFadeIn 0.3s ease-out;`;
