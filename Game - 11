// ─────────────────────────────────────────────────────────────────────────
// HOOK INTO LEVEL-UP SYSTEM
// ─────────────────────────────────────────────────────────────────────────
setTimeout(() => {

  // Apply prestige visuals if already level 20
  if (window.isPrestige()) {
    window.applyPrestigeVisuals();
    window.applyUndyingWill();
  }

  // Show Champion's Call button if account has legacy
  if (window.hasLegacy()) {
    window.updateChampionsCallHUD();
  }

  // Hook level-up to trigger prestige unlock at L20
  const origLevelUp = window.checkForLevelUp;
  if (origLevelUp && !window._s24LevelHooked) {
    window._s24LevelHooked = true;
    window.checkForLevelUp = () => {
      const levelBefore = window._lastKnownLevel || 1;
      origLevelUp();
      const levelAfter = window.getLevelData ? window.getLevelData(player.xp).level : 1;
      if (levelAfter >= window.PRESTIGE_LEVEL && levelBefore < window.PRESTIGE_LEVEL) {
        setTimeout(() => window.unlockPrestige(), 3000); // after level-up overlay
      }
    };
  }

  // Reset Champion's Call at episode start
  const episodeScreen = document.getElementById('episodeSelection');
  if (episodeScreen) {
    new MutationObserver(() => {
      if (episodeScreen.classList.contains('active')) {
        if (player && player.activeEffects) {
          player.activeEffects.championsCallUsed            = false;
          player.activeEffects.undyingWillUsedThisEpisode   = false;
        }
        window.updateChampionsCallHUD();
      }
    }).observe(episodeScreen, { attributes: true, attributeFilter: ['class'] });
  }

  console.log('✅ Prestige hooks attached');
}, 3500);

// ─────────────────────────────────────────────────────────────────────────
// WIRE UNDYING WILL + CHAMPION'S AURA INTO SECTION 12 XP PATH
// These are read by Section 12 via player flags
// undyingWillActive  → handled in Section 12 focus path (like undyingActive)
// accountPrestige    → +5% XP multiplier
// accountPrestige on non-prestige char → +5% legacy XP (championsAura)
// ─────────────────────────────────────────────────────────────────────────
// Patch the awardXP flow via window hook
const _origAwardXP = window.awardXP;
if (typeof awardXP === 'function' && !window._s24XPPatched) {
  window._s24XPPatched = true;
  // We can't reassign closure const — instead we expose a multiplier
  // that Section 12's awardXP call reads
  window.getPrestigeXPMultiplier = () => {
    if (!player) return 1;
    // Prestige character — Undying Will +5%
    if (window.isPrestige() && player.undyingWillActive) return 1.05;
    // Legacy character — Champion's Aura +5%
    if (window.hasLegacy() && !window.isPrestige()) return 1.05;
    return 1;
  };
}

