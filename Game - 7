window.getLevelData = (xp) => {
  const totalXP = xp || 0;
  let current = window.LEVEL_TABLE[0];
  for (let i = window.LEVEL_TABLE.length - 1; i >= 0; i--) {
    if (totalXP >= window.LEVEL_TABLE[i].xpRequired) { current = window.LEVEL_TABLE[i]; break; }
  }
  const next = window.LEVEL_TABLE.find(l => l.xpRequired > totalXP) || null;
  const progressToNext = next
    ? Math.round(((totalXP - current.xpRequired) / (next.xpRequired - current.xpRequired)) * 100)
    : 100;
  return { level: current.level, title: current.title, next, progressToNext };
};

