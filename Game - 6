      const generateEpisodeOpening = async (episode) => {
        console.log('Generating episode opening via Cloud Function...');

        showNarrativeLoading('Conjuring your story…');

        try {
          const desc  = getEpisodeDescription(episode);
          const level = Math.floor((player.xp || 0) / 100) + 1;

          let reputation = 'Apprentice';
          if (typeof reputationSystem !== 'undefined' && reputationSystem.reputation != null) {
            const r = reputationSystem.reputation;
            if      (r >= 75) reputation = 'Legend';
            else if (r >= 50) reputation = 'Master';
            else if (r >= 25) reputation = 'Expert';
            else if (r >=  0) reputation = 'Journeyman';
          }

          const totalQ = episode.encounters
            ? episode.encounters.reduce((sum, enc) => sum + (enc.qCount || enc.questionsPerApproach || 0), 0)
            : 5;

          const prompt = `You are the Dungeon Master for Test Quest, an educational adventure game. Generate a unique, engaging opening narrative for this episode. Every playthrough must feel fresh and different.

EPISODE CONTEXT:
- Genre: ${episodeNarrative.genre}
- Episode Title: "${episodeNarrative.episodeTitle}"
- Episode Description: "${desc}"
- Player: ${player.name}, a Level ${level} ${player.className}
- Reputation: ${reputation}
- Difficulty: ${adaptiveDifficulty ? adaptiveDifficulty.currentLevel : 5}/10
- Challenges Ahead: ${totalQ} trials

NARRATIVE DIRECTION (follow these to make this playthrough unique):
- Character Framing: Tell this ${episodeNarrative.sessionPerspective}
- Atmosphere: ${episodeNarrative.sessionAtmosphere}
- Opening Approach: ${episodeNarrative.sessionHook}
- Writing Style: ${episodeNarrative.sessionStyle}

CONTENT REQUIREMENTS:
- Write 2-3 paragraphs in ${episodeNarrative.genre} style
- Draw directly from the Episode Description — use its specific details, characters, and setting
- Address the player as ${player.name} and acknowledge their ${player.className} class
- Reference specific elements from the description (locations, characters, events mentioned)
- Set up the stakes described in the episode
- Hint at the ${totalQ} challenges ahead without calling them "questions"
- Match tone to their reputation level (${reputation})
- Keep it immersive and exciting
- NO meta-references to "questions", "answers", or "game mechanics"
- Make this feel completely different from a standard opening

Generate the opening narrative now:`;

          console.log('=== Calling Cloud Function ===');
          console.log('Sending prompt (length):', prompt.length);
          console.log('Episode description:', desc.substring(0, 100) + '...');
          console.log('Narrative seeds:', episodeNarrative.sessionPerspective, '|', episodeNarrative.sessionAtmosphere);

          const narrative = await callNarrativeFunction(prompt, 600);

          episodeNarrative.openingNarrative = narrative;
          displayNarrative(narrative, 'opening');
          console.log('AI opening displayed successfully');
          return narrative;

        } catch (error) {
          console.error('AI opening generation failed:', error);
          hideNarrativeLoading();
          const fallback = generateTemplateOpening(episode);
          episodeNarrative.openingNarrative = fallback;
          displayNarrative(fallback, 'opening');
          return fallback;
        }
