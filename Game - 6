      // Use trophy
      const useTrophy = (trophyId, key) => {
        const challengeBox = document.getElementById('challenge-box');
        if (!challengeBox || challengeBox.style.display === 'none') {
          alert('Trophies can only be used during challenges!');
          return;
        }
        
        switch (trophyId) {
          case 'legLamp':
            player.focus += 25;
            player.activeEffects.forgivenError = true;
            showNotification('🦵💡 Leg Lamp: Next error forgiven!', 'ability-used');
            break;
          case 'eternalTorch':
            player.focus += 25;
            player.activeEffects.doubleXPNext = true;
            showNotification('🔥 Eternal Torch: 2x XP next!', 'ability-used');
            break;
          case 'liquidShadow':
            player.focus += 25;
            player.activeEffects.autoCorrectNext = true;
            showNotification('🗡️ Liquid Shadow: Auto-correct next!', 'ability-used');
            break;
          case 'playbook':
            player.focus += 25;
            player.activeEffects.bonusXP = 1.5;
            player.activeEffects.bonusXPDuration = 3;
            const q = currentQuestionSet[currentQuestionIndex];
            if (q) {
              const wrong = [];
              q.options.forEach((opt, i) => {
                if (i !== q.correct && !player.activeEffects.eliminatedAnswers.includes(i)) wrong.push(i);
              });
              wrong.slice(0, 2).forEach(i => player.activeEffects.eliminatedAnswers.push(i));
              if (typeof applyEliminatedAnswers === 'function') applyEliminatedAnswers();
            }
            showNotification('📖 Playbook: +50% XP, 2 eliminated!', 'ability-used');
            break;
          case 'phoenixTear':
            player.focus = 125;
            player.activeEffects.phoenixTearActive = true;
            showNotification('🔮 Phoenix Tear: Overcharged!', 'ability-used');
            break;
