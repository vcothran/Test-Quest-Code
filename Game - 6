      const getEpisodeDescription = (episode) => {
        if (episode.encounters && episode.encounters.length > 0 && episode.encounters[0].narrative) {
          return episode.encounters[0].narrative
            .replace(/^Episode Description:\s*/i, '')
            .trim();
        }
        return '';
      };

      const resetEpisodeNarrative = (episode) => {
        episodeNarrative = {
          genre:                    episode.genre || episode.theme || 'Fantasy',
          episodeTitle:             episode.title || 'Unknown Quest',
          episodeDescription:       getEpisodeDescription(episode),
          currentEncounterTitle:    episode.encounters && episode.encounters[0] ? (episode.encounters[0].title || '') : '',
          currentEncounterNarrative:getEpisodeDescription(episode),
          currentEncounterIndex:    0,
          openingNarrative:         '',
          questionNarratives:       [],
          playerActions:            [],
          storyBeats:               [],
          tonalShift:               'neutral',
          sessionPerspective:       randomSeed(narrativeSeeds.perspectives),
          sessionAtmosphere:        randomSeed(narrativeSeeds.atmospheres),
          sessionHook:              randomSeed(narrativeSeeds.openingHooks),
          sessionStyle:             randomSeed(narrativeSeeds.styleVariants)
