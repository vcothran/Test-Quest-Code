            <div class="diamond-loader-rig">
              <div class="diamond-center"></div>
              <div class="diamond-orbit"></div>
              <div class="diamond-orbit"></div>
              <div class="diamond-orbit"></div>
              <div class="diamond-orbit"></div>
            </div>
            <div class="diamond-loader-label">♦ ${message} ♦</div>
          </div>`;
        loader.style.display = 'block';

        const narrativeEl = document.getElementById('narrative-text');
        if (narrativeEl) narrativeEl.textContent = '';
      };

      const hideNarrativeLoading = () => {
        const loader = document.getElementById('narrative-loader');
        if (loader) {
          loader.innerHTML = '';
          loader.style.display = 'none';
        }
      };

      // Write final narrative — only ever uses textContent, never innerHTML
      const displayNarrative = (narrative, type = 'opening') => {
        const el = document.getElementById('narrative-text');
        if (!el) { console.warn('narrative-text element not found'); return; }

        hideNarrativeLoading();

        el.style.fontStyle  = 'normal';
        el.style.fontSize   = type === 'opening' ? '15px' : '14px';
        el.style.color      = type === 'opening' ? '#ecf0f1' : '#dfe6e9';
        el.style.lineHeight = '1.7';

        el.textContent = narrative;

        el.classList.remove('narrative-ready');
        void el.offsetWidth;
        el.classList.add('narrative-ready');
      };

      const trackPlayerAction = (action) => {
        episodeNarrative.playerActions.push(action);
        if (episodeNarrative.playerActions.length > 10) episodeNarrative.playerActions.shift();
      };

      const updateTonalShift = () => {
        const accuracy     = sessionStats.calculateAccuracy();
        const focusPercent = player.focus || 0;
        if      (accuracy >= 80 && focusPercent >= 70) episodeNarrative.tonalShift = 'triumphant';
        else if (accuracy >= 60 && focusPercent >= 50) episodeNarrative.tonalShift = 'hopeful';
        else if (accuracy <  40 || focusPercent <  30) episodeNarrative.tonalShift = 'desperate';
        else                                            episodeNarrative.tonalShift = 'tense';
      };

      const callNarrativeFunction = async (promptText, maxTokens = 300) => {
        const generateNarrative = httpsCallable(functions, 'generateNarrative');
        const result = await generateNarrative({
          requestData: { model: 'claude-sonnet-4-5', maxTokens, promptText }
        });
        if (result.data && result.data.success && result.data.data && result.data.data.content) {
          return result.data.data.content
            .filter(item => item.type === 'text')
            .map(item => item.text)
            .join('\n\n')
            .replace(/\*\*/g, '')
            .trim();
        }
        throw new Error('Invalid response from Cloud Function');
      };

      // ─────────────────────────────────────────────────────────────
