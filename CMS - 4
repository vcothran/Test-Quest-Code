  const closeAlertBtn = document.getElementById('close-alert-modal');
  if (closeAlertBtn) closeAlertBtn.addEventListener('click', () => this.closeModal('alert-modal'));

  const closeSuccessBtn = document.getElementById('close-success-modal');
  if (closeSuccessBtn) closeSuccessBtn.addEventListener('click', () => this.closeModal('success-modal'));

  console.log('✅ Cancel button listeners attached');
};

// ── BANK SELECT DROPDOWN ─────────────────────────

CMSApp.prototype.populateAIImportBankSelect = function() {
  if (!this.elements.aiSaveBankSelect) return;

  this.elements.aiSaveBankSelect.innerHTML = '<option value="">Select a question bank...</option>';

  const createNewOption = document.createElement('option');
  createNewOption.value = 'CREATE_NEW';
  createNewOption.textContent = '--- Create New Question Bank ---';
  this.elements.aiSaveBankSelect.appendChild(createNewOption);

  this.state.questionBanks.forEach(bank => {
    const option = document.createElement('option');
    option.value = bank.id;
    const questionCount  = (bank.questions || []).length;
    const lastExtraction = bank.lastExtraction;
    option.textContent = `${bank.name || 'Untitled Bank'} (${bank.approach || 'General'}) - ${questionCount} questions${lastExtraction ? ` - Last: ${lastExtraction.testType}` : ''}`;
    this.elements.aiSaveBankSelect.appendChild(option);
  });

  console.log('✅ AI Import bank dropdown populated');
};

// ── NAVIGATION ────────────────────────────────────

CMSApp.prototype.switchPage = function(pageId) {
  console.log('📄 Switched to page:', pageId);

  document.querySelectorAll('.cms-nav-tab').forEach(tab => {
    tab.classList.remove('active');
    if (tab.getAttribute('data-page') === pageId) tab.classList.add('active');
  });

  document.querySelectorAll('.cms-page').forEach(page => {
    page.style.display = 'none';
    page.classList.remove('active');
  });

  // Try both ID patterns to be safe
  const targetPage = document.getElementById('page-' + pageId) || document.getElementById(pageId);
  if (targetPage) {
    targetPage.style.display = 'block';
    targetPage.classList.add('active');
  }

  switch (pageId) {
    case 'dashboard':      this.loadDashboardData();   break;
    case 'question-banks': this.loadQuestionBanks();   break;
    case 'episodes':       this.loadEpisodes();         break;
    case 'genres':         this.loadGenres();           break;
    case 'analytics':      this.refreshAnalytics();     break;
    case 'settings':       this.loadSettingsPage();     break;
  }
};

// ── DASHBOARD ─────────────────────────────────────

CMSApp.prototype.loadDashboardData = function() {
  const stats = {
    totalQBanks:    this.state.questionBanks.length,
    totalEpisodes:  this.state.episodes.length,
    activeEpisodes: this.state.episodes.filter(ep => ep.active).length
  };

  if (this.elements.dashStats.totalQBanks)    this.elements.dashStats.totalQBanks.textContent    = stats.totalQBanks;
  if (this.elements.dashStats.totalEpisodes)  this.elements.dashStats.totalEpisodes.textContent  = stats.totalEpisodes;
  if (this.elements.dashStats.activeEpisodes) this.elements.dashStats.activeEpisodes.textContent = stats.activeEpisodes;

  this.updateDashboardParserStats();
  console.log('✅ Dashboard data loaded');
};

CMSApp.prototype.updateNavigationCounts = function() {
  if (this.elements.banksCount)    this.elements.banksCount.textContent    = this.state.questionBanks.length;
  if (this.elements.episodesCount) this.elements.episodesCount.textContent = this.state.episodes.length;
  console.log('✅ Navigation counts updated');
};

