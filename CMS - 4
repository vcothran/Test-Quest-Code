// ── SYSTEM STATUS ─────────────────────────────────

CMSApp.prototype.getSystemStatus = function() {
  return {
    parserReady:        this.parserReady,
    firebaseConnected:  !!this.db,
    questionBanksLoaded: this.state.questionBanks.length > 0,
    version:            window.ULTIMATE_PARSER_CONFIG?.VERSION || '2.0',
    successRate:        this.state.parserStats.successRate,
    processedDocuments: this.state.parserStats.processedDocuments,
    extractedQuestions: this.state.parserStats.extractedQuestions
  };
};

CMSApp.prototype.logPerformanceMetric = function(operation, duration, success = true) {
  console.log(`📈 Performance: ${operation} took ${duration}ms (${success ? 'success' : 'failed'})`);
  if (window.gtag) {
    window.gtag('event', 'ultimate_parser_performance', {
      operation, duration, success,
      version: window.ULTIMATE_PARSER_CONFIG?.VERSION
    });
  }
};

CMSApp.prototype.verifyInitialization = function() {
  const status = this.getSystemStatus();
  console.log('🔍 System Status Check:', status);
  if (!status.parserReady)       console.warn('⚠️ Ultimate Parser not ready. Some features may be limited.');
  if (!status.firebaseConnected) this.showAlert('❌ Database connection failed. Please refresh the page.', 'error');
  return status.parserReady && status.firebaseConnected;
};

CMSApp.prototype.cleanup = function() {
  console.log('🧹 Cleaning up Ultimate Parser CMS...');
  this.state.isProcessingImport = false;
  this.hideProcessingOverlay();
  this.hideProgress();
  document.querySelectorAll('.cms-modal').forEach(modal => modal.style.display = 'none');
  console.log('✅ Cleanup complete');
};

// ── GLOBAL ERROR HANDLER ──────────────────────────

window.addEventListener('error', function(e) {
  console.error('🚨 Global error:', e.error);
  if (window.cmsApp) window.cmsApp.handleError(e.error, 'system error');
});

window.addEventListener('beforeunload', function() {
  if (window.cmsApp) window.cmsApp.cleanup();
});

console.log('✅ CMS Section 8 COMPLETE — UI Methods, Modals, Alerts, Navigation (v2 + encounter editor)');
