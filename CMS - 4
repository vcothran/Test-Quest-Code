
// ─────────────────────────────────────────────────────────────────────────
// PARSE GEMINI RESPONSE — extract JSON array of questions
// ─────────────────────────────────────────────────────────────────────────
CMSApp.prototype.parseGeminiQuestionResponse = function(responseText) {
  if (!responseText) return [];

  try {
    // Strip markdown code fences
    let clean = responseText
      .replace(/^```json\s*/i, '')
      .replace(/^```\s*/i, '')
      .replace(/\s*```$/i, '')
      .trim();

    // Find the outermost JSON array
    const start = clean.indexOf('[');
    const end   = clean.lastIndexOf(']');
    if (start !== -1 && end !== -1 && end > start) {
      clean = clean.substring(start, end + 1);
    }

    // Attempt repair before parsing
    clean = this.repairJsonString(clean);

    const parsed = JSON.parse(clean);
    if (!Array.isArray(parsed)) return [];

    return parsed.map((q, i) => {
      let options = q.options || {};
      if (Array.isArray(options)) {
        const letters = ['A','B','C','D','E','F','G','H','J'];
        const obj = {};
        options.forEach((text, idx) => { obj[letters[idx]] = text; });
        options = obj;
      }
      return {
        questionNumber: q.questionNumber || (i + 1),
        testType:       q.testType || 'General',
        text:           q.text || q.question || '',
        question:       q.text || q.question || '',
        passageContext: q.passageContext || q.passage || '',
        passage:        q.passageContext || q.passage || '',
        options:        options,
        correct:        q.correct || q.correctAnswer || 'A',
        explanation:    q.explanation || '',
        extractedAt:    new Date().toISOString()
      };
    }).filter(q => q.text.trim() !== '');

  } catch (parseErr) {
    console.error('❌ JSON parse failed, attempting recovery:', parseErr);
    return this.recoverQuestionsFromText(responseText);
  }
};

// ─────────────────────────────────────────────────────────────────────────
// JSON REPAIR — fix common Gemini malformed JSON issues
// ─────────────────────────────────────────────────────────────────────────
CMSApp.prototype.repairJsonString = function(str) {
  try {
    JSON.parse(str);
    return str; // Already valid
  } catch(e) {
    let fixed = str;

    // 1. Remove stray control characters (keep \n \r \t)
    fixed = fixed.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '');

    // 2. Fix smart/curly quotes → straight quotes
    fixed = fixed
      .replace(/[\u2018\u2019]/g, "'")
      .replace(/[\u201C\u201D]/g, '"');

    // 3. Fix trailing commas before ] or }
    fixed = fixed.replace(/,\s*([\]}])/g, '$1');

    // 4. Fix unescaped backslashes
    fixed = fixed.replace(/\\(?!["\\/bfnrtu])/g, '\\\\');

    try {
      JSON.parse(fixed);
      return fixed;
    } catch(e2) {
      console.warn('⚠️ Basic repair failed, trying object extraction...');
      const recovered = JSON.stringify(this.extractJsonObjects(str));
      return recovered;
    }
  }
};

// ─────────────────────────────────────────────────────────────────────────
// EXTRACT JSON OBJECTS — pull valid question objects out one by one
// Handles cases where one malformed question breaks the whole array
// ─────────────────────────────────────────────────────────────────────────
CMSApp.prototype.extractJsonObjects = function(str) {
  const questions = [];
  let depth    = 0;
  let inString = false;
  let escape   = false;
  let objStart = -1;

  for (let i = 0; i < str.length; i++) {
    const ch = str[i];

    if (escape)              { escape = false; continue; }
    if (ch === '\\' && inString) { escape = true; continue; }
    if (ch === '"')          { inString = !inString; continue; }
    if (inString)            continue;

    if (ch === '{') {
      if (depth === 0) objStart = i;
      depth++;
    } else if (ch === '}') {
      depth--;
      if (depth === 0 && objStart !== -1) {
        const objStr = str.substring(objStart, i + 1);
        try {
          const obj = JSON.parse(objStr);
          if (obj.text || obj.question) questions.push(obj);
        } catch(e) {
          // Skip malformed individual object
        }
        objStart = -1;
      }
    }
  }

  console.log(`🔧 Object extraction recovered ${questions.length} questions`);
  return questions;
};

// ─────────────────────────────────────────────────────────────────────────
// RECOVERY PARSER — last resort plain-text extraction
// ─────────────────────────────────────────────────────────────────────────
CMSApp.prototype.recoverQuestionsFromText = function(text) {
  const questions = [];
  const questionBlocks = text.split(/(?=\b(?:Question\s+)?\d+[\.\)]\s)/i);

  questionBlocks.forEach((block, i) => {
    const lines = block.trim().split('\n').filter(l => l.trim());
    if (lines.length < 3) return;

    const questionText = lines[0].replace(/^\d+[\.\)]\s*/, '').trim();
    if (!questionText) return;

    const options = {};
    const optionRegex = /^([A-HJ])[\.\)]\s+(.+)/i;
    let correct = 'A';

    lines.slice(1).forEach(line => {
      const match = line.match(optionRegex);
      if (match) {
        const letter = match[1].toUpperCase();
        options[letter] = match[2].trim();
        if (line.includes('*') || line.toLowerCase().includes('correct')) {
          correct = letter;
        }
      }
    });

    if (Object.keys(options).length >= 2) {
      questions.push({
        questionNumber: i + 1,
        testType:       'General',
        text:           questionText,
        question:       questionText,
        passageContext: '',
        passage:        '',
        options,
        correct,
        explanation:    '',
        extractedAt:    new Date().toISOString()
      });
    }
  });

  return questions;
};

// ─────────────────────────────────────────────────────────────────────────
// FILE HELPERS
// ─────────────────────────────────────────────────────────────────────────

CMSApp.prototype.readFileAsText = function(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload  = e => resolve(e.target.result || '');
    reader.onerror = () => reject(new Error('Failed to read file'));
    reader.readAsText(file);
  });
};

CMSApp.prototype.fileToBase64 = function(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload  = e => {
      const result = e.target.result;
      resolve(result.split(',')[1] || result);
    };
    reader.onerror = () => reject(new Error('Failed to read file as base64'));
    reader.readAsDataURL(file);
  });
};

CMSApp.prototype.extractTextFromPDF = async function(file) {
  if (typeof pdfjsLib === 'undefined') {
    console.warn('pdf.js not loaded, reading as text');
    return this.readFileAsText(file);
  }

  try {
    const arrayBuffer = await file.arrayBuffer();
    const pdf         = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;

    const maxPages  = 10;
    const pageCount = Math.min(pdf.numPages, maxPages);
    const textParts = [];

    for (let p = 1; p <= pageCount; p++) {
      const page    = await pdf.getPage(p);
      const content = await page.getTextContent();
      const pageText = content.items.map(item => item.str).join(' ');
      textParts.push(pageText);
    }

    const fullText = textParts.join('\n\n');
    console.log(`📄 Extracted ${fullText.length} chars from ${pageCount} PDF pages`);

    if (pdf.numPages > maxPages) {
      this.showAlert(`PDF has ${pdf.numPages} pages — only first ${maxPages} pages processed.`, 'warning');
    }

    return fullText;
  } catch (err) {
    console.error('PDF extraction error:', err);
    throw new Error('Could not read PDF: ' + err.message);
  }
};

// ─────────────────────────────────────────────────────────────────────────
// INITIALIZE ULTIMATE PARSER (called from init, sets this.geminiModel)
// ─────────────────────────────────────────────────────────────────────────
CMSApp.prototype.initializeUltimateParser = function() {
  const apiKey = this.getStoredApiKey ? this.getStoredApiKey() : null;
  if (!apiKey) {
    console.warn('⚠️ No Gemini API key found — Ultimate Parser disabled');
    this.parserReady = false;
    return;
  }

  try {
    if (typeof window.GoogleGenerativeAI !== 'undefined') {
      const genAI      = new window.GoogleGenerativeAI(apiKey);
      this.geminiModel = genAI.getGenerativeModel({ model: 'gemini-2.0-flash' });
      this.parserReady = true;
      console.log('✅ Ultimate Parser initialized: gemini-2.0-flash');
    } else {
      console.warn('⚠️ GoogleGenerativeAI SDK not loaded yet — retrying in 1s');
      this.parserReady = false;
      setTimeout(() => this.initializeUltimateParser(), 1000);
    }
  } catch (err) {
    console.error('❌ Error initializing parser:', err);
    this.parserReady = false;
  }
};

// ─────────────────────────────────────────────────────────────────────────
// FETCH TEACHER API KEY from Cloud Function (called at auth time)
// ─────────────────────────────────────────────────────────────────────────
CMSApp.prototype.fetchTeacherApiKey = async function() {
  try {
    const { getFunctions, httpsCallable } = window.firebaseV9;
    const functions = getFunctions(this.firebaseApp);
    const getKey    = httpsCallable(functions, 'getGeminiKey');
    const result    = await getKey();
    const apiKey    = result.data && result.data.key;
    if (apiKey) {
      this.saveApiKey(apiKey);
      // Re-initialize model with the fresh key
      if (typeof window.GoogleGenerativeAI !== 'undefined') {
        const genAI      = new window.GoogleGenerativeAI(apiKey);
        this.geminiModel = genAI.getGenerativeModel({ model: 'gemini-2.0-flash' });
        this.parserReady = true;
        console.log('✅ Gemini API key upgraded from Cloud Function');
      }
    }
    return apiKey;
  } catch (err) {
    console.warn('⚠️ Could not fetch key from Cloud Function:', err);
    this.initializeUltimateParser();
    return null;
  }
};

