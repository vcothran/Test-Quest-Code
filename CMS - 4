    return localStorage.getItem('gemini_api_key') ||
           localStorage.getItem('ultimateParserApiKey') || null;
  } catch(e) { return null; }
};

CMSApp.prototype.saveApiKey = function(key) {
  try {
    localStorage.setItem('gemini_api_key', key);
    localStorage.setItem('ultimateParserApiKey', key);
    window.GEMINI_API_KEY = key;
    window.ULTIMATE_PARSER_CONFIG = window.ULTIMATE_PARSER_CONFIG || {};
    window.ULTIMATE_PARSER_CONFIG.GEMINI_API_KEY = key;
    return true;
  } catch(e) { return false; }
};

CMSApp.prototype.getParserSettings = function() {
  try {
    const s = JSON.parse(localStorage.getItem('parserSettings') || '{}');
    return { ...this.getDefaultSettings(), ...s };
  } catch(e) { return this.getDefaultSettings(); }
};

CMSApp.prototype.saveParserSettings = function(settings) {
  try {
    localStorage.setItem('parserSettings', JSON.stringify(settings));
    return true;
  } catch(e) { return false; }
};

CMSApp.prototype.getDefaultSettings = function() {
