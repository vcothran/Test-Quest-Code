CMSApp.prototype.getSystemStatus = function() {
  return {
    parserReady:         this.parserReady,
    firebaseConnected:   !!this.db,
    questionBanksLoaded: this.state.questionBanks.length > 0,
    version:             window.ULTIMATE_PARSER_CONFIG?.VERSION || '2.3',
    successRate:         this.state.parserStats.successRate,
    processedDocuments:  this.state.parserStats.processedDocuments,
    extractedQuestions:  this.state.parserStats.extractedQuestions
  };
};

CMSApp.prototype.logPerformanceMetric = function(operation, duration, success = true) {
  console.log(`📈 Performance: ${operation} took ${duration}ms (${success ? 'success' : 'failed'})`);
};

CMSApp.prototype.verifyInitialization = function() {
  const status = this.getSystemStatus();
  console.log('🔍 System Status Check:', status);
  if (!status.parserReady)       console.warn('⚠️ Ultimate Parser not ready.');
  if (!status.firebaseConnected) this.showAlert('❌ Database connection failed. Please refresh.', 'error');
  return status.parserReady && status.firebaseConnected;
};

CMSApp.prototype.cleanup = function() {
  this.state.isProcessingImport = false;
  this.hideProcessing();
  this.hideProgress();
  document.querySelectorAll('.cms-modal').forEach(modal => { modal.style.display = 'none'; });
};

