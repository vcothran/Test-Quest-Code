CMSApp.prototype.handleEpisodeAIParser = async function() {
  if (!this.geminiModel) {
    this.showAlert('AI Parser is not ready. Please check your API key in Settings.', 'error');
    return;
  }

  const fileInput    = document.getElementById('ep-ai-file-input');
  const pasteArea    = document.getElementById('ep-ai-paste-area');
  const countSelect  = document.getElementById('ep-ai-encounter-count');
  const statusEl     = document.getElementById('ep-ai-status');
  const submitBtn    = document.getElementById('ep-ai-submit-btn');

  const encounterCount = parseInt(countSelect?.value) || 3;
  let contentText = (pasteArea?.value || '').trim();

  // Read file if provided
  const file = fileInput?.files[0];
  if (file && !contentText) {
    try {
      if (file.type === 'application/pdf') {
        contentText = await this.extractTextFromPDF(file);
      } else {
        contentText = await this.readFileAsText(file);
      }
    } catch(e) {
      this.showAlert('Could not read file: ' + e.message, 'error');
      return;
    }
  }

  if (!contentText) {
    this.showAlert('Please upload a file or paste content first.', 'error');
    return;
  }

  // Show loading state
  if (statusEl) { statusEl.style.display = 'block'; statusEl.textContent = '🤖 AI is building your episode structure (15–30 seconds)...'; }
  if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.6'; }

  const prompt = `You are an expert curriculum designer and educational game developer.
Based on the following content, generate a structured episode for an ACT test prep game.

Create exactly ${encounterCount} encounters that logically break the content into progressive difficulty levels.

Respond ONLY with a valid JSON object — no markdown, no explanation:
{
  "title": "Short catchy episode title (max 8 words)",
  "description": "2-3 sentence episode description explaining what students will learn and practice",
  "encounters": [
    {
      "title": "Encounter title",
      "narrative": "2-3 sentence story narrative describing the scenario students will face",
      "questionsPerApproach": 5,
      "successThreshold": {
        "minAccuracy": 60
      }
    }
  ]
}

Rules:
- Title should be engaging and topic-relevant
- Each encounter narrative should feel like a story moment, not just a description
- questionsPerApproach should be 4-8 depending on complexity
- minAccuracy should be 55-75 depending on difficulty
- Make encounters progressively more challenging
- Keep all text appropriate for high school students

CONTENT TO BUILD FROM:
${contentText.substring(0, 4000)}`;

  try {
    const result = await this.geminiModel.generateContent({
      contents: [{ role: 'user', parts: [{ text: prompt }] }],
      generationConfig: { maxOutputTokens: 2048, temperature: 0.4 }
    });
    const responseText = result.response.text();

    // Parse the response
    let episodeData;
    try {
      let clean = responseText.trim()
        .replace(/^```json\s*/i, '').replace(/^```\s*/i, '').replace(/\s*```$/i, '').trim();
      clean = this.repairJsonString ? this.repairJsonString(clean) : clean;
      episodeData = JSON.parse(clean);
    } catch(parseErr) {
      console.error('Episode AI parse error:', parseErr, responseText);
      this.showAlert('AI returned an unexpected format. Please try again.', 'error');
      if (statusEl) statusEl.style.display = 'none';
      if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '1'; }
      return;
    }

    // Apply to episode form
    if (episodeData.title) {
      const titleEl = document.getElementById('episode-title');
      if (titleEl) titleEl.value = episodeData.title;
    }
    if (episodeData.description) {
      const descEl = document.getElementById('episode-description');
      if (descEl) descEl.value = episodeData.description;
    }
    if (Array.isArray(episodeData.encounters) && episodeData.encounters.length > 0) {
      this.initEncounterEditor(episodeData.encounters);
    }

    // Close parser modal and show success
    document.getElementById('episode-ai-parser-modal')?.remove();
    this._markEpisodeModalDirty();
    this.showAlert(
      `✅ AI generated "${episodeData.title}" with ${episodeData.encounters?.length || 0} encounters — review and save when ready!`,
      'success'
    );

  } catch(err) {
    console.error('Episode AI error:', err);
    this.showAlert('AI generation failed: ' + (err.message || 'Unknown error'), 'error');
    if (statusEl) { statusEl.style.color = '#721c24'; statusEl.style.background = '#f8d7da'; statusEl.textContent = '❌ ' + (err.message || 'Unknown error'); }
  } finally {
    if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '1'; }
  }
};

