// Render options based on selected format
CMSApp.prototype.renderManualQuestionOptions = function(format) {
  const container = document.getElementById('manual-options-container');
  if (!container) return;

  const inputStyle = 'width:100%;padding:10px;border:1px solid #ced4da;border-radius:6px;font-size:14px;box-sizing:border-box;';
  const groupStyle = 'margin-bottom:12px;';
  const labelStyle = 'display:block;font-weight:500;margin-bottom:4px;color:#495057;';

  let letters = [];
  if (format === 'abcd') letters = ['A','B','C','D'];
  else if (format === 'fghj') letters = ['F','G','H','J'];
  else if (format === 'tf') letters = ['T','F2'];
  else if (format === 'custom') letters = ['A','B','C','D','E'];

  let optionsHTML = `<div style="margin-bottom:16px;">
    <div style="font-weight:600;color:#495057;margin-bottom:10px;font-size:15px;">Answer Options *</div>`;

  if (format === 'tf') {
    optionsHTML += `
      <div style="${groupStyle}">
        <label style="${labelStyle}">Option 1:</label>
        <input type="text" id="manual-option-T" value="True" readonly style="${inputStyle}background:#f8f9fa;">
      </div>
      <div style="${groupStyle}">
        <label style="${labelStyle}">Option 2:</label>
        <input type="text" id="manual-option-F2" value="False" readonly style="${inputStyle}background:#f8f9fa;">
      </div>
    `;
  } else {
    const placeholder = format === 'custom' ? ' (leave blank to omit)' : '';
    letters.forEach(l => {
      optionsHTML += `
        <div style="${groupStyle}">
          <label style="${labelStyle}">${l}:</label>
          <input type="text" id="manual-option-${l}" placeholder="Option ${l}${placeholder}" style="${inputStyle}">
        </div>
      `;
    });
  }

  // Correct answer dropdown
  let correctOptions = '';
  if (format === 'tf') {
    correctOptions = '<option value="T">True</option><option value="F2">False</option>';
  } else {
    letters.forEach(l => { correctOptions += `<option value="${l}">${l}</option>`; });
  }

  optionsHTML += `
    <div style="${groupStyle}">
      <label style="${labelStyle}">Correct Answer *</label>
      <select id="manual-correct-answer" required style="${inputStyle}background:#fff;">
        ${correctOptions}
      </select>
    </div>
  </div>`;

  container.innerHTML = optionsHTML;
};
