CMSApp.prototype.loadSettingsPage = function() {
  console.log('⚙️ Loading settings page...');
  const apiKeyInput = document.getElementById('gemini-api-key');
  if (apiKeyInput) {
    const storedKey = this.getStoredApiKey();
    apiKeyInput.value = storedKey || '';
  }
  const settings = this.getParserSettings();
  const extractionModeSelect = document.getElementById('default-extraction-mode');
  const maxPagesSelect       = document.getElementById('max-pdf-pages');
  const multiPassCheckbox    = document.getElementById('enable-multi-pass');
  const autoDetectCheckbox   = document.getElementById('auto-detect-test-type');
  if (extractionModeSelect) extractionModeSelect.value    = settings.defaultExtractionMode;
  if (maxPagesSelect)       maxPagesSelect.value          = settings.maxPdfPages;
  if (multiPassCheckbox)    multiPassCheckbox.checked     = settings.enableMultiPass;
  if (autoDetectCheckbox)   autoDetectCheckbox.checked    = settings.autoDetectTestType;
  this.updateApiKeyStatus();
  this.attachSettingsEventListeners();
  this.updateStorageUsage();
  console.log('✅ Settings page loaded');
};

CMSApp.prototype.attachSettingsEventListeners = function() {
  const toggleBtn   = document.getElementById('toggle-api-key-visibility');
  const apiKeyInput = document.getElementById('gemini-api-key');
  if (toggleBtn && apiKeyInput) {
    toggleBtn.addEventListener('click', () => {
      if (apiKeyInput.type === 'password') { apiKeyInput.type = 'text';     toggleBtn.textContent = '🙈'; }
      else                                 { apiKeyInput.type = 'password'; toggleBtn.textContent = '👁️'; }
    });
  }
  const saveKeyBtn     = document.getElementById('save-api-key');
  const testKeyBtn     = document.getElementById('test-api-key');
  const helpBtn        = document.getElementById('get-api-key-help');
  const saveSettingsBtn = document.getElementById('save-parser-settings');
  const resetBtn       = document.getElementById('reset-parser-settings');
  if (saveKeyBtn)      saveKeyBtn.addEventListener('click',      () => this.handleSaveApiKey());
  if (testKeyBtn)      testKeyBtn.addEventListener('click',      () => this.handleTestApiKey());
  if (helpBtn)         helpBtn.addEventListener('click',         () => this.showApiKeyHelp());
  if (saveSettingsBtn) saveSettingsBtn.addEventListener('click', () => this.handleSaveParserSettings());
  if (resetBtn)        resetBtn.addEventListener('click',        () => this.handleResetSettings());
};

CMSApp.prototype.handleSaveApiKey = function() {
  const apiKeyInput = document.getElementById('gemini-api-key');
  const apiKey = apiKeyInput ? apiKeyInput.value.trim() : '';
  if (!apiKey) { this.showAlert('Please enter an API key.', 'error'); return; }
  if (!apiKey.startsWith('AIza')) { this.showAlert('Invalid API key format. Gemini API keys start with "AIza".', 'error'); return; }
  if (this.saveApiKey(apiKey)) {
    this.showAlert('API key saved! Reinitializing parser...', 'success');
    this.initializeUltimateParser();
    this.updateApiKeyStatus();
  } else {
    this.showAlert('Failed to save API key.', 'error');
  }
};

CMSApp.prototype.handleTestApiKey = function() {
  const apiKey = this.getStoredApiKey();
  if (!apiKey) { this.showAlert('Please save an API key first.', 'warning'); return; }
  this.showProcessing('Testing API connection...');
  if (this.geminiModel) {
    this.geminiModel.generateContent('Respond with exactly: {"status": "connected"}')
      .then(() => { this.hideProcessing(); this.showAlert('✅ API key is working correctly!', 'success'); this.updateApiKeyStatus(true); })
      .catch(error => {
        this.hideProcessing();
        let msg = '❌ API key test failed. ';
        if (error.message.includes('API_KEY_INVALID')) msg += 'The API key is invalid.';
        else if (error.message.includes('quota') || error.message.includes('429')) msg += 'API quota exceeded.';
        else msg += 'Please check your key and billing settings.';
        this.showAlert(msg, 'error');
        this.updateApiKeyStatus(false);
      });
  } else {
    this.hideProcessing();
    this.showAlert('Parser not initialized. Please save API key first.', 'warning');
  }
};

CMSApp.prototype.updateApiKeyStatus = function(testResult = null) {
  const statusDiv  = document.getElementById('api-key-status');
  const statusText = document.getElementById('api-key-status-text');
  if (!statusDiv || !statusText) return;
  const hasKey = !!this.getStoredApiKey();
  if (testResult === true) {
    statusDiv.style.cssText  = 'display:block;background:rgba(40,167,69,0.1);border:1px solid #28a745;';
    statusText.style.color   = '#28a745';
    statusText.textContent   = '✅ API key is working correctly';
  } else if (testResult === false) {
    statusDiv.style.cssText  = 'display:block;background:rgba(220,53,69,0.1);border:1px solid #dc3545;';
    statusText.style.color   = '#dc3545';
    statusText.textContent   = '❌ API key test failed';
  } else if (hasKey) {
    statusDiv.style.cssText  = 'display:block;background:rgba(255,193,7,0.1);border:1px solid #ffc107;';
    statusText.style.color   = '#856404';
    statusText.textContent   = '🔑 API key saved (not tested)';
  } else {
    statusDiv.style.display  = 'none';
  }
};

CMSApp.prototype.showApiKeyHelp = function() {
  this.showAlert('Get a Gemini API key at https://aistudio.google.com/app/apikey — sign in, click Create API key, select your project, copy the key (starts with AIza...) and paste it here.', 'info');
};

CMSApp.prototype.handleSaveParserSettings = function() {
  const settings = {
    defaultExtractionMode: document.getElementById('default-extraction-mode')?.value  || 'smart',
    maxPdfPages:           parseInt(document.getElementById('max-pdf-pages')?.value)   || 10,
    enableMultiPass:       document.getElementById('enable-multi-pass')?.checked       || true,
    autoDetectTestType:    document.getElementById('auto-detect-test-type')?.checked   || true
  };
  if (this.saveParserSettings(settings)) this.showAlert('Parser settings saved!', 'success');
  else                                   this.showAlert('Failed to save settings.', 'error');
};

CMSApp.prototype.handleResetSettings = function() {
  if (!confirm('Reset all parser settings to defaults?')) return;
  const defaults = this.getDefaultSettings();
  document.getElementById('default-extraction-mode').value = defaults.defaultExtractionMode;
  document.getElementById('max-pdf-pages').value           = defaults.maxPdfPages;
  document.getElementById('enable-multi-pass').checked     = defaults.enableMultiPass;
  document.getElementById('auto-detect-test-type').checked = defaults.autoDetectTestType;
  this.saveParserSettings(defaults);
  this.showAlert('Settings reset to defaults!', 'success');
};

CMSApp.prototype.updateStorageUsage = function() {
  const usageSpan = document.getElementById('storage-usage');
  if (!usageSpan) return;
  try {
    let totalSize = 0;
    for (let key in localStorage) {
      if (localStorage.hasOwnProperty(key)) totalSize += localStorage[key].length;
    }
    usageSpan.textContent = `${(totalSize / 1024).toFixed(2)} KB`;
  } catch(e) { usageSpan.textContent = 'Unable to calculate'; }
};

