CMSApp.prototype.showProcessing = function(message) {
  let overlay = document.getElementById('processing-overlay');
  if (!overlay) {
    overlay = document.createElement('div');
    overlay.id = 'processing-overlay';
    overlay.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:99999;display:flex;align-items:center;justify-content:center;';
    overlay.innerHTML = `
      <div style="background:white;padding:30px 40px;border-radius:12px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,0.3);">
        <div style="font-size:32px;margin-bottom:12px;">⚙️</div>
        <div id="processing-message" style="font-size:16px;color:#495057;">${message || 'Processing...'}</div>
      </div>`;
    document.body.appendChild(overlay);
  } else {
    const msgEl = document.getElementById('processing-message');
    if (msgEl) msgEl.textContent = message || 'Processing...';
    overlay.style.display = 'flex';
  }
};

CMSApp.prototype.hideProcessing = function() {
  const overlay = document.getElementById('processing-overlay');
  if (overlay) overlay.style.display = 'none';
};

CMSApp.prototype.hideProcessingOverlay = CMSApp.prototype.hideProcessing;

CMSApp.prototype.updateProgress = function(percent, message) {
  const fill      = this.elements.aiProgressFill;
  const status    = this.elements.aiProcessingStatus;
  const container = this.elements.aiProgressContainer;
  if (container) container.style.display = 'block';
  if (fill)      fill.style.width        = percent + '%';
  if (status)    status.textContent      = message || '';
};

CMSApp.prototype.hideProgress = function() {
  const container = this.elements.aiProgressContainer;
  if (container) container.style.display = 'none';
};

