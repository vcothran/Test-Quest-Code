function renderLogPage() {
  const tbody = document.getElementById('log-tbody');
  if (!allData.log.length) { tbody.innerHTML=`<tr><td colspan="5"><div class="empty-state">No log entries yet</div></td></tr>`; return; }
  tbody.innerHTML = allData.log.slice(0,100).map(entry=>`
    <tr>
      <td style="font-size:0.8rem;white-space:nowrap">${formatDate(entry.timestamp)}</td>
      <td><span class="badge badge-${entry.action?.includes('BLOCK')||entry.action?.includes('DISABLE')||entry.action?.includes('DEACTIVATE')||entry.action?.includes('DELETE')?'blocked':'approved'}">${entry.action||'—'}</span></td>
      <td style="font-size:0.8rem">${escHtml(entry.adminEmail||'—')}</td>
      <td style="font-size:0.8rem">${escHtml(entry.targetId||'—')}</td>
      <td style="font-size:0.8rem;opacity:0.7">${escHtml(entry.details||'—')}</td>
    </tr>`).join('');
}

async function logAction(action, targetId, details) {
  const { collection, addDoc, serverTimestamp } = window.firebaseAdmin;
  try {
    await addDoc(collection(db,'moderationLog'),{ action, targetId, details, adminEmail:currentAdmin.email, timestamp:serverTimestamp() });
  } catch(e) { console.warn('Log error:',e); }
}

