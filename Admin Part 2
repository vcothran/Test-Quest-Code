// API KEYS PAGE
// ══════════════════════════════════════════════════════════════════
function renderApiKeysPage() {
  const search = (document.getElementById('apikey-search')?.value||'').toLowerCase();
  let keys = allData.apiKeys||[];
  if (search) keys = keys.filter(k=>(k.email||'').toLowerCase().includes(search)||(k.id||'').toLowerCase().includes(search));
  const tbody = document.getElementById('apikeys-tbody');
  if (!keys.length) {
    tbody.innerHTML = `<tr><td colspan="5"><div class="empty-state">No personal API keys assigned yet.<br><span style="font-size:12px;">Click "+ Assign Key" to get started. Teachers without a personal key use the system default.</span></div></td></tr>`;
    return;
  }
  tbody.innerHTML = keys.map(k => {
    const key     = k.apiKey||'';
    const masked  = key ? key.substring(0,8)+'••••••••••••'+key.slice(-4) : '—';
    const active  = k.apiKeyActive!==false;
    const badge   = active ? `<span class="badge badge-approved">Active</span>` : `<span class="badge badge-disabled">Deactivated</span>`;
    const assigned = k.assignedAt ? formatDate(k.assignedAt) : '—';
    const uid = escHtml(k.id);
    return `<tr>
      <td><div style="font-size:13px;color:#ecf0f1;">${escHtml(k.email||'—')}</div><div style="font-size:10px;opacity:0.35;font-family:monospace;margin-top:2px;">${uid}</div></td>
      <td style="font-family:monospace;font-size:12px;color:#8892a4;">${masked}</td>
      <td>${badge}</td>
      <td style="font-size:12px;color:#6c757d;">${assigned}</td>
      <td><div style="display:flex;gap:6px;flex-wrap:wrap;">
        ${active ? `<button class="btn-sm btn-sm-red" onclick="toggleApiKey('${uid}',false)">Deactivate</button>` : `<button class="btn-sm btn-sm-green" onclick="toggleApiKey('${uid}',true)">Activate</button>`}
        <button class="btn-sm btn-sm-gold" onclick="openEditKeyModal('${uid}')">Edit</button>
        <button class="btn-sm btn-sm-red" onclick="deleteApiKey('${uid}','${escHtml(k.email||k.id)}')">Delete</button>
      </div></td></tr>`;
  }).join('');
}

function openAssignKeyModal(prefillUid) {
  const input = document.getElementById('ak-teacher-input');
  input.value = prefillUid || '';
  input.dataset.uid = prefillUid || '';
  // If prefillUid, look up email to show something friendly
  if (prefillUid) {
    const t = allData.teachers.find(t=>t.id===prefillUid);
    if (t && t.email) { input.value = t.email; }
  }
  document.getElementById('ak-key-input').value = '';
  document.getElementById('ak-active-check').checked = true;
  document.getElementById('ak-save-btn').dataset.editId = '';
  document.getElementById('ak-modal-title').textContent = 'Assign API Key';
  document.getElementById('ak-teacher-matches').innerHTML = '';
  document.getElementById('assign-key-modal').classList.add('open');
}

function openEditKeyModal(teacherUid) {
  const keyData = (allData.apiKeys||[]).find(k=>k.id===teacherUid);
  if (!keyData) return;
  const input = document.getElementById('ak-teacher-input');
  input.value = keyData.email||keyData.id;
  input.dataset.uid = teacherUid;
  document.getElementById('ak-key-input').value = keyData.apiKey||'';
  document.getElementById('ak-active-check').checked = keyData.apiKeyActive!==false;
  document.getElementById('ak-save-btn').dataset.editId = teacherUid;
  document.getElementById('ak-modal-title').textContent = 'Edit API Key';
  document.getElementById('ak-teacher-matches').innerHTML = '';
  document.getElementById('assign-key-modal').classList.add('open');
}

function closeAssignKeyModal() {
  document.getElementById('assign-key-modal').classList.remove('open');
  document.getElementById('ak-teacher-matches').innerHTML = '';
}

function akSearchTeachers() {
  const val = document.getElementById('ak-teacher-input').value.toLowerCase();
  const box = document.getElementById('ak-teacher-matches');
  if (!val||val.length<2) { box.innerHTML=''; return; }
  const matches = (allData.teachers||[]).filter(t=>(t.email||'').toLowerCase().includes(val)||(t.id||'').toLowerCase().includes(val)).slice(0,6);
  if (!matches.length) { box.innerHTML=''; return; }
  box.innerHTML = matches.map(t=>
    `<div onclick="akSelectTeacher('${escHtml(t.id)}','${escHtml(t.email||t.id)}')"
      style="padding:8px 12px;background:rgba(255,255,255,0.05);border-radius:4px;cursor:pointer;font-size:13px;margin-top:3px;color:#ecf0f1;border:1px solid rgba(255,255,255,0.06);font-family:'Crimson Pro',serif;">
      ${escHtml(t.email||t.id)}
      ${t.displayName?`<span style="opacity:0.5;margin-left:6px;font-size:11px;">${escHtml(t.displayName)}</span>`:''}
    </div>`
  ).join('');
}

function akSelectTeacher(uid, display) {
  const input = document.getElementById('ak-teacher-input');
  input.value = display;
  input.dataset.uid = uid;
  document.getElementById('ak-teacher-matches').innerHTML = '';
}

async function saveApiKeyAssignment() {
  const { doc, setDoc } = window.firebaseAdmin;
  const btn    = document.getElementById('ak-save-btn');
  const input  = document.getElementById('ak-teacher-input');
  const apiKey = document.getElementById('ak-key-input').value.trim();
  const active = document.getElementById('ak-active-check').checked;
  const uid    = input.dataset.uid || btn.dataset.editId || input.value.trim();
  if (!uid)    { alert('Please select a teacher from the list.'); return; }
  if (!apiKey) { alert('Please enter an API key.'); return; }
  if (!apiKey.startsWith('AIza')) { alert('That doesn\'t look like a valid Gemini key (should start with "AIza").'); return; }
  btn.disabled=true; btn.textContent='Saving…';
  const teacher = (allData.teachers||[]).find(t=>t.id===uid||t.email===input.value.trim());
  const email   = teacher?.email || input.value.trim();
  try {
    await setDoc(doc(db,'teachers',uid),{ apiKey, apiKeyActive:active, email, assignedAt:new Date().toISOString(), assignedBy:'admin' },{ merge:true });
    allData.apiKeys = allData.apiKeys||[];
    const existing = allData.apiKeys.findIndex(k=>k.id===uid);
    const updated  = { id:uid, apiKey, apiKeyActive:active, email, assignedAt:new Date().toISOString() };
    if (existing>=0) allData.apiKeys[existing]=updated; else allData.apiKeys.push(updated);
    closeAssignKeyModal();
    renderApiKeysPage();
    document.getElementById('apikey-tab-count').textContent = allData.apiKeys.length;
    showToast('API key saved ✓','success');
    await logAction('ASSIGN_API_KEY', uid, `Key assigned to ${email}`);
  } catch(e) { alert('Error saving key: '+e.message); }
  finally { btn.disabled=false; btn.textContent='Save Key'; }
}

async function toggleApiKey(teacherUid, active) {
  const { doc, updateDoc } = window.firebaseAdmin;
  const label = active?'activate':'deactivate';
  if (!confirm(`Are you sure you want to ${label} this teacher's API key?`)) return;
  try {
    await updateDoc(doc(db,'teachers',teacherUid),{ apiKeyActive:active });
    const k = (allData.apiKeys||[]).find(k=>k.id===teacherUid);
    if (k) k.apiKeyActive = active;
    renderApiKeysPage();
    showToast(`Key ${active?'activated':'deactivated'} ✓`, active?'success':'');
    await logAction(active?'ACTIVATE_API_KEY':'DEACTIVATE_API_KEY', teacherUid, `Key ${label}d`);
  } catch(e) { alert('Error: '+e.message); }
}

async function deleteApiKey(teacherUid, displayName) {
  const { doc, updateDoc } = window.firebaseAdmin;
  if (!confirm(`Delete API key for ${displayName}?\n\nThey will fall back to the system default key.`)) return;
  try {
    await updateDoc(doc(db,'teachers',teacherUid),{ apiKey:null, apiKeyActive:false });
    allData.apiKeys = (allData.apiKeys||[]).filter(k=>k.id!==teacherUid);
    renderApiKeysPage();
    document.getElementById('apikey-tab-count').textContent = allData.apiKeys.length;
    showToast('API key deleted ✓');
    await logAction('DELETE_API_KEY', teacherUid, `Key deleted for ${displayName}`);
  } catch(e) { alert('Error: '+e.message); }
}

