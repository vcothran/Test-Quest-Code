function openEmailModal(teacherEmail, episodeTitle) {
  document.getElementById('email-to').value = teacherEmail;
  document.getElementById('email-subject').value = episodeTitle ? `Content Review — "${episodeTitle}"` : 'Test Quest — Account Notice';
  document.getElementById('email-body').value = episodeTitle
    ? `Hello,\n\nWe are reaching out regarding content you recently submitted in Test Quest.\n\nThe episode "${episodeTitle}" has been flagged during our content review process. Please review our content guidelines and resubmit with appropriate changes.\n\nIf you have questions, please reply to this email.\n\nTest Quest Administration`
    : `Hello,\n\nThis is a notice from Test Quest administration regarding your account.\n\nTest Quest Administration`;
  document.getElementById('email-modal').classList.add('open');
}
function sendEmailViaMailto() {
  const to=document.getElementById('email-to').value, subject=encodeURIComponent(document.getElementById('email-subject').value), body=encodeURIComponent(document.getElementById('email-body').value);
  window.open(`mailto:${to}?subject=${subject}&body=${body}`);
  logAction('EMAIL_TEACHER',to,document.getElementById('email-subject').value);
  closeModal('email-modal');
}
function copyEmailToClipboard() {
  const text=`To: ${document.getElementById('email-to').value}\nSubject: ${document.getElementById('email-subject').value}\n\n${document.getElementById('email-body').value}`;
  navigator.clipboard.writeText(text).then(()=>showToast('Copied to clipboard','success'));
}

