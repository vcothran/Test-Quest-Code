function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m => { m.addEventListener('click',e=>{ if(e.target===m) m.classList.remove('open'); }); });
document.getElementById('assign-key-modal').addEventListener('click',e=>{ if(e.target===document.getElementById('assign-key-modal')) closeAssignKeyModal(); });

function escHtml(str) { return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function formatDate(val) {
  if (!val) return '—';
  try { const d=val?.toDate?val.toDate():new Date(val); return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}); }
  catch { return '—'; }
}
function showToast(msg,type='') { const t=document.getElementById('toast'); t.textContent=msg; t.className=`toast ${type} show`; setTimeout(()=>t.classList.remove('show'),3000); }


// ══════════════════════════════════════════════════════════════════
// SYSTEM HEALTH CHECK
// ══════════════════════════════════════════════════════════════════
async function runHealthCheck() {
  const btn = document.getElementById('health-check-btn');
  const log = document.getElementById('health-log');
  btn.disabled = true;
  btn.textContent = '⟳ Checking…';
  log.innerHTML = '';

  function addLog(msg, color) {
    const line = document.createElement('div');
    line.style.color = color || 'var(--mist)';
    line.textContent = new Date().toLocaleTimeString() + '  ' + msg;
    log.appendChild(line);
    log.scrollTop = log.scrollHeight;
  }

  function setCard(service, status, detail, ok) {
    const card  = document.getElementById('health-' + service + '-card');
    const valEl = document.getElementById('health-' + service + '-status');
    const detEl = document.getElementById('health-' + service + '-detail');
    valEl.textContent = status;
    detEl.textContent = detail;
    valEl.style.color = ok === true ? '#27ae60' : ok === false ? '#e74c3c' : '#e8b84b';
    if (card) card.style.borderColor = ok === true
      ? 'rgba(39,174,96,0.4)'
      : ok === false ? 'rgba(231,76,60,0.4)'
      : 'rgba(232,184,75,0.4)';
  }

  addLog('Starting health check…');

  // 1. Firebase
  addLog('Checking Firebase / Firestore…');
  try {
    const { collection, getDocs } = window.firebaseAdmin;
    const start = Date.now();
    await getDocs(collection(db, 'episodes'));
    const ms = Date.now() - start;
    setCard('firebase', '✅ Online', 'Responded in ' + ms + 'ms', true);
    addLog('✅ Firebase OK — ' + ms + 'ms', '#27ae60');
  } catch(e) {
    setCard('firebase', '❌ Error', e.message.substring(0, 60), false);
    addLog('❌ Firebase ERROR: ' + e.message, '#e74c3c');
  }

  // 2. Anthropic (via generateNarrative Cloud Function)
  addLog('Checking Anthropic AI (generateNarrative)…');
  try {
    const { getFunctions, httpsCallable } = await import('https://www.gstatic.com/firebasejs/9.22.1/firebase-functions.js');
    const fns = getFunctions(db.app);
    const fn  = httpsCallable(fns, 'generateNarrative');
    const start = Date.now();
    const result = await fn({ requestData: { model: 'claude-sonnet-4-5', maxTokens: 10, promptText: 'Reply with the single word: OK' } });
    const ms = Date.now() - start;
    if (result.data && result.data.success) {
      setCard('anthropic', '✅ Online', 'Responded in ' + ms + 'ms', true);
      addLog('✅ Anthropic OK — ' + ms + 'ms', '#27ae60');
    } else {
      setCard('anthropic', '⚠️ Degraded', 'Unexpected response format', null);
      addLog('⚠️ Anthropic returned unexpected response', '#e8b84b');
    }
  } catch(e) {
    const isBilling = (e.message || '').includes('credit') || (e.message || '').includes('400');
    setCard('anthropic', '❌ Error',
      isBilling ? 'Credit balance too low — top up at console.anthropic.com' : e.message.substring(0, 60),
      false);
    addLog('❌ Anthropic: ' + (isBilling
      ? 'Out of credits — visit console.anthropic.com/settings/billing'
      : e.message), '#e74c3c');
  }

  // 3. Gemini (via getGeminiKey Cloud Function)
  addLog('Checking Gemini API key…');
  try {
    const { getFunctions, httpsCallable } = await import('https://www.gstatic.com/firebasejs/9.22.1/firebase-functions.js');
    const fns = getFunctions(db.app);
    const fn  = httpsCallable(fns, 'getGeminiKey');
    const start = Date.now();
    const result = await fn();
    const ms = Date.now() - start;
    if (result.data && result.data.key) {
      setCard('gemini', '✅ Online', 'Key available (' + result.data.source + ') — ' + ms + 'ms', true);
      addLog('✅ Gemini key OK — source: ' + result.data.source + ' — ' + ms + 'ms', '#27ae60');
    } else {
      setCard('gemini', '⚠️ No Key', 'Key not configured in Firebase Secrets', null);
      addLog('⚠️ Gemini: no key returned', '#e8b84b');
    }
  } catch(e) {
    setCard('gemini', '❌ Error', e.message.substring(0, 60), false);
    addLog('❌ Gemini ERROR: ' + e.message, '#e74c3c');
  }

  // 4. Imagen (via generateCutsceneImage — minimal 1:1 test)
  addLog('Checking Imagen / cutscene image service…');
  try {
    const { getFunctions, httpsCallable } = await import('https://www.gstatic.com/firebasejs/9.22.1/firebase-functions.js');
    const fns = getFunctions(db.app);
    const fn  = httpsCallable(fns, 'generateCutsceneImage');
    const start = Date.now();
    const result = await fn({ imagePrompt: 'A single gold coin on a dark wooden table', aspectRatio: '1:1' });
    const ms = Date.now() - start;
    if (result.data && result.data.success) {
      setCard('imagen', '✅ Online', 'Image generated in ' + ms + 'ms', true);
      addLog('✅ Imagen OK — ' + ms + 'ms', '#27ae60');
    } else {
      setCard('imagen', '⚠️ Degraded', 'No image data returned', null);
      addLog('⚠️ Imagen returned no image data', '#e8b84b');
    }
  } catch(e) {
    setCard('imagen', '❌ Error', e.message.substring(0, 60), false);
    addLog('❌ Imagen ERROR: ' + e.message, '#e74c3c');
  }

  const now = new Date().toLocaleString();
  document.getElementById('health-last-checked').textContent = 'Last checked: ' + now;
  addLog('Health check complete — ' + now, 'var(--gold)');

  // Save result to Firestore for audit trail
  try {
    const { collection, addDoc, serverTimestamp } = window.firebaseAdmin;
    await addDoc(collection(db, 'systemHealth'), {
      checkedBy:  currentAdmin.email,
      checkedAt:  serverTimestamp(),
      anthropic:  document.getElementById('health-anthropic-status').textContent,
      gemini:     document.getElementById('health-gemini-status').textContent,
      imagen:     document.getElementById('health-imagen-status').textContent,
      firebase:   document.getElementById('health-firebase-status').textContent,
    });
  } catch(e) { /* non-critical — don't block UI */ }

  btn.disabled = false;
  btn.textContent = '◆ Run Health Check';
}

