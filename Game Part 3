/* === SECTION 11: Authentication & Episode Management === */

      const handleAuthState = async (user) => {
        if (user) {
          if (isTestMode && user.uid === 'testUser123') {
            if (!player || !player.name) {
              player = { uid: user.uid, name: 'Test Hero', className: 'Pathfinder', xp: 0, focus: 100 };
              initializePlayerAbilities();
              showScreen('characterSelect');
              csLoadCharacters(user.uid);
            } else {
              await loadGameContent();
              showScreen('episodeSelection');
            }
          } else {
            const playerRef  = doc(db, "players", user.uid);
            const playerSnap = await getDoc(playerRef);

            if (playerSnap.exists()) {
              player = { uid: user.uid, ...playerSnap.data() };
              if (player.xp    == null) player.xp    = 0;
              if (player.focus == null) player.focus  = 100;
              initializePlayerAbilities();

              if (!player.role) {
                showRoleSelection(user);
              } else if (player.role === 'teacher') {
                handleTeacherLogin(user);
