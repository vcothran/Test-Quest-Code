      // -------------------------------------------------------
      // CHARACTER SELECT
      // -------------------------------------------------------
      const CS_CLASSES = {
        Strategist:  { icon: '⚔️',  color: '#e74c3c', tagline: 'Masters of tactical thinking' },
        Arcanist:    { icon: '🔮',  color: '#9b59b6', tagline: 'Wielders of mystical knowledge' },
