      setTimeout(() => {
        (window.csCharacters || []).forEach(char => {
          const card = document.querySelector(`[data-slot="${char.slotIndex}"]`);
          if (!card) return;
          // Add portrait thumbnail if character has one
          if (char.currentPortraitUrl && !card.querySelector('.cs-portrait-thumb')) {
            const thumb = document.createElement('img');
            thumb.className = 'cs-portrait-thumb';
            // Sanitize — old Firestore records stored raw base64 without data: prefix
            const _thumbUrl = char.currentPortraitUrl;
            thumb.src = (_thumbUrl.startsWith('data:') || _thumbUrl.startsWith('http'))
              ? _thumbUrl : 'data:image/jpeg;base64,' + _thumbUrl;
            thumb.style.cssText = 'width:48px;height:48px;border-radius:50%;border:2px solid #c9a84c;object-fit:cover;position:absolute;top:10px;right:10px;cursor:pointer;';
            thumb.onclick = (e) => { e.stopPropagation(); window.showPortraitGallery(); };
            card.style.position = 'relative';
            card.appendChild(thumb);
          }
          // Add "Create Portrait" button if no portrait exists
          if (!char.currentPortraitUrl && !card.querySelector('.cs-create-portrait-btn')) {
            const btn = document.createElement('button');
            btn.className = 'cs-create-portrait-btn game-btn';
            btn.style.cssText = 'font-size:11px;padding:6px 12px;margin-top:8px;background:linear-gradient(145deg,#667eea,#764ba2);display:block;width:100%;';
            btn.textContent = '🎨 Create Portrait';
            btn.onclick = (e) => {
              e.stopPropagation();
              window.showPortraitCreationScreen(char.id, char.name, char.className);
            };
            card.appendChild(btn);
          }
        });
      }, 100);
    };
    console.log('✅ Portrait grid patch applied');
  }
}, 2000);

