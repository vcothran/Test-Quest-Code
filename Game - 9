];

// Base rarity weights — used at threshold 5
window.LOOT_WEIGHTS_BASE = { common: 60, uncommon: 25, rare: 12, legendary: 3 };

// Escalating weights by threshold level — longer streak = better odds
// Resets to base after a legendary drop
window.LOOT_WEIGHTS_BY_THRESHOLD = {
  5:  { common: 60, uncommon: 25, rare: 12, legendary: 3  },
  10: { common: 45, uncommon: 30, rare: 18, legendary: 7  },
  15: { common: 30, uncommon: 33, rare: 25, legendary: 12 },
  20: { common: 20, uncommon: 30, rare: 32, legendary: 18 },
  25: { common: 10, uncommon: 25, rare: 37, legendary: 28 },
};

// Guaranteed drop thresholds
window.LOOT_STREAK_THRESHOLDS = [5, 10, 15, 20, 25];

// Surprise drop config — random chance between thresholds
window.SURPRISE_DROP_CHANCE     = 0.08;  // 8% chance on each non-threshold correct answer
window.SURPRISE_DROP_COOLDOWN   = 5;     // Min questions between surprise drops
window.SURPRISE_DROP_BUFFER     = 2;     // No surprise within this many of a threshold
window.SURPRISE_DROP_WEIGHTS    = { common: 55, uncommon: 32, rare: 11, legendary: 2 };

// State tracking
window._lootRarityReset   = false;  // True after legendary — next threshold uses base weights
window._lastSurpriseAt    = -99;    // Question index of last surprise drop
window._totalQuestionsAnswered = 0; // Running count for surprise cooldown

// ─────────────────────────────────────────────────────────────────────────
// WEIGHTED RANDOM LOOT PICKER
// ─────────────────────────────────────────────────────────────────────────
window.pickLootDrop = (weights) => {
  const w = weights || window.LOOT_WEIGHTS_BASE;
  const roll = Math.random() * 100;
  let rarity;
  if      (roll < w.legendary)                          rarity = 'legendary';
  else if (roll < w.legendary + w.rare)                 rarity = 'rare';
  else if (roll < w.legendary + w.rare + w.uncommon)    rarity = 'uncommon';
  else                                                  rarity = 'common';

  const pool = window.LOOT_POOL.filter(l => l.rarity === rarity);
  const loot = pool[Math.floor(Math.random() * pool.length)];

  // Reset rarity escalation after a legendary drop
  if (loot && loot.rarity === 'legendary') {
    window._lootRarityReset = true;
    console.log('👑 Legendary drop! Rarity resets to base for next cycle.');
  }
  return loot;
};

// Get weights for a specific threshold — respects reset flag
window.getLootWeightsForThreshold = (threshold) => {
  if (window._lootRarityReset) {
    window._lootRarityReset = false; // Consume the reset
    return window.LOOT_WEIGHTS_BASE;
  }
  return window.LOOT_WEIGHTS_BY_THRESHOLD[threshold] || window.LOOT_WEIGHTS_BASE;
};

// ─────────────────────────────────────────────────────────────────────────
// APPLY LOOT EFFECT to player
// ─────────────────────────────────────────────────────────────────────────
window.applyLootDrop = async (loot) => {
  if (!loot || !player) return;
  window._totalQuestionsAnswered++;

  switch (loot.type) {
    case 'xp':
      player.xp = (player.xp || 0) + loot.value;
      if (typeof savePlayerProgress === 'function') await savePlayerProgress();
      if (window.checkForLevelUp) window.checkForLevelUp();
      if (window.updateHUDLevel)  window.updateHUDLevel();
      break;

    case 'focus':
      const maxFocus = window.getMaxFocus ? window.getMaxFocus(window.getPlayerLevel()) : 100;
      if (loot.value === 999) {
        player.focus = maxFocus; // Full restore
      } else {
        player.focus = Math.min(maxFocus, (player.focus || 0) + loot.value);
      }
      if (typeof updatePlayerStats === 'function') updatePlayerStats();
      break;

    case 'effect':
      if (!player.activeEffects) player.activeEffects = {};
      if (loot.id === 'double_next') {
        player.activeEffects.doubleXPNext = true;
      } else if (loot.id === 'double_3') {
        player.activeEffects.doubleXPDuration = loot.value;
        player.activeEffects.bonusXP = 2;
      } else if (loot.id === 'invincible') {
        player.activeEffects.invincibleQuestions = loot.value;
      } else if (loot.id === 'ability_rech') {
        // Restore 1 use to a random ability that has uses
        if (player.abilities) {
          const keys = Object.keys(player.abilities).filter(k =>
            player.abilities[k].uses >= 0 && player.abilities[k].uses < (player.abilities[k].maxUses || 3)
          );
          if (keys.length) {
            const key = keys[Math.floor(Math.random() * keys.length)];
            player.abilities[key].uses++;
          }
        }
      }
      if (typeof savePlayerProgress === 'function') await savePlayerProgress();
      break;
  }
};

