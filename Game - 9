// HOOK INTO STREAK TRACKING
// Fires after each correct answer — checks streak thresholds
// Uses MutationObserver on feedback-box (same pattern as Section 18)
// ─────────────────────────────────────────────────────────────────────────
window._lastLootStreakFired = 0; // Track last streak that triggered a drop

window.checkForLootDrop = () => {
  if (!player || !sessionStats) return;
  const streak = sessionStats.currentStreak || 0;
  if (streak < 1) return;
  if (streak === window._lastLootStreakFired) return;

  // ── GUARANTEED DROP at threshold ───────────────────────────────────────
  const isThreshold = window.LOOT_STREAK_THRESHOLDS.includes(streak);
  if (isThreshold) {
    window._lastLootStreakFired = streak;
    const weights = window.getLootWeightsForThreshold(streak);
    const loot = window.pickLootDrop(weights);
    if (loot) {
      console.log(`🎲 Guaranteed drop at streak ${streak}:`, loot.label, `(${loot.rarity})`);
      window.showLootDropOverlay(loot, streak);
    }
    return;
  }

  // ── SURPRISE DROP between thresholds ──────────────────────────────────
  // Only between threshold 5+ and with cooldown
  if (streak < 5) return;
  const questionsSinceSurprise = window._totalQuestionsAnswered - window._lastSurpriseAt;
  if (questionsSinceSurprise < window.SURPRISE_DROP_COOLDOWN) return;
  // No surprise if we're within buffer distance of an upcoming threshold
  const nearThreshold = window.LOOT_STREAK_THRESHOLDS.some(t => t > streak && t - streak <= window.SURPRISE_DROP_BUFFER);
  if (nearThreshold) return;

  // Roll for surprise
  if (Math.random() < window.SURPRISE_DROP_CHANCE) {
    window._lastSurpriseAt = window._totalQuestionsAnswered;
    const loot = window.pickLootDrop(window.SURPRISE_DROP_WEIGHTS);
    if (loot) {
      console.log(`🎁 Surprise drop at streak ${streak}:`, loot.label, `(${loot.rarity})`);
      window.showLootDropOverlay(loot, `${streak} ✨ Surprise`);
    }
  }
};

// Reset streak tracker at start of each episode
window._s20_resetStreak = () => {
  window._lastLootStreakFired    = 0;
  window._lastSurpriseAt         = -99;
  window._totalQuestionsAnswered = 0;
};

