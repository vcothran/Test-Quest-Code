  }

  // Add "Create Portrait" option to existing characters that have no portrait
  // by patching csRenderGrid to add a portrait button to each card
  const origCsRenderGrid = window.csRenderGrid;
  if (origCsRenderGrid && !window._portraitGridPatched) {
    window._portraitGridPatched = true;
    window.csRenderGrid = () => {
      origCsRenderGrid();
