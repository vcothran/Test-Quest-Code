  }
};

// Check after episode completes
window.checkEpisodeTitleTriggers = () => {
  if (!player || !sessionStats) return;
  const accuracy = sessionStats.calculateAccuracy();

  // Perfect episode
  if (accuracy === 100) {
    window.awardTitle('perfectionist');
    window.awardBadge('perfect_ep');
  }

  // First episode
  const completed = (player.episodesCompleted || 0) + 1;
  player.episodesCompleted = completed;
  if (completed === 1) window.awardBadge('first_episode');
  if (completed >= 3)  window.awardTitle('thorough');

  // Iron will — finished after hitting 0 focus
  if (player._hitZeroFocus) {
    window.awardTitle('iron_will');
    player._hitZeroFocus = false;
  }
};

