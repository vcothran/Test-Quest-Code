
// ─────────────────────────────────────────────────────────────────────────
// PORTRAIT HISTORY GALLERY
// Shows all saved portraits for the current character
// ─────────────────────────────────────────────────────────────────────────
window.showPortraitGallery = async () => {
  if (!player || !player.uid || !player.activeCharacterId) return;

  const overlay = document.createElement('div');
  overlay.id = 'portrait-gallery-overlay';
  overlay.style.cssText = `
    position:fixed;inset:0;background:rgba(0,0,0,0.95);
    display:flex;align-items:center;justify-content:center;
    z-index:99997;padding:20px;box-sizing:border-box;overflow-y:auto;`;

  overlay.innerHTML = `
    <div style="background:linear-gradient(145deg,#1a2035,#0d1117);
                border:2px solid rgba(201,168,76,0.3);border-radius:24px;
                padding:36px;max-width:700px;width:100%;
                box-shadow:0 30px 80px rgba(0,0,0,0.7);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
        <div>
          <div style="font-family:'Cinzel',serif;font-size:20px;color:#c9a84c;">Portrait Hall</div>
          <div style="font-size:13px;color:#8892a4;margin-top:4px;">${player.name}'s Journey</div>
        </div>
        <button onclick="document.getElementById('portrait-gallery-overlay').remove()"
          style="background:none;border:none;color:#8892a4;cursor:pointer;font-size:24px;opacity:0.6;">✕</button>
      </div>
      <div id="gallery-portraits-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:16px;">
        <div style="color:#8892a4;font-style:italic;grid-column:1/-1;text-align:center;padding:2rem;">
          ⏳ Loading portraits...
        </div>
      </div>
      <div style="margin-top:24px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.08);">
        <button onclick="window.requestPortraitRegen()"
          style="padding:12px 24px;background:rgba(102,126,234,0.15);
                 border:1px solid rgba(102,126,234,0.3);border-radius:10px;
                 color:#667eea;font-size:13px;cursor:pointer;font-family:'Cinzel',serif;">
          🔄 Request New Portrait (${window.PORTRAIT_REGEN_COST} XP · once per ${window.PORTRAIT_REGEN_DAYS} days)
        </button>
      </div>
    </div>`;

  // Close on backdrop click
  overlay.onclick = (e) => { if (e.target === overlay) overlay.remove(); };
  // Close on Escape
  const galleryEsc = (e) => {
    if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', galleryEsc); }
  };
  document.addEventListener('keydown', galleryEsc);

  document.body.appendChild(overlay);

  // Load portraits from Firestore
  try {
    // Fetch from subcollection first, fall back to flat portraitData collection
    const portraitsSnap = await getDocs(
      collection(db, 'players', player.uid, 'characters', player.activeCharacterId, 'portraits')
    );

    let portraitDocs = portraitsSnap.docs;

    // If subcollection is empty, check flat portraitData collection (older portraits)
    if (!portraitDocs.length) {
      try {
        const flatSnap = await getDocs(
          query(collection(db, 'portraitData'),
            where('uid', '==', player.uid),
            where('characterId', '==', player.activeCharacterId))
        );
        if (flatSnap.docs.length) {
          // Remap flat docs to match subcollection shape
          portraitDocs = flatSnap.docs.map(d => ({
            id: d.id,
            data: () => ({
              level: d.data().level || 0,
              url: d.data().dataUrl || d.data().url || '',
              path: d.data().path || '',
              description: '',
              generatedAt: d.data().createdAt || null,
              milestone: window.PORTRAIT_MILESTONES && window.PORTRAIT_MILESTONES.includes(d.data().level)
            })
          }));
          console.log('📸 Loaded', portraitDocs.length, 'portraits from portraitData fallback');
        }
      } catch(fe) { console.warn('portraitData fallback failed:', fe); }
    }

    const grid = document.getElementById('gallery-portraits-grid');
    if (!portraitDocs.length) {
      grid.innerHTML = `
        <div style="grid-column:1/-1;text-align:center;padding:2rem;">
          <div style="color:#8892a4;font-style:italic;margin-bottom:20px;">No portraits yet — paint your legend!</div>
          <button onclick="document.getElementById('portrait-gallery-overlay').remove(); window.showPortraitCreationScreen('${player.activeCharacterId}','${player.name}','${player.className}');"
            style="padding:14px 28px;background:linear-gradient(135deg,#667eea,#764ba2);
                   border:none;border-radius:12px;color:white;font-size:15px;
                   font-weight:700;cursor:pointer;font-family:'Cinzel',serif;">
            🎨 Create My First Portrait
          </button>
        </div>`;
      return;
    }

    const sortedDocs = portraitDocs.slice().sort((a,b) => (a.data().level||0) - (b.data().level||0));
    const activeUrl = player.currentPortraitUrl || '';

    // Store portrait URLs in a lookup so onclick doesn't embed giant base64 strings inline
    window._galleryPortraits = sortedDocs.map(d => {
      const p = d.data();
      return {
        url: p.url && (p.url.startsWith('data:')||p.url.startsWith('http')) ? p.url : 'data:image/jpeg;base64,'+p.url,
        docId: d.id,
        level: p.level,
        milestone: p.milestone,
        generatedAt: p.generatedAt
      };
    });

    grid.innerHTML = window._galleryPortraits.map((p, idx) => {
      const date = p.generatedAt?.toDate ? p.generatedAt.toDate().toLocaleDateString()
                 : p.generatedAt ? new Date(p.generatedAt).toLocaleDateString() : '—';
      const isActive = activeUrl && p.url === activeUrl;
      return `
        <div style="text-align:center;">
          <div style="position:relative;display:inline-block;width:100%;">
            <img src="${p.url}" alt="Level ${p.level} portrait"
              style="width:100%;border-radius:10px;border:3px solid ${isActive ? '#27ae60' : p.milestone ? '#c9a84c' : 'rgba(255,255,255,0.12)'};
                     box-shadow:0 4px 16px rgba(0,0,0,0.4);cursor:pointer;"
              onclick="window.viewPortraitFull(window._galleryPortraits[${idx}].url,'${player.name}','Level ${p.level}')">
            ${isActive ? `<div style="position:absolute;top:6px;left:6px;background:#27ae60;color:#fff;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;font-family:'Cinzel',serif;">✓ ACTIVE</div>` : ''}
            ${p.milestone ? `<div style="position:absolute;top:6px;right:6px;background:#c9a84c;color:#000;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;font-family:'Cinzel',serif;">MILESTONE</div>` : ''}
          </div>
          <div style="font-family:'Cinzel',serif;font-size:12px;color:#c9a84c;margin-top:8px;">Level ${p.level}</div>
          <div style="font-size:10px;color:#4a5568;margin-top:2px;">${date}</div>
          ${isActive
            ? `<div style="margin-top:8px;padding:6px 10px;background:rgba(39,174,96,0.15);border:1px solid #27ae60;border-radius:8px;font-size:10px;color:#27ae60;font-family:'Cinzel',serif;">Active Portrait</div>`
            : `<button onclick="window.setActivePortrait(window._galleryPortraits[${idx}].url, window._galleryPortraits[${idx}].docId)"
                style="margin-top:8px;padding:6px 14px;background:linear-gradient(135deg,#2c3e50,#34495e);
                       border:1px solid rgba(201,168,76,0.4);border-radius:8px;color:#c9a84c;
                       font-size:10px;font-family:'Cinzel',serif;cursor:pointer;width:100%;">
                ⚡ Set as Active
              </button>`}
        </div>`;
    }).join('');
  } catch(e) {
    console.error('Failed to load portraits:', e);
  }
};

// ─────────────────────────────────────────────────────────────────────────
// SET ACTIVE PORTRAIT — player chooses which portrait to display
// ─────────────────────────────────────────────────────────────────────────
window.setActivePortrait = async (url, docId) => {
  console.log('⚡ setActivePortrait called, uid:', player && player.uid, 'docId:', docId);
  if (!player || !player.uid) { console.warn('setActivePortrait: no player'); return; }
  try {
    // Update player object
    player.currentPortraitUrl = url;
    // Save to character doc and top-level player doc
    const portraitUpdate = { currentPortraitUrl: url };
    await setDoc(doc(db, 'players', player.uid, 'characters', player.activeCharacterId),
      portraitUpdate, { merge: true });
    console.log('✅ Character doc updated');
    await setDoc(doc(db, 'players', player.uid),
      portraitUpdate, { merge: true });
    console.log('✅ Player doc updated');
    // Update HUD thumbnail — use window reference to avoid scope issues
    if (window.updateHUDPortrait) window.updateHUDPortrait();
    // Show notification safely
    if (typeof showNotification === 'function') {
      showNotification('✨ Portrait updated!', 'xp-gain');
    } else if (window.showNotification) {
      window.showNotification('✨ Portrait updated!', 'xp-gain');
    }
    // Refresh gallery to show new active state
    const gallery = document.getElementById('portrait-gallery-overlay');
    if (gallery) gallery.remove();
    setTimeout(() => window.showPortraitGallery(), 200);
    console.log('✅ Active portrait set:', docId);
  } catch(e) { console.error('Could not set active portrait:', e); }
};

window.viewPortraitFull = (url, name, label) => {
  const modal = document.createElement('div');
  modal.style.cssText = `position:fixed;inset:0;background:rgba(0,0,0,0.95);display:flex;align-items:center;justify-content:center;z-index:99999;cursor:pointer;`;
  modal.onclick = () => modal.remove();
  modal.innerHTML = `
    <div style="text-align:center;max-width:400px;padding:20px;">
      <img src="${url && (url.startsWith('data:')||url.startsWith('http')) ? url : 'data:image/jpeg;base64,'+url}" style="width:100%;border-radius:16px;border:3px solid #c9a84c;box-shadow:0 0 60px rgba(201,168,76,0.3);">
      <div style="font-family:'Cinzel',serif;color:#c9a84c;margin-top:16px;font-size:16px;">${name}</div>
      <div style="color:#8892a4;font-size:12px;margin-top:4px;">${label}</div>
      <div style="color:#4a5568;font-size:11px;margin-top:16px;">Tap anywhere to close</div>
    </div>`;
  document.body.appendChild(modal);
};

// ─────────────────────────────────────────────────────────────────────────
// RATE-LIMITED STUDENT REGENERATION REQUEST
// ─────────────────────────────────────────────────────────────────────────
window.requestPortraitRegen = async () => {
  if (!player || !player.uid || !player.activeCharacterId) return;

  // Check XP
  if ((player.xp || 0) < window.PORTRAIT_REGEN_COST) {
    alert(`You need ${window.PORTRAIT_REGEN_COST} XP to request a new portrait. Keep playing to earn more!`);
    return;
  }

  // Check cooldown from Firestore
  try {
    const charSnap = await getDoc(doc(db, 'players', player.uid, 'characters', player.activeCharacterId));
    if (charSnap.exists()) {
      const lastRegen = charSnap.data().lastPortraitRegen;
      if (lastRegen) {
        const daysSince = (Date.now() - new Date(lastRegen).getTime()) / (1000 * 60 * 60 * 24);
        if (daysSince < window.PORTRAIT_REGEN_DAYS) {
          const daysLeft = Math.ceil(window.PORTRAIT_REGEN_DAYS - daysSince);
          alert(`You can request a new portrait in ${daysLeft} day${daysLeft > 1 ? 's' : ''}. Your portrait refreshes every ${window.PORTRAIT_REGEN_DAYS} days.`);
          return;
        }
      }
    }
  } catch(e) { console.warn('Cooldown check failed:', e); }

  // Close gallery and open the full portrait creation screen
  // Pre-populate with existing portrait fields so student sees their current settings
  const gallery = document.getElementById('portrait-gallery-overlay');
  if (gallery) gallery.remove();

  // Open the full creation screen — it has all genre/style/gear/hair/eyes/skin fields
  // Override confirmPortraitAndContinue to also handle XP deduction and cooldown save
  window._regenMode = true;
  window.showPortraitCreationScreen(
    player.activeCharacterId,
    player.name,
    player.className
  );

  // Pre-populate fields with existing portrait data after screen renders
  setTimeout(() => {
    const pf = player.portraitEditedFields || {};
    const cv = window.CLASS_VISUALS ? (window.CLASS_VISUALS[player.className] || {}) : {};
    const setVal = (id, val) => {
      const el = document.getElementById(id);
      if (el && val) el.value = val;
    };
    setVal('portrait-field-style',  pf.style  || cv.style  || '');
    setVal('portrait-field-gear',   pf.gear   || cv.gear   || '');
    setVal('portrait-field-weapon', pf.weapon || cv.weapon || '');
    setVal('portrait-field-aura',   pf.aura   || cv.aura   || '');
    setVal('portrait-field-hair',   player.portraitHair || '');
    setVal('portrait-field-eyes',   player.portraitEyes || '');
    setVal('portrait-field-skin',   player.portraitSkin || '');
    setVal('portrait-description-input', player.portraitDescription || '');

    // Update the heading to reflect regen context
    const heading = document.querySelector('#portrait-creation-overlay [style*="Cinzel"]');
    const costEl = document.createElement('div');
    costEl.style.cssText = 'font-size:12px;color:#c9a84c;text-align:center;margin-top:-12px;margin-bottom:16px;';
    costEl.textContent = `🔄 Updating your portrait — costs ${window.PORTRAIT_REGEN_COST} XP`;
    const genreLabel = document.querySelector('#portrait-creation-overlay label');
    if (genreLabel) genreLabel.parentNode.insertBefore(costEl, genreLabel);
  }, 200);
};

// Regen XP deduction and cooldown are handled inline in confirmPortraitAndContinue above via _regenMode flag

// ─────────────────────────────────────────────────────────────────────────
// HOOK INTO LEVEL-UP — trigger milestone portrait after upgrade choice
// ─────────────────────────────────────────────────────────────────────────
window._origCheckLevelUp = window.checkForLevelUp;
window.checkForLevelUp = () => {
  if (!player) return;
  const oldLevel = window._lastKnownLevel || 1;
  window._origCheckLevelUp();
  const newLevel = window.getLevelData(player.xp).level;
  if (newLevel > oldLevel && window.PORTRAIT_MILESTONES.includes(newLevel) && newLevel > 1) {
    // Delay portrait generation until after ability upgrade choice is dismissed
    setTimeout(() => window.triggerMilestonePortrait(newLevel), 5000);
  }
};

// ─────────────────────────────────────────────────────────────────────────
// HOOK INTO CHARACTER CREATION — show portrait screen after csDoCreate
// ─────────────────────────────────────────────────────────────────────────
// Poll for csDoCreate to be available then wrap it
window._portraitHookInterval = setInterval(() => {
  if (typeof window.csDoCreate === 'function' && !window._portraitHookDone) {
    window._portraitHookDone = true;
    clearInterval(window._portraitHookInterval);
    const origCsDoCreate = window.csDoCreate;
    window.csDoCreate = async () => {
      // Capture state BEFORE the original runs
      const slotBefore = window.csCreatingSlot;
      await origCsDoCreate();
      // After creation, find the newest character in Firestore
      setTimeout(async () => {
        try {
          if (!player || !player.uid) return;
          // Fetch all characters, sort client-side to find the newest
          const snap = await getDocs(collection(db, 'players', player.uid, 'characters'));
          if (!snap.empty) {
            const sorted = snap.docs.slice().sort((a,b) => {
              const ta = a.data().createdAt || '';
              const tb = b.data().createdAt || '';
              return tb.localeCompare(ta);
            });
            const newChar = { id: sorted[0].id, ...sorted[0].data() };
            // Only show if character has no portrait yet
            if (!newChar.currentPortraitUrl) {
              window.showPortraitCreationScreen(newChar.id, newChar.name, newChar.className);
            }
          }
        } catch(e) { console.warn('Portrait hook: could not find new character:', e); }
      }, 1000);
    };
    console.log('✅ Portrait hook attached to csDoCreate');
  }
  // Fallback: listen for a custom event fired when character creation closes
  if (!window._portraitEventListenerAdded) {
    window._portraitEventListenerAdded = true;
    document.addEventListener('testquest:characterCreated', async (e) => {
      const { characterId, name, className } = e.detail || {};
      if (characterId && name && className) {
        setTimeout(() => window.showPortraitCreationScreen(characterId, name, className), 500);
      }
    });
  }
}, 500);

setTimeout(() => {

  // Add Portrait Hall button to character select screen
  const csEnterBtn = document.getElementById('cs-enter-btn');
  if (csEnterBtn && !document.getElementById('cs-portrait-btn')) {
    const portraitBtn = document.createElement('button');
    portraitBtn.id = 'cs-portrait-btn';
