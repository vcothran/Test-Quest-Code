CMSApp.prototype.setupModalCloseButtons = function() {
  const modals = ['ai-import-modal', 'question-bank-modal', 'episode-modal', 'genre-modal'];
  modals.forEach(modalId => {
    const closeBtn = document.getElementById(`close-${modalId.replace('-modal', '')}-modal`);
    if (closeBtn) closeBtn.addEventListener('click', () => this.closeModal(modalId));
  });
  document.addEventListener('click', (e) => {
    if (e.target.classList.contains('cms-modal')) this.closeModal(e.target.id);
  });
