CMSApp.prototype.checkDependencies = function() {
  console.log('\u{1F50D} Checking dependencies (Firebase v9 mode)...');
  let firebaseAvailable = false;
  try {
    firebaseAvailable = (
      typeof window.firebaseV9 !== 'undefined' &&
      typeof window.firebaseV9.initializeApp !== 'undefined'
    );
  } catch (e) { console.warn('Firebase v9 detection error:', e); }
  let geminiAvailable = false;
  try {
    geminiAvailable = (typeof window.GoogleGenerativeAI !== 'undefined');
  } catch (e) { console.warn('Gemini detection error:', e); }
