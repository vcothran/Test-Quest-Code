<script>
document.addEventListener('DOMContentLoaded', function() {
  // Framework mode toggle
  const frameworkCheckbox = document.getElementById('framework-mode-enable');
  const frameworkBenefits = document.getElementById('framework-benefits');
  const frameworkAdvanced = document.getElementById('framework-advanced');
  const submitBtn         = document.getElementById('ai-import-submit-btn');
  const submitBtnText     = document.getElementById('submit-btn-text');
  const advancedToggle    = document.getElementById('advanced-settings-toggle');

  if (frameworkCheckbox) {
    frameworkCheckbox.addEventListener('change', function() {
      const on = this.checked;
      if (frameworkBenefits) frameworkBenefits.style.display = on ? 'block' : 'none';
      if (submitBtnText) {
        submitBtnText.textContent = on ? '🔒 Generate Framework Questions' : '🚀 Start Ultimate Extraction';
        if (submitBtn) submitBtn.style.background = on ? 'linear-gradient(135deg,#28a745,#20c997)' : '';
      }
      if (frameworkAdvanced && advancedToggle) {
        frameworkAdvanced.style.display = (on && advancedToggle.checked) ? 'block' : 'none';
      }
    });
  }
  if (advancedToggle) {
    advancedToggle.addEventListener('change', function() {
      if (frameworkAdvanced && frameworkCheckbox) {
        frameworkAdvanced.style.display = (this.checked && frameworkCheckbox.checked) ? 'block' : 'none';
      }
    });
  }

  // Cutscene radio card highlighting
  function updateRadioCards(name) {
    document.querySelectorAll(`input[name="${name}"]`).forEach(radio => {
      const label = radio.closest('label');
      if (!label) return;
      label.style.borderColor = radio.checked ? '#667eea' : '#dee2e6';
      label.style.background  = radio.checked ? 'rgba(102,126,234,0.06)' : '#fff';
    });
  }
  ['encounter-cutscene-style','completion-cutscene-style'].forEach(name => {
    document.querySelectorAll(`input[name="${name}"]`).forEach(radio => {
      radio.addEventListener('change', () => updateRadioCards(name));
    });
    updateRadioCards(name);
  });

  // Cutscene toggle → dim style row when disabled
  const encToggle    = document.getElementById('cutscene-encounters-enabled');
  const encStyleRow  = document.getElementById('encounter-cutscene-style-row');
  const compToggle   = document.getElementById('cutscene-completion-enabled');
  const compStyleRow = document.getElementById('completion-cutscene-style-row');
  if (encToggle && encStyleRow) {
    encToggle.addEventListener('change', function() {
      encStyleRow.style.opacity      = this.checked ? '1' : '0.4';
      encStyleRow.style.pointerEvents = this.checked ? 'auto' : 'none';
    });
  }
  if (compToggle && compStyleRow) {
    compToggle.addEventListener('change', function() {
      compStyleRow.style.opacity      = this.checked ? '1' : '0.4';
      compStyleRow.style.pointerEvents = this.checked ? 'auto' : 'none';
    });
  }
});
</script>
	
