    { id: 'dash-new-genre-btn',    action: () => this.showGenreModal() },
    { id: 'new-q-bank-btn',        action: () => this.showQuestionBankModal() },
    { id: 'quick-import-btn',      action: () => this.showQuickImport() },
    { id: 'new-episode-btn',       action: () => this.showEpisodeModal() },
