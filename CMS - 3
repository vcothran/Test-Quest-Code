<script>
console.log('🤖 Loading Section 7: AI Import Handler...');

// ─────────────────────────────────────────────────────────────────────────
// handleAIImportSubmit
// Called by the Submit button in the AI Import modal (Section 5).
// Reads file/paste input → calls Gemini → parses questions → saves to bank.
// ─────────────────────────────────────────────────────────────────────────
CMSApp.prototype.handleAIImportSubmit = async function(e) {
  if (e) e.preventDefault();
  console.log('🚀 handleAIImportSubmit called');

  // ── 1. Validate bank selection ──────────────────────────────────────
  const bankSelect   = document.getElementById('ai-save-bank-select');
  const selectedBank = bankSelect ? bankSelect.value : '';

  if (!selectedBank) {
    this.showAlert('Please select a question bank before importing.', 'error');
    return;
  }

  // ── 2. Get / create the target bank ─────────────────────────────────
  let targetBankId   = null;
  let targetBankName = '';

  if (selectedBank === 'CREATE_NEW') {
    const newName = window.prompt('Enter a name for the new question bank:', 'New Question Bank');
    if (!newName || !newName.trim()) {
      this.showAlert('Please enter a name for the new question bank.', 'error');
      return;
    }
    try {
      const docRef = await this.addDoc(this.collection(this.db, 'questionBanks'), {
        name:        newName.trim(),
        approach:    'General',
        description: 'Created via Ultimate AI Import',
        questions:   [],
        createdAt:   this.serverTimestamp(),
        createdWith: 'Ultimate Parser CMS v2.3'
      });
      targetBankId   = docRef.id;
      targetBankName = newName.trim();
      this.state.questionBanks.push({
        id:        targetBankId,
        name:      targetBankName,
        approach:  'General',
        questions: []
      });
      console.log('✅ New bank created:', targetBankId);
    } catch (err) {
      console.error('❌ Error creating bank:', err);
      this.showAlert('Error creating question bank. Please try again.', 'error');
      return;
    }
  } else {
    targetBankId = selectedBank;
    const bank   = this.state.questionBanks.find(b => b.id === targetBankId);
    targetBankName = bank ? bank.name : 'Selected Bank';
  }

  // ── 3. Gather content (file or paste) ───────────────────────────────
  let contentText = '';

  const pasteArea = document.getElementById('content-paste-area');
  if (pasteArea) {
    const pasteText = (pasteArea.textContent || pasteArea.innerText || '').trim();
    if (pasteText && pasteText !== ' ') contentText = pasteText;
  }

  const contentFileInput = document.getElementById('content-file-input');
  const contentFile      = contentFileInput && contentFileInput.files[0]
                           ? contentFileInput.files[0]
                           : this.state.contentFile;

  if (!contentText && !contentFile) {
    this.showAlert('Please upload a file or paste text content before importing.', 'error');
    return;
  }

  // ── 4. Check Gemini is ready ─────────────────────────────────────────
  if (!this.geminiModel && !this.parserReady) {
    try {
      await this.fetchTeacherApiKey();
    } catch(e) {
      console.warn('Could not fetch API key:', e);
    }
  }

  if (!this.geminiModel) {
    this.showAlert('AI Parser is not ready. Please check your API key in Settings.', 'error');
    return;
  }

  // ── 5. Read settings ──────────────────────────────────────────────────
  const questionCountSelect = document.getElementById('ai-question-count');
  const difficultySelect    = document.getElementById('ai-difficulty-level');
  const extractionSelect    = document.getElementById('extraction-mode');
  const frameworkCheckbox   = document.getElementById('framework-mode-enable');

  const expectedCount  = questionCountSelect ? questionCountSelect.value : 'auto';
  const difficulty     = difficultySelect    ? difficultySelect.value    : 'auto';
  const extractionMode = extractionSelect    ? extractionSelect.value    : 'smart';
  const frameworkMode  = frameworkCheckbox   ? frameworkCheckbox.checked : false;

  // ── 6. Show progress ──────────────────────────────────────────────────
  this.updateProgress(5, 'Reading content...');
  const submitBtn = document.getElementById('ai-import-submit-btn');
  if (submitBtn) { submitBtn.disabled = true; submitBtn.style.opacity = '0.6'; }

  try {

    // ── 7. Convert file to text/base64 ──────────────────────────────────
    let geminiContent = null;

    if (contentFile) {
      this.updateProgress(15, `Processing ${contentFile.name}...`);

      if (contentFile.type === 'application/pdf') {
        contentText = await this.extractTextFromPDF(contentFile);
        geminiContent = [{ text: contentText }];

      } else if (contentFile.type.startsWith('image/')) {
        const base64 = await this.fileToBase64(contentFile);
        geminiContent = [
          {
            inlineData: {
              mimeType: contentFile.type,
              data:     base64
            }
          },
          { text: 'Extract all questions from this image.' }
        ];

      } else {
        contentText = await this.readFileAsText(contentFile);
        geminiContent = [{ text: contentText }];
      }
    } else {
      geminiContent = [{ text: contentText }];
    }

    // Check answer key file
    const answerFileInput = document.getElementById('answer-file-input');
    const answerFile      = answerFileInput && answerFileInput.files[0]
                            ? answerFileInput.files[0]
                            : this.state.answerFile;

    let answerKeyText = '';
    if (answerFile) {
      this.updateProgress(20, 'Reading answer key...');
      try {
        if (answerFile.type === 'application/pdf') {
          answerKeyText = await this.extractTextFromPDF(answerFile);
        } else {
          answerKeyText = await this.readFileAsText(answerFile);
        }
      } catch(e) {
        console.warn('Could not read answer key:', e);
      }
    }

    // ── 8. Build the Gemini prompt ────────────────────────────────────────
    this.updateProgress(30, 'Building extraction prompt...');

    const modeInstructions = frameworkMode
      ? `Generate COMPLETELY ORIGINAL questions INSPIRED BY the structure and topics of the source material.
         Do NOT copy any text from the source. Create new scenarios, new numbers, new scenarios.
         Preserve the same question type, difficulty, and subject area.`
      : `Extract questions DIRECTLY from the provided content with high accuracy.
         Preserve original wording, answer choices, and correct answers exactly.`;

    const countInstruction = expectedCount === 'auto'
      ? 'Extract ALL questions found in the document.'
      : `Extract exactly ${expectedCount} questions (or as many as are available if fewer exist).`;

    const diffInstruction = difficulty === 'auto'
      ? ''
      : `Target difficulty level: ${difficulty}.`;

    const prompt = `You are the Ultimate ACT Question Parser — a specialist in extracting ACT test questions with 98% accuracy.

${modeInstructions}

${countInstruction} ${diffInstruction}

EXTRACTION RULES:
- Detect test type automatically: Reading (passages + questions), Math (equations, geometry), English (grammar/usage), Science (data interpretation)
- For Reading: include the FULL passage text in passageContext for EVERY question in that passage set
- For Math: preserve ALL mathematical notation, equations, and figures in text form
- Preserve answer choices EXACTLY as labeled: A/B/C/D for Math/Science/English, F/G/H/J for Reading
- Identify the correct answer from the answer key if provided, or from context clues
- Write a DETAILED explanation for every question. The explanation must:
  * State clearly WHY the correct answer is right (not just what it is)
  * Explain the reasoning process step-by-step as a teacher would
  * For Math: show the full calculation or algebraic steps
  * For Reading: cite the specific line or phrase from the passage that supports the answer
  * For English: name the grammar rule or rhetorical principle being tested
  * For Science: explain what the data shows and how to interpret it
  * Point out WHY each wrong answer is wrong if helpful
  * Be 2-4 sentences minimum — never just one word or the answer letter
  * Write as if explaining to a 10th grade student who got it wrong
- IMPORTANT: All string values must use escaped quotes. Do NOT use smart/curly quotes. Do NOT leave unescaped apostrophes inside JSON strings.

${answerKeyText ? `ANSWER KEY PROVIDED:\n${answerKeyText}\n\n` : ''}

OUTPUT FORMAT — respond with ONLY a valid JSON array, no markdown, no explanation:
[
  {
    "questionNumber": 1,
    "testType": "Math",
    "text": "What is the value of x if 2x + 3 = 11?",
    "passageContext": "",
    "options": {
      "A": "2",
      "B": "3",
      "C": "4",
      "D": "5"
    },
    "correct": "C",
    "explanation": "To solve 2x + 3 = 11, subtract 3 from both sides to get 2x = 8, then divide both sides by 2 to get x = 4. Answer A (x=2) is wrong because 2(2)+3=7. Answer B (x=3) gives 9. Answer D (x=5) gives 13."
  }
]

For Reading questions use F/G/H/J as option keys.
passageContext should contain the FULL passage text for reading questions, empty string for others.
correct should be the letter of the correct answer (A, B, C, D, F, G, H, or J).

CONTENT TO PROCESS:
`;

    // ── 9. Call Gemini ─────────────────────────────────────────────────
    this.updateProgress(40, '🤖 Sending to Ultimate Parser AI...');

    let geminiParts;
    if (geminiContent && geminiContent.length > 0 &&
        geminiContent[0].inlineData) {
      geminiParts = [
        { text: prompt + '\n[See attached image above]' },
        ...geminiContent
      ];
    } else {
      const fullText = (geminiContent || []).map(p => p.text || '').join('\n');
      geminiParts = [{ text: prompt + '\n' + fullText }];
    }

    this.updateProgress(55, '🧠 AI extracting questions (this may take 15–30 seconds)...');

    let responseText = '';
    try {
      const result = await this.geminiModel.generateContent({
        contents: [{ role: 'user', parts: geminiParts }],
        generationConfig: {
          maxOutputTokens: 8192,
          temperature: 0.1
        }
      });
      responseText = result.response.text();
    } catch (apiErr) {
      console.error('Gemini API error:', apiErr);
      throw new Error('AI extraction failed: ' + (apiErr.message || 'Unknown error'));
    }

    this.updateProgress(70, 'Parsing extracted questions...');

    // ── 10. Parse the JSON response ───────────────────────────────────────
    const questions = this.parseGeminiQuestionResponse(responseText);

    if (!questions || questions.length === 0) {
      throw new Error('No questions could be extracted from the content. Try a different document or paste the text manually.');
    }

    console.log(`✅ Extracted ${questions.length} questions`);
    this.updateProgress(80, `Found ${questions.length} questions — saving to bank...`);

    // ── 11. Save questions to Firestore ───────────────────────────────────
    const bank = this.state.questionBanks.find(b => b.id === targetBankId);
    const existingQuestions = bank ? (bank.questions || []) : [];
    const mergedQuestions   = [...existingQuestions, ...questions];

    const lastExtraction = {
      testType:    questions[0]?.testType || extractionMode,
      count:       questions.length,
      extractedAt: new Date().toISOString(),
      mode:        frameworkMode ? 'framework' : 'extraction'
    };

    await this.updateDoc(this.doc(this.db, 'questionBanks', targetBankId), {
      questions:      mergedQuestions,
      lastExtraction: lastExtraction,
      updatedAt:      this.serverTimestamp()
    });

    if (bank) {
      bank.questions      = mergedQuestions;
      bank.lastExtraction = lastExtraction;
    }

    this.updateProgress(100, '✅ Complete!');

    // ── 12. Success ───────────────────────────────────────────────────────
    setTimeout(() => {
      this.closeModal('ai-import-modal');
      this.hideProgress();
      this.loadQuestionBanks();
      this.showAlert(
        `✅ Successfully ${frameworkMode ? 'generated' : 'extracted'} ${questions.length} question${questions.length !== 1 ? 's' : ''} into "${targetBankName}"!`,
        'success'
      );
    }, 600);

    this.state.parserStats = this.state.parserStats || { processedDocuments: 0, extractedQuestions: 0 };
    this.state.parserStats.processedDocuments++;
    this.state.parserStats.extractedQuestions += questions.length;

  } catch (err) {
    console.error('❌ AI Import error:', err);
    this.hideProgress();
    this.showAlert('Import failed: ' + (err.message || 'Unknown error. Please try again.'), 'error');
  } finally {
    if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '1'; }
  }
};
