function renderReportsDashboard() {
  document.getElementById('reports-loading').style.display = 'none';
  if (reportsAllStudents.length === 0) {
    document.getElementById('reports-empty').style.display = 'block';
    return;
  }
  document.getElementById('reports-table').style.display = 'table';

  const total          = reportsAllStudents.length;
  const totalCompleted = reportsAllStudents.reduce((sum, s) => sum + s.progressData.filter(p => p.completed).length, 0);
  const avgProgress    = Math.round(reportsAllStudents.reduce((sum, s) => {
    const c = s.progressData.filter(p => p.completed).length;
    return sum + (c / (s.progressData.length || 1) * 100);
  }, 0) / total);
  const avgAccuracy    = Math.round(reportsAllStudents.reduce((sum, s) => {
    return sum + s.progressData.reduce((a, p) => a + (p.accuracy || 0), 0) / (s.progressData.length || 1);
  }, 0) / total * 100);

  document.getElementById('reports-total-students').textContent    = total;
  document.getElementById('reports-avg-progress').textContent      = avgProgress + '%';
  document.getElementById('reports-avg-accuracy').textContent      = avgAccuracy + '%';
  document.getElementById('reports-completed-episodes').textContent = totalCompleted;

  renderReportsTable();
}

function renderReportsTable(students) {
  const list  = students || reportsAllStudents;
  const tbody = document.getElementById('reports-table-body');
  if (!tbody) return;
  tbody.innerHTML = '';

  list.forEach(student => {
    const completed = student.progressData.filter(p => p.completed).length;
    const total     = student.progressData.length || 1;
    const progress  = Math.round(completed / total * 100);
    const accuracy  = Math.round(student.progressData.reduce((s, p) => s + (p.accuracy || 0), 0) / total * 100);
    let bg = '#d4edda', fg = '#155724';
    if (accuracy < 60)      { bg = '#f8d7da'; fg = '#721c24'; }
    else if (accuracy < 75) { bg = '#fff3cd'; fg = '#856404'; }
    else if (accuracy < 90) { bg = '#d1ecf1'; fg = '#0c5460'; }
    const status = accuracy >= 90 ? 'excellent' : accuracy >= 75 ? 'good' : accuracy >= 60 ? 'fair' : 'needs help';

    const row = document.createElement('tr');
    row.style.cursor  = 'pointer';
    row.onmouseover   = () => row.style.background = '#f8f9ff';
    row.onmouseout    = () => row.style.background = '';
    row.onclick       = () => openStudentModal(student);
    row.innerHTML =
      '<td style="padding:15px; border-bottom:1px solid #f0f0f0;"><div style="font-weight:600; color:#333;">' + student.name + '</div><div style="font-size:13px; color:#999;">' + (student.email || '') + '</div></td>' +
      '<td style="padding:15px; border-bottom:1px solid #f0f0f0;">' + completed + ' / ' + total + '</td>' +
      '<td style="padding:15px; border-bottom:1px solid #f0f0f0;"><div style="background:#e0e0e0; height:8px; border-radius:4px;"><div style="height:100%; background:linear-gradient(90deg,#667eea,#764ba2); border-radius:4px; width:' + progress + '%;"></div></div><div style="font-size:12px; color:#666; margin-top:4px;">' + progress + '%</div></td>' +
      '<td style="padding:15px; border-bottom:1px solid #f0f0f0;"><strong>' + accuracy + '%</strong></td>' +
      '<td style="padding:15px; border-bottom:1px solid #f0f0f0;"><span style="padding:4px 12px; border-radius:12px; font-size:12px; font-weight:600; background:' + bg + '; color:' + fg + ';">' + status + '</span></td>' +
      '<td style="padding:15px; border-bottom:1px solid #f0f0f0;"><button onclick="event.stopPropagation(); openStudentModal(reportsAllStudents.find(s=>s.id===\'' + student.id + '\'))" style="padding:6px 12px; background:#667eea; color:white; border:none; border-radius:6px; cursor:pointer;">View Details</button></td>';
    tbody.appendChild(row);
  });
}

