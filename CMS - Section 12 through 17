CMSApp.prototype.closeEditQuestionModal = function() {
  const modal = document.getElementById('edit-question-modal');
  if (modal) modal.remove();
  if (this.imageManager) {
    this.imageManager.currentContext = null;
    this.imageManager.currentQuestionIndex = null;
    this.imageManager.currentBankId = null;
    this.imageManager.images = {};
  }
};

