    // We temporarily patch it to capture the episode ID
    let savedEpisodeId = null;
    const _origAddDoc = this.addDoc?.bind(this);

    // Override addDoc briefly to capture the new episode ID
    this._captureNextEpisodeId = true;
    await _originalHandleEpisodeSubmit.call(this, e);

    // Get the last saved episode (most recently created)
    // §13 saves then calls loadEpisodes() — we need the ID
    // We'll look it up by title + recent timestamp
    await new Promise(r => setTimeout(r, 800)); // brief wait for Firestore write
    savedEpisodeId = await this.findRecentEpisodeId(title);

    if (!savedEpisodeId) {
      console.warn('§17: Could not find saved episode ID for moderation update');
      return;
    }

    // ── STEP 3: Update episode with moderation fields ─────────────────
    this.showProcessing?.('🎨 Generating cutscene image…');

    const moderationUpdate = {
      moderationStatus:  scanResult.status,    // 'approved' or 'flagged'
      moderationReason:  scanResult.reason || null,
      cutscenePrompt:    narrative,
      teacherEmail:      this.state?.currentUser?.email || null,
      teacherId:         this.state?.currentUser?.uid   || null,
    };

    if (scanResult.status === 'flagged') {
      // Don't generate image yet — store prompt only, notify admin
      Object.assign(moderationUpdate, { cutsceneImageUrl: null });
      await this.updateEpisodeModeration(savedEpisodeId, moderationUpdate);
      await this.notifyAdminFlag(title, narrative, scanResult.reason,
        this.state?.currentUser?.email);
      this.hideProcessing?.();
      this.showAlert?.('warning',
        '⚑ Episode Saved — Awaiting Review',
        'Your episode has been saved but is pending admin review before students can access it. You will be notified when it is approved.'
      );
    } else {
      // APPROVED — generate the cutscene image
      let imageGenResult = null;
      try {
        imageGenResult = await this.generateCutsceneImage(narrative);
      } catch(imgErr) {
        console.warn('§17: Image generation failed:', imgErr);
      }

      if (imageGenResult?.blocked) {
        // Image was blocked even though text passed — escalate to flagged
        Object.assign(moderationUpdate, {
          moderationStatus: 'flagged',
          moderationReason: 'Image generation blocked: ' + imageGenResult.reason,
          flaggedImageData: null,
          cutsceneImageUrl: null
        });
        await this.updateEpisodeModeration(savedEpisodeId, moderationUpdate);
        await this.notifyAdminFlag(title, narrative,
          'Image generation blocked: ' + imageGenResult.reason,
          this.state?.currentUser?.email);
        this.hideProcessing?.();
        this.showAlert?.('warning',
          '⚑ Episode Saved — Image Under Review',
          'Your episode narrative looks great, but the AI image system flagged the generated cutscene for review. Your episode will be available once approved.'
        );
      } else {
        // Full success
        Object.assign(moderationUpdate, {
          cutsceneImageUrl: imageGenResult?.imageData || null,
        });
        await this.updateEpisodeModeration(savedEpisodeId, moderationUpdate);
        this.hideProcessing?.();
        // Episode is live — no extra alert needed (§13 already shows success)
      }
    }

  } catch (err) {
    console.error('§17 moderation error:', err);
    this.hideProcessing?.();
    // Don't block the teacher — episode already saved by §13, just log
    console.warn('§17: Moderation update failed, episode saved without moderation fields');
  }
};

// ── SCAN NARRATIVE TEXT ─────────────────────────────────────────────────
CMSApp.prototype.scanNarrativeText = async function(narrative, title) {
  // First: fast local pattern check
  for (const pattern of FLAG_PATTERNS) {
    if (pattern.test(narrative)) {
      return {
        status: 'flagged',
        reason: `Potentially inappropriate content detected in narrative text. Pattern matched: "${narrative.match(pattern)?.[0]}"`
      };
    }
  }

  // Second: Gemini text safety check
  try {
    const model = this.geminiModel || this.state?.geminiModel;
    if (!model) return { status: 'approved' }; // no model = pass through

    const safetyPrompt = `You are a content moderator for an educational game used by students aged 13-18 in school.

Review the following episode narrative text for a fantasy educational RPG game. 

Flag it if it contains ANY of:
- Sexual content, nudity, or suggestive/erotic language
- Graphic violence, gore, murder, torture
- Drug or alcohol glorification  
- Hate speech, slurs, or discrimination
- Self-harm or suicide references
- Anything inappropriate for a classroom setting

Narrative to review:
"${narrative}"

Episode title: "${title}"

Respond with ONLY a JSON object:
{"safe": true} if appropriate for school
{"safe": false, "reason": "brief reason"} if problematic`;

    const result = await model.generateContent(safetyPrompt);
    const response = result.response;

    // Check finish reason
    if (BLOCK_FINISH_REASONS.includes(response.candidates?.[0]?.finishReason)) {
      return { status: 'blocked', reason: 'Content blocked by AI safety filters' };
    }

    const text = response.text().trim();
    const clean = text.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);

    if (!parsed.safe) {
      return { status: 'flagged', reason: parsed.reason || 'AI safety review flagged this content' };
    }
    return { status: 'approved' };

  } catch(e) {
    console.warn('§17: Text scan error:', e);
    // On scan error — flag for human review rather than auto-approve
    return { status: 'flagged', reason: 'Automated scan error — flagged for manual review' };
  }
};

// ── GENERATE CUTSCENE IMAGE ─────────────────────────────────────────────
CMSApp.prototype.generateCutsceneImage = async function(narrative) {
  try {
    const apiKey = localStorage.getItem('gemini_api_key') ||
      window.ULTIMATE_PARSER_CONFIG?.geminiApiKey;
    if (!apiKey) throw new Error('No API key configured');

    const prompt = IMAGE_SAFETY_PREFIX + narrative;

    // Use Imagen via Gemini API
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/imagen-3.0-generate-002:predict?key=${apiKey}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          instances: [{ prompt }],
          parameters: {
            sampleCount: 1,
            aspectRatio: '16:9',
            safetyFilterLevel: 'block_medium_and_above',
            personGeneration: 'allow_adult'
          }
        })
      }
    );

    if (!response.ok) {
      const err = await response.json();
      // Check if it's a safety block
      if (err.error?.message?.includes('safety') || response.status === 400) {
        return { blocked: true, reason: err.error?.message || 'Image safety filter triggered' };
      }
      throw new Error(err.error?.message || `HTTP ${response.status}`);
    }

    const data = await response.json();
    const imageBytes = data.predictions?.[0]?.bytesBase64Encoded;

    if (!imageBytes) {
      // Check for safety block in response
      const filterReason = data.predictions?.[0]?.safetyAttributes?.blocked;
      if (filterReason) {
        return { blocked: true, reason: 'Image content filter triggered' };
      }
      throw new Error('No image data returned');
    }

    return { imageData: `data:image/png;base64,${imageBytes}` };

  } catch(e) {
    // Fallback: try gemini-2.0-flash with image output
    try {
      return await this.generateCutsceneImageFallback(narrative);
    } catch(e2) {
      console.warn('§17: Both image generation methods failed:', e2);
      return null; // Non-fatal — episode saves without image
    }
  }
};

CMSApp.prototype.generateCutsceneImageFallback = async function(narrative) {
  const apiKey = localStorage.getItem('gemini_api_key') ||
    window.ULTIMATE_PARSER_CONFIG?.geminiApiKey;

  const response = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-preview-image-generation:generateContent?key=${apiKey}`,
    {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{ parts: [{ text: IMAGE_SAFETY_PREFIX + narrative }] }],
        generationConfig: { responseModalities: ['IMAGE', 'TEXT'] }
      })
    }
  );

  if (!response.ok) {
    const err = await response.json();
    if (err.error?.message?.includes('safety')) {
      return { blocked: true, reason: err.error.message };
    }
    throw new Error(err.error?.message);
  }

  const data = await response.json();
  const imagePart = data.candidates?.[0]?.content?.parts
    ?.find(p => p.inlineData?.mimeType?.startsWith('image/'));

  if (imagePart?.inlineData?.data) {
    return { imageData: `data:${imagePart.inlineData.mimeType};base64,${imagePart.inlineData.data}` };
  }
  return null;
};

// ── UPDATE EPISODE WITH MODERATION FIELDS ──────────────────────────────
CMSApp.prototype.updateEpisodeModeration = async function(episodeId, fields) {
  try {
    const { doc, updateDoc } = window.firebaseV9;
    const db = this.db || this._v9Functions?.getFirestore?.();
    await updateDoc(doc(db, 'episodes', episodeId), fields);
  } catch(e) {
    console.error('§17: Failed to update moderation fields:', e);
  }
};

// ── FIND RECENTLY SAVED EPISODE BY TITLE ───────────────────────────────
CMSApp.prototype.findRecentEpisodeId = async function(title) {
  try {
    const { collection, query, where, orderBy, limit, getDocs } = window.firebaseV9;
    const db = this.db;
    const q  = query(
      collection(db, 'episodes'),
      where('title', '==', title),
      orderBy('createdAt', 'desc'),
      limit(1)
    );
    const snap = await getDocs(q);
    return snap.empty ? null : snap.docs[0].id;
  } catch(e) {
    console.warn('§17: findRecentEpisodeId error:', e);
    return null;
  }
};

// ── NOTIFY ADMIN VIA MAILTO ─────────────────────────────────────────────
CMSApp.prototype.notifyAdminFlag = async function(episodeTitle, narrative, reason, teacherEmail) {
  // Log to Firestore moderationLog
  try {
    const { collection, addDoc, serverTimestamp } = window.firebaseV9;
    await addDoc(collection(this.db, 'moderationLog'), {
      action:       'AUTO_FLAG',
      episodeTitle:  episodeTitle,
      teacherEmail:  teacherEmail || 'unknown',
      reason:        reason,
      narrativeSnippet: (narrative || '').substring(0, 300),
      timestamp:    serverTimestamp()
    });
  } catch(e) {
    console.warn('§17: Could not log flag to Firestore:', e);
  }

  // Open mailto as a gentle notification trigger
  // (In production, replace with EmailJS or a Cloud Function)
  const subject = encodeURIComponent(`[ACT Quest] ⚑ Content Flagged — "${episodeTitle}"`);
  const body = encodeURIComponent(
    `A teacher episode has been automatically flagged for review.\n\n` +
    `Episode: "${episodeTitle}"\n` +
    `Teacher: ${teacherEmail || 'unknown'}\n` +
    `Reason: ${reason}\n\n` +
    `Narrative snippet:\n"${(narrative||'').substring(0, 500)}"\n\n` +
    `Review in the admin portal: [your admin URL here]`
  );
  // Non-blocking mailto — opens quietly in background tab
  const link = document.createElement('a');
  link.href = `mailto:${ADMIN_NOTIFICATION_EMAIL}?subject=${subject}&body=${body}`;
  link.target = '_blank';
  link.style.display = 'none';
  document.body.appendChild(link);
  link.click();
  setTimeout(() => link.remove(), 1000);
};

