      '<td style="padding:15px; border-bottom:1px solid #f0f0f0;"><span style="padding:4px 12px; border-radius:12px; font-size:12px; font-weight:600; background:' + bg + '; color:' + fg + ';">' + statusLabel + '</span></td>' +
