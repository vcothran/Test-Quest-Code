CMSApp.prototype.renderQuestions = function(questions, bankId) {
  if (!questions || questions.length === 0) return '<div class="empty-state">No questions found</div>';

  return questions.map((q, index) => {
    const questionNum = q.questionNumber || (index + 1);
    const hasPassage = q.passageContext || q.passage || (q.passageImages && q.passageImages.length > 0);
    const hasQuestionImages = q.questionImages && q.questionImages.length > 0;

    // Normalize display of correct answer and options
    let correctDisplay = '?';
    let optionsHTML = '<p style="color:#6c757d;font-style:italic;">No options</p>';

    if (Array.isArray(q.options) && q.options.length > 0) {
      const correctIdx = typeof q.correct === 'number' ? q.correct
                       : typeof q.correctAnswer === 'number' ? q.correctAnswer : 0;
      correctDisplay = String.fromCharCode(65 + correctIdx);
      optionsHTML = q.options.map((opt, i) => {
        const isCorrect = i === correctIdx;
        const optImages = q.optionImages && q.optionImages[i] ? q.optionImages[i] : [];
        return `<div style="padding:10px 15px;margin:6px 0;border-radius:6px;font-size:14px;
                            background:${isCorrect ? '#d4edda' : '#f8f9fa'};
                            border-left:4px solid ${isCorrect ? '#28a745' : '#dee2e6'};">
                  ${opt}${isCorrect ? ' <strong style="color:#28a745;">✓</strong>' : ''}
                  ${optImages.length > 0 ? `<div style="display:flex;gap:6px;margin-top:6px;">
                    ${optImages.map(img => `<img src="${img}" style="height:60px;border-radius:4px;cursor:pointer;"
                      onclick="window.cmsApp.viewImage('${img}')">`).join('')}
                  </div>` : ''}
                </div>`;
      }).join('');
    } else if (q.options && typeof q.options === 'object') {
      correctDisplay = q.correct || '?';
      optionsHTML = Object.entries(q.options).map(([letter, text]) => {
        const isCorrect = letter === q.correct;
        const optImages = q.optionImages && q.optionImages[letter] ? q.optionImages[letter] : [];
        return `<div style="padding:10px 15px;margin:6px 0;border-radius:6px;font-size:14px;
                            background:${isCorrect ? '#d4edda' : '#f8f9fa'};
                            border-left:4px solid ${isCorrect ? '#28a745' : '#dee2e6'};">
                  <strong>${letter}:</strong> ${text}${isCorrect ? ' <strong style="color:#28a745;">✓</strong>' : ''}
                  ${optImages.length > 0 ? `<div style="display:flex;gap:6px;margin-top:6px;">
                    ${optImages.map(img => `<img src="${img}" style="height:60px;border-radius:4px;cursor:pointer;"
                      onclick="window.cmsApp.viewImage('${img}')">`).join('')}
                  </div>` : ''}
                </div>`;
      }).join('');
    }

    return `
      <div style="border:1px solid #dee2e6;border-radius:8px;padding:18px;
                  margin-bottom:18px;background:#fff;">
        <div style="display:flex;justify-content:space-between;align-items:center;
                    margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid #e9ecef;">
          <div style="display:flex;align-items:center;gap:8px;">
            <strong style="color:#495057;">Q${questionNum}</strong>
            <span style="background:#28a745;color:white;padding:2px 10px;border-radius:10px;
                         font-size:12px;font-weight:600;">Answer: ${correctDisplay}</span>
            ${q.testType ? `<span style="background:#6c757d;color:white;padding:2px 8px;border-radius:10px;font-size:11px;">${q.testType}</span>` : ''}
            ${q.addedManually ? `<span style="background:#fff3cd;color:#856404;padding:2px 8px;border-radius:10px;font-size:11px;">✏️ Manual</span>` : ''}
            ${hasPassage ? `<span style="background:#17a2b8;color:white;padding:2px 8px;border-radius:10px;font-size:11px;">📖 Passage</span>` : ''}
            ${hasQuestionImages ? `<span style="background:#6f42c1;color:white;padding:2px 8px;border-radius:10px;font-size:11px;">🖼️ Images</span>` : ''}
          </div>
          <div style="display:flex;gap:8px;">
            <button onclick="window.cmsApp.editQuestion('${bankId}',${index})"
                    style="padding:5px 12px;background:#007bff;color:white;border:none;
                           border-radius:5px;font-size:12px;cursor:pointer;">✏️ Edit</button>
            <button onclick="window.cmsApp.deleteQuestion('${bankId}',${index})"
                    style="padding:5px 12px;background:#dc3545;color:white;border:none;
                           border-radius:5px;font-size:12px;cursor:pointer;">🗑️ Delete</button>
          </div>
        </div>

        ${hasPassage ? `
          <details style="margin-bottom:12px;">
            <summary style="cursor:pointer;color:#007bff;font-size:12px;
                            padding:5px 10px;background:#e7f3ff;border-radius:4px;">
              📖 Passage (${(q.passageContext || q.passage || '').length} chars)
            </summary>
            <div style="margin-top:6px;padding:12px;background:#f8f9fa;
                        border-left:3px solid #007bff;border-radius:4px;
                        max-height:200px;overflow-y:auto;font-size:13px;line-height:1.6;">
              ${q.passageContext || q.passage || ''}
            </div>
            ${q.passageImages && q.passageImages.length > 0 ? `
              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;">
                ${q.passageImages.map(img => `<img src="${img}" style="height:80px;border-radius:4px;cursor:pointer;border:1px solid #dee2e6;"
                  onclick="window.cmsApp.viewImage('${img}')">`).join('')}
              </div>` : ''}
          </details>
        ` : ''}

        <p style="margin:8px 0;font-size:15px;line-height:1.5;">${q.text || q.question || 'No question text'}</p>

        ${hasQuestionImages ? `
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin:10px 0;">
            ${q.questionImages.map(img => `<img src="${img}" style="height:100px;border-radius:4px;cursor:pointer;border:1px solid #dee2e6;"
              onclick="window.cmsApp.viewImage('${img}')">`).join('')}
