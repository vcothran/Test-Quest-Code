function generateLastNameCode() {
  const currentUser = window.cmsApp ? window.cmsApp.state.currentUser : null;
  const name = currentUser ? (currentUser.displayName || currentUser.name || currentUser.email || 'TEACHER') : 'TEACHER';
  const parts = name.trim().split(/\s+/);
  const lastName = parts.length > 1 ? parts[parts.length - 1] : parts[0];
  const clean = lastName.toUpperCase().replace(/[^A-Z]/g, '').substring(0, 8);
  const num = Math.floor(1000 + Math.random() * 9000);
  return clean + num;
}

function generateRandomCode() {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let code = '';
  for (let i = 0; i < 6; i++) code += chars.charAt(Math.floor(Math.random() * chars.length));
  return code;
}

