    // ============================================
    // INITIALIZATION FUNCTION
    // ============================================
    
    function initializeGame() {
      // DO NOT redeclare variables here - they are global above!
      
      // ENHANCED: Player abilities with Empowered Spell starting at 2 charges
      const initializePlayerAbilities = () => {
        if (!player.abilities) {
          player.abilities = {
            powerStrike: { uses: 1, maxUses: 1 },
            tacticalAnalysis: { uses: 2, maxUses: 2 },
            empoweredSpell: { uses: 2, maxUses: 2 },
